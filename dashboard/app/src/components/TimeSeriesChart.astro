---
/* Wykres serii czasowych na uPlot. Dane wstrzykiwane w build jako JSON
   (data-chart); jeden hoisted script inicjalizuje wszystkie instancje.
   Serie rozróżniane kolorem (--series-1..3) ORAZ wzorem kreski
   (solid/dash/dot) – wtórne kodowanie wymagane przez paletę (CVD ΔE 7.5). */
interface Series {
  label: string;
  values: (number | null)[];
  /* Wypełnienie obszaru pod serią (mockup: jedna seria-obszar per wykres). */
  fill?: boolean;
  /* Opcjonalny token CSS, np. --status-ok; domyślnie --series-1..3. */
  color?: string;
  /* Wzór linii Canvas; [] oznacza linię ciągłą. */
  dash?: number[];
}
interface Props {
  title: string;
  /* Podpis po prawej w nagłówku wykresu (źródło / okno danych). */
  meta?: string;
  timestamps: number[];
  series: Series[];
  unit?: string;
  precision?: number;
  /* Przełącznik zakresu osi X (7d/30d/3m/… jak w BWT); przyciski ograniczone
     do zakresu danych, podpis pokazuje wybrane okno dat. */
  ranges?: boolean;
  /* Zwarty wariant z handoffu Przeglądu: legenda nad wykresem, wysokość 170 px. */
  overview?: boolean;
  /* Kolor kwadratu źródła przy tytule, np. --sen. */
  sourceColor?: string;
  /* Minimalna liczba pomiarów potrzebna do pokazania linii. */
  minPoints?: number;
  /* Druga seria na prawej osi (np. kliknięcia + wyświetlenia). */
  secondaryAxis?: boolean;
  /* Odwrócona oś Y dla metryk, w których niżej znaczy lepiej (pozycja). */
  invert?: boolean;
  /* Wymusza punkty na linii niezależnie od liczby próbek. */
  points?: boolean;
  emptyTitle?: string;
  emptyDescription?: string;
}
const {
  title,
  meta,
  timestamps: rawTs,
  series: rawSeries,
  unit = '',
  precision = 0,
  ranges = false,
  overview = false,
  sourceColor,
  minPoints = 2,
  secondaryAxis = false,
  invert = false,
  points = false,
  emptyTitle = 'Zbieramy historię',
  emptyDescription,
} = Astro.props;

/* Przycięcie krańców bez żadnego odczytu: oś X zaczyna się od pierwszego
   pomiaru serii (np. Ahrefs zbierany od 18.07 na tle rocznego backfillu
   GSC dawał „pustą" oś z linią wciśniętą w prawą krawędź). */
const hasAny = (i: number) => rawSeries.some((s) => s.values[i] !== null);
let start = 0;
while (start < rawTs.length && !hasAny(start)) start++;
let end = rawTs.length - 1;
while (end >= start && !hasAny(end)) end--;
const timestamps = rawTs.slice(start, end + 1);
const series = rawSeries.map((s) => ({ ...s, values: s.values.slice(start, end + 1) }));

const payload = JSON.stringify({ timestamps, series, unit, precision, overview, secondaryAxis, invert, points });
/* Linia ma sens od 2 punktów – pojedynczy pomiar to nadal „zbieramy historię"
   (handoff „Przegląd": empty state z datą pierwszego odczytu). */
const nonNullMax = Math.max(0, ...series.map((s) => s.values.filter((v) => v !== null).length));
const hasData = timestamps.length > 1 && nonNullMax >= minPoints;
const firstReadTs = series.length
  ? timestamps.find((_, i) => series.some((s) => s.values[i] !== null))
  : undefined;
const firstRead = firstReadTs
  ? new Date(firstReadTs * 1000).toLocaleDateString('pl-PL', { day: '2-digit', month: '2-digit', year: 'numeric' })
  : null;

const RANGE_OPTIONS: [string, number, string][] = [
  ['7d', 7, '7 dni'],
  ['30d', 30, '30 dni'],
  ['3m', 91, '3 mies.'],
  ['6m', 183, '6 mies.'],
  ['12m', 365, '12 mies.'],
  ['18m', 548, '18 mies.'],
  ['24m', 730, '24 mies.'],
];
const spanDays =
  timestamps.length > 1 ? (timestamps[timestamps.length - 1]! - timestamps[0]!) / 86400 : 0;
const rangeOptions = ranges && hasData ? RANGE_OPTIONS.filter(([, d]) => d <= spanDays + 7) : [];
const defaultRange = rangeOptions.some(([k]) => k === '30d') ? '30d' : (rangeOptions[0]?.[0] ?? 'all');
---

<figure class:list={['chart-card', 'rchart', { overview }]}>
  <figcaption class="cap">
    <span class="cap-title">
      {sourceColor && <i class="source-dot" style={`background:var(${sourceColor})`}></i>}
      {title}
    </span>
    <span class="cap-side side">
      {
        rangeOptions.length > 0 && (
          <span class="seg seg-mini" data-chart-ranges>
            {rangeOptions.map(([k, d, label]) => (
              <button type="button" class={k === defaultRange ? 'active' : ''} data-days={d}>
                {label}
              </button>
            ))}
            <button type="button" class={defaultRange === 'all' ? 'active' : ''} data-days="all">
              całość
            </button>
          </span>
        )
      }
      {meta && <span class="cap-meta" data-chart-meta data-base-meta={meta}>{meta}</span>}
    </span>
  </figcaption>
  {hasData && (
    <div class="series-legend rlegend" aria-label="Legenda wykresu">
      {series.map((item, index) => {
        const color = item.color ?? `--series-${(index % 3) + 1}`;
        const dashed = (item.dash ?? (index === 0 ? [] : index === 1 ? [6, 4] : [2, 4])).length > 0;
        return (
          <span style={`color:var(${color})`}>
            <i class:list={{ dashed }}></i>{item.label}
          </span>
        );
      })}
    </div>
  )}
  {
    hasData ? (
      <div class:list={['chart-stage', { compact: overview }]} aria-busy="true">
        <div class="skel chart-skeleton" aria-hidden="true">
          <span class="sk sk-line wide"></span>
          <span class="sk sk-line"></span>
          <span class="sk sk-block"></span>
        </div>
        <div class="ts-chart" data-chart={payload} />
      </div>
    ) : (
      <div class="empty-chart">
        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M3 17l5-5 4 3 6-7" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M3 21h18" stroke-linecap="round" />
        </svg>
        <h4>{emptyTitle}</h4>
        <p>
          {emptyDescription ?? 'Wykres pojawi się po kilku dziennych przebiegach collectora (cron 6:30).'}
          {firstRead && ` Pierwszy odczyt: ${firstRead}.`}
        </p>
      </div>
    )
  }
</figure>

<script>
  import uPlot from 'uplot';
  import 'uplot/dist/uPlot.min.css';

  const DASHES: (number[] | undefined)[] = [undefined, [6, 4], [2, 4]];

  function cssVar(name: string): string {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }

  function buildChart(el: HTMLElement) {
    const cfg = JSON.parse(el.dataset.chart!) as {
      timestamps: number[];
      series: { label: string; values: (number | null)[]; fill?: boolean; color?: string; dash?: number[] }[];
      unit: string;
      precision: number;
      overview: boolean;
      secondaryAxis: boolean;
      invert: boolean;
      points: boolean;
    };
    /* Gradient pod serią (lifting §3): pełniejszy u góry, zanika do zera.
       Fallback na płaską alfę, gdy kolor nie jest hexem. */
    const hexA = (hex: string, a: number) =>
      /^#[0-9a-f]{6}$/i.test(hex)
        ? `rgba(${parseInt(hex.slice(1, 3), 16)},${parseInt(hex.slice(3, 5), 16)},${parseInt(hex.slice(5, 7), 16)},${a})`
        : hex;
    const areaFill = (hex: string) => (u: uPlot) => {
      const { top, height } = u.bbox;
      // Ukryty/zerowy kontener → bbox NaN → createLinearGradient rzuca.
      if (!Number.isFinite(top) || !Number.isFinite(height) || height <= 0) return hexA(hex, 0.14);
      const g = u.ctx.createLinearGradient(0, top, 0, top + height);
      g.addColorStop(0, hexA(hex, 0.28));
      g.addColorStop(1, hexA(hex, 0));
      return g;
    };
    const fmt = (v: number | null) =>
      v == null
        ? '–'
        : v.toLocaleString('pl-PL', { maximumFractionDigits: cfg.precision }) +
          (cfg.unit ? ` ${cfg.unit}` : '');

    let plot: uPlot | null = null;

    const render = () => {
      plot?.destroy();
      const ink = cssVar('--ink-faint') || cssVar('--ink-muted');
      const grid = cssVar('--hairline');
      const colors = [cssVar('--series-1'), cssVar('--series-2'), cssVar('--series-3')];
      const chartHeight = cfg.overview ? 170 : 280;
      /* Lifting §3: siatka tylko pozioma, bez ticków, osie w --ink-faint. */
      const axis = {
        stroke: ink,
        grid: { show: false as const },
        ticks: { show: false as const },
        font: '11px Inter, system-ui, sans-serif',
      };
      const yAxis = { ...axis, grid: { show: true as const, stroke: grid, width: 1 } };
      // Mało próbek (start zbierania) = linia niewidoczna – wtedy rysuj punkty
      // i zepnij oś X wokół danych zamiast auto-zakresu na lata.
      const sparse = cfg.timestamps.length < 15;
      const showPoints = cfg.points || cfg.invert || cfg.timestamps.length <= 8;
      const scales = {
        ...(sparse
          ? {
            x: {
              time: true,
              range: [
                cfg.timestamps[0]! - 3 * 86400,
                cfg.timestamps[cfg.timestamps.length - 1]! + 3 * 86400,
              ] as [number, number],
            },
          }
          : {}),
        ...(cfg.invert ? { y: { dir: -1 as const } } : {}),
        ...(cfg.secondaryAxis ? { b: {} } : {}),
      };
      plot = new uPlot(
        {
          width: el.clientWidth,
          height: chartHeight,
          padding: [12, 8, 0, 0],
          cursor: { points: { size: 7 }, y: false },
          legend: { show: false },
          scales,
          series: [
            {
              label: 'Data',
              value: (_u: uPlot, ts: number | null) =>
                ts == null ? '–' : new Date(ts * 1000).toLocaleDateString('pl-PL'),
            },
            ...cfg.series.map((s, i) => {
              const color = s.color ? cssVar(s.color) : colors[i % colors.length]!;
              const fill = s.fill ?? (cfg.series.length === 1 && i === 0);
              return {
                label: s.label,
                stroke: color,
                fill: fill ? areaFill(color) : undefined,
                width: 2.4,
                dash: s.dash ?? DASHES[i % DASHES.length],
                scale: cfg.secondaryAxis && i === 1 ? 'b' : 'y',
                points: { show: showPoints, size: 6, stroke: color, fill: color },
                value: (_u: uPlot, v: number | null) => fmt(v),
                spanGaps: true,
              };
            }),
          ],
          axes: [
            { ...axis, space: 54, values: (_u: uPlot, ticks: number[]) =>
              ticks.map((t) => {
                const d = new Date(t * 1000);
                return `${d.getUTCDate()}.${String(d.getUTCMonth() + 1).padStart(2, '0')}`;
              }) },
            { ...yAxis, size: 56, values: (_u: uPlot, ticks: number[]) =>
              ticks.map((t) => t.toLocaleString('pl-PL', { maximumFractionDigits: cfg.precision })) },
            ...(cfg.secondaryAxis
              ? [{
                  ...axis,
                  scale: 'b',
                  side: 1 as const,
                  size: 56,
                  values: (_u: uPlot, ticks: number[]) =>
                    ticks.map((t) => t.toLocaleString('pl-PL', { maximumFractionDigits: cfg.precision })),
                }]
              : []),
          ],
        },
        [cfg.timestamps, ...cfg.series.map((s) => s.values)] as uPlot.AlignedData,
        el,
      );
    };

    render();
    const stage = el.closest<HTMLElement>('.chart-stage');
    stage?.classList.add('ready');
    stage?.setAttribute('aria-busy', 'false');

    /* Przełącznik zakresu osi X (opcjonalny – [data-chart-ranges] w nagłówku). */
    const figure = el.closest('figure');
    const rangeSeg = figure?.querySelector<HTMLElement>('[data-chart-ranges]');
    const metaEl = figure?.querySelector<HTMLElement>('[data-chart-meta]');
    let currentDays: number | 'all' = 'all';

    const applyRange = () => {
      if (!plot || cfg.timestamps.length === 0) return;
      const last = cfg.timestamps[cfg.timestamps.length - 1]!;
      const first = cfg.timestamps[0]!;
      const min = currentDays === 'all' ? first : Math.max(first, last - currentDays * 86400);
      plot.setScale('x', { min, max: last });
      if (metaEl) {
        const d = (ts: number) => new Date(ts * 1000).toLocaleDateString('pl-PL');
        const base = metaEl.dataset.baseMeta ?? '';
        metaEl.textContent = `${base ? base + ' · ' : ''}${d(min)} → ${d(last)}`;
      }
    };

    const renderWithRange = () => {
      render();
      applyRange();
    };

    if (rangeSeg) {
      const active = rangeSeg.querySelector<HTMLButtonElement>('button.active');
      currentDays = active?.dataset.days === 'all' || !active ? 'all' : Number(active.dataset.days);
      rangeSeg.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('button[data-days]') as HTMLButtonElement | null;
        if (!btn) return;
        rangeSeg.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === btn));
        currentDays = btn.dataset.days === 'all' ? 'all' : Number(btn.dataset.days);
        applyRange();
      });
      applyRange();
    }

    new ResizeObserver(() => plot && plot.setSize({ width: el.clientWidth, height: cfg.overview ? 170 : 280 })).observe(
      el,
    );
    window.addEventListener('themechange', renderWithRange);
  }

  document.querySelectorAll<HTMLElement>('.ts-chart').forEach(buildChart);
</script>

<style>
  .chart-card {
    background: linear-gradient(180deg, color-mix(in srgb, var(--ink) 3%, var(--bg-surface-1)), var(--bg-surface-1) 55%);
    border: 1px solid var(--hairline);
    border-radius: 14px;
    padding: 16px 18px 10px;
    margin: 0;
    min-width: 0;
    transition: border-color 0.15s ease;
  }
  .chart-stage {
    position: relative;
    min-height: 280px;
  }
  .chart-stage.compact {
    min-height: 170px;
  }
  .chart-skeleton {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: grid;
    grid-template-columns: 72px 1fr;
    grid-template-rows: 18px 18px 1fr;
    gap: 10px 14px;
    padding: 10px 4px 8px;
    pointer-events: none;
  }
  .chart-skeleton .sk-line {
    height: 12px;
  }
  .chart-skeleton .wide {
    grid-column: 1 / -1;
    width: 42%;
  }
  .chart-skeleton .sk-block {
    grid-column: 1 / -1;
    min-height: 180px;
  }
  .chart-stage.compact .chart-skeleton .sk-block {
    min-height: 96px;
  }
  .chart-stage.ready .chart-skeleton {
    display: none;
  }
  .chart-card:hover {
    border-color: color-mix(in srgb, var(--accent-blue) 30%, var(--hairline));
  }
  figcaption {
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .cap-title {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .source-dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    flex: none;
  }
  .cap-meta {
    color: var(--ink-faint);
    font-size: 0.76rem;
    font-weight: 500;
    font-family: var(--font-body);
  }
  .cap-side {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
    font-family: var(--font-body);
    font-weight: 500;
  }
  .cap-side :global(.seg-mini) {
    padding: 2px;
  }
  .cap-side :global(.seg-mini button) {
    font-size: 0.74rem;
    padding: 4px 9px;
  }
  .chart-empty {
    color: var(--ink-faint);
    font-size: 0.88rem;
    padding: 32px 0 40px;
    text-align: center;
  }
  .chart-card.overview {
    border-radius: 16px;
    padding: 16px 18px 10px;
  }
  .chart-card.overview figcaption {
    margin-bottom: 4px;
  }
  .series-legend {
    display: flex;
    gap: 14px;
    margin: 2px 0 6px;
    font-size: 0.74rem;
    color: var(--ink-muted);
    flex-wrap: wrap;
  }
  .series-legend span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .series-legend i {
    width: 13px;
    height: 3px;
    border-radius: 2px;
    background: currentColor;
  }
  .series-legend i.dashed {
    height: 2px;
    background: repeating-linear-gradient(90deg, currentColor 0 4px, transparent 4px 7px);
  }
  .chart-card.overview .empty-chart {
    min-height: 176px;
    padding: 26px 20px;
  }
  /* Legenda uPlot w tokenach – zawsze widoczna, wartości przy hoverze */
  .chart-card :global(.u-legend) {
    font: 12px Inter, system-ui, sans-serif;
    color: var(--ink-muted);
    text-align: left;
    padding-top: 6px;
  }
  .chart-card :global(.u-legend .u-value) {
    font-variant-numeric: tabular-nums;
    color: var(--ink);
  }
  .chart-card :global(.u-legend .u-marker) {
    width: 12px;
    height: 12px;
    border-radius: 3px;
  }
  .chart-card :global(.u-select) {
    background: var(--accent-blue-soft);
  }
</style>
