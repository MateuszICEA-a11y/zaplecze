---
import type { SourceResult } from '../lib/data';

interface Props {
  name: string;
  result?: SourceResult;
}
const { name, result } = Astro.props;

const STATUS_META: Record<string, { label: string; cls: string }> = {
  ok: { label: 'OK', cls: 'ok' },
  token_expired: { label: 'token wygasł', cls: 'warn' },
  error: { label: 'błąd', cls: 'err' },
  not_configured: { label: 'nieskonfigurowane', cls: 'off' },
};
const meta = STATUS_META[result?.status ?? 'not_configured'] ?? STATUS_META.error;
---

<span class="rstat" title={result?.error ?? ''}>
  <span class={`d ${meta.cls}`} aria-hidden="true"></span>
  <span><b>{name}</b> {meta.label}</span>
</span>

<style>
  .rstat b {
    color: var(--ink);
    font-weight: 600;
    margin-right: 3px;
  }
</style>
