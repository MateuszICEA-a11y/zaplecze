---
/* Nagłówek strony sekcji: eyebrow z domeną, duży tytuł sekcji (display font),
   chip z datą pomiaru. Nawigacja sekcji żyje w sidebarze (Layout). */
import type { Snapshot } from '../lib/data';
import { DOMAIN_SECTIONS } from '../lib/data';
import { fmtDate } from '../lib/format';

interface Props {
  domain: string;
  name: string;
  active: string; // slug aktywnej sekcji ('' = przegląd)
  latest: Snapshot | null;
  themeToggle?: boolean;
  accent?: string;
  measurementLabel?: string;
  measurementStatus?: 'ok' | 'warn';
}
const {
  name,
  active,
  latest,
  themeToggle = false,
  accent,
  measurementLabel,
  measurementStatus = 'ok',
} = Astro.props;

const TITLES: Record<string, string> = {
  '': 'Przegląd',
  senuto: 'Widoczność · Senuto',
  gsc: 'Google Search Console',
  ga4: 'Ruch · Google Analytics 4',
  bing: 'Bing Webmaster Tools',
  ahrefs: 'Profil linków · Ahrefs',
  clarity: 'Zachowania · Clarity',
  'boty-ai': 'Crawlery AI · Cloudflare',
  matrix: 'Matrix · kondycja stron',
  leady: 'Leady i użycia narzędzi',
};
const title = TITLES[active] ?? DOMAIN_SECTIONS.find((s) => s.slug === active)?.label ?? '';
---

<header class="page-header">
  <div class="eyebrow" style={accent ? `color:${accent}` : undefined}>{name}</div>
  <div class="title-row">
    <h1>{title}</h1>
    <div class="header-actions">
      <span class:list={['measured', measurementStatus]} title="Data ostatniego przebiegu collectora">
        <i aria-hidden="true"></i>
        {measurementLabel ?? (latest?.date ? fmtDate(latest.date) : 'brak pomiaru')}
      </span>
      {themeToggle && (
        <button class="header-theme-toggle" type="button" aria-label="Przełącz motyw">
          <span aria-hidden="true" data-header-theme-icon>☀</span>
          <span data-header-theme-label>Jasny</span>
        </button>
      )}
    </div>
  </div>
</header>

{themeToggle && (
  <script>
    const headerThemeButton = document.querySelector<HTMLButtonElement>('.header-theme-toggle');
    const syncHeaderTheme = () => {
      const light = document.documentElement.dataset.theme === 'light';
      const icon = headerThemeButton?.querySelector<HTMLElement>('[data-header-theme-icon]');
      const label = headerThemeButton?.querySelector<HTMLElement>('[data-header-theme-label]');
      if (icon) icon.textContent = light ? '☾' : '☀';
      if (label) label.textContent = light ? 'Ciemny' : 'Jasny';
    };
    headerThemeButton?.addEventListener('click', () => {
      document.getElementById('theme-toggle')?.click();
      syncHeaderTheme();
    });
    window.addEventListener('themechange', syncHeaderTheme);
    syncHeaderTheme();
  </script>
)}

<style>
  .page-header {
    margin-bottom: 6px;
  }
  .eyebrow {
    color: var(--accent-blue);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  h1 {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .measured {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink-muted);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 5px 13px;
  }
  .measured i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--status-ok);
    box-shadow: 0 0 6px color-mix(in srgb, var(--status-ok) 60%, transparent);
  }
  .measured.warn i {
    background: var(--status-warn-fg);
    box-shadow: 0 0 6px color-mix(in srgb, var(--status-warn-fg) 60%, transparent);
  }
  .header-theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline);
    border-radius: 2px;
    color: var(--ink-muted);
    font: inherit;
    font-size: 0.82rem;
    padding: 7px 12px;
    cursor: pointer;
    white-space: nowrap;
  }
  .header-theme-toggle:hover {
    color: var(--ink);
    border-color: var(--ink-faint);
  }
</style>
