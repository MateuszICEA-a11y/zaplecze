---
/* Stat tile wg kontraktu dataviz: label · value · delta (kierunek × czy wzrost
   jest dobry) · opcjonalny 12-punktowy sparkline liczony w build time (SVG,
   zero JS). `goodWhen="down"` odwraca kolor delty (np. średnia pozycja). */
interface Props {
  label: string;
  value: number | string | null;
  delta?: number | null;
  deltaLabel?: string;
  deltaUnit?: string;
  unit?: string;
  precision?: number;
  goodWhen?: 'up' | 'down';
  trend?: (number | null)[];
  hero?: boolean;
  /* Link – cała karta staje się klikalna (np. skok do zakładki źródła). */
  href?: string;
  /* Nazwa tokenu koloru źródła (sen/gsc/ga4/ahrefs/bing) – kropka przy labelu,
     akcent hero-kreski i sparkline'a (handoff „Przegląd – układ"). */
  src?: 'sen' | 'gsc' | 'ga4' | 'ahrefs' | 'bing';
  /* Dowolny kolor CSS kropki przy labelu (np. tier TOP 3/10/50 z handoffu
     „Senuto – układ") – niezależny od koloru akcentu karty. */
  dot?: string;
  /* Data ostatniego udanego pomiaru, gdy źródło leży – karta „nieaktualna":
     wyciszona wartość + pigułka „dane z …" zamiast delty (handoff §4a). */
  staleDate?: string | null;
  /* Dopisek do stanu nieaktualnego, np. „limit API". */
  staleReason?: string;
  /* Jawny komunikat, gdy nie ma jeszcze historii do policzenia delty. */
  emptyDeltaLabel?: string;
}
const {
  label,
  value,
  delta = null,
  deltaLabel = '7 dni',
  deltaUnit = '',
  unit = '',
  precision = 0,
  goodWhen = 'up',
  trend,
  hero = false,
  href,
  src,
  dot,
  staleDate = null,
  staleReason,
  emptyDeltaLabel,
} = Astro.props;
const Tag = href ? 'a' : 'div';
const srcStyle = src ? `--src-color: var(--${src});` : undefined;

const formatted =
  value === null
    ? '–'
    : typeof value === 'number'
      ? value.toLocaleString('pl-PL', { maximumFractionDigits: precision })
      : value;
const deltaText =
  delta === null
    ? null
    : `${delta > 0 ? '+' : ''}${delta.toLocaleString('pl-PL', { maximumFractionDigits: Math.max(precision, 0) })}${deltaUnit}`;
const direction = delta === null ? 'flat' : delta > 0 ? 'up' : delta < 0 ? 'down' : 'flat';
const sentiment =
  direction === 'flat' ? 'flat' : (direction === 'up') === (goodWhen === 'up') ? 'good' : 'bad';

/* Sparkline: ostatnie 12 niepustych punktów, 100×28 viewBox. */
const points = (trend ?? []).filter((v): v is number => typeof v === 'number').slice(-12);
let path = '';
if (points.length >= 2) {
  const min = Math.min(...points);
  const max = Math.max(...points);
  const span = max - min || 1;
  path = points
    .map((v, i) => {
      const x = (i / (points.length - 1)) * 100;
      const y = 26 - ((v - min) / span) * 24;
      return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
    })
    .join(' ');
}
---

<Tag class:list={['stat-card', { hero, stale: staleDate !== null }]} href={href} style={srcStyle}>
  <div class="stat-label">
    {src && <span class="src-dot" aria-hidden="true"></span>}
    {!src && dot && <span class="src-dot" style={`background:${dot}`} aria-hidden="true"></span>}
    {label}
  </div>
  <div class="stat-row">
    <div class="stat-value">{formatted}{value !== null && unit ? (unit === '%' ? unit : ` ${unit}`) : ''}</div>
    {
      path && (
        <svg class="spark" viewBox="0 0 100 28" preserveAspectRatio="none" aria-hidden="true">
          <path
            d={path}
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            vector-effect="non-scaling-stroke"
          />
        </svg>
      )
    }
  </div>
  <slot />
  {
    staleDate !== null ? (
      <div class="stat-foot">
        <span class="stale-tag">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l3 2" stroke-linecap="round" />
          </svg>
          dane z {staleDate}{staleReason ? ` · ${staleReason}` : ''}
        </span>
      </div>
    ) : deltaText !== null ? (
      <div class="stat-foot">
        <span class={`rtrend ${sentiment === 'good' ? 'up' : sentiment === 'bad' ? 'down' : 'flat'}`}>
          {direction !== 'flat' && (
            <svg viewBox="0 0 12 12" aria-hidden="true">
              <path
                d={direction === 'up' ? 'M2 8.5 6 4.5 10 8.5' : 'M2 3.5 6 7.5 10 3.5'}
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          )}
          {direction === 'flat' ? 'bez zmian' : deltaText}
          {deltaLabel && <span class="per">/ {deltaLabel}</span>}
        </span>
      </div>
    ) : emptyDeltaLabel ? (
      <div class="stat-foot">
        <span class="rtrend flat">— <span class="per">{emptyDeltaLabel}</span></span>
      </div>
    ) : (
      trend && trend.length > 0 && (
        <div class="stat-foot">
          <span class="rtrend flat">zbieramy dane</span>
        </div>
      )
    )
  }
</Tag>

<style>
  a.stat-card {
    display: block;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }
  a.stat-card:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }
  .stat-card {
    position: relative;
    background: linear-gradient(180deg, color-mix(in srgb, var(--ink) 3%, var(--bg-surface-1)), var(--bg-surface-1) 55%);
    border: 1px solid var(--hairline);
    border-radius: 14px;
    padding: 16px 18px;
    min-width: 0;
    overflow: hidden;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .stat-card:hover {
    border-color: color-mix(in srgb, var(--src-color, var(--accent-blue)) 35%, var(--hairline));
  }
  .stat-card.hero::before {
    content: '';
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--src-color, var(--accent-blue)), transparent 70%);
  }
  .stat-card.stale .stat-value {
    color: var(--ink-muted);
  }
  .src-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--src-color, var(--accent-blue));
    margin-right: 6px;
    vertical-align: middle;
  }
  .stat-label {
    color: var(--ink-muted);
    font-size: 0.74rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 8px;
  }
  .stat-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
  }
  .stat-value {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.02;
  }
  .hero .stat-value {
    font-size: 3rem;
  }
  .stat-foot {
    margin-top: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .spark {
    width: 96px;
    height: 30px;
    color: var(--src-color, var(--accent-blue));
    opacity: 0.9;
    flex: none;
  }
  .stat-delta {
    margin-top: 6px;
    font-size: 0.8rem;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  .stat-delta.good {
    color: var(--status-ok);
  }
  .stat-delta.bad {
    color: var(--status-err-fg);
  }
</style>
