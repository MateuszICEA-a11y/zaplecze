---
/* Karta tabeli: nagłówek + licznik + opcjonalny filtr tekstowy (progressive
   enhancement, filtruje wiersze po textContent) + poziomy scroll dla wąskich
   ekranów. Tabelę renderuje strona przez <slot /> (klasy .data-table z theme.css). */
interface Props {
  title: string;
  meta?: string;
  count?: number;
  filter?: boolean;
  empty?: string;
}
const { title, meta, count, filter = false, empty = 'Brak danych.' } = Astro.props;
const isEmpty = count === 0;
---

<section class="table-card">
  <div class="table-head">
    <h3>
      {title}
      {typeof count === 'number' && <span class="table-meta"> · {count.toLocaleString('pl-PL')}</span>}
    </h3>
    {meta && <span class="table-meta">{meta}</span>}
    {!isEmpty && filter && (
      <input class="table-filter" type="search" placeholder="Filtruj…" data-table-filter aria-label={`Filtruj: ${title}`} />
    )}
  </div>
  {
    isEmpty ? (
      <div class="table-empty">{empty}</div>
    ) : (
      <div class="table-scroll">
        <slot />
      </div>
    )
  }
</section>

<script>
  document.querySelectorAll<HTMLInputElement>('[data-table-filter]').forEach((input) => {
    const card = input.closest('.table-card');
    const rows = card?.querySelectorAll<HTMLTableRowElement>('tbody tr');
    if (!rows?.length) return;
    input.addEventListener('input', () => {
      const needle = input.value.trim().toLowerCase();
      rows.forEach((row) => {
        row.hidden = needle !== '' && !(row.textContent ?? '').toLowerCase().includes(needle);
      });
    });
  });

  /* Sortowanie klikiem w nagłówek (progressive enhancement). Kolumny .num
     sortowane numerycznie (parsowanie pl-PL z komórki), reszta leksykalnie. */
  const numFrom = (cell: HTMLTableCellElement | undefined): number => {
    const t = (cell?.textContent ?? '').replace(/[\s  ]/g, '').replace(',', '.');
    const m = t.match(/-?\d+(?:\.\d+)?/);
    return m ? parseFloat(m[0]) : -Infinity;
  };
  document.querySelectorAll<HTMLTableElement>('.table-card table.data-table').forEach((table) => {
    const body = table.tBodies[0];
    const ths = table.querySelectorAll<HTMLTableCellElement>('thead th');
    if (!body || body.rows.length < 2) return;
    ths.forEach((th, idx) => {
      th.classList.add('sortable');
      const caret = document.createElement('span');
      caret.className = 'sort-caret';
      th.appendChild(caret);
      th.addEventListener('click', () => {
        const numeric = th.classList.contains('num');
        const dir = th.dataset.dir === 'asc' ? 'desc' : th.dataset.dir === 'desc' ? 'asc' : numeric ? 'desc' : 'asc';
        ths.forEach((other) => {
          other.classList.remove('active');
          delete other.dataset.dir;
          const c = other.querySelector('.sort-caret');
          if (c) c.textContent = '';
        });
        th.classList.add('active');
        th.dataset.dir = dir;
        caret.textContent = dir === 'desc' ? '↓' : '↑';
        const sign = dir === 'desc' ? -1 : 1;
        Array.from(body.rows)
          .sort((a, b) => {
            if (numeric) return sign * (numFrom(a.cells[idx]) - numFrom(b.cells[idx]));
            return sign * (a.cells[idx]?.textContent ?? '').localeCompare(b.cells[idx]?.textContent ?? '', 'pl');
          })
          .forEach((row) => body.appendChild(row));
      });
    });
  });
</script>
