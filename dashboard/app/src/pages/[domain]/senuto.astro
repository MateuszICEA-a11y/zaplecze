---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TableCard from '../../components/TableCard.astro';
import TimeSeriesChart from '../../components/TimeSeriesChart.astro';
import SourceState from '../../components/SourceState.astro';
import {
  loadConfig,
  loadSnapshots,
  loadDetails,
  latestSnapshot,
  latestWithDelta,
  metricSeries,
  sourceStatuses,
  isTemporarySourceFailure,
} from '../../lib/data';
import { fmtInt, fmtNum, fmtDate, posClass, barWidth } from '../../lib/format';

export function getStaticPaths() {
  return loadConfig().domains.map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);
const keywords = details.sources.senuto?.keywords ?? [];

const top3 = metricSeries(snapshots, 'senuto', 'top3');
const top10 = metricSeries(snapshots, 'senuto', 'top10');
const top50 = metricSeries(snapshots, 'senuto', 'top50');
const visibility = metricSeries(snapshots, 'senuto', 'visibility');

const statTop3 = latestWithDelta(snapshots, 'senuto', 'top3');
const statTop10 = latestWithDelta(snapshots, 'senuto', 'top10');
const statTop50 = latestWithDelta(snapshots, 'senuto', 'top50');
const statVisibility = latestWithDelta(snapshots, 'senuto', 'visibility');
const statRank = latestWithDelta(snapshots, 'senuto', 'domain_rank');

const visibilityPrevious =
  statVisibility.value !== null && statVisibility.delta !== null
    ? statVisibility.value - statVisibility.delta
    : null;
const visibilityDeltaPct =
  visibilityPrevious && statVisibility.delta !== null
    ? (statVisibility.delta / visibilityPrevious) * 100
    : null;

/* Handoff pokazuje trendy z ostatnich 3 miesięcy, nie pełny backfill. */
const lastTimestamp = Math.max(0, ...top10.timestamps, ...visibility.timestamps);
const trendCutoff = lastTimestamp - 91 * 86400;
const trimTrend = (series: { timestamps: number[]; values: (number | null)[] }) => {
  const found = series.timestamps.findIndex((timestamp) => timestamp >= trendCutoff);
  const start = found === -1 ? 0 : found;
  return { timestamps: series.timestamps.slice(start), values: series.values.slice(start) };
};
const top3Trend = trimTrend(top3);
const top10Trend = trimTrend(top10);
const top50Trend = trimTrend(top50);
const visibilityTrend = trimTrend(visibility);

const senuto = sourceStatuses(latest).senuto;
const senutoLastOk = [...snapshots].reverse().find((snapshot) => snapshot.sources.senuto?.status === 'ok');
const senutoStaleDate = isTemporarySourceFailure(senuto) ? senutoLastOk?.date ?? null : null;
const maxSearches = Math.max(...keywords.map((k) => k.searches ?? 0), 0);

const diffClass = (d: number | null | undefined) =>
  typeof d !== 'number' ? '' : d < 40 ? 'easy' : d < 60 ? 'med' : 'hard';
---

<Layout title={`${name} – Senuto`}>
  <DomainHeader domain={domain!} name={name} active="senuto" latest={latest} themeToggle />

  <div class="senuto-note">
    Indeks widoczności to kluczowy wskaźnik na tym widoku. Karty zakresów (<b>TOP 3, 10 i 50</b>) służą do filtrowania tabeli,
    w której znajdziesz pełne zestawienie rankujących fraz. Wyniki możesz sortować według pozycji, jej zmiany, liczby wyszukiwań
    i trudności słowa kluczowego. Źródłem danych jest Senuto.
  </div>

  <SourceState
    name="Senuto"
    result={senuto}
    lastDate={senutoLastOk?.date}
    metrics={[
      { label: 'Indeks widoczności', value: statVisibility.value },
      { label: 'Frazy TOP 10', value: statTop10.value },
      { label: 'Ranking domeny', value: statRank.value },
    ]}
  />

  <div class="section-head"><h2>Widoczność organiczna</h2><span class="section-meta">porównanie 7-dniowe</span></div>
  <div class="stat-grid rgrid senuto-kpis">
    <StatCard
      label="Indeks widoczności"
      value={statVisibility.value}
      delta={visibilityDeltaPct}
      deltaUnit="%"
      precision={1}
      trend={visibility.values}
      src="sen"
      staleDate={senutoStaleDate}
      hero
    />
    <StatCard label="Frazy w TOP 3" value={statTop3.value} delta={statTop3.delta} staleDate={senutoStaleDate} dot="var(--status-ok)" href="#top-3" />
    <StatCard label="Frazy w TOP 10" value={statTop10.value} delta={statTop10.delta} staleDate={senutoStaleDate} dot="var(--accent-blue)" href="#top-10" />
    <StatCard label="Frazy w TOP 50" value={statTop50.value} delta={statTop50.delta} staleDate={senutoStaleDate} dot="var(--ink-faint)" href="#top-50" />
    <StatCard
      label="Ranking domeny"
      value={statRank.value}
      delta={statRank.delta}
      goodWhen="down"
      staleDate={senutoStaleDate}
    />
  </div>

  <div class="section-head"><h2>Trendy</h2><span class="section-meta">3 miesiące</span></div>
  <div class="senuto-charts">
    <TimeSeriesChart
      title="Frazy w TOP 3 / 10 / 50"
      timestamps={top10Trend.timestamps}
      series={[
        { label: 'TOP 3', values: top3Trend.values, color: '--status-ok', dash: [] },
        { label: 'TOP 10', values: top10Trend.values, color: '--accent-blue', dash: [] },
        { label: 'TOP 50', values: top50Trend.values, color: '--ink-faint', dash: [] },
      ]}
      overview
    />
    <TimeSeriesChart
      title="Indeks widoczności"
      timestamps={visibilityTrend.timestamps}
      series={[{ label: 'Widoczność', values: visibilityTrend.values, color: '--sen', dash: [], fill: true }]}
      precision={2}
      overview
    />
  </div>

  <div class="section-head"><h2>Rankujące frazy</h2></div>
  <TableCard
    title="Frazy"
    meta={details.date ? `stan z ${fmtDate(details.date)} · ${keywords.length} najlepszych pozycji z pełnej bazy fraz` : undefined}
    count={keywords.length}
    filter
    empty="Lista fraz pojawi się po najbliższym przebiegu collectora (codziennie 6:30)."
  >
    <table class="data-table kw-table" data-filter-col="0">
      <thead>
        <tr>
          <th>Fraza</th>
          <th class="num">Pozycja</th>
          <th class="num">Zmiana <span class="info-badge" title="Różnica pozycji z API Senuto – porównanie z poprzednią aktualizacją indeksu (~7 dni)">i</span></th>
          <th class="num">Wolumen / mies.</th>
          <th class="num">Trudność</th>
        </tr>
      </thead>
      <tbody>
        {
          keywords.map((k) => (
            <tr>
              <td class="grow kw-cell">
                <span class="txt" title={k.keyword}>{k.keyword}</span>
                {k.url ? (
                  <a class="url" href={`https://${k.url}`} rel="noopener" target="_blank" title={k.url}>
                    {k.url}
                  </a>
                ) : (
                  <span class="url">–</span>
                )}
              </td>
              <td class="num">
                <span class={`rbadge ${posClass(k.position)}`}>{fmtInt(k.position)}</span>
              </td>
              <td class="num" data-sort={k.diff ?? 0}>
                {typeof k.diff === 'number' && k.diff !== 0 ? (
                  <span class={`rdelta ${k.diff > 0 ? 'up' : 'down'}`}>
                    <svg viewBox="0 0 12 12" aria-hidden="true">
                      <path
                        d={k.diff > 0 ? 'M2 8.5 6 4.5 10 8.5' : 'M2 3.5 6 7.5 10 3.5'}
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    {Math.abs(k.diff)}
                  </span>
                ) : (
                  <span class="rdelta">—</span>
                )}
              </td>
              <td class="num">
                <span class="cell-bar rbar">
                  {fmtInt(k.searches)}
                  <span class="bar sen">
                    <i style={`width:${barWidth(k.searches, maxSearches)}%`} />
                  </span>
                </span>
              </td>
              <td class="num">
                <span class={`diff-bar ${diffClass(k.difficulty)}`}>
                  <span class="t">
                    <i style={`width:${Math.min(100, Math.max(0, k.difficulty ?? 0))}%`} />
                  </span>
                  <span class="v">{fmtNum(k.difficulty, 0)}</span>
                </span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </TableCard>

  <script>
    /* Karty TOP 3/10/50 (i chipy w nagłówku tabeli) filtrują frazy po kolumnie
       Pozycja – toggle, wspólny stan. Filtr idzie CustomEventem do kontrolera
       TableCard (spójny z filtrem tekstowym, sortowaniem i pagerem). */
    const card = document.querySelector<HTMLElement>('.table-card');
    const head = card?.querySelector<HTMLElement>('.table-head h3');
    if (card && head) {
      const tiers = [3, 10, 50];
      const chips = new Map<number | null, HTMLButtonElement>();
      const box = document.createElement('div');
      box.className = 'fchips';
      head.after(box);

      const posOf = (row: HTMLTableRowElement) =>
        parseFloat((row.cells[1]?.textContent ?? '').replace(/[\s  ]/g, '').replace(',', '.'));

      let active: number | null = null;
      const apply = (max: number | null) => {
        active = max;
        card.dispatchEvent(
          new CustomEvent('tablecard:refilter', {
            detail: max === null ? null : (row: HTMLTableRowElement) => posOf(row) <= max,
          }),
        );
        chips.forEach((chip, tier) => chip.classList.toggle('on', tier === max));
        document.querySelectorAll<HTMLAnchorElement>('a.stat-card[href^="#top-"]').forEach((a) => {
          a.classList.toggle('on', parseInt(a.getAttribute('href')!.slice(5), 10) === max);
        });
      };

      ([null, ...tiers] as (number | null)[]).forEach((tier) => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'fchip';
        chip.textContent = tier === null ? 'Wszystkie' : `TOP ${tier}`;
        chip.addEventListener('click', () => apply(active === tier ? null : tier));
        chips.set(tier, chip);
        box.appendChild(chip);
      });
      apply(null);

      document.querySelectorAll<HTMLAnchorElement>('a.stat-card[href^="#top-"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const max = parseInt(a.getAttribute('href')!.slice(5), 10);
          apply(active === max ? null : max);
          card.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }
  </script>
</Layout>

<style>
  .senuto-note {
    border-left: 2px solid var(--sen);
    background: color-mix(in srgb, var(--sen) 6%, transparent);
    color: var(--ink-muted);
    font-size: 0.84rem;
    line-height: 1.5;
    padding: 10px 14px;
    border-radius: 0 10px 10px 0;
    margin: 16px 0 4px;
  }
  .senuto-note b { color: var(--ink); }
  .senuto-charts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 18px;
  }
  @media (max-width: 1080px) {
    .senuto-charts { grid-template-columns: 1fr; }
  }
</style>
