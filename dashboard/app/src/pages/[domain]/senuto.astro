---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TableCard from '../../components/TableCard.astro';
import TimeSeriesChart from '../../components/TimeSeriesChart.astro';
import {
  loadConfig,
  loadSnapshots,
  loadDetails,
  latestSnapshot,
  latestWithDelta,
  metricSeries,
} from '../../lib/data';
import { fmtInt, fmtNum, posClass, barWidth } from '../../lib/format';

export function getStaticPaths() {
  return loadConfig().domains.map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);
const keywords = details.sources.senuto?.keywords ?? [];

const top3 = metricSeries(snapshots, 'senuto', 'top3');
const top10 = metricSeries(snapshots, 'senuto', 'top10');
const top50 = metricSeries(snapshots, 'senuto', 'top50');
const visibility = metricSeries(snapshots, 'senuto', 'visibility');

const statTop3 = latestWithDelta(snapshots, 'senuto', 'top3');
const statTop10 = latestWithDelta(snapshots, 'senuto', 'top10');
const statTop50 = latestWithDelta(snapshots, 'senuto', 'top50');
const statVisibility = latestWithDelta(snapshots, 'senuto', 'visibility');
const statRank = latestWithDelta(snapshots, 'senuto', 'domain_rank');

const senuto = latest?.sources.senuto;
const maxSearches = Math.max(...keywords.map((k) => k.searches ?? 0), 0);
---

<Layout title={`${name} – Senuto`}>
  <DomainHeader domain={domain!} name={name} active="senuto" latest={latest} />

  {
    senuto && senuto.status !== 'ok' && (
      <div class={`banner ${senuto.status === 'token_expired' ? 'warn' : 'err'}`}>
        <strong>Senuto</strong>: {senuto.error ?? 'błąd źródła'}
      </div>
    )
  }

  <div class="section-head"><h2>Widoczność organiczna</h2></div>
  <div class="stat-grid">
    <StatCard label="Frazy w TOP 3" value={statTop3.value} delta={statTop3.delta} trend={top3.values} href="#top-3" />
    <StatCard label="Frazy w TOP 10" value={statTop10.value} delta={statTop10.delta} trend={top10.values} href="#top-10" />
    <StatCard label="Frazy w TOP 50" value={statTop50.value} delta={statTop50.delta} trend={top50.values} href="#top-50" />
    <StatCard
      label="Indeks widoczności"
      value={statVisibility.value}
      delta={statVisibility.delta}
      precision={2}
      trend={visibility.values}
      hero
    />
    <StatCard
      label="Ranking domeny"
      value={statRank.value}
      delta={statRank.delta}
      goodWhen="down"
    />
  </div>

  <div class="chart-grid">
    <TimeSeriesChart
      title="Frazy w TOP 3 / 10 / 50"
      meta="dziennie"
      timestamps={top10.timestamps}
      series={[
        { label: 'TOP 3', values: top3.values },
        { label: 'TOP 10', values: top10.values },
        { label: 'TOP 50', values: top50.values, fill: true },
      ]}
    />
    <TimeSeriesChart
      title="Indeks widoczności"
      meta="dziennie"
      timestamps={visibility.timestamps}
      series={[{ label: 'Widoczność', values: visibility.values }]}
      precision={2}
    />
  </div>

  <TableCard
    title="Rankujące frazy"
    meta={details.date ? `stan z ${details.date} · ${keywords.length} najlepszych pozycji z pełnej bazy fraz` : undefined}
    count={keywords.length}
    filter
    empty="Lista fraz pojawi się po najbliższym przebiegu collectora (codziennie 6:30)."
  >
    <table class="data-table">
      <thead>
        <tr>
          <th>Fraza</th>
          <th class="num">Pozycja</th>
          <th class="num">Zmiana</th>
          <th class="num">Wolumen / mies.</th>
          <th class="num">Trudność</th>
          <th>URL</th>
        </tr>
      </thead>
      <tbody>
        {
          keywords.map((k) => (
            <tr>
              <td class="grow">{k.keyword}</td>
              <td class="num">
                <span class={`pos-badge ${posClass(k.position)}`}>{fmtInt(k.position)}</span>
              </td>
              <td class="num">
                {typeof k.diff === 'number' && k.diff !== 0 ? (
                  <span class={`delta ${k.diff > 0 ? 'up' : 'down'}`}>
                    {k.diff > 0 ? '▲' : '▼'} {Math.abs(k.diff)}
                  </span>
                ) : (
                  <span class="delta">•</span>
                )}
              </td>
              <td class="num">
                <span class="cell-bar">
                  {fmtInt(k.searches)}
                  <span class="bar">
                    <i style={`width:${barWidth(k.searches, maxSearches)}%`} />
                  </span>
                </span>
              </td>
              <td class="num">{fmtNum(k.difficulty, 0)}</td>
              <td>
                {k.url ? (
                  <a class="cell-url" href={`https://${k.url}`} rel="noopener" target="_blank">
                    {k.url}
                  </a>
                ) : (
                  '–'
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </TableCard>

  <script>
    /* Karty TOP 3/10/50 filtrują tabelę fraz po kolumnie Pozycja (toggle).
       Filtr idzie przez CustomEvent do kontrolera TableCard (spójny z filtrem
       tekstowym, sortowaniem i pagerem). */
    const card = document.querySelector<HTMLElement>('.table-card');
    const head = card?.querySelector<HTMLElement>('.table-head h3');
    if (card && head) {
      const chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'chip pos-filter-chip';
      chip.hidden = true;
      head.after(chip);

      const posOf = (row: HTMLTableRowElement) =>
        parseFloat((row.cells[1]?.textContent ?? '').replace(/[\s  ]/g, '').replace(',', '.'));

      let active: number | null = null;
      const apply = (max: number | null) => {
        active = max;
        card.dispatchEvent(
          new CustomEvent('tablecard:refilter', {
            detail: max === null ? null : (row: HTMLTableRowElement) => posOf(row) <= max,
          }),
        );
        chip.hidden = max === null;
        chip.textContent = `tylko TOP ${max} ✕`;
      };
      chip.addEventListener('click', () => apply(null));

      document.querySelectorAll<HTMLAnchorElement>('a.stat-card[href^="#top-"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const max = parseInt(a.getAttribute('href')!.slice(5), 10);
          apply(active === max ? null : max);
          card.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }
  </script>
</Layout>
