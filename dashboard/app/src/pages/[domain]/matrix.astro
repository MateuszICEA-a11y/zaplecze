---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TableCard from '../../components/TableCard.astro';
import { loadConfig, loadSnapshots, loadDetails, latestSnapshot, sectionEnabled, sourceStatuses, isTemporarySourceFailure } from '../../lib/data';
import { fmtInt, fmtPct, fmtNum, fmtDateRange, posClass, barWidth } from '../../lib/format';

export function getStaticPaths() {
  return loadConfig()
    .domains.filter((d) => sectionEnabled(d, 'indexing'))
    .map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);
const indexing = sourceStatuses(latest).indexing;
const indexingLastOk = [...snapshots].reverse().find((snapshot) => snapshot.sources.indexing?.status === 'ok');
const indexingStaleDate = isTemporarySourceFailure(indexing) ? indexingLastOk?.date ?? null : null;
const rows = details.sources.indexing?.rows ?? [];
const window = details.sources.indexing?.window;

// GA4: sesje per landing page (okno 28 dni) do zestawienia z GSC.
// GA4 oddaje ścieżki bez końcowego slasha (`/kariera`), sitemap z (`/kariera/`)
// – normalizujemy obie strony joinu; duplikaty po normalizacji scalamy
// (suma sesji, engagement ważony sesjami).
const normPath = (p: string) => p.replace(/\/+$/, '') || '/';
const ga4Landing = new Map<string, { sessions: number; engagement_rate: number | null }>();
for (const r of details.sources.ga4?.landing_pages?.rows ?? []) {
  const key = normPath(r.path);
  const prev = ga4Landing.get(key);
  if (!prev) {
    ga4Landing.set(key, { sessions: r.sessions, engagement_rate: r.engagement_rate ?? null });
  } else {
    const sessions = prev.sessions + r.sessions;
    const weighted =
      prev.engagement_rate === null && r.engagement_rate == null
        ? null
        : ((prev.engagement_rate ?? 0) * prev.sessions + (r.engagement_rate ?? 0) * r.sessions) /
          (sessions || 1);
    ga4Landing.set(key, { sessions, engagement_rate: weighted });
  }
}
const stripOrigin = (url: string) => url.replace(/^https?:\/\/[^/]+/, '') || '/';

// Senuto: pozycje per URL (agregacja fraz z kolektora). Adresy Senuto są bez
// schematu i www („grupa-icea.pl/blog/x") – join po samej ścieżce.
const senutoByPath = new Map(
  (details.sources.senuto?.urls ?? []).map((u) => [
    normPath(u.url.replace(/^(https?:\/\/)?(www\.)?[^/]+/, '') || '/'),
    u,
  ]),
);

const joined = rows.map((r) => {
  const path = normPath(stripOrigin(r.url));
  const ga4Row = ga4Landing.get(path);
  const sen = senutoByPath.get(path);
  return {
    ...r,
    ga4_sessions: ga4Row?.sessions ?? null,
    engagement_rate: ga4Row?.engagement_rate ?? null,
    senuto_position: sen?.best_position ?? null,
    senuto_keyword: sen?.best_keyword ?? null,
    senuto_keywords: sen?.keywords ?? null,
    senuto_top10: sen?.top10 ?? null,
  };
});

// Segmenty serwisu: agregacja po pierwszym poziomie ścieżki (/oferta/…,
// /blog/…). Segmenty jednostronicowe (kontakt, o-nas) trafiają do „pozostałe",
// strona główna ma własny wiersz.
type JoinedRow = (typeof joined)[number];
const segmentOf = (path: string) => {
  if (path === '/' || path === '') return 'strona główna';
  const first = path.split('/').filter(Boolean)[0]!;
  return `/${first}/`;
};
const segGroups = new Map<string, JoinedRow[]>();
for (const r of joined) {
  const seg = segmentOf(normPath(stripOrigin(r.url)));
  (segGroups.get(seg) ?? segGroups.set(seg, []).get(seg)!).push(r);
}
// Progi: segment z ≥2 stronami = własny wiersz; reszta → „pozostałe".
const segRows: { segment: string; rows: JoinedRow[] }[] = [];
const leftovers: JoinedRow[] = [];
for (const [seg, rs] of segGroups) {
  if (seg === 'strona główna' || rs.length >= 2) segRows.push({ segment: seg, rows: rs });
  else leftovers.push(...rs);
}
if (leftovers.length) segRows.push({ segment: 'pozostałe', rows: leftovers });

const segments = segRows
  .map(({ segment, rows: rs }) => {
    const clicks = rs.reduce((s, r) => s + (r.clicks ?? 0), 0);
    const impressions = rs.reduce((s, r) => s + (r.impressions ?? 0), 0);
    const sessions = rs.reduce((s, r) => s + (r.ga4_sessions ?? 0), 0);
    const engWeight = rs.reduce((s, r) => s + (r.engagement_rate !== null ? (r.ga4_sessions ?? 0) : 0), 0);
    const engSum = rs.reduce(
      (s, r) => s + (r.engagement_rate !== null ? r.engagement_rate * (r.ga4_sessions ?? 0) : 0),
      0,
    );
    const senutoTop10 = rs.reduce((s, r) => s + (r.senuto_top10 ?? 0), 0);
    const senutoKeywords = rs.reduce((s, r) => s + (r.senuto_keywords ?? 0), 0);
    const bestPositions = rs.map((r) => r.senuto_position).filter((p): p is number => p !== null);
    return {
      segment,
      pages: rs.length,
      indexed: rs.filter((r) => r.indexed).length,
      clicks,
      impressions,
      ctr: impressions > 0 ? Math.round((clicks / impressions) * 10000) / 100 : null,
      sessions,
      engagement_rate: engWeight > 0 ? engSum / engWeight : null,
      senuto_keywords: senutoKeywords,
      senuto_top10: senutoTop10,
      senuto_best: bestPositions.length ? Math.min(...bestPositions) : null,
    };
  })
  .sort((a, b) => {
    const preferred = ['/blog/', 'strona główna', '/oferta/', '/seo-newsy/', 'pozostałe'];
    const ai = preferred.indexOf(a.segment);
    const bi = preferred.indexOf(b.segment);
    if (ai !== -1 || bi !== -1) return (ai === -1 ? preferred.length - 1 : ai) - (bi === -1 ? preferred.length - 1 : bi);
    return b.pages - a.pages || b.impressions - a.impressions;
  });

// Priorytety optymalizacji: strony tracące kliknięcia wg porównań GSC
// (3 mies. vs poprzednie 3 mies. i vs rok temu), największe straty najpierw.
const compare = details.sources.gsc?.compare;
const declining = (mode: 'qoq' | 'yoy') =>
  (compare?.[mode]?.pages ?? [])
    .map((p) => ({
      ...p,
      clicks_delta: p.clicks - p.prev_clicks,
      impressions_delta: p.impressions - p.prev_impressions,
      position_delta:
        typeof p.position === 'number' && typeof p.prev_position === 'number'
          ? Math.round((p.position - p.prev_position) * 10) / 10
          : null,
      engagement_rate: ga4Landing.get(normPath(stripOrigin(p.key)))?.engagement_rate ?? null,
    }))
    .filter((p) => p.clicks_delta < 0 || (p.position_delta ?? 0) > 1)
    .sort((a, b) => a.clicks_delta - b.clicks_delta || (b.position_delta ?? 0) - (a.position_delta ?? 0))
    .slice(0, 50);
// Dekodowanie przyczyny spadku (§10.4): pierwszy pasujący warunek wygrywa.
// Progi (dPos>1) do kalibracji na realnym rozkładzie.
const decodeCause = (dImpr: number, dPos: number | null, dClicks: number) => {
  if (dImpr > 0 && dClicks < 0) return { key: 'ctr', label: 'Spadek CTR' };
  if ((dPos ?? 0) > 1) return { key: 'pos', label: 'Spadek pozycji' };
  if (dImpr < 0) return { key: 'demand', label: 'Popyt / sezon' };
  return { key: 'mixed', label: 'Mieszane' };
};
const priorities = { qoq: declining('qoq'), yoy: declining('yoy') };
const prioLabel = {
  qoq: compare?.qoq ? `${fmtDateRange(compare.cur.start, compare.cur.end)} vs ${fmtDateRange(compare.qoq.prev.start, compare.qoq.prev.end)}` : '',
  yoy: compare?.yoy ? `${fmtDateRange(compare.cur.start, compare.cur.end)} vs ${fmtDateRange(compare.yoy.prev.start, compare.yoy.prev.end)}` : '',
};

const indexed = indexing?.data?.indexed ?? joined.filter((r) => r.indexed).length;
const checked = indexing?.data?.pages_checked ?? joined.length;
const notIndexed = indexing?.data?.not_indexed ?? checked - indexed;
const sitemapUrls = indexing?.data?.sitemap_urls ?? checked;
const maxImpressions = Math.max(...joined.map((r) => r.impressions ?? 0), 0);
const indexingLastOkWhen = indexingLastOk
  ? new Date(indexingLastOk.collected_at).toLocaleString('pl-PL', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      timeZone: 'Europe/Warsaw',
    })
  : null;
const indexingError = (indexing?.error ?? 'źródło chwilowo niedostępne').replace(/^indexing:\s*/i, '');
---

<Layout title={`${name} – Matrix`}>
  <DomainHeader domain={domain!} name={name} active="matrix" latest={latest} themeToggle />

  <div class="matrix-note">
    Matrix zestawia te same adresy w wielu wymiarach: indeksację, pozycję <b class="sen">Senuto</b>,
    ruch <b class="gsc">GSC</b> i zaangażowanie <b class="ga4">GA4</b>. Segmenty pokazujemy jako
    karty, a spadki w jednej tabeli z automatycznie rozpoznaną przyczyną. Dane <b class="ahrefs">Ahrefs</b>
    pozostają w profilu domeny, ponieważ bieżące API nie zwraca linków dla poszczególnych adresów.
  </div>

  {
    indexing && indexing.status !== 'ok' && indexing.status !== 'not_configured' && (
      <div class:list={['matrix-down', { error: !isTemporarySourceFailure(indexing) }]} role="status">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z" />
        </svg>
        <span>
          Indeksacja: <strong>{indexingError}</strong>
          {isTemporarySourceFailure(indexing) && ' — pokazujemy ostatni udany pomiar i odświeżymy dane automatycznie.'}
        </span>
        {indexingLastOkWhen && <span class="when">ostatni pomiar: {indexingLastOkWhen}</span>}
      </div>
    )
  }
  {
    indexing?.data?.aborted && (
      <div class="banner warn">
        <strong>Indeksacja</strong>: przejazd częściowy ({checked} z {sitemapUrls} adresów) –{' '}
        {indexing.data.aborted}; reszta dogra się kolejnym przebiegiem collectora (cron 6:30).
      </div>
    )
  }

  <div class="section-head">
    <h2>Indeksacja</h2>
    <span class="section-meta">sitemap · GSC URL Inspection</span>
  </div>
  <div class="stat-grid matrix-kpis">
    <div class:list={['k', 'hero', { stale: indexingStaleDate !== null }]}>
      <div class="lbl">Zaindeksowane</div>
      <div class="val">
        {fmtInt(indexed)} <small style="font-size:.45em;color:var(--ink-faint);">z {fmtInt(sitemapUrls)}</small>
      </div>
      <div class="idxbar" title={`pokrycie indeksem: ${sitemapUrls ? Math.round((indexed / sitemapUrls) * 100) : 0}%`}>
        <i style={`width:${sitemapUrls ? Math.round((indexed / sitemapUrls) * 100) : 0}%`} />
      </div>
      {indexingStaleDate && <div class="foot"><span class="stale-tag">dane z {indexingStaleDate}</span></div>}
    </div>
    <StatCard label="Adresy w sitemapie" value={sitemapUrls} staleDate={indexingStaleDate} />
    <StatCard label="Niezaindeksowane" value={notIndexed} goodWhen="down" staleDate={indexingStaleDate} />
    <StatCard label="Sprawdzone" value={checked} staleDate={indexingStaleDate} />
  </div>

  {
    segments.length > 1 && (
      <>
        <div class="section-head" style="margin-bottom:10px;">
          <h2>Segmenty serwisu</h2>
          <span class="section-meta">agregacja po pierwszym poziomie ścieżki</span>
        </div>
        <div class="seg-grid">
          {segments.map((s) => (
            <div class="seg-card">
              <div class="hd">
                <b title={s.segment}>{s.segment}</b>
                <span class="cnt">{fmtInt(s.pages)} {s.pages === 1 ? 'strona' : 'stron'}</span>
              </div>
              <div class="idxbar">
                <i style={`width:${s.pages ? Math.round((s.indexed / s.pages) * 100) : 0}%`} />
              </div>
              <div class="cov">
                w indeksie {fmtInt(s.indexed)}/{fmtInt(s.pages)}
                {s.indexed < s.pages && ` · poza: ${fmtInt(s.pages - s.indexed)}`}
              </div>
              <div class="mgrid">
                <div class="mm">
                  <span class="l"><i class="src gsc" />Wyświetlenia</span>
                  <div class="v">{fmtInt(s.impressions)}</div>
                </div>
                <div class="mm">
                  <span class="l"><i class="src gsc" />Kliknięcia</span>
                  <div class="v">{fmtInt(s.clicks)}</div>
                </div>
                <div class="mm">
                  <span class="l"><i class="src ga4" />Engagement</span>
                  <div class="v">{fmtPct(s.engagement_rate)}</div>
                </div>
                <div class="mm">
                  <span class="l"><i class="src sen" />Frazy TOP10</span>
                  <div class="v">{fmtInt(s.senuto_top10)}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </>
    )
  }

  <div class="section-head" style="margin-bottom:6px;">
    <h2>Matrix stron</h2>
    <div class="matrix-head-actions">
      <span class="section-meta">jeden adres — realne źródła obok siebie</span>
      <div class="fchips" data-matrix-filters>
        <button type="button" class="fchip on" data-f="all">Wszystkie</button>
        <button type="button" class="fchip" data-f="top10" title="Pozycja Senuto ≤ 10">Wygrywające (TOP10)</button>
        <button type="button" class="fchip" data-f="chance" title="Pozycja Senuto 11–30">Szansa (11–30)</button>
        <button type="button" class="fchip" data-f="noindex">Poza indeksem</button>
      </div>
    </div>
  </div>
  <TableCard
    title="Strony"
    count={joined.length}
    filter
    empty="Dane pojawią się po najbliższym przebiegu collectora (codziennie 6:30)."
  >
    <table class="data-table m-table">
      <thead>
        <tr class="grp">
          <th />
          <th class="num g g-sen sep">Senuto</th>
          <th class="num g g-gsc sep" colspan="3">GSC</th>
          <th class="num g g-ga4 sep" colspan="2">GA4</th>
        </tr>
        <tr>
          <th>Strona</th>
          <th class="num sep" title="Najlepsza pozycja frazy rankującej na ten adres (Senuto)">Pozycja</th>
          <th class="num sep">Wyświetlenia</th>
          <th class="num">Kliknięcia</th>
          <th class="num">CTR</th>
          <th class="num sep">Sesje</th>
          <th class="num">Engagement</th>
        </tr>
      </thead>
      <tbody>
        {
          joined.map((r) => (
            <tr data-pos={r.senuto_position ?? ''} data-indexed={r.indexed ? '1' : '0'}>
              <td class="grow">
                <span class="m-url">
                  <i
                    class={`st ${r.indexed ? 'ok' : 'no'}`}
                    title={r.indexed ? `w indeksie · ostatni crawl: ${r.last_crawl ?? '–'}` : (r.coverage_state ?? 'poza indeksem')}
                  />
                  <a class="cell-url" href={r.url} rel="noopener" target="_blank">
                    {stripOrigin(r.url)}
                  </a>
                </span>
              </td>
              <td class="num sep">
                <span
                  class={`pos-badge rbadge ${r.senuto_position === null ? 'na' : posClass(r.senuto_position)}`}
                  title={
                    r.senuto_keyword
                      ? `„${r.senuto_keyword}" · fraz: ${r.senuto_keywords}, w TOP10: ${r.senuto_top10}`
                      : 'brak fraz Senuto dla tego adresu'
                  }
                >
                  {fmtNum(r.senuto_position, 0)}
                </span>
              </td>
              <td class="num sep">
                <span class="cell-bar rbar">
                  {fmtInt(r.impressions)}
                  <span class="bar">
                    <i style={`width:${barWidth(r.impressions, maxImpressions)}%`} />
                  </span>
                </span>
              </td>
              <td class="num">{fmtInt(r.clicks)}</td>
              <td class="num">{fmtPct(r.ctr)}</td>
              <td class="num sep">{r.ga4_sessions === null ? '–' : fmtInt(r.ga4_sessions)}</td>
              <td class="num">
                {r.engagement_rate === null ? (
                  '–'
                ) : (
                  <span class="erate">
                    <span class="t">
                      <i style={`width:${Math.min(100, Math.round(r.engagement_rate))}%`} />
                    </span>
                    <span class="v">{fmtPct(r.engagement_rate)}</span>
                  </span>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </TableCard>

  {
    (priorities.qoq.length > 0 || priorities.yoy.length > 0) && (
      <>
        <div class="section-head" style="margin-bottom:6px;">
          <div class="section-title-with-meta">
            <h2>Dekodowanie spadków</h2>
            <span class="section-meta">dlaczego ruch spadł — nie tylko „o ile”</span>
          </div>
          <div class="seg" data-prio-seg>
            <button type="button" class="active" data-mode="qoq">kw/kw (3 mies.)</button>
            <button type="button" data-mode="yoy">r/r</button>
          </div>
        </div>
        <div class="legend-cause">
          <span><i class="cause ctr" style="padding:1px 7px;">&nbsp;</i> wyświetlenia rosną, kliknięcia nie → popraw tytuł/opis</span>
          <span><i class="cause pos" style="padding:1px 7px;">&nbsp;</i> pozycja spadła → treść/linki</span>
          <span><i class="cause demand" style="padding:1px 7px;">&nbsp;</i> pozycja trzyma, mniej wyszukiwań → sezonowość popytu</span>
        </div>
        {(['qoq', 'yoy'] as const).map((mode) => (
          <div data-prio-view={mode} hidden={mode !== 'qoq'}>
            <TableCard
              title="Strony tracące ruch"
              meta={`GSC: ${prioLabel[mode]} · engagement: GA4 (28 dni)`}
              count={priorities[mode].length}
              filter
              empty="Brak spadków w tym porównaniu."
            >
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Strona</th>
                    <th>Przyczyna</th>
                    <th class="num">Kliknięcia</th>
                    <th class="num">Δ kliknięć</th>
                    <th class="num">Wyświetlenia</th>
                    <th class="num">Δ wyświetleń</th>
                    <th class="num">Pozycja (GSC)</th>
                    <th class="num">Δ pozycji</th>
                    <th class="num">Engagement</th>
                  </tr>
                </thead>
                <tbody>
                  {priorities[mode].map((p) => (
                    <tr>
                      <td class="grow">
                        <a class="cell-url" href={p.key} rel="noopener" target="_blank">
                          {stripOrigin(p.key)}
                        </a>
                      </td>
                      <td>
                        {(() => {
                          const c = decodeCause(p.impressions_delta, p.position_delta, p.clicks_delta);
                          return <span class={`cause ${c.key}`}>{c.label}</span>;
                        })()}
                      </td>
                      <td class="num">{fmtInt(p.clicks)}</td>
                      <td class="num">
                        <span class={`ddelta ${p.clicks_delta < 0 ? 'down' : p.clicks_delta > 0 ? 'up' : 'flat'}`}>
                          {p.clicks_delta > 0 ? '+' : ''}
                          {fmtInt(p.clicks_delta).replace('-', '−')}
                        </span>
                      </td>
                      <td class="num">{fmtInt(p.impressions)}</td>
                      <td class="num">
                        <span class={`ddelta ${p.impressions_delta < 0 ? 'down' : p.impressions_delta > 0 ? 'up' : 'flat'}`}>
                          {p.impressions_delta > 0 ? '+' : ''}
                          {fmtInt(p.impressions_delta).replace('-', '−')}
                        </span>
                      </td>
                      <td class="num">
                        <span class={`pos-badge rbadge ${posClass(p.position)}`}>{fmtNum(p.position, 1)}</span>
                      </td>
                      <td class="num">
                        <span class={`ddelta ${(p.position_delta ?? 0) > 0 ? 'down' : (p.position_delta ?? 0) < 0 ? 'up' : 'flat'}`}>
                          {p.position_delta === null
                            ? '–'
                            : (p.position_delta > 0 ? '+' : '') + fmtNum(p.position_delta, 1).replace('-', '−')}
                        </span>
                      </td>
                      <td class="num">
                        {p.engagement_rate === null ? (
                          '–'
                        ) : (
                          <span class="erate">
                            <span class="t">
                              <i style={`width:${Math.min(100, Math.round(p.engagement_rate))}%`} />
                            </span>
                            <span class="v">{fmtPct(p.engagement_rate)}</span>
                          </span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </TableCard>
          </div>
        ))}
        <script>
          /* Filtry Matrixa stron (.fchip): predykat wpinany w kontroler TableCard
             (tablecard:refilter) – współgra z filtrem tekstowym, sortem i pagerem. */
          {
            const chips = document.querySelector<HTMLElement>('[data-matrix-filters]');
            const card = document.querySelector('table.m-table')?.closest('.table-card');
            if (chips && card) {
              const PREDICATES: Record<string, ((row: HTMLTableRowElement) => boolean) | null> = {
                all: null,
                top10: (r) => r.dataset.pos !== '' && Number(r.dataset.pos) <= 10,
                chance: (r) => {
                  const p = Number(r.dataset.pos);
                  return r.dataset.pos !== '' && p >= 11 && p <= 30;
                },
                noindex: (r) => r.dataset.indexed === '0',
              };
              chips.addEventListener('click', (e) => {
                const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('button[data-f]');
                if (!btn) return;
                chips.querySelectorAll('button').forEach((b) => b.classList.toggle('on', b === btn));
                card.dispatchEvent(
                  new CustomEvent('tablecard:refilter', { detail: PREDICATES[btn.dataset.f!] ?? null }),
                );
              });
            }
          }

          document.querySelector('[data-prio-seg]')?.addEventListener('click', (e) => {
            const btn = (e.target as HTMLElement).closest('button[data-mode]') as HTMLButtonElement | null;
            if (!btn) return;
            document
              .querySelectorAll('[data-prio-seg] button')
              .forEach((b) => b.classList.toggle('active', b === btn));
            document.querySelectorAll<HTMLElement>('[data-prio-view]').forEach((view) => {
              view.hidden = view.dataset.prioView !== btn.dataset.mode;
            });
          });
        </script>
      </>
    )
  }
