---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TableCard from '../../components/TableCard.astro';
import TimeSeriesChart from '../../components/TimeSeriesChart.astro';
import {
  loadConfig,
  loadSnapshots,
  loadDetails,
  latestSnapshot,
  latestWithDelta,
  metricSeries,
} from '../../lib/data';
import { fmtInt, fmtPct, fmtNum, posClass, barWidth } from '../../lib/format';

export function getStaticPaths() {
  return loadConfig().domains.map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);
const gscDetails = details.sources.gsc;

// Okna okresów (przełącznik jak w BWT). Fallback na stare pojedyncze okno,
// dopóki collector nie dogra details z `windows`.
const WINDOW_LABELS: [string, string][] = [
  ['7d', '7 dni'],
  ['30d', '30 dni'],
  ['3m', '3 mies.'],
  ['6m', '6 mies.'],
  ['12m', '12 mies.'],
  ['16m', '16 mies. (max GSC)'],
];
const windows = gscDetails?.windows;
const windowOptions = windows ? WINDOW_LABELS.filter(([k]) => windows[k]) : [];
const defaultWindow = windows?.['30d'] ?? windows?.[windowOptions[0]?.[0] ?? ''] ?? null;
const queries = defaultWindow?.queries ?? gscDetails?.queries ?? [];
const pages = defaultWindow?.pages ?? gscDetails?.pages ?? [];
const activeWindow = defaultWindow ?? gscDetails?.window ?? null;
const windowMeta = activeWindow ? `okno ${activeWindow.start} → ${activeWindow.end}` : undefined;

const clicks = metricSeries(snapshots, 'gsc', 'clicks');
const impressions = metricSeries(snapshots, 'gsc', 'impressions');
const position = metricSeries(snapshots, 'gsc', 'position');
const queriesSeries = metricSeries(snapshots, 'gsc', 'queries');

const statClicks = latestWithDelta(snapshots, 'gsc', 'clicks');
const statImpressions = latestWithDelta(snapshots, 'gsc', 'impressions');
const statCtr = latestWithDelta(snapshots, 'gsc', 'ctr');
const statPosition = latestWithDelta(snapshots, 'gsc', 'position');
const statQueries = latestWithDelta(snapshots, 'gsc', 'queries');
const dataDate = latest?.sources.gsc?.data?.data_date ?? null;
const gsc = latest?.sources.gsc;

const maxQueryImpressions = Math.max(...queries.map((q) => q.impressions ?? 0), 0);

// Układ „Potencjał": opp = wyświetlenia × waga pozycji. Premiuje duży popyt
// blisko czołówki (striking distance 4-20), nie frazy już wygrane (top3)
// ani beznadziejnie dalekie (>50).
const oppMult = (pos: number | null) =>
  typeof pos !== 'number' ? 0.32 : pos <= 3 ? 0.35 : pos <= 20 ? 1.0 : pos <= 50 ? 0.65 : 0.32;
const withOpp = (rows: typeof queries) => {
  const scored = rows.map((q) => ({ ...q, opp: (q.impressions ?? 0) * oppMult(q.position) }));
  const maxOpp = Math.max(...scored.map((q) => q.opp), 0);
  return scored
    .map((q) => {
      const nrm = maxOpp > 0 ? q.opp / maxOpp : 0;
      return {
        ...q,
        oppDots: maxOpp > 0 ? Math.max(1, Math.round(nrm * 5)) : 1,
        oppLabel: nrm >= 0.6 ? 'Wysoki' : nrm >= 0.3 ? 'Średni' : 'Niski',
      };
    })
    .sort((a, b) => b.opp - a.opp);
};
const queriesOpp = withOpp(queries);
const queryHistory = gscDetails?.query_history ?? null;
const maxPageImpressions = Math.max(...pages.map((p) => p.impressions ?? 0), 0);
const stripOrigin = (url: string) => url.replace(/^https?:\/\/[^/]+/, '') || '/';

// Plansza „Co spadło" – porównania okres-do-okresu z details (collector, §compare).
import type { GscCompareRow } from '../../lib/data';
const compare = gscDetails?.compare;

const dropPanel = (rows: GscCompareRow[], isPage: boolean) => {
  const withDelta = rows.map((r) => ({ ...r, dImpr: r.impressions - r.prev_impressions }));
  const drops = withDelta.filter((r) => r.dImpr < 0).sort((a, b) => a.dImpr - b.dImpr);
  return {
    dropCount: drops.length,
    gainCount: withDelta.filter((r) => r.dImpr > 0).length,
    rows: drops.slice(0, 6).map((r, i) => ({
      rank: i + 1,
      name: isPage ? stripOrigin(r.key) : r.key,
      delta: `▼ ${fmtInt(Math.abs(r.dImpr))} wyśw.`,
      flow: `${fmtInt(r.prev_impressions)} → ${fmtInt(r.impressions)} · poz. ${fmtNum(r.prev_position, 1)}→${fmtNum(r.position, 1)}`,
    })),
  };
};

const compareModes = (
  [
    { id: 'qoq', short: '3 mies. vs 3 mies.', label: 'Ostatnie 3 mies. vs poprzednie 3 mies.', data: compare?.qoq },
    { id: 'yoy', short: '3 mies. vs rok temu', label: 'Ostatnie 3 mies. vs ten sam okres rok temu', data: compare?.yoy },
  ] as const
)
  .filter((m) => m.data)
  .map((m) => ({
    id: m.id,
    short: m.short,
    meta: `${m.label} · ${m.data!.prev.start} → ${m.data!.prev.end} vs ${compare!.cur.start} → ${compare!.cur.end} · sortowane wg największego spadku wyświetleń`,
    queries: dropPanel(m.data!.queries ?? [], false),
    pages: dropPanel(m.data!.pages ?? [], true),
  }));
---

<Layout title={`${name} – Google Search Console`}>
  <DomainHeader domain={domain!} name={name} active="gsc" latest={latest} />

  {
    gsc && gsc.status !== 'ok' && (
      <div class={`banner ${gsc.status === 'token_expired' ? 'warn' : 'err'}`}>
        <strong>GSC</strong>: {gsc.error ?? 'błąd źródła'}
      </div>
    )
  }

  <div class="section-head">
    <h2>Ruch z wyszukiwarki</h2>
    {dataDate && <span class="section-meta">dzienne metryki z {dataDate} (opóźnienie GSC ~3 dni)</span>}
  </div>
  <div class="stat-grid">
    <StatCard label="Kliknięcia / dzień" value={statClicks.value} delta={statClicks.delta} trend={clicks.values} hero />
    <StatCard
      label="Wyświetlenia / dzień"
      value={statImpressions.value}
      delta={statImpressions.delta}
      trend={impressions.values}
    />
    <StatCard label="CTR" value={statCtr.value} delta={statCtr.delta} unit="%" precision={2} />
    <StatCard
      label="Średnia pozycja"
      value={statPosition.value}
      delta={statPosition.delta}
      precision={1}
      goodWhen="down"
      trend={position.values}
    />
    <StatCard
      label="Frazy z wyświetleniami"
      value={statQueries.value}
      delta={statQueries.delta}
      trend={queriesSeries.values}
    />
  </div>

  <div class="chart-grid">
    <TimeSeriesChart
      title="Kliknięcia i wyświetlenia"
      meta="dziennie"
      timestamps={clicks.timestamps}
      series={[
        { label: 'Kliknięcia', values: clicks.values },
        { label: 'Wyświetlenia', values: impressions.values, fill: true },
      ]}
    />
    <TimeSeriesChart
      title="Średnia pozycja"
      meta="niżej = lepiej"
      timestamps={position.timestamps}
      series={[{ label: 'Pozycja', values: position.values }]}
      precision={1}
    />
    <TimeSeriesChart
      title="Frazy z wyświetleniami"
      meta="dziennie"
      timestamps={queriesSeries.timestamps}
      series={[{ label: 'Frazy', values: queriesSeries.values }]}
    />
  </div>

  {
    compareModes.length > 0 && (
      <div class="drops-board">
        <div class="section-head" style="margin-bottom:6px;">
          <h2>Co spadło – szybki podgląd</h2>
          {compareModes.length > 1 && (
            <div class="seg" data-drops-seg>
              {compareModes.map((m, i) => (
                <button type="button" class={i === 0 ? 'active' : ''} data-mode={m.id}>
                  {m.short}
                </button>
              ))}
            </div>
          )}
        </div>
        {compareModes.map((m, i) => (
          <div class="drops-view" data-drops-view={m.id} hidden={i !== 0}>
            <div class="drops-meta">{m.meta}</div>
            <div class="drops-grid">
              {(
                [
                  ['Frazy, które spadły', m.queries],
                  ['Strony, które spadły', m.pages],
                ] as const
              ).map(([title, panel]) => (
                <div class="drop-panel">
                  <header>
                    <h4>{title}</h4>
                    <div class="drop-summary">
                      <span class="chip bad">▼ <b>{fmtInt(panel.dropCount)}</b></span>
                      <span class="chip good">▲ <b>{fmtInt(panel.gainCount)}</b></span>
                    </div>
                  </header>
                  {panel.rows.length === 0 && <div class="drop-empty">Brak spadków wyświetleń w tym oknie.</div>}
                  {panel.rows.map((r) => (
                    <div class="drop-row">
                      <span class="drop-rank">{r.rank}</span>
                      <span class="drop-name" title={r.name}>
                        {r.name}
                      </span>
                      <div class="drop-metric">
                        <span class="drop-delta down">{r.delta}</span>
                        <span class="drop-flow">{r.flow}</span>
                      </div>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    )
  }
  <script>
    /* Przełącznik okresu tabel GSC (jak w BWT): przepina wiersze obu tabel na
       dane wybranego okna z osadzonego JSON-a, resetuje sort i pager. */
    const dataEl = document.getElementById('gsc-windows-data');
    const winSeg = document.querySelector<HTMLElement>('[data-gsc-window-seg]');
    if (dataEl && winSeg) {
      type Row = {
        key: string;
        clicks: number;
        impressions: number;
        ctr: number | null;
        position: number | null;
      };
      type Win = { start: string; end: string; queries: Row[]; pages: Row[] };
      const windows: Record<string, Win> = JSON.parse(dataEl.textContent ?? '{}');
      const cards = document.querySelectorAll<HTMLElement>('.table-card');
      const esc = (s: string) =>
        s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
      const fi = (n: number | null | undefined) => (typeof n === 'number' ? n.toLocaleString('pl-PL') : '–');
      const fp = (v: number | null) =>
        typeof v === 'number' ? `${v.toLocaleString('pl-PL', { maximumFractionDigits: 2 })}%` : '–';
      const f1 = (v: number | null) =>
        typeof v === 'number' ? v.toLocaleString('pl-PL', { maximumFractionDigits: 1 }) : '–';
      const posCls = (p: number | null) =>
        typeof p !== 'number' ? '' : p <= 3 ? 'top3' : p <= 10 ? 'top10' : p <= 30 ? 'mid' : 'low';
      const bar = (v: number, max: number) => (max > 0 ? Math.max(2, Math.round((v / max) * 100)) : 0);
      const stripOrigin = (url: string) => url.replace(/^https?:\/\/[^/]+/, '') || '/';

      const pageRowHtml = (r: Row, max: number) => `
        <tr>
          <td class="grow"><a class="cell-url" href="${esc(r.key)}" rel="noopener" target="_blank">${esc(stripOrigin(r.key))}</a></td>
          <td class="num">${fi(r.clicks)}</td>
          <td class="num"><span class="cell-bar">${fi(r.impressions)}<span class="bar"><i style="width:${bar(
            r.impressions,
            max,
          )}%"></i></span></span></td>
          <td class="num"><span class="${typeof r.ctr === 'number' && r.ctr > 0 ? 'ctr-pos' : ''}">${fp(r.ctr)}</span></td>
          <td class="num"><span class="pos-badge ${posCls(r.position)}">${f1(r.position)}</span></td>
        </tr>`;

      /* Układ „Potencjał" (q-table): opp = wyświetlenia × waga pozycji, sort
         domyślny malejąco – lustro logiki z frontmatteru. */
      const oppMult = (p: number | null) =>
        typeof p !== 'number' ? 0.32 : p <= 3 ? 0.35 : p <= 20 ? 1.0 : p <= 50 ? 0.65 : 0.32;
      const qRowHtml = (r: Row & { opp: number; dots: number; label: string }, max: number) => `
        <tr class="q-row" data-key="${esc(r.key)}" data-clicks="${r.clicks}" data-ctr="${r.ctr ?? ''}"
            data-pos="${r.position ?? ''}" data-imp="${r.impressions}" data-opp-label="${r.label}">
          <td class="grow"><span class="q-kw"><span class="chev">▸</span><span class="txt">${esc(r.key)}</span></span></td>
          <td class="num qc-clk"><span class="clicks-val ${r.clicks ? '' : 'zero'}">${fi(r.clicks)}</span></td>
          <td class="num qc-pos"><span class="pos-badge ${posCls(r.position)}">${f1(r.position)}</span></td>
          <td class="num qc-imp"><span class="cell-bar">${fi(r.impressions)}<span class="bar"><i style="width:${bar(
            r.impressions,
            max,
          )}%"></i></span></span></td>
          <td class="num qc-opp" data-sort="${r.opp}" title="${r.label} (${fi(Math.round(r.opp))})"><span class="opp-dots">${[1, 2, 3, 4, 5]
            .map((i) => `<i class="${i <= r.dots ? 'on' : ''}"></i>`)
            .join('')}</span></td>
        </tr>`;
      const withOpp = (rows: Row[]) => {
        const scored = rows.map((r) => ({ ...r, opp: (r.impressions ?? 0) * oppMult(r.position) }));
        const maxOpp = Math.max(...scored.map((r) => r.opp), 0);
        return scored
          .map((r) => {
            const nrm = maxOpp > 0 ? r.opp / maxOpp : 0;
            return {
              ...r,
              dots: maxOpp > 0 ? Math.max(1, Math.round(nrm * 5)) : 1,
              label: nrm >= 0.6 ? 'Wysoki' : nrm >= 0.3 ? 'Średni' : 'Niski',
            };
          })
          .sort((a, b) => b.opp - a.opp);
      };

      const applyWindow = (key: string) => {
        const win = windows[key];
        if (!win) return;
        ([
          [cards[0], win.queries, false],
          [cards[1], win.pages, true],
        ] as const).forEach(([card, rows, isPage]) => {
          if (!card) return;
          const body = card.querySelector('table.data-table tbody');
          if (!body) return;
          const max = Math.max(...rows.map((r) => r.impressions ?? 0), 0);
          body.innerHTML = isPage
            ? rows.map((r) => pageRowHtml(r, max)).join('')
            : withOpp(rows).map((r) => qRowHtml(r, max)).join('');
          const countEl = card.querySelector('.table-head h3 .table-meta');
          if (countEl) countEl.textContent = ` · ${rows.length.toLocaleString('pl-PL')}`;
          const metaEl = card.querySelector('.table-head > .table-meta');
          if (metaEl) metaEl.textContent = `okno ${win.start} → ${win.end}`;
          card.querySelectorAll<HTMLTableCellElement>('thead th').forEach((th) => {
            th.classList.remove('active');
            delete th.dataset.dir;
            const caret = th.querySelector('.sort-caret');
            if (caret) caret.textContent = '';
          });
          card.dispatchEvent(new CustomEvent('tablecard:refilter', { detail: null }));
        });
      };

      winSeg.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('button[data-window]') as HTMLButtonElement | null;
        if (!btn) return;
        winSeg.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === btn));
        applyWindow(btn.dataset.window!);
      });
    }

    /* Rozwijane wiersze tabeli fraz (q-drawer): sparkline 14 dni + fakty
       (CTR przeniesiony tu z kolumn). Szuflady zamykane przed sortem/filtrem/
       pagerem (capture-phase), żeby nie psuły stronicowania TableCard. */
    {
      const qTable = document.querySelector<HTMLTableElement>('table.q-table');
      const qCard = qTable?.closest<HTMLElement>('.table-card');
      const histEl = document.getElementById('gsc-qhistory');
      const history: {
        window: { start: string; end: string };
        series: Record<string, [string, number][]>;
      } | null = histEl ? JSON.parse(histEl.textContent ?? 'null') : null;
      const fiL = (n: number) => n.toLocaleString('pl-PL');

      const sparkSvg = (key: string): string => {
        const raw = history?.series?.[key];
        if (!raw || raw.length === 0)
          return '<div class="spark-empty">brak danych dziennych dla tej frazy</div>';
        const byDate = new Map(raw);
        const days: number[] = [];
        const start = new Date(history!.window.start + 'T00:00:00Z');
        const end = new Date(history!.window.end + 'T00:00:00Z');
        for (let d = new Date(start); d <= end; d.setUTCDate(d.getUTCDate() + 1)) {
          days.push(byDate.get(d.toISOString().slice(0, 10)) ?? 0);
        }
        const max = Math.max(...days, 1);
        const pts = days
          .map((v, i) => `${((i / Math.max(days.length - 1, 1)) * 96).toFixed(1)},${(28 - (v / max) * 26).toFixed(1)}`)
          .join(' ');
        return `<svg viewBox="0 0 96 30" preserveAspectRatio="none" class="spark-svg"><polyline points="${pts}" fill="none" stroke="var(--accent-blue)" stroke-width="1.6" /></svg>`;
      };

      const closeDrawers = () => {
        qTable?.querySelectorAll('tr.q-drawer').forEach((d) => d.remove());
        qTable?.querySelectorAll('tr.q-row.open').forEach((r) => r.classList.remove('open'));
      };

      if (qTable && qCard) {
        qTable.addEventListener('click', (e) => {
          const row = (e.target as HTMLElement).closest<HTMLTableRowElement>('tr.q-row');
          if (!row) return;
          const wasOpen = row.classList.contains('open');
          closeDrawers();
          if (wasOpen) return;
          row.classList.add('open');
          const d = row.dataset;
          const fp2 = (v: string | undefined) =>
            v ? `${parseFloat(v).toLocaleString('pl-PL', { maximumFractionDigits: 2 })}%` : '–';
          const f1p = (v: string | undefined) =>
            v ? parseFloat(v).toLocaleString('pl-PL', { maximumFractionDigits: 1 }) : '–';
          const drawer = document.createElement('tr');
          drawer.className = 'q-drawer';
          drawer.innerHTML = `<td colspan="5"><div class="drawer-grid">
            <div class="spark"><h4>Wyświetlenia – ostatnie 14 dni</h4>${sparkSvg(d.key ?? '')}</div>
            <dl class="facts">
              <div><dt>Kliknięcia</dt><dd>${fiL(Number(d.clicks ?? 0))}</dd></div>
              <div><dt>CTR</dt><dd>${fp2(d.ctr)}</dd></div>
              <div><dt>Pozycja</dt><dd>${f1p(d.pos)}</dd></div>
              <div><dt>Wyświetlenia</dt><dd>${fiL(Number(d.imp ?? 0))}</dd></div>
              <div><dt>Potencjał</dt><dd>${d.oppLabel ?? '–'}</dd></div>
            </dl>
          </div></td>`;
          row.after(drawer);
        });
        /* Zamknięcie szuflad zanim TableCard przerenderuje widok. */
        qCard.addEventListener('click', (e) => {
          const t = e.target as HTMLElement;
          if (t.closest('thead th') || t.closest('.pager button')) closeDrawers();
        }, true);
        qCard.querySelector('[data-table-filter]')?.addEventListener('input', closeDrawers, true);
        qCard.addEventListener('tablecard:refilter', closeDrawers, true);
      }
    }

    document.querySelectorAll('[data-drops-seg]').forEach((seg) => {
      seg.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('button[data-mode]') as HTMLButtonElement | null;
        if (!btn) return;
        seg.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === btn));
        document.querySelectorAll<HTMLElement>('[data-drops-view]').forEach((view) => {
          view.hidden = view.dataset.dropsView !== btn.dataset.mode;
        });
      });
    });
  </script>

  {
    windowOptions.length > 1 && (
      <div class="section-head" style="margin-bottom:6px;">
        <h2>Frazy i strony</h2>
        <div class="seg" data-gsc-window-seg>
          {windowOptions.map(([k, label]) => (
            <button type="button" class={k === '30d' ? 'active' : ''} data-window={k}>
              {label}
            </button>
          ))}
        </div>
      </div>
    )
  }
  {windows && (
    <script
      type="application/json"
      id="gsc-windows-data"
      set:html={JSON.stringify(windows).replace(/</g, '\\u003c')}
    />
  )}

  <TableCard
    title="Frazy w Google"
    meta={windowMeta}
    count={queries.length}
    filter
    empty="Lista fraz pojawi się po najbliższym przebiegu collectora (codziennie 6:30)."
  >
    <table class="data-table q-table">
      <thead>
        <tr>
          <th>Fraza</th>
          <th class="num qc-clk">Kliknięcia</th>
          <th class="num qc-pos">Pozycja</th>
          <th class="num qc-imp">Wyświetlenia</th>
          <th class="num qc-opp" data-dir="desc">
            Potencjał
            <span class="info" title="Potencjał = wyświetlenia × waga pozycji. Wagi: TOP 3 → 0,35 (już wygrane) · 4–20 → 1,0 (striking distance) · 21–50 → 0,65 · dalej → 0,32. Premiuje duży popyt blisko czołówki – frazy warte pchnięcia w górę.">ⓘ</span>
          </th>
        </tr>
      </thead>
      <tbody>
        {
          queriesOpp.map((q) => (
            <tr
              class="q-row"
              data-key={q.key}
              data-clicks={q.clicks}
              data-ctr={q.ctr ?? ''}
              data-pos={q.position ?? ''}
              data-imp={q.impressions}
              data-opp-label={q.oppLabel}
            >
              <td class="grow">
                <span class="q-kw">
                  <span class="chev">▸</span>
                  <span class="txt">{q.key}</span>
                </span>
              </td>
              <td class="num qc-clk">
                <span class={`clicks-val ${!q.clicks ? 'zero' : ''}`}>{fmtInt(q.clicks)}</span>
              </td>
              <td class="num qc-pos">
                <span class={`pos-badge ${posClass(q.position)}`}>{fmtNum(q.position, 1)}</span>
              </td>
              <td class="num qc-imp">
                <span class="cell-bar">
                  {fmtInt(q.impressions)}
                  <span class="bar">
                    <i style={`width:${barWidth(q.impressions, maxQueryImpressions)}%`} />
                  </span>
                </span>
              </td>
              <td class="num qc-opp" data-sort={q.opp} title={`${q.oppLabel} (${fmtInt(Math.round(q.opp))})`}>
                <span class="opp-dots">
                  {[1, 2, 3, 4, 5].map((i) => (
                    <i class={i <= q.oppDots ? 'on' : ''} />
                  ))}
                </span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </TableCard>
  {queryHistory && (
    <script
      type="application/json"
      id="gsc-qhistory"
      set:html={JSON.stringify(queryHistory).replace(/</g, '\\u003c')}
    />
  )}

  <TableCard
    title="Strony w Google"
    meta={windowMeta}
    count={pages.length}
    filter
    empty="Lista stron pojawi się po najbliższym przebiegu collectora."
  >
    <table class="data-table">
      <thead>
        <tr>
          <th>Strona</th>
          <th class="num">Kliknięcia</th>
          <th class="num">Wyświetlenia</th>
          <th class="num">CTR</th>
          <th class="num">Pozycja</th>
        </tr>
      </thead>
      <tbody>
        {
          pages.map((p) => (
            <tr>
              <td class="grow">
                <a class="cell-url" href={p.key} rel="noopener" target="_blank">
                  {stripOrigin(p.key)}
                </a>
              </td>
              <td class="num">{fmtInt(p.clicks)}</td>
              <td class="num">
                <span class="cell-bar">
                  {fmtInt(p.impressions)}
                  <span class="bar">
                    <i style={`width:${barWidth(p.impressions, maxPageImpressions)}%`} />
                  </span>
                </span>
              </td>
              <td class="num">
                <span class={typeof p.ctr === 'number' && p.ctr > 0 ? 'ctr-pos' : ''}>{fmtPct(p.ctr)}</span>
              </td>
              <td class="num">
                <span class={`pos-badge ${posClass(p.position)}`}>{fmtNum(p.position, 1)}</span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </TableCard>
</Layout>
