---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TableCard from '../../components/TableCard.astro';
import TimeSeriesChart from '../../components/TimeSeriesChart.astro';
import {
  loadConfig,
  loadSnapshots,
  loadDetails,
  latestSnapshot,
  latestWithDelta,
  metricSeries,
  sectionEnabled,
} from '../../lib/data';
import { fmtInt, fmtPct, fmtNum, fmtDuration, barWidth } from '../../lib/format';

export function getStaticPaths() {
  return loadConfig()
    .domains.filter((d) => sectionEnabled(d, 'ga4'))
    .map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);
const ga4 = latest?.sources.ga4;
const channels = details.sources.ga4?.channels ?? [];
const trafficSources = details.sources.ga4?.sources ?? [];
const pages = details.sources.ga4?.pages ?? [];
const landing = details.sources.ga4?.landing_pages?.rows ?? [];
const landingWindow = details.sources.ga4?.landing_pages?.window;
const monthly = details.sources.ga4?.monthly ?? [];
const channelsMonthly = details.sources.ga4?.channels_monthly ?? [];

// Dzienne szeregi ze snapshotów.
const sessions = metricSeries(snapshots, 'ga4', 'sessions');
const organicDaily = metricSeries(snapshots, 'ga4', 'organic_sessions');
const statSessions = latestWithDelta(snapshots, 'ga4', 'sessions');
const statUsers = latestWithDelta(snapshots, 'ga4', 'active_users');
const statNewUsers = latestWithDelta(snapshots, 'ga4', 'new_users');
const statReturning = latestWithDelta(snapshots, 'ga4', 'returning_users');
const statOrganic = latestWithDelta(snapshots, 'ga4', 'organic_sessions');
const statEngRate = latestWithDelta(snapshots, 'ga4', 'engagement_rate');
const statEngTime = latestWithDelta(snapshots, 'ga4', 'avg_engagement_s');
const statEngPerUser = latestWithDelta(snapshots, 'ga4', 'engaged_per_user');
const statPagesPerSession = latestWithDelta(snapshots, 'ga4', 'pages_per_session');
const dataDate = ga4?.data?.data_date ?? null;

/* Podział nowi/powracający w karcie Użytkownicy (handoff „GA4 – układ"). */
const splitTotal = (statNewUsers.value ?? 0) + (statReturning.value ?? 0);
const splitNewPct = splitTotal > 0 ? Math.round(((statNewUsers.value ?? 0) / splitTotal) * 100) : 0;
const hasSplit = splitTotal > 0;

// Trend miesięczny (25 mies. z Data API) + delta r/r na ostatnim pełnym miesiącu.
const monthTs = (m: string) => Math.floor(Date.UTC(+m.slice(0, 4), +m.slice(4, 6) - 1, 1) / 1000);
const monthlyTs = monthly.map((m) => monthTs(m.month));
const lastFull = monthly.length >= 2 ? monthly[monthly.length - 2] : null;
const lastFullYoY = lastFull ? monthly.find((m) => +m.month === +lastFull.month - 100) : null;
const yoyDelta = (field: 'sessions' | 'users') =>
  lastFull && lastFullYoY ? lastFull[field] - lastFullYoY[field] : null;
const monthLabel = lastFull ? `${lastFull.month.slice(0, 4)}-${lastFull.month.slice(4, 6)}` : null;

// Kanały miesięcznie → serie per kanał (pozostałe zsumowane w „Inne").
const MAIN_CHANNELS = ['Organic Search', 'Direct', 'Referral', 'Paid Search', 'Organic Social'];
const channelSeries = MAIN_CHANNELS.map((channel) => ({
  label: channel === 'Organic Search' ? 'Organic' : channel === 'Organic Social' ? 'Social' : channel,
  values: monthly.map(
    (m) => channelsMonthly.find((c) => c.month === m.month && c.channel === channel)?.sessions ?? 0,
  ),
}));
const otherSeries = monthly.map((m) =>
  channelsMonthly
    .filter((c) => c.month === m.month && !MAIN_CHANNELS.includes(c.channel))
    .reduce((sum, c) => sum + c.sessions, 0),
);
const organicMonthly = channelSeries[0]?.values ?? [];

const maxChannel = Math.max(...channels.map((c) => c.sessions), 0);
const maxSource = Math.max(...trafficSources.map((s) => s.sessions), 0);
const maxPage = Math.max(...pages.map((p) => p.pageviews), 0);
const maxLanding = Math.max(...landing.map((l) => l.sessions), 0);

/* Wartości techniczne GA4 ((not set), Unassigned…) – wyciszamy, nie udajemy treści. */
const isJunk = (name: string) => /^\(|unassigned|not set|not available/i.test(name);
---

<Layout title={`${name} – GA4`}>
  <DomainHeader domain={domain!} name={name} active="ga4" latest={latest} />

  {
    ga4 && ga4.status !== 'ok' && (
      <div class={`banner ${ga4.status === 'error' ? 'err' : 'warn'}`}>
        <strong>GA4</strong>: {ga4.error ?? 'błąd źródła'}
      </div>
    )
  }

  <div class="section-head">
    <h2>Ruch w witrynie</h2>
    {dataDate && <span class="section-meta">pełna doba {dataDate} · delty 7-dniowe</span>}
  </div>
  <div class="rgrid4">
    <StatCard label="Sesje / dzień" value={statSessions.value} delta={statSessions.delta} trend={sessions.values} hero />
    <StatCard label="Użytkownicy" value={statUsers.value} delta={hasSplit ? null : statUsers.delta}>
      {hasSplit && (
        <div class="split">
          <div class="bar">
            <i class="a" style={`width:${splitNewPct}%`} />
            <i class="b" style={`width:${100 - splitNewPct}%`} />
          </div>
          <div class="lg">
            <span><span class="dot" style="background:var(--accent-blue)"></span>Nowi <b>{fmtInt(statNewUsers.value)}</b></span>
            <span><span class="dot" style="background:var(--series-3)"></span>Powracający <b>{fmtInt(statReturning.value)}</b></span>
          </div>
        </div>
      )}
    </StatCard>
    <StatCard label="Engagement rate" value={statEngRate.value} delta={statEngRate.delta} unit="%" precision={1} />
    <StatCard label="Sesje organiczne" value={statOrganic.value} delta={statOrganic.delta} trend={organicDaily.values} />
  </div>
  <div class="micro">
    <div class="m">
      <div class="l">Śr. czas zaangażowania / sesję</div>
      <div class="v">{fmtDuration(statEngTime.value)}</div>
    </div>
    <div class="m">
      <div class="l">Strony / sesję</div>
      <div class="v">{fmtNum(statPagesPerSession.value, 2)}</div>
    </div>
    <div class="m">
      <div class="l">Engaged sessions / użytkownika</div>
      <div class="v">{fmtNum(statEngPerUser.value, 2)}</div>
    </div>
  </div>

  {
    monthly.length > 1 && (
      <>
        <div class="section-head">
          <h2>Trendy miesięczne</h2>
          <span class="section-meta">
            {monthLabel && `ostatni pełny miesiąc: ${monthLabel}`}
            {yoyDelta('sessions') !== null &&
              ` · sesje r/r: ${yoyDelta('sessions')! > 0 ? '+' : ''}${fmtInt(yoyDelta('sessions'))}`}
            {yoyDelta('users') !== null &&
              ` · użytkownicy r/r: ${yoyDelta('users')! > 0 ? '+' : ''}${fmtInt(yoyDelta('users'))}`}
          </span>
        </div>
        <div class="chart-grid">
          <TimeSeriesChart
            title="Użytkownicy: nowi vs powracający"
            meta="miesięcznie"
            timestamps={monthlyTs}
            series={[
              { label: 'Nowi', values: monthly.map((m) => m.new_users), fill: true },
              { label: 'Powracający', values: monthly.map((m) => Math.max(0, m.users - m.new_users)) },
            ]}
          />
          <TimeSeriesChart
            title="Sesje per kanał"
            meta="miesięcznie"
            timestamps={monthlyTs}
            series={[...channelSeries, { label: 'Inne', values: otherSeries }].filter((s) =>
              s.values.some((v) => v > 0),
            )}
          />
          <TimeSeriesChart
            title="Ruch organiczny"
            meta="miesięcznie · sezonowość"
            timestamps={monthlyTs}
            series={[{ label: 'Sesje organiczne', values: organicMonthly, fill: true }]}
          />
        </div>
      </>
    )
  }

  <div class="chart-grid">
    <TimeSeriesChart
      title="Sesje i sesje organiczne"
      meta="dziennie"
      timestamps={sessions.timestamps}
      series={[
        { label: 'Sesje', values: sessions.values, fill: true },
        { label: 'Organiczne', values: organicDaily.values },
      ]}
    />
  </div>

  <div class="section-head">
    <h2>Wczoraj – skąd i dokąd</h2>
    <div class="seg" data-ga4-panes-seg>
      <button type="button" class="active" data-pane="kanaly">Kanały · {channels.length}</button>
      <button type="button" data-pane="zrodla">Źródła · {trafficSources.length}</button>
      <button type="button" data-pane="strony">Strony · {pages.length}</button>
    </div>
  </div>

  <div data-ga4-pane="kanaly">
    <TableCard title="Kanały" count={channels.length} empty="Brak danych.">
      <table class="data-table">
        <thead>
          <tr>
            <th>Kanał</th>
            <th class="num">Sesje</th>
            <th class="num">Użytkownicy</th>
            <th class="num">Odsłony</th>
          </tr>
        </thead>
        <tbody>
          {
            channels.map((c) => (
              <tr>
                <td class="grow"><span class={isJunk(c.channel) ? 'muted-tag' : ''}>{c.channel}</span></td>
                <td class="num">
                  <span class="cell-bar">
                    {fmtInt(c.sessions)}
                    <span class="bar">
                      <i style={`width:${barWidth(c.sessions, maxChannel)}%`} />
                    </span>
                  </span>
                </td>
                <td class="num">{fmtInt(c.users)}</td>
                <td class="num">{fmtInt(c.pageviews)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </TableCard>
  </div>

  <div data-ga4-pane="zrodla" hidden>
    <TableCard title="Źródła sesji" count={trafficSources.length} filter empty="Brak danych.">
      <table class="data-table">
        <thead>
          <tr>
            <th>Źródło</th>
            <th class="num">Sesje</th>
            <th class="num">Użytkownicy</th>
          </tr>
        </thead>
        <tbody>
          {
            trafficSources.map((s) => (
              <tr>
                <td class="grow"><span class={isJunk(s.source) ? 'muted-tag' : ''}>{s.source}</span></td>
                <td class="num">
                  <span class="cell-bar">
                    {fmtInt(s.sessions)}
                    <span class="bar">
                      <i style={`width:${barWidth(s.sessions, maxSource)}%`} />
                    </span>
                  </span>
                </td>
                <td class="num">{fmtInt(s.users)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </TableCard>
  </div>

  <div data-ga4-pane="strony" hidden>
    <TableCard title="Najpopularniejsze strony" count={pages.length} filter empty="Brak danych.">
      <table class="data-table">
        <thead>
          <tr>
            <th>Strona</th>
            <th class="num">Odsłony</th>
            <th class="num">Użytkownicy</th>
          </tr>
        </thead>
        <tbody>
          {
            pages.map((p) => (
              <tr>
                <td class="grow"><span class="cell-url">{p.path}</span></td>
                <td class="num">
                  <span class="cell-bar">
                    {fmtInt(p.pageviews)}
                    <span class="bar">
                      <i style={`width:${barWidth(p.pageviews, maxPage)}%`} />
                    </span>
                  </span>
                </td>
                <td class="num">{fmtInt(p.users)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </TableCard>
  </div>

  <TableCard
    title="Landing pages – zaangażowanie"
    meta={landingWindow ? `okno ${landingWindow.start} → ${landingWindow.end}` : undefined}
    count={landing.length}
    filter
    empty="Dane pojawią się po najbliższym przebiegu collectora."
  >
    <table class="data-table">
      <thead>
        <tr>
          <th>Landing page</th>
          <th class="num">Sesje</th>
          <th class="num">Engagement rate</th>
          <th class="num">Śr. czas zaangaż.</th>
          <th class="num">Strony / sesję</th>
        </tr>
      </thead>
      <tbody>
        {
          landing.map((l) => (
            <tr>
              <td class="grow"><span class={isJunk(l.path) ? 'muted-tag' : 'cell-url'}>{l.path}</span></td>
              <td class="num">
                <span class="cell-bar">
                  {fmtInt(l.sessions)}
                  <span class="bar">
                    <i style={`width:${barWidth(l.sessions, maxLanding)}%`} />
                  </span>
                </span>
              </td>
              <td class="num" data-sort={l.engagement_rate}>
                <span class="erate">
                  <span class="t"><i style={`width:${Math.min(100, Math.max(0, l.engagement_rate ?? 0))}%`} /></span>
                  <span class="v">{fmtPct(l.engagement_rate)}</span>
                </span>
              </td>
              <td class="num">{fmtDuration(l.avg_engagement_s)}</td>
              <td class="num">{fmtNum(l.pages_per_session, 2)}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </TableCard>

  <script>
    /* Przełącznik trzech list „wczoraj" (Kanały/Źródła/Strony) – jedna karta
       widoczna naraz; karty zachowują własny filtr/sort/eksport TableCard. */
    const seg = document.querySelector<HTMLElement>('[data-ga4-panes-seg]');
    const panes = Array.from(document.querySelectorAll<HTMLElement>('[data-ga4-pane]'));
    seg?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button[data-pane]') as HTMLButtonElement | null;
      if (!btn) return;
      seg.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === btn));
      panes.forEach((p) => (p.hidden = p.dataset.ga4Pane !== btn.dataset.pane));
    });
  </script>
</Layout>
