---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TableCard from '../../components/TableCard.astro';
import TimeSeriesChart from '../../components/TimeSeriesChart.astro';
import SourceState from '../../components/SourceState.astro';
import {
  loadConfig,
  loadSnapshots,
  loadDetails,
  latestSnapshot,
  latestWithDelta,
  metricSeries,
  sectionEnabled,
  sourceStatuses,
  isTemporarySourceFailure,
} from '../../lib/data';
import { fmtInt, fmtPct, fmtNum, fmtDuration, fmtDate, fmtDateRange, barWidth } from '../../lib/format';

export function getStaticPaths() {
  return loadConfig()
    .domains.filter((d) => sectionEnabled(d, 'ga4'))
    .map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);
const ga4 = sourceStatuses(latest).ga4;
const ga4LastOk = [...snapshots].reverse().find((snapshot) => snapshot.sources.ga4?.status === 'ok');
const ga4StaleDate = isTemporarySourceFailure(ga4) ? ga4LastOk?.date ?? null : null;
const channels = details.sources.ga4?.channels ?? [];
const trafficSources = details.sources.ga4?.sources ?? [];
const pages = details.sources.ga4?.pages ?? [];
const landing = details.sources.ga4?.landing_pages?.rows ?? [];
const landingWindow = details.sources.ga4?.landing_pages?.window;
const daily = details.sources.ga4?.daily ?? [];
const monthly = details.sources.ga4?.monthly ?? [];
const channelsMonthly = details.sources.ga4?.channels_monthly ?? [];

// Historia dzienna pochodzi bezpośrednio z GA4 Data API. Snapshoty zostają
// fallbackiem dla danych zebranych przed rozszerzeniem collectora.
type DailyMetric = Exclude<(typeof daily)[number], undefined>;
type DailyKey = Exclude<keyof DailyMetric, 'date'>;
const dailySeries = (field: DailyKey) => daily.map((row) => Number(row[field] ?? 0));
const dailyTimestamps = daily.map((row) => Math.floor(new Date(`${row.date}T00:00:00Z`).getTime() / 1000));
const dailyStat = (field: DailyKey, fallback: { value: number | null; delta: number | null }) => {
  if (!daily.length) return fallback;
  const last = daily.at(-1)!;
  const lastTime = new Date(`${last.date}T00:00:00Z`).getTime();
  const reference = [...daily]
    .reverse()
    .find((row) => new Date(`${row.date}T00:00:00Z`).getTime() <= lastTime - 7 * 86400_000);
  const value = Number(last[field]);
  return { value, delta: reference ? value - Number(reference[field]) : null };
};
const sessions = daily.length
  ? { timestamps: dailyTimestamps, values: dailySeries('sessions') }
  : metricSeries(snapshots, 'ga4', 'sessions');
const organicDaily = daily.length
  ? { timestamps: dailyTimestamps, values: dailySeries('organic_sessions') }
  : metricSeries(snapshots, 'ga4', 'organic_sessions');
const statSessions = dailyStat('sessions', latestWithDelta(snapshots, 'ga4', 'sessions'));
const statUsers = dailyStat('active_users', latestWithDelta(snapshots, 'ga4', 'active_users'));
const statNewUsers = dailyStat('new_users', latestWithDelta(snapshots, 'ga4', 'new_users'));
const statReturning = dailyStat('returning_users', latestWithDelta(snapshots, 'ga4', 'returning_users'));
const statOrganic = dailyStat('organic_sessions', latestWithDelta(snapshots, 'ga4', 'organic_sessions'));
const statEngRate = dailyStat('engagement_rate', latestWithDelta(snapshots, 'ga4', 'engagement_rate'));
const statEngTime = dailyStat('avg_engagement_s', latestWithDelta(snapshots, 'ga4', 'avg_engagement_s'));
const statEngPerUser = dailyStat('engaged_per_user', latestWithDelta(snapshots, 'ga4', 'engaged_per_user'));
const statPagesPerSession = dailyStat('pages_per_session', latestWithDelta(snapshots, 'ga4', 'pages_per_session'));
const dataDate = daily.at(-1)?.date ?? ga4?.data?.data_date ?? null;

/* Podział nowi/powracający w karcie Użytkownicy (handoff „GA4 – układ"). */
const splitTotal = (statNewUsers.value ?? 0) + (statReturning.value ?? 0);
const splitNewPct = splitTotal > 0 ? Math.round(((statNewUsers.value ?? 0) / splitTotal) * 100) : 0;
const hasSplit = splitTotal > 0;

// Trend miesięczny (25 mies. z Data API) + delta r/r na ostatnim pełnym miesiącu.
const monthTs = (m: string) => Math.floor(Date.UTC(+m.slice(0, 4), +m.slice(4, 6) - 1, 1) / 1000);
const monthlyTs = monthly.map((m) => monthTs(m.month));
const lastFull = monthly.length >= 2 ? monthly[monthly.length - 2] : null;
const lastFullYoY = lastFull ? monthly.find((m) => +m.month === +lastFull.month - 100) : null;
const yoyDelta = (field: 'sessions' | 'users') =>
  lastFull && lastFullYoY ? lastFull[field] - lastFullYoY[field] : null;
const monthLabel = lastFull ? `${lastFull.month.slice(0, 4)}-${lastFull.month.slice(4, 6)}` : null;

// Kanały miesięcznie → serie per kanał (pozostałe zsumowane w „Inne").
const MAIN_CHANNELS = ['Organic Search', 'Direct', 'Referral', 'Paid Search', 'Organic Social'];
const channelSeries = MAIN_CHANNELS.map((channel) => ({
  label: channel === 'Organic Search' ? 'Organic' : channel === 'Organic Social' ? 'Social' : channel,
  values: monthly.map(
    (m) => channelsMonthly.find((c) => c.month === m.month && c.channel === channel)?.sessions ?? 0,
  ),
}));
const otherSeries = monthly.map((m) =>
  channelsMonthly
    .filter((c) => c.month === m.month && !MAIN_CHANNELS.includes(c.channel))
    .reduce((sum, c) => sum + c.sessions, 0),
);
const organicMonthly = channelSeries[0]?.values ?? [];

const maxChannel = Math.max(...channels.map((c) => c.sessions), 0);
const maxSource = Math.max(...trafficSources.map((s) => s.sessions), 0);
const maxPage = Math.max(...pages.map((p) => p.pageviews), 0);
const maxLanding = Math.max(...landing.map((l) => l.sessions), 0);

/* Wartości techniczne GA4 ((not set), Unassigned…) – wyciszamy, nie udajemy treści. */
const isJunk = (name: string) => /^\(|unassigned|not set|not available/i.test(name);
---

<Layout title={`${name} – GA4`}>
  <div class="ga4-page">
  <DomainHeader domain={domain!} name={name} active="ga4" latest={latest} themeToggle />

  <div class="ga4-note">
    GA4 pokazuje ruch z ostatniej pełnej doby: najważniejszą liczbę, użytkowników z podziałem na nowych
    i powracających, metryki zaangażowania oraz trendy miesięczne. Listy „skąd i dokąd” łączą kanały,
    źródła i strony w jednym przełączanym widoku.
  </div>

  <SourceState
    name="GA4"
    result={ga4}
    lastDate={ga4LastOk?.date}
    metrics={[
      { label: 'Sesje', value: statSessions.value },
      { label: 'Użytkownicy', value: statUsers.value },
      { label: 'Sesje organiczne', value: statOrganic.value },
    ]}
  />

  <div class="section-head">
    <h2>Ruch w witrynie</h2>
    {dataDate && <span class="section-meta">pełna doba {fmtDate(String(dataDate))} · delty 7-dniowe z API GA4</span>}
  </div>
  <div class="rgrid rgrid4">
    <StatCard label="Sesje / dzień" value={statSessions.value} delta={statSessions.delta} trend={sessions.values} staleDate={ga4StaleDate} hero />
    <StatCard label="Użytkownicy" value={statUsers.value} delta={hasSplit ? null : statUsers.delta} staleDate={ga4StaleDate}>
      {hasSplit && (
        <div class="split">
          <div class="bar">
            <i class="a" style={`width:${splitNewPct}%`} />
            <i class="b" style={`width:${100 - splitNewPct}%`} />
          </div>
          <div class="lg">
            <span><span class="dot" style="background:var(--accent-blue)"></span>Nowi <b>{fmtInt(statNewUsers.value)}</b></span>
            <span><span class="dot" style="background:var(--series-3)"></span>Powracający <b>{fmtInt(statReturning.value)}</b></span>
          </div>
        </div>
      )}
    </StatCard>
    <StatCard label="Engagement rate" value={statEngRate.value} delta={statEngRate.delta} unit="%" precision={1} staleDate={ga4StaleDate} />
    <StatCard label="Sesje organiczne" value={statOrganic.value} delta={statOrganic.delta} trend={organicDaily.values} staleDate={ga4StaleDate} />
  </div>
  <div class="micro">
    <div class="m">
      <div class="l">Śr. czas zaangażowania / sesję</div>
      <div class="v">{fmtDuration(statEngTime.value)}</div>
    </div>
    <div class="m">
      <div class="l">Strony / sesję</div>
      <div class="v">{fmtNum(statPagesPerSession.value, 2)}</div>
    </div>
    <div class="m">
      <div class="l">Engaged sessions / użytkownika</div>
      <div class="v">{fmtNum(statEngPerUser.value, 2)}</div>
    </div>
  </div>

  <div class="section-head">
    <h2>Trendy miesięczne</h2>
    <span class="section-meta">
      {monthly.length > 1 ? `${monthly.length} miesięcy · sezonowość` : 'historia ruchu'}
      {monthLabel && ` · ostatni pełny miesiąc: ${monthLabel}`}
      {yoyDelta('sessions') !== null &&
        ` · sesje r/r: ${yoyDelta('sessions')! > 0 ? '+' : ''}${fmtInt(yoyDelta('sessions'))}`}
      {yoyDelta('users') !== null &&
        ` · użytkownicy r/r: ${yoyDelta('users')! > 0 ? '+' : ''}${fmtInt(yoyDelta('users'))}`}
    </span>
  </div>
  <div class="ga4-charts">
    {
      monthly.length > 1 && (
        <>
          <TimeSeriesChart
            title="Użytkownicy: nowi vs powracający"
            timestamps={monthlyTs}
            series={[
              { label: 'Nowi', values: monthly.map((m) => m.new_users), fill: true },
              { label: 'Powracający', values: monthly.map((m) => Math.max(0, m.users - m.new_users)) },
            ]}
            overview
          />
          <TimeSeriesChart
            title="Sesje per kanał"
            timestamps={monthlyTs}
            series={[...channelSeries, { label: 'Inne', values: otherSeries }].filter((s) =>
              s.values.some((v) => v > 0),
            )}
            overview
          />
          <TimeSeriesChart
            title="Ruch organiczny"
            meta="sezonowość"
            timestamps={monthlyTs}
            series={[{ label: 'Sesje organiczne', values: organicMonthly, fill: true }]}
            overview
          />
        </>
      )
    }
    <TimeSeriesChart
      title="Sesje i sesje organiczne"
      meta="dziennie"
      timestamps={sessions.timestamps}
      series={[
        { label: 'Sesje', values: sessions.values, fill: true },
        { label: 'Organiczne', values: organicDaily.values },
      ]}
      overview
    />
  </div>

  <div class="section-head">
    <h2>Wczoraj – skąd i dokąd</h2>
    <span class="section-meta">trzy listy w jednym przełączanym widoku</span>
  </div>

  <div data-ga4-pane="kanaly">
    <TableCard title="Ruch wczoraj" count={channels.length} empty="Brak danych.">
      <Fragment slot="actions">
        <div class="seg" data-ga4-panes-seg>
          <button type="button" class="active" data-pane="kanaly">Kanały · {channels.length}</button>
          <button type="button" data-pane="zrodla">Źródła · {trafficSources.length}</button>
          <button type="button" data-pane="strony">Strony · {pages.length}</button>
        </div>
      </Fragment>
      <table class="data-table">
        <thead>
          <tr>
            <th>Kanał</th>
            <th class="num">Sesje</th>
            <th class="num">Użytkownicy</th>
            <th class="num">Odsłony</th>
          </tr>
        </thead>
        <tbody>
          {
            channels.map((c) => (
              <tr>
                <td class="grow"><span class={isJunk(c.channel) ? 'muted-tag' : ''}>{c.channel}</span></td>
                <td class="num">
                  <span class="cell-bar rbar">
                    {fmtInt(c.sessions)}
                    <span class="bar">
                      <i style={`width:${barWidth(c.sessions, maxChannel)}%`} />
                    </span>
                  </span>
                </td>
                <td class="num">{fmtInt(c.users)}</td>
                <td class="num">{fmtInt(c.pageviews)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </TableCard>
  </div>

  <div data-ga4-pane="zrodla" hidden>
    <TableCard title="Ruch wczoraj" count={trafficSources.length} filter empty="Brak danych.">
      <Fragment slot="actions">
        <div class="seg" data-ga4-panes-seg>
          <button type="button" data-pane="kanaly">Kanały · {channels.length}</button>
          <button type="button" class="active" data-pane="zrodla">Źródła · {trafficSources.length}</button>
          <button type="button" data-pane="strony">Strony · {pages.length}</button>
        </div>
      </Fragment>
      <table class="data-table">
        <thead>
          <tr>
            <th>Źródło</th>
            <th class="num">Sesje</th>
            <th class="num">Użytkownicy</th>
          </tr>
        </thead>
        <tbody>
          {
            trafficSources.map((s) => (
              <tr>
                <td class="grow"><span class={isJunk(s.source) ? 'muted-tag' : ''}>{s.source}</span></td>
                <td class="num">
                  <span class="cell-bar rbar">
                    {fmtInt(s.sessions)}
                    <span class="bar">
                      <i style={`width:${barWidth(s.sessions, maxSource)}%`} />
                    </span>
                  </span>
                </td>
                <td class="num">{fmtInt(s.users)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </TableCard>
  </div>

  <div data-ga4-pane="strony" hidden>
    <TableCard title="Ruch wczoraj" count={pages.length} filter empty="Brak danych.">
      <Fragment slot="actions">
        <div class="seg" data-ga4-panes-seg>
          <button type="button" data-pane="kanaly">Kanały · {channels.length}</button>
          <button type="button" data-pane="zrodla">Źródła · {trafficSources.length}</button>
          <button type="button" class="active" data-pane="strony">Strony · {pages.length}</button>
        </div>
      </Fragment>
      <table class="data-table">
        <thead>
          <tr>
            <th>Strona</th>
            <th class="num">Odsłony</th>
            <th class="num">Użytkownicy</th>
          </tr>
        </thead>
        <tbody>
          {
            pages.map((p) => (
              <tr>
                <td class="grow"><span class="cell-url">{p.path}</span></td>
                <td class="num">
                  <span class="cell-bar rbar">
                    {fmtInt(p.pageviews)}
                    <span class="bar">
                      <i style={`width:${barWidth(p.pageviews, maxPage)}%`} />
                    </span>
                  </span>
                </td>
                <td class="num">{fmtInt(p.users)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </TableCard>
  </div>

  <TableCard
    title="Landing pages – zaangażowanie"
    meta={landingWindow ? `okno ${fmtDateRange(landingWindow.start, landingWindow.end)}` : undefined}
    count={landing.length}
    filter
    empty="Dane pojawią się po najbliższym przebiegu collectora."
  >
    <table class="data-table">
      <thead>
        <tr>
          <th>Landing page</th>
          <th class="num">Sesje</th>
          <th class="num">Engagement rate</th>
          <th class="num">Śr. czas zaangaż.</th>
          <th class="num">Strony / sesję</th>
        </tr>
      </thead>
      <tbody>
        {
          landing.map((l) => (
            <tr>
              <td class="grow"><span class={isJunk(l.path) ? 'muted-tag' : 'cell-url'}>{l.path}</span></td>
              <td class="num">
                <span class="cell-bar rbar">
                  {fmtInt(l.sessions)}
                  <span class="bar">
                    <i style={`width:${barWidth(l.sessions, maxLanding)}%`} />
                  </span>
                </span>
              </td>
              <td class="num" data-sort={l.engagement_rate}>
                <span class="erate">
                  <span class="t"><i style={`width:${Math.min(100, Math.max(0, l.engagement_rate ?? 0))}%`} /></span>
                  <span class="v">{fmtPct(l.engagement_rate)}</span>
                </span>
              </td>
              <td class="num">{fmtDuration(l.avg_engagement_s)}</td>
              <td class="num">{fmtNum(l.pages_per_session, 2)}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </TableCard>

  <script>
    /* Przełącznik trzech list „wczoraj" (Kanały/Źródła/Strony) – jedna karta
       widoczna naraz; karty zachowują własny filtr/sort/eksport TableCard. */
    const segs = Array.from(document.querySelectorAll<HTMLElement>('[data-ga4-panes-seg]'));
    const panes = Array.from(document.querySelectorAll<HTMLElement>('[data-ga4-pane]'));
    segs.forEach((seg) => seg.addEventListener('click', (e) => {
      const button = (e.target as HTMLElement).closest('button[data-pane]') as HTMLButtonElement | null;
      if (!button) return;
      const pane = button.dataset.pane;
      segs.forEach((item) => item.querySelectorAll('button').forEach((candidate) =>
        candidate.classList.toggle('active', candidate.dataset.pane === pane),
      ));
      panes.forEach((item) => (item.hidden = item.dataset.ga4Pane !== pane));
    }));
  </script>
  </div>
</Layout>

<style>
  .ga4-page {
    width: 100%;
  }
  .ga4-note {
    margin: 16px 0 4px;
    padding: 10px 14px;
    border-left: 2px solid var(--accent-blue);
    border-radius: 0 10px 10px 0;
    background: color-mix(in srgb, var(--accent-blue) 6%, transparent);
    color: var(--ink-muted);
    font-size: 0.84rem;
    line-height: 1.5;
  }
  .ga4-charts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 18px;
  }
  @media (max-width: 1080px) {
    .ga4-charts {
      grid-template-columns: 1fr;
    }
  }
</style>
