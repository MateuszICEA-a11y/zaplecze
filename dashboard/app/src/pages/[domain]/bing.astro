---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TableCard from '../../components/TableCard.astro';
import TimeSeriesChart from '../../components/TimeSeriesChart.astro';
import SourceState from '../../components/SourceState.astro';
import {
  loadConfig,
  loadSnapshots,
  loadDetails,
  loadBingAiQueries,
  latestSnapshot,
  latestWithDelta,
  sectionEnabled,
  sourceStatuses,
  isTemporarySourceFailure,
} from '../../lib/data';
import { fmtInt, fmtNum, fmtDate, fmtDateRange, posClass, barWidth } from '../../lib/format';

export function getStaticPaths() {
  return loadConfig()
    .domains.filter((d) => sectionEnabled(d, 'bing'))
    .map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);
const bing = sourceStatuses(latest).bing;
const bingLastOk = [...snapshots].reverse().find((snapshot) => snapshot.sources.bing?.status === 'ok');
const bingStaleDate = isTemporarySourceFailure(bing) ? bingLastOk?.date ?? null : null;
const traffic = details.sources.bing?.traffic ?? [];

// Frazy per okno (7d/30d/…, jak w BWT). Fallback: płaska lista `queries`
// ze starych snapshotów (bez informacji o oknie).
const WINDOW_LABELS: [string, string][] = [
  ['7d', '7 dni'],
  ['30d', '30 dni'],
  ['3m', '3 mies.'],
  ['6m', '6 mies.'],
  ['12m', '12 mies.'],
  ['18m', '18 mies.'],
  ['24m', '24 mies.'],
];
const queryWindows = details.sources.bing?.queries_windows;
const windowOptions = queryWindows ? WINDOW_LABELS.filter(([k]) => queryWindows[k]) : [];
const defaultKey = queryWindows?.['30d'] ? '30d' : (windowOptions[0]?.[0] ?? null);
const defaultWindow = defaultKey ? queryWindows?.[defaultKey] : null;
const queries = defaultWindow?.queries ?? details.sources.bing?.queries ?? [];
const queriesMeta =
  defaultWindow?.start && defaultWindow?.end
    ? `okno ${fmtDateRange(defaultWindow.start, defaultWindow.end)}`
    : 'okres wg BWT (brak dat w API)';

const statClicks = latestWithDelta(snapshots, 'bing', 'clicks');
const statImpressions = latestWithDelta(snapshots, 'bing', 'impressions');
const statQueries = latestWithDelta(snapshots, 'bing', 'queries');
const dataDate = bing?.data?.data_date ?? null;

// Historia z details (BWT oddaje ~ostatnie tygodnie) – bogatsza niż snapshoty
// na starcie; gdy snapshotów przybędzie, oba wykresy się zejdą.
const histTs = traffic.map((t) => Math.floor(new Date(t.date).getTime() / 1000));
const histClicks = traffic.map((t) => t.clicks);
const histImpressions = traffic.map((t) => t.impressions);
const latestTraffic = traffic.at(-1) ?? null;
const compareTrafficDate = latestTraffic
  ? new Date(`${latestTraffic.date}T00:00:00Z`).getTime() - 7 * 86400_000
  : null;
const compareTraffic = compareTrafficDate === null
  ? null
  : traffic.find((t) => new Date(`${t.date}T00:00:00Z`).getTime() === compareTrafficDate) ?? null;
const clicksDelta7 = latestTraffic && compareTraffic ? latestTraffic.clicks - compareTraffic.clicks : statClicks.delta;
const impressionsDelta7 = latestTraffic && compareTraffic
  ? latestTraffic.impressions - compareTraffic.impressions
  : statImpressions.delta;

const maxQueryImpr = Math.max(...queries.map((q) => q.impressions), 0);

// AI Performance (Copilot/Bing AI) – brak API, dane z ręcznego eksportu CSV
// wrzucanego do dashboard/imports/bing-ai/<domena>/.
const aiPerf = loadBingAiQueries(domain!);
const aiRows = aiPerf?.rows ?? [];
const maxCitations = Math.max(...aiRows.map((r) => r.citations), 0);
const totalCitations = aiRows.reduce((s, r) => s + r.citations, 0);

/* Normalizacja intencji z eksportu BWT do stałych pigułek (handoff „Bing – układ"). */
const intentKey = (intent: string): 'learn' | 'info' | 'cmp' | 'other' =>
  /learn|solve/i.test(intent) ? 'learn' : /inform/i.test(intent) ? 'info' : /compar/i.test(intent) ? 'cmp' : 'other';
const INTENTS: Record<string, { label: string; color: string }> = {
  learn: { label: 'Learn & Solve', color: 'var(--series-3)' },
  info: { label: 'Informational', color: 'var(--accent-blue)' },
  cmp: { label: 'Comparison', color: 'var(--series-2)' },
  other: { label: 'Inne', color: 'var(--ink-faint)' },
};
const intentSplit = Object.keys(INTENTS)
  .map((key) => {
    const cit = aiRows.filter((r) => intentKey(r.intent) === key).reduce((s, r) => s + r.citations, 0);
    return { key, ...INTENTS[key], cit, pct: totalCitations > 0 ? Math.round((cit / totalCitations) * 100) : 0 };
  })
  .filter((i) => i.cit > 0);
const shareClass = (share: number | null): string =>
  share === null ? 'lo' : share >= 15 ? 'hi' : share >= 5 ? 'mid' : 'lo';
---

<Layout title={`${name} – Bing Webmaster Tools`}>
  <DomainHeader domain={domain!} name={name} active="bing" latest={latest} themeToggle accent="var(--bing)" />

  <div class="bing-note">
    Wyróżnikiem Binga jest <strong>AI Performance</strong>: liczba cytowań marki w odpowiedziach Copilot i Bing AI,
    rozkład intencji oraz zapytania grounding. Niżej pozostają klasyczny ruch z wyszukiwarki i frazy z BWT.
  </div>

  <SourceState
    name="Bing"
    result={bing}
    lastDate={bingLastOk?.date}
    metrics={[
      { label: 'Kliknięcia', value: statClicks.value },
      { label: 'Wyświetlenia', value: statImpressions.value },
      { label: 'Frazy', value: statQueries.value },
    ]}
  />

  <div class="section-head">
    <h2>Ruch z Binga</h2>
    {dataDate && <span class="section-meta">ostatni pełny dzień: {fmtDate(String(dataDate))}</span>}
  </div>
  <div class="kwrap rgrid bing-kpis">
    <StatCard
      label="Wyświetlenia / dzień"
      value={statImpressions.value}
      delta={impressionsDelta7}
      trend={histImpressions}
      src="bing"
      staleDate={bingStaleDate}
      hero
    />
    <StatCard label="Kliknięcia / dzień" value={statClicks.value} delta={clicksDelta7} trend={histClicks} src="bing" staleDate={bingStaleDate} />
    <StatCard
      label={defaultKey ? `Frazy w Bing (${WINDOW_LABELS.find(([k]) => k === defaultKey)?.[1]})` : 'Frazy w Bing'}
      value={statQueries.value}
      delta={statQueries.delta}
      src="bing"
      staleDate={bingStaleDate}
    />
  </div>

  {
    aiRows.length > 0 && (
      <>
        <div class="section-head">
          <h2>AI Performance<span class="tagx">wyróżnik</span></h2>
          <span class="section-meta">
            cytowania marki w Copilot / Bing AI · import CSV z BWT · stan z {fmtDate(aiPerf!.date)}
          </span>
        </div>
        <div class="ai-sum">
          <div>
            <div class="cap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 3l2.1 5.5L20 10l-5.9 1.5L12 17l-2.1-5.5L4 10l5.9-1.5L12 3z" />
              </svg>
              Cytowania AI
            </div>
            <div class="big">{fmtInt(totalCitations)}</div>
            <div class="sub">
              w <b>{fmtInt(aiRows.length)}</b> zapytaniach grounding – frazach, którymi AI sięgało po treść
            </div>
          </div>
          <div class="isplit">
            {intentSplit.map((i) => (
              <div class="r">
                <span class="dot" style={`background:${i.color}`} />
                <span class="nm">{i.label}</span>
                <span class="t"><i style={`width:${i.pct}%;background:${i.color}`} /></span>
                <span class="n"><b>{fmtInt(i.cit)}</b> · {i.pct}%</span>
              </div>
            ))}
          </div>
        </div>
        <div data-ai-card>
          <TableCard title="Grounding queries" count={aiRows.length} filter>
            <table class="data-table">
              <thead>
                <tr>
                  <th>Grounding query</th>
                  <th>Intencja</th>
                  <th>Temat</th>
                  <th class="num">Cytowania</th>
                  <th class="num">Udział cytowań</th>
                </tr>
              </thead>
              <tbody>
                {aiRows.map((r) => (
                  <tr data-intent={intentKey(r.intent)}>
                    <td class="grow">{r.query}</td>
                    <td><span class={`tag-int ${intentKey(r.intent)}`}>{r.intent || INTENTS[intentKey(r.intent)].label}</span></td>
                    <td><span class="topic-cell">{r.topic}</span></td>
                    <td class="num">
                      <span class="cell-bar rbar bing">
                        {fmtInt(r.citations)}
                        <span class="bar">
                          <i style={`width:${barWidth(r.citations, maxCitations)}%`} />
                        </span>
                      </span>
                    </td>
                    <td class="num">
                      <span class={`share ${shareClass(r.citation_share)}`}>
                        {r.citation_share === null ? '–' : `${fmtNum(r.citation_share, 2)}%`}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </TableCard>
        </div>
      </>
    )
  }

  <div class="section-head" style="margin-bottom:14px;"><h2>Ruch klasyczny</h2><span class="section-meta">kliknięcia i wyświetlenia</span></div>
  <div class="chart-grid">
    <TimeSeriesChart
      title="Kliknięcia i wyświetlenia"
      meta="dziennie"
      timestamps={histTs}
      series={[
        { label: 'Kliknięcia', values: histClicks, fill: true },
        { label: 'Wyświetlenia', values: histImpressions },
      ]}
      secondaryAxis
      ranges
      overview
    />
  </div>

  {
    windowOptions.length > 1 && (
      <div class="section-head" style="margin-bottom:6px;">
        <h2>Frazy w Bing</h2>
        <div class="seg" data-bing-window-seg>
          {windowOptions.map(([k, label]) => (
            <button type="button" class={k === defaultKey ? 'active' : ''} data-window={k}>
              {label}
            </button>
          ))}
        </div>
      </div>
    )
  }
  {queryWindows && (
    <script
      type="application/json"
      id="bing-windows-data"
      set:html={JSON.stringify(queryWindows).replace(/</g, '\\u003c')}
    />
  )}

  <TableCard
    title="Frazy w Bing"
    meta={queriesMeta}
    count={queries.length}
    filter
    empty="Dane pojawią się po najbliższym przebiegu collectora (wymaga BING_WEBMASTER_API_KEY i zweryfikowanej witryny w BWT)."
  >
    <table class="data-table">
      <thead>
        <tr>
          <th>Fraza</th>
          <th class="num">Kliknięcia</th>
          <th class="num">Wyświetlenia</th>
          <th class="num">Śr. pozycja klikn.</th>
        </tr>
      </thead>
      <tbody>
        {
          queries.map((q) => (
            <tr>
              <td class="grow">{q.query}</td>
              <td class="num">{fmtInt(q.clicks)}</td>
              <td class="num">
                <span class="cell-bar rbar">
                  {fmtInt(q.impressions)}
                  <span class="bar">
                    <i style={`width:${barWidth(q.impressions, maxQueryImpr)}%`} />
                  </span>
                </span>
              </td>
              <td class="num">
                <span class={`pos-badge rbadge ${posClass(q.position)}`}>{fmtNum(q.position, 1)}</span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </TableCard>

  <script>
    /* Filtry intencji grounding queries: chipy wpinają predykat w kontroler
       TableCard (tablecard:refilter), więc współgrają z filtrem tekstowym,
       sortowaniem, paginacją i eksportem CSV. */
    const aiWrap = document.querySelector<HTMLElement>('[data-ai-card]');
    const aiCard = aiWrap?.querySelector<HTMLElement>('.table-card');
    const aiHead = aiCard?.querySelector<HTMLElement>('.table-head');
    if (aiCard && aiHead) {
      const CHIPS: [string, string][] = [
        ['all', 'Wszystkie'],
        ['learn', 'Learn & Solve'],
        ['info', 'Informational'],
        ['cmp', 'Comparison'],
      ];
      const present = new Set(
        Array.from(aiCard.querySelectorAll<HTMLElement>('tbody tr[data-intent]')).map((r) => r.dataset.intent),
      );
      const box = document.createElement('div');
      box.className = 'fchips';
      CHIPS.filter(([k]) => k === 'all' || present.has(k)).forEach(([key, label]) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = key === 'all' ? 'fchip on-bing' : 'fchip';
        b.textContent = label;
        b.dataset.intent = key;
        b.addEventListener('click', () => {
          box.querySelectorAll('button').forEach((o) => o.classList.toggle('on-bing', o === b));
          const predicate =
            key === 'all' ? null : (row: HTMLTableRowElement) => row.dataset.intent === key;
          aiCard.dispatchEvent(new CustomEvent('tablecard:refilter', { detail: predicate }));
        });
        box.appendChild(b);
      });
      aiHead.insertBefore(box, aiHead.querySelector('[data-table-filter]'));
    }

    /* Przełącznik okresu tabeli „Frazy w Bing" (jak w BWT): przepina wiersze
       na dane wybranego okna z osadzonego JSON-a, resetuje sort i pager. */
    const dataEl = document.getElementById('bing-windows-data');
    const winSeg = document.querySelector<HTMLElement>('[data-bing-window-seg]');
    if (dataEl && winSeg) {
      type Row = { query: string; clicks: number; impressions: number; position: number | null };
      type Win = { start: string | null; end: string | null; queries: Row[] };
      const windows: Record<string, Win> = JSON.parse(dataEl.textContent ?? '{}');
      const card = Array.from(document.querySelectorAll<HTMLElement>('.table-card')).find((c) =>
        c.querySelector('.table-head h3')?.textContent?.includes('Frazy w Bing'),
      );
      const esc = (s: string) =>
        s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
      const fi = (n: number | null | undefined) =>
        typeof n === 'number' ? n.toLocaleString('pl-PL') : '–';
      const f1 = (v: number | null) =>
        typeof v === 'number' ? v.toLocaleString('pl-PL', { maximumFractionDigits: 1 }) : '–';
      const posCls = (p: number | null) =>
        typeof p !== 'number' ? '' : p <= 3 ? 'top3' : p <= 10 ? 'top10' : p <= 30 ? 'mid' : 'low';
      const bar = (v: number, max: number) => (max > 0 ? Math.max(2, Math.round((v / max) * 100)) : 0);

      const rowHtml = (r: Row, max: number) => `
        <tr>
          <td class="grow">${esc(r.query)}</td>
          <td class="num">${fi(r.clicks)}</td>
          <td class="num"><span class="cell-bar rbar">${fi(r.impressions)}<span class="bar"><i style="width:${bar(
            r.impressions,
            max,
          )}%"></i></span></span></td>
          <td class="num"><span class="pos-badge rbadge ${posCls(r.position)}">${f1(r.position)}</span></td>
        </tr>`;

      winSeg.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('button[data-window]') as HTMLButtonElement | null;
        if (!btn || !card) return;
        const win = windows[btn.dataset.window!];
        if (!win) return;
        winSeg.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === btn));
        const body = card.querySelector('table.data-table tbody');
        if (!body) return;
        const max = Math.max(...win.queries.map((r) => r.impressions ?? 0), 0);
        body.innerHTML = win.queries.map((r) => rowHtml(r, max)).join('');
        const countEl = card.querySelector('.table-head h3 .table-meta');
        if (countEl) countEl.textContent = ` · ${win.queries.length.toLocaleString('pl-PL')}`;
        const metaEl = card.querySelector('.table-head > .table-meta');
        if (metaEl)
          metaEl.textContent =
            win.start && win.end ? `okno ${new Date(`${win.start}T00:00:00Z`).toLocaleDateString('pl-PL')}–${new Date(`${win.end}T00:00:00Z`).toLocaleDateString('pl-PL')}` : 'okres wg BWT';
        card.querySelectorAll<HTMLTableCellElement>('thead th').forEach((th) => {
          th.classList.remove('active');
          delete th.dataset.dir;
          const caret = th.querySelector('.sort-caret');
          if (caret) caret.textContent = '';
        });
        card.dispatchEvent(new CustomEvent('tablecard:refilter', { detail: null }));
      });
    }
  </script>
</Layout>

<style>
  .bing-note {
    margin: 16px 0 4px;
    padding: 10px 14px;
    border-left: 2px solid var(--bing);
    border-radius: 0 10px 10px 0;
    background: color-mix(in srgb, var(--bing) 7%, transparent);
    color: var(--ink-muted);
    font-size: 0.84rem;
    line-height: 1.5;
  }
  .bing-note strong {
    color: var(--bing);
  }
  .kwrap.bing-kpis {
    grid-template-columns: 1.4fr 1fr 1fr;
  }
  @media (max-width: 900px) {
    .kwrap.bing-kpis {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 620px) {
    .kwrap.bing-kpis {
      grid-template-columns: 1fr;
    }
  }
</style>
