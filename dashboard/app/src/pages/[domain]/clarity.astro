---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TableCard from '../../components/TableCard.astro';
import SourceState from '../../components/SourceState.astro';
import {
  loadConfig,
  loadSnapshots,
  loadDetails,
  latestSnapshot,
  latestWithDelta,
  sourceStatuses,
  isTemporarySourceFailure,
} from '../../lib/data';
import { fmtInt, fmtNum, fmtDuration, fmtDate, barWidth } from '../../lib/format';

export function getStaticPaths() {
  return loadConfig().domains.map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);
const clarity = sourceStatuses(latest).clarity;
const clarityDetails = details.sources.clarity;
const configured = clarity != null && clarity.status !== 'not_configured';

/* Clarity leży (np. HTTP 429)? Pokazujemy ostatni udany pomiar zamiast zwijać
   sekcję (handoff „Clarity – układ"): baner + przygaszone karty z datą danych. */
const lastOk = [...snapshots].reverse().find((s) => s.sources.clarity?.status === 'ok');
const isDown = configured && isTemporarySourceFailure(clarity);
const staleDate = isDown && lastOk ? fmtDate(lastOk.date) : null;
const measurementDate = lastOk ? fmtDate(lastOk.date) : null;
const measurementTag = measurementDate ? `pomiar ${measurementDate}` : 'brak historii porównawczej';
const lastOkWhen = lastOk
  ? new Date(lastOk.collected_at).toLocaleString('pl-PL', {
      day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Warsaw',
    })
  : null;
const okData = (lastOk?.sources.clarity?.data ?? {}) as Record<string, number>;

const statSessions = latestWithDelta(snapshots, 'clarity', 'sessions');
const statUsers = latestWithDelta(snapshots, 'clarity', 'users');
const statScroll = latestWithDelta(snapshots, 'clarity', 'scroll_depth_avg');

/* EngagementTime z Data Export API to już średnie NA SESJĘ (sekundy). */
const engagementActive = okData.engagement_active_s ?? null;
const engagementTotal = okData.engagement_total_s ?? null;
const pagesPerSession = okData.pages_per_session ?? null;
const scrollAvg = typeof statScroll.value === 'number' ? statScroll.value : null;
const activeShare =
  typeof engagementActive === 'number' && typeof engagementTotal === 'number' && engagementTotal > 0
    ? Math.round((engagementActive / engagementTotal) * 100)
    : null;

/* Sygnały frustracji: liczby + udział w sesjach ostatniego udanego pomiaru.
   Data Export API zwraca subTotal jako string – koercja przed formatowaniem. */
const num = (v: unknown): number | null => (v == null || v === '' || isNaN(Number(v)) ? null : Number(v));
const sessionCount = typeof statSessions.value === 'number' ? statSessions.value : null;
const rateOf = (v: number | null | undefined) =>
  typeof v === 'number' && sessionCount ? fmtNum((v / sessionCount) * 100, 1) + '%' : null;
const frustration = [
  {
    key: 'rage',
    label: 'Rage clicks',
    value: num(clarityDetails?.rage_clicks),
    desc: 'wielokrotne kliknięcia w to samo miejsce',
    icon: 'M13 2L3 14h7l-1 8 10-12h-7l1-8z',
  },
  {
    key: 'dead',
    label: 'Dead clicks',
    value: num(clarityDetails?.dead_clicks),
    desc: 'kliknięcia w element bez reakcji',
    icon: null,
  },
  {
    key: 'quick',
    label: 'Quick backs',
    value: num(clarityDetails?.quickback_clicks),
    desc: 'szybki powrót po wejściu na stronę',
    icon: 'M11 17l-5-5 5-5M18 17l-5-5 5-5',
  },
].filter((f) => f.value != null);
const scriptErrors = num(clarityDetails?.script_errors);

const hasName = (row: { name: string }) => Boolean(row.name && row.name.trim() !== '?');
/* Stare dane mogły zawierać „?”: collector pytał o nieobsługiwany wymiar
   Referrer, a etykiety URL pochodziły ze starszego parsera. Nie pokazujemy
   kilkudziesięciu identycznych, nieweryfikowalnych wierszy. */
const urlRows = (clarityDetails?.url ?? []).filter(hasName);
const refRows = (clarityDetails?.referrer ?? []).filter(hasName);
const urlLabelsMissing = (clarityDetails?.url?.length ?? 0) > 0 && urlRows.length === 0;
const refLabelsMissing = (clarityDetails?.referrer?.length ?? 0) > 0 && refRows.length === 0;
const maxUrl = Math.max(...urlRows.map((r) => r.sessions ?? 0), 0);
const maxRef = Math.max(...refRows.map((r) => r.sessions ?? 0), 0);

/* Urządzenia: donut conic-gradient liczony w build time z udziałów sesji. */
const deviceRows = clarityDetails?.device ?? [];
const devTotal = deviceRows.reduce((sum, r) => sum + (r.sessions ?? 0), 0);
const devColors = ['var(--accent-blue)', 'var(--series-3)', 'var(--series-2)', 'var(--ink-faint)'];
const devices = deviceRows.slice(0, 4).map((r, i) => ({
  name: r.name,
  pct: devTotal ? Math.round(((r.sessions ?? 0) / devTotal) * 100) : 0,
  color: devColors[i],
}));
let acc = 0;
const donutStops = devices
  .map((d) => {
    const from = acc;
    acc += d.pct;
    return `${d.color} ${from}% ${acc}%`;
  })
  .concat(acc < 100 ? [`var(--bg-surface-3) ${acc}% 100%`] : [])
  .join(', ');

const ghost = isDown ? 'stale-ghost' : '';
const metaSuffix = staleDate ? ` · dane z ${staleDate}` : '';
---

<Layout title={`${name} – Microsoft Clarity`}>
  <DomainHeader
    domain={domain!}
    name={name}
    active="clarity"
    latest={latest}
    themeToggle
    measurementStatus={isDown ? 'warn' : 'ok'}
    measurementLabel={isDown && staleDate ? `ostatnio: ${staleDate}` : undefined}
  />

  <div class="clarity-note">
    Clarity pokazuje, jak użytkownicy zachowują się na stronie: średnią głębokość scrolla, czas aktywny,
    strony na sesję oraz sygnały frustracji. Gdy API zwraca limit HTTP 429, widok zachowuje ostatni udany
    pomiar i automatycznie oznacza wszystkie wartości jego datą.
  </div>

  {
    !configured ? (
      <div class="placeholder-card" style="margin-top:20px">
        <strong>Clarity czeka na token Data Export API.</strong>
        <br />
        Wygeneruj token w panelu Clarity (projekt tej domeny → Settings → Data Export →
        „Generate new API token") i dodaj go w GitHub → Settings → Secrets → Actions pod nazwą
        z <code>token_env</code> w domains.yaml (domyślnie <code>CLARITY_API_TOKEN</code>).
        Sekcja zapełni się po najbliższym przebiegu collectora –
        sesje, użytkownicy, scroll depth, frustracje (rage/dead clicks) i top strony z
        ostatnich 3 dni.
      </div>
    ) : (
      <>
        {isDown ? (
          <div class="clarity-down" role="status">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z" />
            </svg>
            <span>
              Clarity: <strong>{clarity?.error ?? 'źródło chwilowo niedostępne'}</strong> — pokazujemy ostatni udany pomiar.
              Odświeżymy dane automatycznie po zwolnieniu limitu.
            </span>
            {lastOkWhen && <span class="when">ostatni pomiar: {lastOkWhen}</span>}
          </div>
        ) : (
          <SourceState
            name="Clarity"
            result={clarity}
            lastDate={lastOk?.date}
            metrics={[
              { label: 'Sesje', value: statSessions.value },
              { label: 'Użytkownicy', value: statUsers.value },
              { label: 'Średni scroll', value: statScroll.value, unit: '%' },
            ]}
          />
        )}

        <div class="section-head">
          <h2>Zachowania użytkowników</h2>
          <span class="section-meta">okno: ostatnie 3 dni{metaSuffix}</span>
        </div>
        <div class:list={['stat-grid', 'rgrid', 'clarity-kpis', ghost]}>
          <StatCard label="Sesje" value={statSessions.value} delta={isDown ? null : statSessions.delta} emptyDeltaLabel={measurementTag} staleDate={staleDate} />
          <StatCard label="Użytkownicy" value={statUsers.value} delta={isDown ? null : statUsers.delta} emptyDeltaLabel={measurementTag} staleDate={staleDate} />
          <StatCard label="Śr. scroll depth" value={statScroll.value} delta={isDown ? null : statScroll.delta} emptyDeltaLabel={measurementTag} unit="%" precision={1} staleDate={staleDate} />
          <StatCard
            label="Aktywny czas / sesja"
            value={typeof engagementActive === 'number' ? fmtDuration(engagementActive) : null}
            emptyDeltaLabel={measurementTag}
            staleDate={staleDate}
          />
          <StatCard
            label="Strony / sesja"
            value={typeof pagesPerSession === 'number' ? fmtNum(pagesPerSession, 1) : null}
            emptyDeltaLabel={measurementTag}
            staleDate={staleDate}
          />
        </div>

        <div class="section-head"><h2>Uwaga i zaangażowanie</h2></div>
        <div class:list={['beh-grid', ghost]}>
          <div class="beh-card">
            <h4>Głębokość scrolla</h4>
            <div class="sub">średnia głębokość dostępna w Data Export API</div>
            <div class="scroll-meter">
              <span class="big">{scrollAvg !== null ? fmtNum(scrollAvg, 0) + '%' : '–'}</span>
              <span class="t"><i style={`width:${Math.min(100, Math.max(0, scrollAvg ?? 0))}%`} /></span>
            </div>
          </div>
          <div class="beh-card">
            <h4>Zaangażowanie</h4>
            <div class="sub">czas i aktywność w sesji</div>
            <div class="eng-stats">
              <div class="s"><div class="l">Aktywny czas / sesja</div><div class="v">{fmtDuration(engagementActive)}</div></div>
              <div class="s"><div class="l">Całkowity czas / sesja</div><div class="v">{fmtDuration(engagementTotal)}</div></div>
              <div class="s"><div class="l">Strony / sesja</div><div class="v">{typeof pagesPerSession === 'number' ? fmtNum(pagesPerSession, 1) : '–'}</div></div>
              <div class="s"><div class="l">Czas aktywny</div><div class="v">{activeShare !== null ? activeShare : '–'}<small>%</small></div></div>
            </div>
          </div>
        </div>

        {frustration.length > 0 && (
          <>
            <div class="section-head">
              <h2>Sygnały frustracji</h2>
              {typeof scriptErrors === 'number' && (
                <span class={`chip ${scriptErrors > 0 ? 'bad' : 'good'}`}>
                  Błędy JS <strong>{fmtInt(scriptErrors)}</strong>
                </span>
              )}
              <span class="section-meta">gdzie użytkownicy się gubią</span>
            </div>
            <div class:list={['frust-grid', ghost]}>
              {frustration.map((f) => (
                <div class={`fcard ${f.key}`}>
                  <div class="h">
                    <span class="ic">
                      {f.icon ? (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path d={f.icon} stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      ) : (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <circle cx="12" cy="12" r="9" />
                          <path d="M8 12h8" stroke-linecap="round" />
                        </svg>
                      )}
                    </span>
                    <span class="t">{f.label}</span>
                  </div>
                  <div class="big">{fmtInt(f.value as number)}</div>
                  <div class="rate">
                    {rateOf(f.value as number) ? (
                      <>
                        <b>{rateOf(f.value as number)}</b> sesji · {f.desc}
                      </>
                    ) : (
                      f.desc
                    )}
                  </div>
                </div>
              ))}
            </div>
          </>
        )}

        <div class:list={['two-col', ghost]}>
          <TableCard title="Najczęściej oglądane strony" meta={staleDate ? `dane z ${staleDate}` : undefined} count={urlRows.length} filter={urlRows.length > 10} empty={urlLabelsMissing ? 'Poprzedni odczyt nie zawierał etykiet URL. Poprawiony collector uzupełni je przy następnym pomiarze.' : 'Brak danych w tym oknie.'}>
            <table class="data-table">
              <thead>
                <tr>
                  <th>Strona</th>
                  <th class="num">Sesje</th>
                  <th class="num">Użytkownicy</th>
                </tr>
              </thead>
              <tbody>
                {urlRows.map((row) => (
                  <tr>
                    <td class="grow">
                      <span class="cell-url" title={row.name}>{row.name}</span>
                    </td>
                    <td class="num">
                      <span class="cell-bar rbar">
                        {fmtInt(row.sessions)}
                        <span class="bar">
                          <i style={`width:${barWidth(row.sessions, maxUrl)}%`} />
                        </span>
                      </span>
                    </td>
                    <td class="num">{fmtInt(row.users)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </TableCard>
          <TableCard title="Źródła ruchu" meta="wymiar Source" count={refRows.length} filter={refRows.length > 10} empty={refLabelsMissing ? 'Poprzednio użyto nieobsługiwanego wymiaru Referrer. Przy następnym pomiarze pojawią się wartości Source.' : 'Brak danych w tym oknie.'}>
            <table class="data-table">
              <thead>
                <tr>
                  <th>Źródło</th>
                  <th class="num">Sesje</th>
                </tr>
              </thead>
              <tbody>
                {refRows.map((row) => (
                  <tr>
                    <td class="grow">
                      <span class="cell-url" title={row.name}>{row.name}</span>
                    </td>
                    <td class="num">
                      <span class="cell-bar rbar">
                        {fmtInt(row.sessions)}
                        <span class="bar">
                          <i style={`width:${barWidth(row.sessions, maxRef)}%`} />
                        </span>
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </TableCard>
        </div>

        {devices.length > 0 && (
          <>
            <div class="section-head">
              <h2>Urządzenia</h2>
              {staleDate && <span class="section-meta">dane z {staleDate}</span>}
            </div>
            <div class:list={['beh-card', ghost]} style="margin-bottom:18px">
              <div class="devgrid">
                <div class="donut" style={`background: conic-gradient(${donutStops});`}>
                  <div class="c"><b>{devices[0].pct}%</b><span>{devices[0].name}</span></div>
                </div>
                <div class="devleg">
                  {devices.map((d) => (
                    <div class="r">
                      <span class="dot" style={`background:${d.color}`} />
                      <span class="n">{d.name}</span>
                      <span class="v">{d.pct}%</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </>
        )}
      </>
    )
  }
</Layout>

<style>
  .clarity-note {
    margin: 16px 0 4px;
    padding: 10px 14px;
    border-left: 2px solid var(--accent-blue);
    border-radius: 0 10px 10px 0;
    background: color-mix(in srgb, var(--accent-blue) 6%, transparent);
    color: var(--ink-muted);
    font-size: 0.84rem;
    line-height: 1.5;
  }
  .clarity-down {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 18px;
    padding: 13px 16px;
    border: 1px solid color-mix(in srgb, var(--status-warn-fg) 30%, transparent);
    border-radius: 12px;
    background: var(--status-warn-bg);
    color: var(--status-warn-fg);
    font-size: 0.88rem;
  }
  .clarity-down svg {
    width: 18px;
    height: 18px;
    flex: none;
  }
  .clarity-down strong {
    color: var(--ink);
  }
  .clarity-down .when {
    margin-left: auto;
    color: var(--ink-faint);
    font-size: 0.8rem;
    white-space: nowrap;
  }
  .stat-grid.clarity-kpis {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }
  @media (max-width: 1080px) {
    .stat-grid.clarity-kpis {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 620px) {
    .clarity-down {
      align-items: flex-start;
      flex-wrap: wrap;
    }
    .clarity-down .when {
      width: 100%;
      margin-left: 30px;
    }
    .stat-grid.clarity-kpis {
      grid-template-columns: 1fr;
    }
  }
</style>
