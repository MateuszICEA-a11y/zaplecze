---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TimeSeriesChart from '../../components/TimeSeriesChart.astro';
import {
  loadConfig,
  loadSnapshots,
  loadDetails,
  latestSnapshot,
  latestWithDelta,
  latestWithDeltaFrom,
  metricSeries,
  metricSeriesFrom,
} from '../../lib/data';

export function getStaticPaths() {
  return loadConfig().domains.map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);

const top3 = metricSeries(snapshots, 'senuto', 'top3');
const top10 = metricSeries(snapshots, 'senuto', 'top10');
const top50 = metricSeries(snapshots, 'senuto', 'top50');
const linkSpec = (field: string): [string, string][] => [
  ['ahrefs', field],
  ['backlinks', field],
];
const backlinks = metricSeriesFrom(snapshots, linkSpec('backlinks'));
const refDomains = metricSeriesFrom(snapshots, linkSpec('referring_domains'));
const gscClicks = metricSeries(snapshots, 'gsc', 'clicks');
const gscImpressions = metricSeries(snapshots, 'gsc', 'impressions');

const statTop10 = latestWithDelta(snapshots, 'senuto', 'top10');
const statClicks = latestWithDelta(snapshots, 'gsc', 'clicks');
const statImpressions = latestWithDelta(snapshots, 'gsc', 'impressions');
const statDR = latestWithDelta(snapshots, 'ahrefs', 'domain_rating', 30);
const statRefDomains = latestWithDeltaFrom(snapshots, linkSpec('referring_domains'));
const statSessions = latestWithDelta(snapshots, 'clarity', 'sessions');

const leads = details.sources.leads?.leads ?? [];
const weekAgo = Date.now() - 7 * 86400_000;
const leadsRecent = leads.filter((l) => new Date(l.ts).getTime() >= weekAgo).length;
const leadsConfigured = latest?.sources.leads != null && latest.sources.leads.status !== 'not_configured';
const clarityConfigured = latest?.sources.clarity != null && latest.sources.clarity.status !== 'not_configured';

// Bannery problemów: token_expired/error z ostatniego snapshotu.
const problems = Object.entries(latest?.sources ?? {}).filter(([, r]) =>
  ['token_expired', 'error'].includes(r.status),
);
---

<Layout title={`${name} – dashboard`}>
  <DomainHeader domain={domain!} name={name} active="" latest={latest} />

  {
    problems.map(([source, result]) => (
      <div class={`banner ${result.status === 'token_expired' ? 'warn' : 'err'}`}>
        <strong>{source}</strong>: {(result.error ?? '').replace(new RegExp(`^${source}:\\s*`), '')}
      </div>
    ))
  }

  <div class="section-head"><h2>Najważniejsze wskaźniki</h2></div>
  <div class="stat-grid">
    <StatCard label="Frazy w TOP 10" value={statTop10.value} delta={statTop10.delta} trend={top10.values} />
    <StatCard label="Kliknięcia / dzień" value={statClicks.value} delta={statClicks.delta} trend={gscClicks.values} />
    <StatCard
      label="Wyświetlenia / dzień"
      value={statImpressions.value}
      delta={statImpressions.delta}
      trend={gscImpressions.values}
    />
    <StatCard label="Domain Rating" value={statDR.value} delta={statDR.delta} deltaLabel="30 dni" precision={1} />
    <StatCard label="Domeny linkujące" value={statRefDomains.value} delta={statRefDomains.delta} trend={refDomains.values} />
    {clarityConfigured && <StatCard label="Sesje (3 dni)" value={statSessions.value} delta={statSessions.delta} />}
    {leadsConfigured && <StatCard label="Leady · 7 dni" value={leadsRecent} />}
  </div>

  <div class="section-head">
    <h2>Trendy</h2>
    <span class="section-meta">szczegóły i pełne listy w zakładkach sekcji</span>
  </div>
  <div class="chart-grid">
    <TimeSeriesChart
      title="Frazy w TOP 3 / 10 / 50 (Senuto)"
      timestamps={top10.timestamps}
      series={[
        { label: 'TOP 3', values: top3.values },
        { label: 'TOP 10', values: top10.values },
        { label: 'TOP 50', values: top50.values, fill: true },
      ]}
    />
    <TimeSeriesChart
      title="Kliknięcia i wyświetlenia (GSC)"
      timestamps={gscClicks.timestamps}
      series={[
        { label: 'Kliknięcia', values: gscClicks.values },
        { label: 'Wyświetlenia', values: gscImpressions.values, fill: true },
      ]}
    />
    <TimeSeriesChart
      title="Backlinki i domeny linkujące (Ahrefs)"
      timestamps={backlinks.timestamps}
      series={[
        { label: 'Backlinki', values: backlinks.values, fill: true },
        { label: 'Domeny', values: refDomains.values },
      ]}
    />
  </div>
</Layout>
