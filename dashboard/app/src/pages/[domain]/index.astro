---
import Layout from '../../layouts/Layout.astro';
import StatCard from '../../components/StatCard.astro';
import TimeSeriesChart from '../../components/TimeSeriesChart.astro';
import SourceStatus from '../../components/SourceStatus.astro';
import { loadConfig, loadSnapshots, latestSnapshot, latestWithDelta, metricSeries } from '../../lib/data';

export function getStaticPaths() {
  return loadConfig().domains.map((d) => ({
    params: { domain: d.id },
    props: { name: d.name },
  }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);

const top3 = metricSeries(snapshots, 'senuto', 'top3');
const top10 = metricSeries(snapshots, 'senuto', 'top10');
const top50 = metricSeries(snapshots, 'senuto', 'top50');
const visibility = metricSeries(snapshots, 'senuto', 'visibility');
const backlinks = metricSeries(snapshots, 'backlinks', 'backlinks');
const refDomains = metricSeries(snapshots, 'backlinks', 'referring_domains');

const statTop10 = latestWithDelta(snapshots, 'senuto', 'top10');
const statTop3 = latestWithDelta(snapshots, 'senuto', 'top3');
const statVisibility = latestWithDelta(snapshots, 'senuto', 'visibility');
const statBacklinks = latestWithDelta(snapshots, 'backlinks', 'backlinks');
const statRefDomains = latestWithDelta(snapshots, 'backlinks', 'referring_domains');

// Bannery problemów: token_expired/error z ostatniego snapshotu.
const problems = Object.entries(latest?.sources ?? {}).filter(([, r]) =>
  ['token_expired', 'error'].includes(r.status),
);
---

<Layout title={`${name} – dashboard`}>
  <nav class="crumbs"><a href="/">← wszystkie domeny</a></nav>
  <div class="page-head">
    <h1>{name}</h1>
    <div class="badges">
      {
        Object.entries(latest?.sources ?? {}).map(([source, result]) => (
          <SourceStatus name={source} result={result} />
        ))
      }
    </div>
  </div>
  <p class="meta">Ostatni pomiar: {latest?.date ?? 'brak'}</p>

  {
    problems.map(([source, result]) => (
      <div class={`banner ${result.status === 'token_expired' ? 'warn' : 'err'}`}>
        <strong>{source}</strong>: {(result.error ?? '').replace(new RegExp(`^${source}:\\s*`), '')}
      </div>
    ))
  }

  <section>
    <h2>SEO – widoczność (Senuto)</h2>
    <div class="stat-grid">
      <StatCard label="Frazy w TOP 3" value={statTop3.value} delta={statTop3.delta} />
      <StatCard label="Frazy w TOP 10" value={statTop10.value} delta={statTop10.delta} />
      <StatCard
        label="Indeks widoczności"
        value={statVisibility.value}
        delta={statVisibility.delta}
        precision={2}
      />
    </div>
    <div class="chart-grid">
      <TimeSeriesChart
        title="Frazy w TOP 3 / 10 / 50"
        timestamps={top10.timestamps}
        series={[
          { label: 'TOP 3', values: top3.values },
          { label: 'TOP 10', values: top10.values },
          { label: 'TOP 50', values: top50.values },
        ]}
      />
      <TimeSeriesChart
        title="Indeks widoczności"
        timestamps={visibility.timestamps}
        series={[{ label: 'Widoczność', values: visibility.values }]}
        precision={2}
      />
    </div>
  </section>

  <section>
    <h2>Linki (DataForSEO)</h2>
    <div class="stat-grid">
      <StatCard label="Backlinki" value={statBacklinks.value} delta={statBacklinks.delta} />
      <StatCard
        label="Domeny linkujące"
        value={statRefDomains.value}
        delta={statRefDomains.delta}
      />
    </div>
    <div class="chart-grid">
      <TimeSeriesChart
        title="Backlinki"
        timestamps={backlinks.timestamps}
        series={[{ label: 'Backlinki', values: backlinks.values }]}
      />
      <TimeSeriesChart
        title="Domeny linkujące"
        timestamps={refDomains.timestamps}
        series={[{ label: 'Domeny', values: refDomains.values }]}
      />
    </div>
  </section>

  <section>
    <h2>Microsoft Clarity</h2>
    <div class="placeholder">
      Integracja z Clarity Data Export API czeka na token (<code>CLARITY_API_TOKEN</code>). Po
      podpięciu pojawią się tu sesje, scroll depth i AI-boty.
    </div>
  </section>
</Layout>

<style>
  .crumbs {
    margin-bottom: 8px;
    font-size: 0.88rem;
  }
  .page-head {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  h1 {
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    margin: 0;
  }
  h2 {
    font-size: 1.15rem;
    margin: 34px 0 14px;
  }
  .meta {
    color: var(--ink-faint);
    font-size: 0.85rem;
    margin: 6px 0 0;
  }
  .badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .banner {
    margin-top: 16px;
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 0.9rem;
  }
  .banner.warn {
    background: var(--status-warn-bg);
    color: var(--status-warn-fg);
  }
  .banner.err {
    background: var(--status-err-bg);
    color: var(--status-err-fg);
  }
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
    margin-bottom: 18px;
  }
  .chart-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 16px;
  }
  .placeholder {
    background: var(--bg-surface-1);
    border: 1px dashed var(--hairline);
    border-radius: 12px;
    color: var(--ink-muted);
    padding: 24px;
    font-size: 0.92rem;
  }
</style>
