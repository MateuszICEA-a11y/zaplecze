---
import Layout from '../../layouts/Layout.astro';
import DomainHeader from '../../components/DomainHeader.astro';
import StatCard from '../../components/StatCard.astro';
import TimeSeriesChart from '../../components/TimeSeriesChart.astro';
import {
  loadConfig,
  loadSnapshots,
  loadDetails,
  latestSnapshot,
  latestWithDelta,
  latestWithDeltaFrom,
  metricSeries,
  metricSeriesFrom,
} from '../../lib/data';
import { fmtInt } from '../../lib/format';

export function getStaticPaths() {
  return loadConfig().domains.map((d) => ({ params: { domain: d.id }, props: { name: d.name } }));
}

const { domain } = Astro.params;
const { name } = Astro.props;

const snapshots = loadSnapshots(domain!);
const latest = latestSnapshot(domain!);
const details = loadDetails(domain!);

const top3 = metricSeries(snapshots, 'senuto', 'top3');
const top10 = metricSeries(snapshots, 'senuto', 'top10');
const top50 = metricSeries(snapshots, 'senuto', 'top50');
const linkSpec = (field: string): [string, string][] => [
  ['ahrefs', field],
  ['backlinks', field],
];
const backlinks = metricSeriesFrom(snapshots, linkSpec('backlinks'));
const refDomains = metricSeriesFrom(snapshots, linkSpec('referring_domains'));
const gscClicks = metricSeries(snapshots, 'gsc', 'clicks');
const gscImpressions = metricSeries(snapshots, 'gsc', 'impressions');

const statTop10 = latestWithDelta(snapshots, 'senuto', 'top10');
const statClicks = latestWithDelta(snapshots, 'gsc', 'clicks');
const statImpressions = latestWithDelta(snapshots, 'gsc', 'impressions');
const statDR = latestWithDelta(snapshots, 'ahrefs', 'domain_rating', 30);
const statRefDomains = latestWithDeltaFrom(snapshots, linkSpec('referring_domains'));
const statSessions = latestWithDelta(snapshots, 'clarity', 'sessions');
const impressionsPrevious =
  statImpressions.value !== null && statImpressions.delta !== null
    ? statImpressions.value - statImpressions.delta
    : null;
const impressionsDeltaPct =
  impressionsPrevious && statImpressions.delta !== null
    ? (statImpressions.delta / impressionsPrevious) * 100
    : null;
const drHistory = metricSeries(snapshots, 'ahrefs', 'domain_rating').values.filter(
  (value): value is number => typeof value === 'number',
);
const drDeltaAvailable =
  statDR.delta ?? (drHistory.length >= 2 ? drHistory.at(-1)! - drHistory[0]! : null);
const firstRefDomainsTimestamp = refDomains.timestamps.find(
  (_, index) => typeof refDomains.values[index] === 'number',
);
const firstRefDomainsDate = firstRefDomainsTimestamp
  ? new Date(firstRefDomainsTimestamp * 1000).toLocaleDateString('pl-PL', {
      timeZone: 'UTC', day: '2-digit', month: '2-digit',
    })
  : null;

/* Trendy na Przeglądzie pokazują dokładnie ostatnie 3 miesiące z realnych
   serii, zamiast całego dostępnego backfillu. */
const lastTimestamp = Math.max(
  0,
  ...top10.timestamps,
  ...gscClicks.timestamps,
  ...backlinks.timestamps,
);
const trendCutoff = lastTimestamp - 91 * 86400;
const trimTrend = (series: { timestamps: number[]; values: (number | null)[] }) => {
  const start = Math.max(0, series.timestamps.findIndex((timestamp) => timestamp >= trendCutoff));
  return { timestamps: series.timestamps.slice(start), values: series.values.slice(start) };
};
const top3Trend = trimTrend(top3);
const top10Trend = trimTrend(top10);
const top50Trend = trimTrend(top50);
const clicksTrend = trimTrend(gscClicks);
const impressionsTrend = trimTrend(gscImpressions);
const backlinksTrend = trimTrend(backlinks);
const refDomainsTrend = trimTrend(refDomains);

const leads = details.sources.leads?.leads ?? [];
const weekAgo = Date.now() - 7 * 86400_000;
const leadsRecent = leads.filter((l) => new Date(l.ts).getTime() >= weekAgo).length;
const leadsConfigured = latest?.sources.leads != null && latest.sources.leads.status !== 'not_configured';
const clarityConfigured = latest?.sources.clarity != null && latest.sources.clarity.status !== 'not_configured';

/* '2026-07-22' → '22.07' (pasek zdrowia, pigułki stale). */
const fmtShort = (date: string | null | undefined): string =>
  date ? `${date.slice(8, 10)}.${date.slice(5, 7)}` : '–';

/* Ostatni snapshot, w którym źródło miało status ok (data + dane). */
const lastOk = (source: string): { date: string; data: Record<string, unknown> } | null => {
  for (let i = snapshots.length - 1; i >= 0; i--) {
    const src = snapshots[i].sources[source];
    if (src?.status === 'ok') return { date: snapshots[i].date, data: src.data ?? {} };
  }
  return null;
};

/* Pasek zdrowia źródeł (handoff „Przegląd": hchip z kropką + datą pomiaru). */
const HEALTH_LABELS: [string, string][] = [
  ['senuto', 'Senuto'],
  ['gsc', 'GSC'],
  ['ahrefs', 'Ahrefs'],
  ['ga4', 'GA4'],
  ['clarity', 'Clarity'],
  ['bing', 'Bing'],
];
const health = HEALTH_LABELS.flatMap(([key, label]) => {
  const src = latest?.sources[key];
  if (!src || src.status === 'not_configured') return [];
  const cls = src.status === 'ok' ? 'ok' : src.status === 'token_expired' ? 'warn' : 'err';
  const when = src.status === 'ok'
    ? fmtShort(latest!.date)
    : src.status === 'token_expired'
      ? `token wygasł · ${fmtShort(lastOk(key)?.date)}`
      : src.error?.includes('429')
        ? `limit API · ${fmtShort(lastOk(key)?.date)}`
        : `błąd · ${fmtShort(lastOk(key)?.date)}`;
  return [{ label, cls, when }];
});

/* Clarity: gdy źródło leży, karta pokazuje ostatni udany pomiar zamiast „–". */
const clarityDown = clarityConfigured && latest?.sources.clarity?.status !== 'ok';
const clarityLast = clarityDown ? lastOk('clarity') : null;
const claritySessions = clarityDown
  ? typeof clarityLast?.data.sessions === 'number'
    ? (clarityLast.data.sessions as number)
    : null
  : statSessions.value;

/* ── „Co wymaga uwagi" – automatyczne sygnały z danych szczegółowych ── */
const compare = details.sources.gsc?.compare;
const cmpPeriod = compare?.qoq ?? compare?.yoy ?? null;
const cmpKind = compare?.qoq ? 'kw/kw' : 'r/r';
const pageDrops = (cmpPeriod?.pages ?? [])
  .map((r) => ({ key: r.key, dClicks: r.clicks - r.prev_clicks }))
  .filter((r) => r.dClicks < 0)
  .sort((a, b) => a.dClicks - b.dClicks);
const dropsTotal = pageDrops.reduce((s, r) => s + r.dClicks, 0);
const topDrop = pageDrops[0] ?? null;
const asPath = (url: string): string => url.replace(/^https?:\/\/[^/]+/, '') || '/';

/* Polska liczba mnoga: 1 fraza / 2 frazy / 5 fraz (z wyjątkiem nastek). */
const plural = (n: number, one: string, few: string, many: string): string => {
  if (n === 1) return one;
  const d = n % 10;
  const dd = n % 100;
  return d >= 2 && d <= 4 && !(dd >= 12 && dd <= 14) ? few : many;
};

const gscQueries =
  details.sources.gsc?.windows?.['30d']?.queries ?? details.sources.gsc?.queries ?? [];
const nearTop = gscQueries.filter(
  (q) => typeof q.position === 'number' && q.position > 10 && q.position <= 20 && q.impressions > 0,
);

const idxRows = details.sources.indexing?.rows ?? [];
const idxDone = idxRows.filter((r) => r.indexed).length;
const idxPct = idxRows.length > 0 ? Math.round((idxDone / idxRows.length) * 100) : null;
const notIndexed = idxRows.filter((r) => !r.indexed);
const segOf = (url: string): string => {
  const path = url.replace(/^https?:\/\/[^/]+/, '');
  const seg = path.split('/').filter(Boolean)[0];
  return seg ? `/${seg}/` : 'strona główna';
};
const topMissSeg = [...notIndexed.reduce((m, r) => m.set(segOf(r.url), (m.get(segOf(r.url)) ?? 0) + 1), new Map<string, number>()).entries()].sort((a, b) => b[1] - a[1])[0] ?? null;

const hasAttention = pageDrops.length > 0 || nearTop.length > 0 || idxRows.length > 0;
---

<Layout title={`${name} – dashboard`}>
  <DomainHeader domain={domain!} name={name} active="" latest={latest} themeToggle />

  <div class="overview-note">
    Przegląd jest hubem wielu źródeł: pasek zdrowia integracji, KPI oznaczone kolorem źródła
    (<b class="sen">Senuto</b>/<b class="gsc">GSC</b>/<b class="ahrefs">Ahrefs</b>/<b class="ga4">GA4</b>),
    porównania z historią i ostatni udany pomiar, gdy źródło jest chwilowo niedostępne. Na dole znajdują się automatyczne sygnały wymagające uwagi.
  </div>

  {
    health.length > 0 && (
      <div class="health">
        {health.map((h) => (
          <span class="hchip">
            <span class={`d ${h.cls}`} />
            <b>{h.label}</b>
            <span class="when">{h.when}</span>
          </span>
        ))}
      </div>
    )
  }

  <div class="section-head">
    <h2>Najważniejsze wskaźniki</h2>
    <span class="section-meta">porównanie 7-dniowe</span>
  </div>
  <div class="kwrap">
    <StatCard
      label="Wyświetlenia / dzień · GSC"
      value={statImpressions.value}
      delta={impressionsDeltaPct}
      precision={1}
      deltaUnit="%"
      trend={gscImpressions.values}
      src="gsc"
      hero
      href={`/${domain}/gsc/`}
    />
    <StatCard label="Kliknięcia / dzień · GSC" value={statClicks.value} delta={statClicks.delta} src="gsc" href={`/${domain}/gsc/`} />
    <StatCard label="Frazy w TOP 10 · Senuto" value={statTop10.value} delta={statTop10.delta} src="sen" href={`/${domain}/senuto/`} />
    <StatCard label="Domain Rating · Ahrefs" value={statDR.value} delta={drDeltaAvailable} deltaLabel="" precision={1} src="ahrefs" href={`/${domain}/ahrefs/`} />
    <StatCard
      label="Domeny linkujące · Ahrefs"
      value={statRefDomains.value}
      delta={statRefDomains.delta}
      emptyDeltaLabel={firstRefDomainsDate ? `zbieramy od ${firstRefDomainsDate}` : 'zbieramy dane'}
      src="ahrefs"
      href={`/${domain}/ahrefs/`}
    />
    {clarityConfigured && (
      <StatCard
        label="Sesje · Clarity (3 dni)"
        value={claritySessions}
        delta={clarityDown ? null : statSessions.delta}
        staleDate={clarityDown ? fmtShort(clarityLast?.date) : null}
        staleReason={clarityDown && latest?.sources.clarity?.error?.includes('429') ? 'limit API' : undefined}
        dot="var(--ga4)"
        href={`/${domain}/clarity/`}
      />
    )}
    {leadsConfigured && <StatCard label="Leady · 7 dni" value={leadsRecent} href={`/${domain}/leady/`} />}
  </div>

  <div class="section-head"><h2>Trendy</h2><span class="section-meta">3 miesiące</span></div>
  <div class="overview-charts">
    <TimeSeriesChart
      title="Frazy w TOP 3 / 10 / 50"
      timestamps={top10Trend.timestamps}
      series={[
        { label: 'TOP 3', values: top3Trend.values, color: '--status-ok', dash: [] },
        { label: 'TOP 10', values: top10Trend.values, color: '--gsc', dash: [] },
        { label: 'TOP 50', values: top50Trend.values, color: '--ink-faint', dash: [] },
      ]}
      sourceColor="--sen"
      overview
    />
    <TimeSeriesChart
      title="Kliknięcia i wyświetlenia"
      timestamps={clicksTrend.timestamps}
      series={[
        { label: 'Kliknięcia', values: clicksTrend.values, color: '--gsc', dash: [] },
        { label: 'Wyświetlenia', values: impressionsTrend.values, fill: true, color: '--series-2', dash: [6, 4] },
      ]}
      sourceColor="--gsc"
      overview
    />
    <TimeSeriesChart
      title="Backlinki i domeny linkujące"
      timestamps={backlinksTrend.timestamps}
      series={[
        { label: 'Backlinki', values: backlinksTrend.values, fill: true, color: '--gsc', dash: [] },
        { label: 'Domeny', values: refDomainsTrend.values, color: '--series-2', dash: [6, 4] },
      ]}
      sourceColor="--ahrefs"
      overview
      emptyTitle="Backlinki — zbieramy historię"
      emptyDescription={`Ahrefs zwraca stan bieżący (DR ${fmtInt(statDR.value)} · ${fmtInt(statRefDomains.value)} domen). Wykres pojawi się po drugim pomiarze.`}
    />
  </div>

  {
    hasAttention && (
      <>
        <div class="section-head">
          <h2>Co wymaga uwagi</h2>
          <span class="section-meta">automatyczne sygnały z ostatniego okna</span>
        </div>
        <div class="attn">
          {pageDrops.length > 0 && (
            <div class="acard err">
              <div class="top">
                <span class="ic">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z" />
                  </svg>
                </span>
                <span class="t">Spadki ruchu</span>
              </div>
              <div class="big">{fmtInt(pageDrops.length)} {plural(pageDrops.length, 'strona', 'strony', 'stron')}</div>
              <p>
                Straciły łącznie <b>{fmtInt(dropsTotal)} kliknięć</b> {cmpKind}.
                {topDrop && (
                  <>
                    {' '}Najwięcej: <b>{asPath(topDrop.key)}</b> ({fmtInt(topDrop.dClicks)}).
                  </>
                )}
              </p>
              <a href={`/${domain}/matrix/`}>Otwórz dekodowanie spadków →</a>
            </div>
          )}
          {nearTop.length > 0 && (
            <div class="acard warn">
              <div class="top">
                <span class="ic">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="7" />
                    <path d="M21 21l-4-4" stroke-linecap="round" />
                  </svg>
                </span>
                <span class="t">Blisko TOP</span>
              </div>
              <div class="big">{fmtInt(nearTop.length)} {plural(nearTop.length, 'fraza', 'frazy', 'fraz')}</div>
              <p>Na pozycjach 11–20 z realnym popytem – najbliżej awansu do TOP 10. Priorytet contentowy.</p>
              <a href={`/${domain}/gsc/`}>Zobacz frazy z potencjałem →</a>
            </div>
          )}
          {idxRows.length > 0 && idxPct !== null && (
            <div class={`acard ${idxPct >= 90 ? 'ok' : 'warn'}`}>
              <div class="top">
                <span class="ic">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="t">Indeksacja</span>
              </div>
              <div class="big">{idxPct}%</div>
              <p>
                {fmtInt(idxDone)} z {fmtInt(idxRows.length)} adresów w indeksie Google.
                {notIndexed.length > 0 && topMissSeg && (
                  <>
                    {' '}{fmtInt(notIndexed.length)} poza – głównie <b>{topMissSeg[0]}</b>.
                  </>
                )}
              </p>
              <a href={`/${domain}/matrix/`}>Otwórz Matrix →</a>
            </div>
          )}
        </div>
      </>
    )
  }
</Layout>

<style>
  .overview-note {
    border-left: 2px solid var(--accent-blue);
    background: color-mix(in srgb, var(--accent-blue) 6%, transparent);
    color: var(--ink-muted);
    font-size: 0.84rem;
    line-height: 1.5;
    padding: 10px 14px;
    border-radius: 0 10px 10px 0;
    margin: 16px 0 4px;
  }
  .overview-note b { font-weight: 700; }
  .overview-note .sen { color: var(--sen); }
  .overview-note .gsc { color: var(--gsc); }
  .overview-note .ahrefs { color: var(--ahrefs); }
  .overview-note .ga4 { color: var(--ga4); }
  .overview-charts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 18px;
  }
  @media (max-width: 1080px) {
    .overview-charts { grid-template-columns: 1fr; }
  }
</style>
