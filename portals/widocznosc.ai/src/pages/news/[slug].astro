---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Article from '../../components/Article.astro';
import NewsCTA from '../../components/NewsCTA.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import { getImage } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { buildGraph, newsArticleNode, breadcrumbNode } from '../../lib/schema';

export const getStaticPaths = async () => {
  const items = await getCollection('news');
  const blog = await getCollection('blog');

  return items.map((item) => {
    // Powiązany artykuł bazy wiedzy – dobór po liczbie wspólnych tagów.
    const related = blog
      .map((post) => ({
        post,
        score: post.data.tags.filter((t) => item.data.tags.includes(t)).length,
      }))
      .filter((x) => x.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 2)
      .map((x) => x.post);

    return { params: { slug: item.id }, props: { item, related } };
  });
};

const { item, related } = Astro.props;
const { Content } = await render(item);

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });

const optimizedOg = await getImage({ src: item.data.image, format: 'webp', width: 1200 });
const ogImageUrl = `https://widocznosc.ai${optimizedOg.src}`;

const articleData = {
  title: item.data.title,
  subtitle: item.data.lead,
  date: formatDate(item.data.date),
  image: item.data.image.src,
  author: {
    name: 'Redakcja widocznosc.ai',
    role: `Opracowanie na podstawie: ${item.data.sourceName}`,
    avatar: '/favicon.svg',
  },
  tags: item.data.tags,
};

const schema = buildGraph(
  newsArticleNode({
    slug: item.id,
    title: item.data.title,
    lead: item.data.lead,
    imageUrl: ogImageUrl,
    datePublished: item.data.date.toISOString(),
    sourceName: item.data.sourceName,
    sourceUrl: item.data.sourceUrl,
    tags: item.data.tags,
    author: item.data.author,
  }),
  breadcrumbNode([
    { name: 'Strona główna', path: '/' },
    { name: 'News', path: '/news/' },
    { name: item.data.title, path: `/news/${item.id}/` },
  ]),
);
---

<Layout
  title={`${item.data.title} – News – widocznosc.ai`}
  description={item.data.lead}
  ogType="article"
  articleMeta={{ publishedTime: item.data.date.toISOString(), author: item.data.author, tags: item.data.tags }}
>
  <script type="application/ld+json" is:inline set:html={schema} />

  <Navbar />
  <Article articleData={articleData}>
    <nav slot="breadcrumb" class="news-breadcrumb" aria-label="Ścieżka nawigacji">
      <a href="/news/" class="news-breadcrumb-link">News</a>
      <span class="news-breadcrumb-sep" aria-hidden="true">›</span>
      <span class="news-breadcrumb-current">{item.data.title}</span>
    </nav>

    <div class="news-content">
      <Content />
    </div>

    <p class="news-source">
      Opracowanie redakcyjne na podstawie:{' '}
      <a href={item.data.sourceUrl} rel="nofollow noopener noreferrer" target="_blank">
        {item.data.sourceName}
      </a>
    </p>

    {
      related.length > 0 && (
        <aside class="news-related" aria-label="Powiązane w bazie wiedzy">
          <div class="news-related-label">Pogłębione w bazie wiedzy</div>
          <ul class="news-related-list">
            {related.map((r) => (
              <li>
                <a href={`/${r.id}/`} class="news-related-link">
                  <span class="news-related-arrow" aria-hidden="true">
                    →
                  </span>
                  {r.data.title}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }

    <NewsCTA />
  </Article>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .news-breadcrumb {
    display: flex;
    gap: 8px;
    align-items: center;
    font-size: var(--fs-caption);
    color: var(--ink-muted);
  }
  .news-breadcrumb-link {
    color: var(--ink-muted);
    text-decoration: none;
  }
  .news-breadcrumb-link:hover {
    color: var(--ink);
  }
  .news-breadcrumb-current {
    color: var(--ink);
  }

  /* Atrybucja źródła – wyróżniona nota pod treścią */
  .news-source {
    margin: 36px 0 0;
    padding: 14px 18px;
    border-left: 2px solid var(--accent-blue);
    background: var(--bg-surface-1);
    border-radius: 0 var(--r-md) var(--r-md) 0;
    font-size: var(--fs-body-sm);
    color: var(--ink-muted);
  }
  .news-source a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Box „pogłębione w bazie wiedzy" – wewnętrzny anchor newsowy */
  .news-related {
    margin: 28px 0 0;
    padding: 22px;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background: var(--bg-surface-1);
  }
  .news-related-label {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 12px;
  }
  .news-related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .news-related-link {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.3;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .news-related-link:hover {
    color: var(--accent-blue);
  }
  .news-related-arrow {
    color: var(--accent-blue);
    flex-shrink: 0;
  }

  /* Wyróżnik nagłówków sekcji w treści newsa – lewy niebieski akcent
     + wyraźniejszy odstęp pod nagłówkiem (treść nie zlewa się z h2).
     Selektor z .news-content pobija specyficzność Article (0,5,1 > 0,4,1). */
  :global(.article-page .article-body-grid .article-content .news-content h2) {
    padding-left: 18px;
    border-left: 3px solid var(--accent-blue);
    margin-top: 3.25rem;
    margin-bottom: 1.25rem;
  }
  :global(.article-page .article-body-grid .article-content .news-content h2:first-child) {
    margin-top: 0;
  }
  :global(.article-page .article-body-grid .article-content .news-content h3) {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }
</style>
