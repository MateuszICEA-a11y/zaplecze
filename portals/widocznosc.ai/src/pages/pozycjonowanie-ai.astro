---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollUpButton from '../components/ScrollUpButton.astro';
import CTABand from '../components/CTABand.astro';
import { AI_MODELS } from '../data/aiModels';

const services = [
  {
    id: 'audyt',
    title: 'Audyt widoczności w AI',
    desc: 'Sprawdzamy, jak Twoja marka jest obecnie cytowana w 5 głównych modelach AI. Budujemy mapę cytowań oraz przeprowadzamy analizę luk (gap analysis) i porównanie z działaniami Twojej konkurencji.',
    variant: 'violet',
  },
  {
    id: 'content',
    title: 'Optymalizacja treści pod modele językowe',
    desc: 'Optymalizujemy istniejące teksty pod kątem gęstości faktów i danych strukturalnych (Schema), by stały się idealnym źródłem do cytowania dla sztucznej inteligencji. Tworzymy precyzyjne wytyczne (briefy) dla copywriterów.',
    variant: 'cyan',
  },
  {
    id: 'monitoring',
    title: 'Stały monitoring cytowań',
    desc: 'Regularnie, z tygodnia na tydzień, śledzimy od 50 do 200 najważniejszych zapytań dla Twojej firmy. Otrzymujesz alerty o działaniach konkurencji oraz dostęp do panelu analitycznego (dashboardu) z historią widoczności.',
    variant: 'green',
  },
  {
    id: 'strategia',
    title: 'Strategia GEO na 12 miesięcy',
    desc: 'Tworzymy kompleksowy plan widoczności na cały rok: mapę fraz, kalendarz publikacji treści, plan dystrybucji oraz strategię pozyskiwania wzmianek o Twojej firmie.',
    variant: 'blue',
  },
] as const;

const gradientStyle = (variant: string) => {
  if (variant === 'violet')
    return 'background: var(--grad-violet); background-size: 130% 130%; background-position: 25% 30%;';
  if (variant === 'cyan')
    return 'background: var(--grad-cyan); background-size: 130% 130%; background-position: 30% 30%;';
  if (variant === 'green')
    return 'background: var(--grad-green); background-size: 130% 130%; background-position: 70% 30%;';
  return 'background: var(--grad-blue); background-size: 130% 130%; background-position: 70% 25%;';
};

const heroStats = [
  { value: '5', label: 'modeli AI', detail: 'ChatGPT · Claude · Gemini · Perplexity · Copilot' },
  { value: '500+', label: 'projektów SEO', detail: 'wdrożonych przez zespół' },
  { value: '15+', label: 'lat doświadczenia', detail: 'SEO, content, analityka' },
  { value: '#1', label: 'SEMKRK', detail: 'najwyżej oceniona prezentacja 2024' },
] as const;

const modelHooks: Record<string, { value: string; label: string }> = {
  chatgpt: { value: '140', label: 'wysz./mc' },
  claude: { value: '30', label: 'wysz./mc' },
  gemini: { value: '50', label: 'wysz./mc' },
  perplexity: { value: '40', label: 'wysz./mc' },
  'bing-copilot': { value: '20', label: 'wysz./mc' },
};

const decisionRows = [
  {
    model: 'ChatGPT',
    icp: 'B2C, edukacja, usługi masowe',
    usage: 'Najszerszy punkt wejścia dla zapytań poradnikowych i rekomendacyjnych.',
    roi: 'Pierwszy wybór, gdy liczy się skala zapytań i świadomość marki.',
  },
  {
    model: 'Claude',
    icp: 'technologie B2B, SaaS, doradztwo',
    usage: 'Dłuższe analizy, badania, porównania ofert i dokumentów.',
    roi: 'Najlepszy przy droższych usługach i dłuższym procesie decyzyjnym.',
  },
  {
    model: 'Gemini',
    icp: 'E-commerce, lokalne usługi, marki z SEO',
    usage: 'Odpowiedzi powiązane z indeksem Google i AI Overviews.',
    roi: 'Dobry wybór, gdy masz już mocny content i autorytet w Google.',
  },
  {
    model: 'Perplexity',
    icp: 'Finanse, medycyna, prawo, badania B2B',
    usage: 'Zapytania wymagające jawnych źródeł i szybkiej weryfikacji.',
    roi: 'Wysoki, gdy masz cytowalne raporty, dane i eksperckie strony ofertowe.',
  },
  {
    model: 'Bing Copilot',
    icp: 'Enterprise, Microsoft 365, Windows',
    usage: 'Środowiska firmowe, Edge, Bing i asystenci w pakiecie Microsoft.',
    roi: 'Najlepszy jako kanał wspierający dla segmentu korporacyjnego.',
  },
] as const;

const siteUrl = 'https://widocznosc.ai';
const pageUrl = `${siteUrl}/pozycjonowanie-ai/`;
const pageDescription =
  'Pozycjonowanie marki w wyszukiwarkach AI: ChatGPT, Claude, Gemini, Perplexity, Bing Copilot. Audyt widoczności, optymalizacja treści, monitoring cytowań, strategia GEO.';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${pageUrl}#webpage`,
      url: pageUrl,
      name: 'Pozycjonowanie AI',
      description: pageDescription,
      isPartOf: {
        '@type': 'WebSite',
        name: 'widocznosc.ai',
        url: siteUrl,
      },
      breadcrumb: {
        '@id': `${pageUrl}#breadcrumb`,
      },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Strona główna',
          item: `${siteUrl}/`,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Pozycjonowanie AI',
          item: pageUrl,
        },
      ],
    },
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      serviceType: 'Generative Engine Optimization',
      name: 'Pozycjonowanie w wyszukiwarkach AI',
      description: pageDescription,
      provider: {
        '@type': 'Organization',
        name: 'widocznosc.ai',
        url: siteUrl,
        parentOrganization: {
          '@type': 'Organization',
          name: 'ICEA',
          url: 'https://grupa-icea.pl',
        },
      },
      areaServed: {
        '@type': 'Country',
        name: 'Polska',
      },
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Pozycjonowanie w wyszukiwarkach AI',
        itemListElement: services.map((service, index) => ({
          '@type': 'Offer',
          position: index + 1,
          itemOffered: {
            '@type': 'Service',
            name: service.title,
            description: service.desc,
          },
        })),
      },
    },
  ],
};
---

<Layout
  title="Pozycjonowanie AI – widoczność marki w ChatGPT, Gemini, Perplexity"
  description={pageDescription}
>
  <Navbar />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <section class="pillar-hero">
    <div class="content-container">
      <div class="pillar-hero-inner">
        <span class="eyebrow pillar-hero-eyebrow">Usługi · Generative Engine Optimization</span>
        <h1 class="display-xxl pillar-hero-title">
          Pozycjonowanie w&nbsp;<span class="accent">AI</span>
        </h1>
        <p class="pillar-hero-lead">
          Zbuduj widoczność swojej marki w ChatGPT, Claude, Gemini, Perplexity i Bing Copilot. W
          nowym standardzie wyszukiwania nie walczymy o pozycje w rankingu – walczymy o bycie
          cytowanym źródłem. Ponieważ każdy model AI wymaga innego podejścia, wybierz konkretny
          silnik poniżej lub zacznij od kompleksowego audytu wszystkich pięciu.
        </p>
        <div class="pillar-hero-actions">
          <a class="btn-primary" href="/kontakt?type=audyt-ai">Zamów audyt wszystkich modeli</a>
          <a class="btn-secondary" href="/narzedzia/brand-check">Sprawdź widoczność · 60s</a>
        </div>
      </div>
    </div>
  </section>

  <section class="hero-stat-strip" aria-label="Liczby dla pozycjonowania AI">
    <div class="content-container">
      <dl class="hero-stat-grid">
        {
          heroStats.map((stat) => (
            <div class="hero-stat-cell">
              <dt>{stat.label}</dt>
              <dd>{stat.value}</dd>
              <p>{stat.detail}</p>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- 5 modeli AI – grid z linkami do podstron -->
  <section class="pillar-section" aria-labelledby="models-title">
    <div class="content-container">
      <header class="section-head">
        <div class="head-left">
          <div class="head-meta">
            <span class="section-index">P/01</span>
            <span class="eyebrow">5 modeli</span>
          </div>
          <h2 id="models-title" class="display-xl">
            Wybierz silnik AI, w którym chcesz być widoczny
          </h2>
        </div>
        <div class="head-right">
          <p class="subhead">
            Każdy model AI inaczej buduje swoje odpowiedzi: ChatGPT łączy dane treningowe z
            wyszukiwaniem na żywo, Gemini cytuje bezpośrednio z indeksu Google, a Perplexity stawia
            na maksymalną transparentność źródeł. Optymalizacja pod tylko jeden model to dziś za
            mało.
          </p>
        </div>
      </header>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-5">
        {
          AI_MODELS.map((model) => (
            <a href={model.href} class="card-template model-card group flex flex-col">
              <div class="flex items-start justify-between gap-3">
                <div class="text-ink-muted text-sm">{model.vendor}</div>
                <div
                  class="model-hook"
                  aria-label={`${modelHooks[model.slug].value} ${modelHooks[model.slug].label}`}
                >
                  <strong>{modelHooks[model.slug].value}</strong>
                  <span>{modelHooks[model.slug].label}</span>
                </div>
              </div>
              <h3
                class="mt-2 mb-3 text-2xl font-medium"
                style="font-family: var(--font-display); letter-spacing: -1px;"
              >
                {model.name}
              </h3>
              <p class="text-ink-muted text-sm leading-relaxed">{model.shortDesc}</p>
              <div class="text-accent-blue mt-5 flex items-center gap-2 text-sm opacity-0 transition group-hover:opacity-100">
                Pozycjonowanie w {model.name}
                <span aria-hidden="true">→</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Metodologia – 4 services condensed -->
  <section class="pillar-section" aria-labelledby="method-title">
    <div class="content-container">
      <header class="section-head">
        <div class="head-left">
          <div class="head-meta">
            <span class="section-index">P/02</span>
            <span class="eyebrow">Metodologia</span>
          </div>
          <h2 id="method-title" class="display-xl">Cztery filary współpracy</h2>
        </div>
        <div class="head-right">
          <p class="subhead">
            Niezależnie od tego, który model AI ma być Twoim głównym kanałem pozyskiwania ruchu,
            nasz proces pracy pozostaje ten sam. Mierzymy, optymalizujemy, monitorujemy i
            strategicznie planujemy.
          </p>
        </div>
      </header>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        {
          services.map((service, i) => (
            <div
              id={service.id}
              class="relative flex scroll-mt-24 flex-col overflow-hidden rounded-[30px] p-8 lg:p-10"
              style={gradientStyle(service.variant)}
            >
              <div class="display-md mb-2 leading-none" style="color: #fff;">
                0{i + 1}
              </div>
              <div class="mb-6 text-sm" style="color: rgba(255,255,255,0.7);">
                Filar {i + 1}
              </div>
              <h3
                class="mb-3 text-xl font-medium"
                style="font-family: var(--font-display); letter-spacing: -0.5px; color: #fff;"
              >
                {service.title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.85);">
                {service.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pillar-section" aria-labelledby="decision-title">
    <div class="content-container">
      <header class="section-head">
        <div class="head-left">
          <div class="head-meta">
            <span class="section-index">P/03</span>
            <span class="eyebrow">Decyzja</span>
          </div>
          <h2 id="decision-title" class="display-xl">Który model ma największy sens biznesowo?</h2>
        </div>
        <div class="head-right">
          <p class="subhead">
            Zacznij od modelu, w którym Twoi klienci już zadają pytania. Potem rozszerz monitoring
            na pozostałe silniki, żeby porównać koszt contentu z realną szansą na cytowanie.
          </p>
        </div>
      </header>

      <div
        class="decision-table"
        role="table"
        aria-label="Porównanie modeli AI według grupy docelowej, wykorzystania i ROI"
      >
        <div class="decision-row decision-head" role="row">
          <div role="columnheader">Model</div>
          <div role="columnheader">Grupa docelowa</div>
          <div role="columnheader">Wykorzystanie</div>
          <div role="columnheader">ROI</div>
        </div>
        {
          decisionRows.map((row) => (
            <div class="decision-row" role="row">
              <div class="decision-model" role="cell">
                <span class="decision-model-dot" aria-hidden="true"></span>
                <span>{row.model}</span>
              </div>
              <div role="cell" data-label="Grupa docelowa">
                {row.icp}
              </div>
              <div role="cell" data-label="Wykorzystanie">
                {row.usage}
              </div>
              <div role="cell" data-label="ROI">
                {row.roi}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Decyzja"
    title="Nie wiesz, od którego modelu zacząć?"
    subtitle="Skorzystaj z bezpłatnej, 30-minutowej konsultacji. Wskażemy, o co użytkownicy AI najczęściej pytają w Twojej branży, i podpowiemy, który silnik najszybciej wygeneruje dla Ciebie zwrot z inwestycji (ROI)."
    primaryLabel="Zamów audyt AI"
    primaryHref="/kontakt?type=audyt-ai"
    ghostLabel="Bezpłatna konsultacja"
    ghostHref="/kontakt?type=konsultacja"
  />

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .pillar-hero {
    position: relative;
    overflow: hidden;
    padding: 128px 0 88px;
    border-bottom: 1px solid var(--hairline-soft);
    background:
      radial-gradient(
        circle at 50% 10%,
        color-mix(in srgb, var(--accent-blue) 17%, transparent) 0%,
        transparent 32%
      ),
      radial-gradient(circle at 84% 16%, rgba(167, 139, 250, 0.18) 0%, transparent 30%),
      linear-gradient(180deg, var(--bg-surface-1) 0%, var(--bg-canvas) 82%);
  }

  .pillar-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(var(--hairline-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.14), transparent 66%);
    pointer-events: none;
  }

  .pillar-hero-inner {
    position: relative;
    align-items: center;
    display: flex;
    flex-direction: column;
    margin-inline: auto;
    max-width: 1180px;
    text-align: center;
  }

  .pillar-hero-eyebrow {
    justify-content: center;
    margin-bottom: 44px;
  }

  .pillar-hero-title {
    margin: 0;
    max-width: 1000px;
    text-wrap: balance;
  }

  .pillar-hero-lead {
    color: var(--ink);
    font-size: clamp(18px, 1.7vw, 24px);
    line-height: 1.55;
    margin: 36px auto 0;
    max-width: 980px;
    text-wrap: pretty;
  }

  .pillar-hero-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: center;
    margin-top: 56px;
  }

  .pillar-section {
    padding: 56px 0;
    width: 100%;
  }

  .hero-stat-strip {
    border-top: 1px solid var(--hairline-soft);
    border-bottom: 1px solid var(--hairline-soft);
    background: var(--bg-canvas);
    padding: 32px 0;
  }

  .hero-stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin: 0;
    padding: 0;
  }

  .hero-stat-cell {
    --stat-accent: var(--accent-blue);
    background:
      radial-gradient(
        circle at 12% 0%,
        color-mix(in srgb, var(--stat-accent) 13%, transparent) 0%,
        transparent 36%
      ),
      var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    padding: 22px 24px;
  }

  .hero-stat-cell:nth-child(2) {
    --stat-accent: #4ade80;
  }

  .hero-stat-cell:nth-child(3) {
    --stat-accent: #fbbf24;
  }

  .hero-stat-cell:nth-child(4) {
    --stat-accent: #a78bfa;
  }

  :global(:root[data-theme='light']) .hero-stat-cell:nth-child(2) {
    --stat-accent: #16a34a;
  }

  :global(:root[data-theme='light']) .hero-stat-cell:nth-child(3) {
    --stat-accent: #d97706;
  }

  :global(:root[data-theme='light']) .hero-stat-cell:nth-child(4) {
    --stat-accent: #7c3aed;
  }

  .hero-stat-cell dt {
    color: var(--ink-muted);
    font-size: 12px;
    line-height: 1.35;
    margin-bottom: 8px;
  }

  .hero-stat-cell dd {
    color: var(--stat-accent);
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 68px);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin: 0;
  }

  .hero-stat-cell p {
    color: var(--ink-faint);
    font-size: 12px;
    line-height: 1.4;
    margin: 10px 0 0;
    max-width: 220px;
  }

  .model-hook {
    align-items: flex-end;
    display: flex;
    flex-direction: column;
    flex: 0 0 auto;
    gap: 2px;
    text-align: right;
  }

  .model-hook strong {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .model-hook span {
    color: var(--ink-faint);
    font-size: 11px;
    line-height: 1.2;
  }

  .model-card {
    --model-accent: var(--accent-blue);
    border-radius: 15px;
    padding: 24px;
    background:
      radial-gradient(
        circle at 14% 0%,
        color-mix(in srgb, var(--model-accent) 14%, transparent) 0%,
        transparent 36%
      ),
      var(--bg-surface-1);
    border-color: var(--hairline-soft);
  }

  .model-card:nth-child(2) {
    --model-accent: #4ade80;
  }

  .model-card:nth-child(3) {
    --model-accent: #fbbf24;
  }

  .model-card:nth-child(4) {
    --model-accent: #a78bfa;
  }

  .model-card:nth-child(5) {
    --model-accent: #22d3ee;
  }

  :global(:root[data-theme='light']) .model-card:nth-child(2) {
    --model-accent: #16a34a;
  }

  :global(:root[data-theme='light']) .model-card:nth-child(3) {
    --model-accent: #d97706;
  }

  :global(:root[data-theme='light']) .model-card:nth-child(4) {
    --model-accent: #7c3aed;
  }

  .model-card .model-hook strong,
  .model-card .text-accent-blue {
    color: var(--model-accent);
  }

  .decision-table {
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--bg-surface-1) 72%, transparent), transparent 68%),
      var(--bg-canvas);
    box-shadow: var(--shadow-l2);
    overflow: hidden;
  }

  .decision-row {
    display: grid;
    grid-template-columns: minmax(170px, 0.72fr) minmax(220px, 1fr) minmax(280px, 1.42fr) minmax(280px, 1.36fr);
  }

  .decision-row:not(.decision-head) {
    --decision-accent: var(--accent-blue);
    position: relative;
    background: color-mix(in srgb, var(--bg-surface-1) 54%, transparent);
    transition: background 0.18s ease, box-shadow 0.18s ease;
  }

  .decision-row:not(.decision-head):nth-child(3) {
    --decision-accent: #4ade80;
  }

  .decision-row:not(.decision-head):nth-child(4) {
    --decision-accent: #fbbf24;
  }

  .decision-row:not(.decision-head):nth-child(5) {
    --decision-accent: #a78bfa;
  }

  .decision-row:not(.decision-head):nth-child(6) {
    --decision-accent: #22d3ee;
  }

  .decision-row:not(.decision-head):hover {
    background: color-mix(in srgb, var(--decision-accent) 7%, var(--bg-surface-1));
    box-shadow: inset 3px 0 0 color-mix(in srgb, var(--decision-accent) 82%, transparent);
  }

  .decision-row + .decision-row {
    border-top: 1px solid var(--hairline-soft);
  }

  .decision-row > div {
    color: var(--ink-muted);
    font-family: var(--font-sans);
    font-size: 15px;
    letter-spacing: -0.012em;
    line-height: 1.45;
    padding: 20px 24px;
  }

  .decision-row > div + div {
    border-left: 1px solid var(--hairline-soft);
  }

  .decision-head {
    background: color-mix(in srgb, var(--bg-surface-2) 62%, var(--bg-canvas));
  }

  .decision-head > div {
    color: var(--ink-faint);
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.045em;
    line-height: 1;
    padding-bottom: 13px;
    padding-top: 13px;
    text-transform: uppercase;
  }

  .decision-model {
    align-items: center;
    color: var(--ink) !important;
    display: inline-flex;
    font-size: 15px !important;
    font-weight: 700;
    gap: 10px;
