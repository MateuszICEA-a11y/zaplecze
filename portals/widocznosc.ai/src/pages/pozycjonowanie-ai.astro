---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollUpButton from '../components/ScrollUpButton.astro';
import CTABand from '../components/CTABand.astro';

const services = [
  {
    id: 'audyt',
    symbol: '◐',
    eyebrow: 'Diagnoza',
    title: 'Audyt widoczności AI',
    desc:
      'Pierwszy krok każdej współpracy. Sprawdzamy jak Twoja marka i kluczowe produkty są cytowane w pięciu wyszukiwarkach AI – ChatGPT, Claude, Gemini, Perplexity i Bing Copilot. Identyfikujemy konkurentów, którzy wyprzedzają Cię w odpowiedziach LLM-ów.',
    bullets: [
      'Skan 30-100 zapytań brand + kategoria',
      'Mapa cytowań i pokrycia tematycznego',
      'Lista konkurencji wymienianej zamiast Twojej marki',
      'Raport z konkretną listą rekomendacji',
    ],
  },
  {
    id: 'content',
    symbol: '✦',
    eyebrow: 'Optymalizacja',
    title: 'Optymalizacja treści pod LLM',
    desc:
      'Generative Engine Optimization to nie SEO 2.0. To inny rytm pisania – fact-density, struktura definicyjna, źródła cytowalne, klarowna semantyka. Przepisujemy istniejący content tak, żeby ChatGPT cytował Twoją domenę, nie konkurencji.',
    bullets: [
      'Audyt 20-50 stron pod kątem GEO',
      'Rewriting headerów, lead paragraphów, FAQ',
      'Wprowadzenie schema.org + structured data',
      'Briefy dla copywriterów + szablony',
    ],
  },
  {
    id: 'monitoring',
    symbol: '⊡',
    eyebrow: 'Monitoring',
    title: 'Monitoring cytowań AI',
    desc:
      'Stały tracking. Co tydzień sprawdzamy czy marka pojawia się w wybranych zapytaniach, czy konkurencja Cię nie wyprzedziła, czy nowe modele (np. nowsza wersja Claude) inaczej Cię cytują. Alerty mailowe gdy coś się zmienia.',
    bullets: [
      'Weekly snapshot 50-200 zapytań',
      'Alerty o pojawieniu się konkurencji',
      'Tracking sentiment i dokładności cytatu',
      'Dashboard z historią widoczności',
    ],
  },
  {
    id: 'strategia',
    symbol: '◇',
    eyebrow: 'Strategia',
    title: 'Strategia GEO 12 miesięcy',
    desc:
      'Plan widoczności na cały rok: jakie tematy pokrywać, gdzie publikować, jakie sygnały budować, jak trafić do training data nowych modeli i RAG-ów. Konkretne KPI i milestones. Oparte na danych z audytu i monitoringu.',
    bullets: [
      'Mapa fraz i intentów na 12 miesięcy',
      'Content calendar z briefami',
      'Plan distribution + linkbuilding pod GEO',
      'Quartal reviews z weryfikacją KPI',
    ],
  },
  {
    id: 'konsultacje',
    symbol: '∴',
    eyebrow: 'Doradztwo',
    title: 'Konsultacje 1:1',
    desc:
      'Indywidualne sesje z ekspertami ICEA. Dla zespołów marketingu, contentu i decision-makerów. Diagnoza konkretnego problemu, sparing intelektualny, rekomendacje na cito. Bez formularzy, bez pakietów.',
    bullets: [
      'Sesje 60 lub 90 minut',
      'Online lub w biurze ICEA',
      'Przygotowanie merytoryczne pod konkretny case',
      'Notatki i action items po sesji',
    ],
  },
  {
    id: 'wdrozenie',
    symbol: '⊕',
    eyebrow: 'Pełen pakiet',
    title: 'Audyt + wdrożenie 90 dni',
    desc:
      'Najwyższa formuła współpracy. Pełny audyt, mapa fraz, content plan, wdrożenie zmian, monitoring efektów. Konkretne mierniki ustalane na starcie, raport co miesiąc. Nasz zespół staje się częścią Twojego workflow.',
    bullets: [
      'Pełen audyt + strategia (miesiąc 1)',
      'Implementacja + content rewriting (miesiąc 2)',
      'Monitoring + iteracje (miesiąc 3)',
      'Final report z next steps',
    ],
  },
];
---

<Layout
  title="Pozycjonowanie AI – widocznosc.ai"
  description="Pozycjonowanie marki w wyszukiwarkach AI: audyt widoczności, optymalizacja content, monitoring cytowań w ChatGPT/Claude/Gemini/Perplexity, doradztwo GEO."
>
  <Navbar />

  <!-- Hero -->
  <section
    class="relative flex w-full items-center justify-center overflow-hidden pb-16 md:pb-20"
    style="background: var(--bg);"
  >
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(at 20% 30%, rgba(255,106,46,0.18) 0%, transparent 55%), radial-gradient(at 80% 70%, rgba(255,106,46,0.12) 0%, transparent 55%);"
      aria-hidden="true"
    >
    </div>
    <div class="content-container relative z-10 pt-32 md:pt-40 lg:pt-44">
      <div class="mx-auto max-w-4xl text-center">
        <span class="meta mb-6 inline-block">Usługi · Generative Engine Optimization</span>
        <h1
          class="text-ink font-display text-[2.5rem] leading-[1.05] font-semibold tracking-[-0.04em] sm:text-[3.5rem] lg:text-[4.5rem]"
        >
          Pozycjonowanie marki w wyszukiwarkach <span class="text-accent">AI</span>
        </h1>
        <p class="text-ink-soft mx-auto mt-6 max-w-2xl text-lg leading-relaxed">
          Sześć formuł współpracy – od jednorazowego audytu po stałe wdrożenie. Wszystkie oparte
          na realnych danych z pięciu modeli AI, nie na deklaracjach.
        </p>
      </div>
    </div>
  </section>

  <!-- Services list (anchored sections) -->
  <section class="relative w-full" style="background: var(--bg);">
    <div class="content-container py-16 lg:py-24">
      <div class="space-y-16 lg:space-y-24">
        {
          services.map((service, i) => (
            <article
              id={service.id}
              class="border-rule grid scroll-mt-24 grid-cols-1 gap-10 border-t pt-16 lg:grid-cols-12 lg:gap-16 lg:pt-24"
            >
              <div class="lg:col-span-5">
                <div class="feat-icon mb-5 font-mono">{service.symbol}</div>
                <span class="meta">{service.eyebrow}</span>
                <h2
                  class="text-ink font-display mt-3 mb-5 text-2xl font-semibold tracking-[-0.03em] sm:text-3xl lg:text-4xl"
                >
                  {service.title}
                </h2>
                <p class="text-ink-soft leading-relaxed">{service.desc}</p>
              </div>
              <div class="lg:col-span-7">
                <div class="border-rule bg-bg-card rounded-xl border p-6 sm:p-8">
                  <div class="text-ink-mute mb-4 font-mono text-[11px] tracking-[0.12em] uppercase">
                    Co dostajesz
                  </div>
                  <ul class="space-y-3">
                    {service.bullets.map((bullet) => (
                      <li class="text-ink flex items-start gap-3">
                        <span class="text-accent mt-1.5 flex-shrink-0" aria-hidden="true">
                          ✓
                        </span>
                        <span class="leading-relaxed">{bullet}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="border-rule-soft mt-6 border-t pt-5">
                    <a
                      href="/kontakt"
                      class="text-accent flex items-center gap-2 font-mono text-[11px] tracking-wider uppercase transition hover:gap-3"
                    >
                      Zapytaj o {service.title.toLowerCase()}
                      <span aria-hidden="true">→</span>
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Decyzja"
    title="Nie wiesz która formuła pasuje do Twojej marki?"
    subtitle="Bezpłatna konsultacja 30 minut. Diagnozujemy gdzie jesteś, gdzie powinieneś być i jak najszybciej tam dojść – bez sprzedaży, bez pakietów."
    primaryLabel="Zamów audyt AI"
    primaryHref="/kontakt"
    ghostLabel="Bezpłatna konsultacja"
    ghostHref="/kontakt?type=konsultacja"
  />

  <Footer />
  <ScrollUpButton />
</Layout>
