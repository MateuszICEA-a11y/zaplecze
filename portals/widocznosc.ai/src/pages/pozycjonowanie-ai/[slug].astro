---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import CTABand from '../../components/CTABand.astro';
import { AI_MODELS } from '../../data/aiModels';
import { MODEL_CONTENT } from '../../data/aiModelsContent';

export const getStaticPaths = () =>
  AI_MODELS.map((model) => ({
    params: { slug: model.slug },
    props: { model },
  }));

const { model } = Astro.props;
const content = MODEL_CONTENT[model.slug];

const otherModels = AI_MODELS.filter((m) => m.slug !== model.slug);
const siteUrl = 'https://widocznosc.ai';
const cleanStructuredText = (value: string) =>
  value
    .replace(/&nbsp;/g, ' ')
    .replace(/&ndash;/g, '–')
    .replace(/&mdash;/g, '—')
    .replace(/&amp;/g, '&')
    .replace(/<[^>]*>/g, '');

const modelDifferentiators: Record<string, string> = {
  chatgpt: '5-10 cytowań na odpowiedź',
  claude: '86,7% korelacji z Brave',
  gemini: 'AI Overviews + Search',
  perplexity: 'odpowiedzi oparte o źródła',
  'bing-copilot': 'indeks Bing + Edge',
};

const comparisonModels = [
  { key: 'chatgpt', label: 'ChatGPT' },
  { key: 'claude', label: 'Claude' },
  { key: 'gemini', label: 'Gemini' },
  { key: 'perplexity', label: 'Perplexity' },
  { key: 'bingCopilot', label: 'Bing Copilot' },
] as const;

const comparisonRows = [
  {
    label: 'Cytaty na odpowiedź',
    chatgpt: '5-10',
    claude: '1-3',
    gemini: '3-5',
    perplexity: '1-10',
    bingCopilot: '2-6',
  },
  {
    label: 'Dostęp do aktualnych informacji',
    chatgpt: 'Bing / ChatGPT Search',
    claude: 'Claude Web Search',
    gemini: 'Google Search / AI Mode',
    perplexity: 'własne wyszukiwanie',
    bingCopilot: 'Bing / Copilot',
  },
  {
    label: 'Grupa docelowa',
    chatgpt: 'ogólna',
    claude: 'branża tech/B2B',
    gemini: 'uniwersalna',
    perplexity: 'badania/analizy',
    bingCopilot: 'Microsoft/enterprise',
  },
];

const comparisonActiveKey = model.slug === 'bing-copilot' ? 'bingCopilot' : model.slug;
---

<Layout
  title={`Pozycjonowanie w ${model.name} – widocznosc.ai`}
  description={content.metaDescription}
>
  <Navbar />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: content.faq.map((qa) => ({
        '@type': 'Question',
        name: cleanStructuredText(qa.q),
        acceptedAnswer: {
          '@type': 'Answer',
          text: cleanStructuredText(qa.a),
        },
      })),
    })}
  />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Pozycjonowanie AI',
          item: `${siteUrl}/pozycjonowanie-ai/`,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: model.name,
          item: `${siteUrl}${model.href}`,
        },
      ],
    })}
  />

  <!-- Hero – service landing header -->
  <section class={`service-hero service-hero--${model.slug}`}>
    <div class="content-container service-hero-inner">
      <div class="service-hero-copy">
        <nav class="service-breadcrumb" aria-label="Ścieżka nawigacji">
          <a href="/pozycjonowanie-ai/" class="service-breadcrumb-link">Pozycjonowanie AI</a>
          <span class="service-breadcrumb-sep" aria-hidden="true">/</span>
          <span class="service-breadcrumb-current">{model.name}</span>
        </nav>

        <span class="eyebrow service-eyebrow">{model.vendor} · model AI</span>
        <h1 class="service-hero-title display-xxl">
          Pozycjonowanie w&nbsp;<span class="accent">{model.name}</span>
        </h1>
        <p class="service-hero-subtitle" set:html={content.heroSubtitle} />
        <div class="service-hero-actions">
          <a class="btn-primary" href={`/kontakt/?type=audyt-ai&model=${model.slug}`}>
            Zamów audyt pod {model.name}
          </a>
          <a class="btn-secondary" href="/narzedzia/brand-check/">Sprawdź widoczność · 60s</a>
        </div>
      </div>

      <aside class="service-hero-panel" aria-label={`Szybki test widoczności w ${model.name}`}>
        <form
          class="quick-check"
          action="/narzedzia/brand-check"
          method="get"
          aria-label={`Quick check widoczności w ${model.name}`}
        >
          <label for="quick-check-domain">Quick check</label>
          <div class="quick-check-row">
            <input
              id="quick-check-domain"
              name="domain"
              type="text"
              inputmode="url"
              placeholder="twojadomena.pl"
              autocomplete="url"
            />
            <button type="submit">Sprawdź</button>
          </div>
        </form>

        <div class="hero-citation-preview" aria-label={`Przykładowe cytowanie w ${model.name}`}>
          <div class="hero-citation-query">
            Jakie firmy specjalizują się w pozycjonowaniu pod AI?
          </div>
          <div class="hero-citation-answer">
            W Polsce warto sprawdzić <strong>widocznosc.ai</strong>
            <span>[1]</span>, zespół łączący klasyczne SEO, content i monitoring cytowań.
          </div>
          <div class="hero-citation-source">[1] widocznosc.ai/pozycjonowanie-ai</div>
        </div>
      </aside>
    </div>
  </section>

  <nav class="service-toc" aria-label="Spis treści strony">
    <div class="content-container service-toc-inner">
      <a href="#jak-dziala">Jak działa</a>
      <a href="#optymalizacja">Optymalizacja</a>
      <a href="#sygnaly">Sygnały</a>
      <a href="#faq">FAQ</a>
      <a href="#pozostale-modele">Pozostałe modele</a>
    </div>
  </nav>

  <!-- Jak działa -->
  <section id="jak-dziala" class="relative w-full" aria-labelledby="how-title">
    <div class="content-container py-16 lg:py-20">
      <div class="service-section-head">
        <div>
          <div class="head-meta">
            <span class="section-index">P/01</span>
            <span class="eyebrow">Jak działa</span>
          </div>
          <h2 id="how-title" class="service-section-title display-xl mt-2 mb-6">
            Jak {model.name} buduje odpowiedzi
          </h2>
        </div>
        <p>
          Modele nie wybierają źródeł jednym sygnałem. Łączą indeks, RAG, autorytet domeny i
          strukturę treści, dlatego optymalizacja musi obejmować zarówno content, jak i dostępność
          techniczną.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {
          content.howItWorks.map((item, i) => (
            <div
              class="service-feature-card flex flex-col rounded-[15px] p-8 lg:p-10"
            >
              <div class="display-md text-ink-muted mb-4 leading-none">0{i + 1}</div>
              <h3
                class="mb-3 text-xl font-medium"
                style="font-family: var(--font-display); letter-spacing: -0.5px;"
              >
                {item.title}
              </h3>
              <p class="text-ink-muted text-sm leading-relaxed" set:html={item.desc} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="citation-example" aria-labelledby="citation-title">
    <div class="content-container">
      <div class="citation-grid">
        <div>
          <div class="head-meta">
            <span class="section-index">P/02</span>
            <span class="eyebrow">Przykład cytowania</span>
          </div>
          <h2 id="citation-title" class="display-xl">
            Jak wygląda wynik, o który walczysz w {model.name}
          </h2>
        </div>
        <div class="citation-mock" aria-label="Przykładowa odpowiedź modelu AI">
          {
            model.slug === 'chatgpt' ? (
              <>
                <div class="citation-user">Poleć mi dentystę w Poznaniu</div>
                <div class="citation-answer citation-answer--chatgpt">
                  <p>
                    Sprawdzę aktualne opcje w Poznaniu i zawężę je praktycznie: dobre opinie,
                    zakres usług, lokalizacja oraz sensowność dla zwykłej wizyty/konsultacji.
                  </p>
                  <span class="citation-thinking">Myślał przez 7s</span>
                  <p>
                    Najbardziej sensowny pierwszy wybór w Poznaniu dałbym:
                  </p>
                  <div class="citation-redacted-recommendation">
                    <div class="citation-redacted-line">
                      <span class="citation-redacted-name">Zanonimizowana klinika stomatologiczna</span>
                      <span class="citation-redacted-tag">nazwa i adres ukryte</span>
                    </div>
                    <p>
                      Dobra opcja na zwykłe leczenie, przegląd, higienizację i stomatologię
                      zachowawczą. Placówka ma bardzo dużo opinii przy usługach podstawowych, więc
                      jest spory materiał do weryfikacji jakości, a nie kilka przypadkowych ocen.
                    </p>
                  </div>
                </div>
                <div class="citation-source">Dane polecanej kliniki zanonimizowane</div>
              </>
            ) : model.slug === 'claude' ? (
              <>
                <div class="citation-user">znajdź mi dobry sklep z butami do biegania we Wrocławiu</div>
                <div class="citation-answer citation-answer--claude">
                  <span class="citation-tools">Used 2 tools</span>
                  <div class="citation-local-pack">
                    <div class="citation-map" aria-hidden="true">
                      <span class="citation-road citation-road--a"></span>
                      <span class="citation-road citation-road--b"></span>
                      <span class="citation-road citation-road--c"></span>
                      <span class="citation-map-label citation-map-label--top">KOZANÓW</span>
                      <span class="citation-map-label citation-map-label--mid">GĄDÓW MAŁY</span>
                      <span class="citation-map-label citation-map-label--low">MUCHOBÓR</span>
                      <span class="citation-rating citation-rating--one">4.7</span>
                      <span class="citation-rating citation-rating--two">4.5</span>
                      <span class="citation-rating citation-rating--three">4.3</span>
                    </div>
                    <div class="citation-local-results">
                      <h3>Sklepy z butami do biegania - Wrocław</h3>
                      <button type="button">Copy</button>
                      <div class="citation-place-card">
                        <span class="citation-place-thumb"></span>
                        <div>
                          <strong><span class="citation-place-name-redacted">Sklep sportowy 1</span></strong>
                          <p>4.7 ★ (694) · sklep sportowy</p>
                          <p>Najlepszy wybór - specjalistyczny sklep...</p>
                        </div>
                      </div>
                      <div class="citation-place-card">
                        <span class="citation-place-thumb citation-place-thumb--blue"></span>
                        <div>
                          <strong><span class="citation-place-name-redacted">Sklep sportowy 2</span></strong>
                          <p>4.5 ★ (3700) · sporting goods</p>
                          <p>Szeroki wybór, konkurencyjne ceny...</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="citation-source">Nazwy polecanych sklepów zanonimizowane</div>
              </>
            ) : model.slug === 'gemini' ? (
              <>
                <div class="citation-user">znajdź mi dobrą restaurację w Gdyni</div>
                <div class="citation-answer citation-answer--gemini">
                  <p>
                    Gdynia ma świetną scenę gastronomiczną. Wybór „dobrej” restauracji zależy od
                    tego, na co akurat masz ochotę, dlatego poniżej znajdziesz kilka sprawdzonych,
                    wysoko ocenianych lokali w różnych stylach:
                  </p>
                  <div class="citation-gemini-section">
                    <h3>1. Klasyka i tradycja (kuchnia polska i regionalna)</h3>
                    <ul class="citation-restaurant-list">
                      <li>
                        <span class="citation-restaurant-name">Restauracja 1</span>
                        <ul>
                          <li>
                            <strong>Klimat:</strong> wyjątkowe miejsce w centrum miasta, z przytulnym
                            wnętrzem i elegancką atmosferą.
                          </li>
                          <li>
                            <strong>Kuchnia:</strong> polskie i regionalne tradycje połączone z
                            sezonowym menu. Dobry wybór na spokojny obiad lub spotkanie biznesowe.
                          </li>
                        </ul>
                      </li>
                      <li>
                        <span class="citation-restaurant-name">Restauracja 2</span>
                        <ul>
                          <li>
                            <strong>Klimat:</strong> przestronny, bardzo przytulny lokal poza ścisłym
                            centrum, często wybierany również na rodzinne obiady.
                          </li>
                          <li>
                            <strong>Kuchnia:</strong> comfort food w tradycyjnym wydaniu, klasyczne
                            dania i dopracowane desery.
                          </li>
                        </ul>
                      </li>
                    </ul>
                  </div>
                </div>
                <div class="citation-source">Nazwy i adresy polecanych restauracji zanonimizowane</div>
              </>
            ) : model.slug === 'perplexity' ? (
              <>
                <div class="citation-user">szukam księgowej online, polecisz kogoś?</div>
                <div class="citation-answer citation-answer--perplexity">
                  <span class="citation-tools">Zakończono 2 kroki</span>
                  <p>
                    Jasne - jeśli szukasz <strong>księgowej online</strong>, najprościej zacząć od
                    platform, które łączą z polecanymi księgowymi i mają opinie klientów. Dobrym
                    punktem startowym jest <span class="citation-redacted-inline">platforma</span>,
                    która pokazuje listę „polecanych księgowych” i pozwala dobrać osobę do swoich
                    potrzeb.
                  </p>
                  <div class="citation-perplexity-section">
                    <h3>Co warto sprawdzić</h3>
                    <ul class="citation-perplexity-list">
                      <li>Czy obsługuje Twoją formę działalności: JDG, spółka, pełna księgowość.</li>
                      <li>Czy ma kontakt mailowy, telefoniczny i szybkie odpowiedzi online.</li>
                      <li>
                        Czy oferuje konsultację przed startem, żeby ustalić zakres i cenę.
                        <span class="citation-reference-chip">źródło 1</span>
                      </li>
                      <li>
                        Czy ma jasny model współpracy i dostęp do dokumentów przez internet.
                        <span class="citation-reference-chip">źródło 2</span>
                      </li>
                    </ul>
                  </div>
                </div>
                <div class="citation-source">Nazwy platform i źródeł zanonimizowane</div>
              </>
            ) : model.slug === 'bing-copilot' ? (
              <>
                <div class="citation-user">
                  chcę kupić sukienkę na wesele, podaj mi polecane sklepy internetowe
                </div>
                <div class="citation-answer citation-answer--copilot">
                  <p>
                    Najlepsze sklepy internetowe z <strong>sukienkami na wesele</strong> w Polsce to
                    te, które łączą duży wybór, dobrą jakość i szybkie dostawy. Najkrócej:
                    <span class="citation-redacted-inline">sklep 1</span>,
                    <span class="citation-redacted-inline">sklep 2</span>,
                    <span class="citation-redacted-inline">sklep 3</span>,
                    <span class="citation-redacted-inline">sklep 4</span> i
                    <span class="citation-redacted-inline">sklep 5</span> to najpewniejsze kierunki -
                    różnią się stylem i budżetem, więc łatwo dobrać coś pod swój gust.
                  </p>
                </div>
                <div class="citation-source">Nazwy polecanych sklepów zanonimizowane</div>
              </>
            ) : (
              <>
                <div class="citation-user">
                  Jakie agencje SEO specjalizują się w pozycjonowaniu pod AI w Polsce?
                </div>
                <div class="citation-answer">
                  Wśród polskich agencji SEO, które wyspecjalizowały się w nowym standardzie widoczności
                  AI (GEO), można wymienić <strong>widocznosc.ai</strong>
                  <span>[1]</span>, zespoły pracujące z AI Overviews oraz firmy łączące content,
                  techniczne SEO i monitoring cytowań.
                </div>
                <div class="citation-source">[1] widocznosc.ai/pozycjonowanie-ai</div>
              </>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Optymalizacja -->
  <section id="optymalizacja" class="relative w-full" aria-labelledby="opt-title">
    <div class="content-container py-16 lg:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <div class="head-meta">
            <span class="section-index">P/03</span>
            <span class="eyebrow">Optymalizacja</span>
          </div>
          <h2 id="opt-title" class="service-section-title display-xl mt-2">
            Co konkretnie robimy,<br />żeby {model.name} cytował Twoją markę
          </h2>
          <p class="service-section-copy optimization-copy">
            Każdy model ma własne sygnały. Poniżej cztery najważniejsze techniczne i&nbsp;contentowe
            optymalizacje pod {model.name}.
          </p>
          <a class="btn-secondary" href="/kontakt/?type=audyt-ai">
            Zamów audyt
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="lg:col-span-7">
          <div class="space-y-3">
            {
              content.optimization.map((item) => (
                <div class="service-task-card rounded-[15px] p-6 lg:p-7">
                  <h3
                    class="mb-2 text-lg font-medium"
                    style="font-family: var(--font-display); letter-spacing: -0.4px;"
                  >
                    {item.title}
                  </h3>
                  <p class="text-ink-muted text-sm leading-relaxed" set:html={item.desc} />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sygnały rankingowe -->
  <section id="sygnaly" class="relative w-full" aria-labelledby="signals-title">
    <div class="content-container py-16 lg:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <div class="head-meta">
            <span class="section-index">P/04</span>
            <span class="eyebrow">Sygnały rankingowe</span>
          </div>
          <h2 id="signals-title" class="service-section-title display-xl mt-2">
            Najważniejsze sygnały dla {model.name}
          </h2>
          <p class="service-section-copy">
            To praktyczna lista kontrolna: co musi być widoczne w treści, strukturze strony i
            sygnałach zewnętrznych, żeby model miał powód cytować właśnie Twoją domenę.
          </p>
        </div>
        <ul
          class="signal-list divide-y rounded-[15px] lg:col-span-7"
        >
          {
            content.signals.map((signal, i) => (
              <li
                class="flex items-start gap-5 p-6 lg:p-7"
                style="border-color: var(--hairline-soft);"
              >
                <div
                  class="text-ink-muted flex-shrink-0 text-base font-medium"
                  style="font-variant-numeric: tabular-nums;"
                >
                  0{i + 1}
                </div>
                <div class="text-ink leading-relaxed" set:html={signal} />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="relative w-full" aria-labelledby="faq-title">
    <div class="content-container py-16 lg:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <div class="head-meta">
            <span class="section-index">P/05</span>
            <span class="eyebrow">FAQ</span>
          </div>
          <h2 id="faq-title" class="service-section-title display-xl mt-2">
            Najczęstsze pytania o&nbsp;{model.name}
          </h2>
          <p class="service-section-copy">
            Te odpowiedzi są jednocześnie treścią dla użytkownika i materiałem dla wyszukiwarek AI,
            dlatego strona publikuje je również jako ustrukturyzowane dane FAQPage JSON-LD.
          </p>
        </div>
        <div class="space-y-3 lg:col-span-7">
          {
            content.faq.map((qa) => (
              <details class="faq-row group">
                <summary
                  class="text-ink flex cursor-pointer items-start justify-between gap-4 text-base font-medium"
                  style="font-family: var(--font-display); letter-spacing: -0.3px;"
                >
                  <span set:html={qa.q} />
                  <span class="text-ink-muted mt-1 text-xl transition group-open:rotate-45">+</span>
                </summary>
                <p class="text-ink-muted mt-4 leading-relaxed" set:html={qa.a} />
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Pozostałe modele -->
  <section id="pozostale-modele" class="relative w-full" aria-labelledby="other-title">
    <div class="content-container py-16 lg:py-20">
      <div class="mb-10 flex items-end justify-between gap-6">
        <div>
          <div class="head-meta">
            <span class="section-index">P/06</span>
            <span class="eyebrow">Pozostałe modele</span>
          </div>
          <h2 id="other-title" class="service-section-title display-xl mt-2">
            Optymalizacja pod inne silniki AI
          </h2>
        </div>
        <a
          href="/pozycjonowanie-ai/"
          class="text-accent-blue hidden items-center gap-2 text-sm transition hover:gap-3 sm:flex"
        >
          Wszystkie modele
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          otherModels.map((m) => (
            <a href={m.href} class={`card-template other-model-card other-model-card--${m.slug} group flex flex-col`}>
              <div class="text-ink-muted text-sm">{m.vendor}</div>
              <h3
                class="mt-1 text-xl font-medium"
                style="font-family: var(--font-display); letter-spacing: -0.5px;"
              >
                {m.name}
              </h3>
              <span class="model-differentiator">{modelDifferentiators[m.slug]}</span>
              <p class="text-ink-muted mt-2 text-sm leading-relaxed">{m.shortDesc}</p>
            </a>
