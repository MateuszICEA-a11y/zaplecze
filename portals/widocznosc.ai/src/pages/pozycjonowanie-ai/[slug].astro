---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import CTABand from '../../components/CTABand.astro';
import { AI_MODELS } from '../../data/aiModels';
import { MODEL_CONTENT } from '../../data/aiModelsContent';

export const getStaticPaths = () =>
  AI_MODELS.map((model) => ({
    params: { slug: model.slug },
    props: { model },
  }));

const { model } = Astro.props;
const content = MODEL_CONTENT[model.slug];

const otherModels = AI_MODELS.filter((m) => m.slug !== model.slug);
const siteUrl = 'https://widocznosc.ai';
const cleanStructuredText = (value: string) =>
  value
    .replace(/&nbsp;/g, ' ')
    .replace(/&ndash;/g, '–')
    .replace(/&mdash;/g, '—')
    .replace(/&amp;/g, '&')
    .replace(/<[^>]*>/g, '');

const modelDifferentiators: Record<string, string> = {
  chatgpt: '5-10 cytowań na odpowiedź',
  claude: '86,7% korelacji z Brave',
  gemini: 'AI Overviews + Search',
  perplexity: 'odpowiedzi oparte o źródła',
  'bing-copilot': 'indeks Bing + Edge',
};

const comparisonRows = [
  { label: 'Cytaty/odp.', chatgpt: '5-10', claude: '1-3', gemini: '3-5', perplexity: '1-10' },
  { label: 'Cykl', chatgpt: '24-72h', claude: '48-96h', gemini: 'tydz.-mc', perplexity: '24-48h' },
  {
    label: 'Grupa docelowa',
    chatgpt: 'masowa',
    claude: 'branża tech/B2B',
    gemini: 'uniwersalna',
    perplexity: 'badania/analizy',
  },
];
---

<Layout
  title={`Pozycjonowanie w ${model.name} – widocznosc.ai`}
  description={content.metaDescription}
>
  <Navbar />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: content.faq.map((qa) => ({
        '@type': 'Question',
        name: cleanStructuredText(qa.q),
        acceptedAnswer: {
          '@type': 'Answer',
          text: cleanStructuredText(qa.a),
        },
      })),
    })}
  />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Pozycjonowanie AI',
          item: `${siteUrl}/pozycjonowanie-ai`,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: model.name,
          item: `${siteUrl}${model.href}`,
        },
      ],
    })}
  />

  <!-- Hero – service landing header -->
  <section class="service-hero">
    <div class="content-container service-hero-inner">
      <div class="service-hero-copy">
        <nav class="service-breadcrumb" aria-label="Ścieżka nawigacji">
          <a href="/pozycjonowanie-ai" class="service-breadcrumb-link">Pozycjonowanie AI</a>
          <span class="service-breadcrumb-sep" aria-hidden="true">/</span>
          <span class="service-breadcrumb-current">{model.name}</span>
        </nav>

        <span class="eyebrow service-eyebrow">{model.vendor} · model AI</span>
        <h1 class="service-hero-title">
          Pozycjonowanie w&nbsp;<span class="accent">{model.name}</span>
        </h1>
        <p class="service-hero-subtitle" set:html={content.heroSubtitle} />
        <div class="service-hero-actions">
          <a class="btn-primary" href={`/kontakt?type=audyt-ai&model=${model.slug}`}>
            Zamów audyt pod {model.name}
          </a>
          <a class="btn-secondary" href="/narzedzia/brand-check">Sprawdź widoczność · 60s</a>
        </div>
      </div>

      <aside class="service-hero-panel" aria-label={`Szybki test widoczności w ${model.name}`}>
        <form
          class="quick-check"
          action="/narzedzia/brand-check"
          method="get"
          aria-label={`Quick check widoczności w ${model.name}`}
        >
          <label for="quick-check-domain">Quick check</label>
          <div class="quick-check-row">
            <input
              id="quick-check-domain"
              name="domain"
              type="text"
              inputmode="url"
              placeholder="twojadomena.pl"
              autocomplete="url"
            />
            <button type="submit">Sprawdź</button>
          </div>
        </form>

        <div class="hero-citation-preview" aria-label={`Przykładowe cytowanie w ${model.name}`}>
          <div class="hero-citation-query">
            Jakie firmy specjalizują się w pozycjonowaniu pod AI?
          </div>
          <div class="hero-citation-answer">
            W Polsce warto sprawdzić <strong>widocznosc.ai</strong>
            <span>[1]</span>, zespół łączący klasyczne SEO, content i monitoring cytowań.
          </div>
          <div class="hero-citation-source">[1] widocznosc.ai/pozycjonowanie-ai</div>
        </div>
      </aside>
    </div>
  </section>

  <nav class="service-toc" aria-label="Spis treści strony">
    <div class="content-container service-toc-inner">
      <a href="#jak-dziala">Jak działa</a>
      <a href="#optymalizacja">Optymalizacja</a>
      <a href="#sygnaly">Sygnały</a>
      <a href="#faq">FAQ</a>
      <a href="#pozostale-modele">Pozostałe modele</a>
    </div>
  </nav>

  <!-- Jak działa -->
  <section id="jak-dziala" class="relative w-full" aria-labelledby="how-title">
    <div class="content-container py-16 lg:py-20">
      <div class="service-section-head">
        <div>
          <div class="head-meta">
            <span class="section-index">P/01</span>
            <span class="eyebrow">Jak działa</span>
          </div>
          <h2 id="how-title" class="service-section-title display-lg mt-2 mb-6">
            Jak {model.name} buduje odpowiedzi
          </h2>
        </div>
        <p>
          Modele nie wybierają źródeł jednym sygnałem. Łączą indeks, RAG, autorytet domeny i
          strukturę treści, dlatego optymalizacja musi obejmować zarówno content, jak i dostępność
          techniczną.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {
          content.howItWorks.map((item, i) => (
            <div
              class="flex flex-col rounded-[15px] p-8 lg:p-10"
              style="background: var(--bg-surface-1);"
            >
              <div class="display-md text-ink-muted mb-4 leading-none">0{i + 1}</div>
              <h3
                class="mb-3 text-xl font-medium"
                style="font-family: var(--font-display); letter-spacing: -0.5px;"
              >
                {item.title}
              </h3>
              <p class="text-ink-muted text-sm leading-relaxed" set:html={item.desc} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="citation-example" aria-labelledby="citation-title">
    <div class="content-container">
      <div class="citation-grid">
        <div>
          <div class="head-meta">
            <span class="section-index">P/02</span>
            <span class="eyebrow">Przykład cytowania</span>
          </div>
          <h2 id="citation-title" class="display-lg">
            Jak wygląda wynik, o który walczysz w {model.name}
          </h2>
        </div>
        <div class="citation-mock" aria-label="Przykładowa odpowiedź modelu AI">
          <div class="citation-user">
            Jakie agencje SEO specjalizują się w pozycjonowaniu pod AI w Polsce?
          </div>
          <div class="citation-answer">
            Wśród polskich agencji SEO, które wyspecjalizowały się w nowym standardzie widoczności
            AI (GEO), można wymienić <strong>widocznosc.ai</strong>
            <span>[1]</span>, zespoły pracujące z AI Overviews oraz firmy łączące content,
            techniczne SEO i monitoring cytowań.
          </div>
          <div class="citation-source">[1] widocznosc.ai/pozycjonowanie-ai</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Optymalizacja -->
  <section id="optymalizacja" class="relative w-full" aria-labelledby="opt-title">
    <div class="content-container py-16 lg:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <div class="head-meta">
            <span class="section-index">P/03</span>
            <span class="eyebrow">Optymalizacja</span>
          </div>
          <h2 id="opt-title" class="service-section-title display-lg mt-2 mb-6">
            Co konkretnie robimy,<br />żeby {model.name} cytował Twoją markę
          </h2>
          <p class="text-ink mb-8 text-lg leading-relaxed">
            Każdy model ma własne sygnały. Poniżej cztery najważniejsze techniczne i&nbsp;contentowe
            optymalizacje pod {model.name}.
          </p>
          <a class="btn-secondary" href="/kontakt?type=audyt-ai">
            Zamów audyt
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="lg:col-span-7">
          <div class="space-y-3">
            {
              content.optimization.map((item) => (
                <div class="rounded-[15px] p-6 lg:p-7" style="background: var(--bg-surface-1);">
                  <h3
                    class="mb-2 text-lg font-medium"
                    style="font-family: var(--font-display); letter-spacing: -0.4px;"
                  >
                    {item.title}
                  </h3>
                  <p class="text-ink-muted text-sm leading-relaxed" set:html={item.desc} />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sygnały rankingowe -->
  <section id="sygnaly" class="relative w-full" aria-labelledby="signals-title">
    <div class="content-container py-16 lg:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <div class="head-meta">
            <span class="section-index">P/04</span>
            <span class="eyebrow">Sygnały rankingowe</span>
          </div>
          <h2 id="signals-title" class="service-section-title display-lg mt-2">
            Najważniejsze sygnały dla {model.name}
          </h2>
          <p class="service-section-copy">
            To praktyczna lista kontrolna: co musi być widoczne w treści, strukturze strony i
            sygnałach zewnętrznych, żeby model miał powód cytować właśnie Twoją domenę.
          </p>
        </div>
        <ul
          class="divide-y rounded-[15px] lg:col-span-7"
          style="background: var(--bg-surface-1); border-color: var(--hairline-soft);"
        >
          {
            content.signals.map((signal, i) => (
              <li
                class="flex items-start gap-5 p-6 lg:p-7"
                style="border-color: var(--hairline-soft);"
              >
                <div
                  class="text-ink-muted flex-shrink-0 text-base font-medium"
                  style="font-variant-numeric: tabular-nums;"
                >
                  0{i + 1}
                </div>
                <div class="text-ink leading-relaxed" set:html={signal} />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="relative w-full" aria-labelledby="faq-title">
    <div class="content-container py-16 lg:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <div class="head-meta">
            <span class="section-index">P/05</span>
            <span class="eyebrow">FAQ</span>
          </div>
          <h2 id="faq-title" class="service-section-title display-lg mt-2">
            Najczęstsze pytania o&nbsp;{model.name}
          </h2>
          <p class="service-section-copy">
            Te odpowiedzi są jednocześnie treścią dla użytkownika i materiałem dla wyszukiwarek AI,
            dlatego strona publikuje je również jako ustrukturyzowane dane FAQPage JSON-LD.
          </p>
        </div>
        <div class="space-y-3 lg:col-span-7">
          {
            content.faq.map((qa) => (
              <details class="faq-row group">
                <summary
                  class="text-ink flex cursor-pointer items-start justify-between gap-4 text-base font-medium"
                  style="font-family: var(--font-display); letter-spacing: -0.3px;"
                >
                  <span set:html={qa.q} />
                  <span class="text-ink-muted mt-1 text-xl transition group-open:rotate-45">+</span>
                </summary>
                <p class="text-ink-muted mt-4 leading-relaxed" set:html={qa.a} />
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Pozostałe modele -->
  <section id="pozostale-modele" class="relative w-full" aria-labelledby="other-title">
    <div class="content-container py-16 lg:py-20">
      <div class="mb-10 flex items-end justify-between gap-6">
        <div>
          <div class="head-meta">
            <span class="section-index">P/06</span>
            <span class="eyebrow">Pozostałe modele</span>
          </div>
          <h2 id="other-title" class="service-section-title display-lg mt-2">
            Optymalizacja pod inne silniki AI
          </h2>
        </div>
        <a
          href="/pozycjonowanie-ai"
          class="text-accent-blue hidden items-center gap-2 text-sm transition hover:gap-3 sm:flex"
        >
          Wszystkie modele
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          otherModels.map((m) => (
            <a
              href={m.href}
              class="card-template other-model-card group flex flex-col"
            >
              <div class="text-ink-muted text-sm">{m.vendor}</div>
              <h3
                class="mt-1 text-xl font-medium"
                style="font-family: var(--font-display); letter-spacing: -0.5px;"
              >
                {m.name}
              </h3>
              <span class="model-differentiator">{modelDifferentiators[m.slug]}</span>
              <p class="text-ink-muted mt-2 text-sm leading-relaxed">{m.shortDesc}</p>
            </a>
          ))
        }
      </div>

      <div class="model-comparison" aria-label="Porównanie modeli AI">
        <div class="comparison-head">
          <span>Porównanie modeli</span>
          <strong>{model.name} vs reszta</strong>
        </div>
        <div class="comparison-table">
          <div></div>
          <div>ChatGPT</div>
          <div>Claude</div>
          <div>Gemini</div>
          <div>Perplexity</div>
          {
            comparisonRows.map((row) => (
              <>
                <div>{row.label}</div>
                <div>{row.chatgpt}</div>
                <div>{row.claude}</div>
                <div>{row.gemini}</div>
                <div>{row.perplexity}</div>
              </>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <CTABand
    eyebrow={`Audyt pod ${model.name}`}
    title={`Sprawdź jak ${model.name} cytuje Twoją markę`}
    subtitle="Bezpłatna konsultacja 30 minut. Pokażemy gdzie marka pojawia się w odpowiedziach, gdzie konkurencja Cię wyprzedza i co realnie zrobić w pierwszych 90 dniach."
    primaryLabel="Zamów audyt AI"
    primaryHref={`/kontakt?type=audyt-ai&model=${model.slug}`}
    ghostLabel="Bezpłatna konsultacja"
    ghostHref="/kontakt?type=konsultacja"
  />

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .service-hero {
    position: relative;
    overflow: hidden;
    padding: 104px 0 88px;
    background:
      radial-gradient(
        circle at 50% 12%,
        color-mix(in srgb, var(--accent-blue) 12%, transparent) 0%,
        transparent 34%
      ),
      linear-gradient(180deg, var(--bg-surface-1) 0%, var(--bg-canvas) 78%);
    border-bottom: 1px solid var(--hairline-soft);
  }

  .service-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(var(--hairline-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.16), transparent 62%);
    pointer-events: none;
  }

  .service-hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .service-hero-copy {
    max-width: 820px;
  }

  .service-breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 36px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-muted);
  }

  .service-breadcrumb-link {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .service-breadcrumb-link:hover {
    color: var(--ink);
  }

  .service-breadcrumb-sep {
    color: var(--ink-faint);
  }

  .service-breadcrumb-current {
    color: var(--ink);
  }

  .service-eyebrow {
    margin-bottom: 28px;
  }

  .service-hero-title {
    max-width: 980px;
    margin: 0 0 28px;
    font-family: var(--font-display);
    font-size: clamp(48px, 6.4vw, 86px);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: -0.045em;
    color: var(--ink);
    text-wrap: balance;
  }

  .service-hero-subtitle {
    max-width: 780px;
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(17px, 1.4vw, 21px);
    line-height: 1.55;
    letter-spacing: -0.018em;
    color: var(--ink);
  }

  .service-hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .service-hero-panel {
    --citation-brand: #4ade80;
    display: grid;
    gap: 0.85rem;
    min-width: 0;
    padding: clamp(1rem, 2.2vw, 1.35rem);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background:
      radial-gradient(
        circle at 20% 0%,
        color-mix(in srgb, var(--accent-blue) 14%, transparent) 0%,
        transparent 34%
      ),
      var(--bg-surface-1);
  }

  :global(:root[data-theme='light']) .service-hero-panel,
  :global(:root[data-theme='light']) .citation-example {
    --citation-brand: #15803d;
  }

  .quick-check {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-lg);
    background: color-mix(in srgb, var(--bg-surface-2) 78%, transparent);
  }

  .quick-check label {
    display: block;
    margin: 0 0 0.5rem;
    color: var(--ink-faint);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .quick-check-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.55rem;
  }

  .quick-check input {
    min-width: 0;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-md);
    background: var(--bg-canvas);
    color: var(--ink);
    font: inherit;
    padding: 0.8rem 0.9rem;
  }

  .quick-check button {
    border: 0;
    border-radius: var(--r-md);
    background: var(--ink);
    color: var(--bg-canvas);
    cursor: pointer;
    font-weight: 500;
    padding: 0.8rem 1rem;
  }

  .hero-citation-preview {
    display: grid;
    gap: 0.65rem;
  }

  .hero-citation-query,
  .hero-citation-answer,
  .hero-citation-source {
    border-radius: var(--r-md);
    padding: 0.85rem 0.95rem;
    line-height: 1.5;
  }

  .hero-citation-query {
    justify-self: end;
    max-width: 86%;
    background: var(--bg-surface-2);
    color: var(--ink);
    font-size: 0.9rem;
  }

  .hero-citation-answer {
    background: var(--bg-canvas);
    color: var(--ink-muted);
    font-size: 0.9rem;
  }

  .hero-citation-answer strong,
  .citation-answer strong {
    color: var(--citation-brand);
  }

  .hero-citation-answer span,
  .hero-citation-source,
  .citation-answer span,
  .citation-source {
    color: var(--citation-brand);
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 0.84rem;
  }

  .hero-citation-source {
    border: 1px solid color-mix(in srgb, var(--citation-brand) 34%, var(--hairline-soft));
    background: color-mix(in srgb, var(--citation-brand) 9%, var(--bg-canvas));
  }

  .service-toc {
    position: sticky;
    top: 64px;
    z-index: 20;
    border-bottom: 1px solid var(--hairline-soft);
    background: color-mix(in srgb, var(--bg-canvas) 86%, transparent);
    backdrop-filter: blur(16px);
  }

  .service-toc-inner {
    display: flex;
    gap: 0.55rem;
    overflow-x: auto;
    padding-top: 0.65rem;
    padding-bottom: 0.65rem;
  }

  .service-toc a {
    flex: 0 0 auto;
    color: var(--ink-muted);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
  }

  .service-toc a:hover {
    color: var(--ink);
  }

  .service-section-head,
  .citation-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .service-section-head p,
  .service-section-copy {
    margin: 0;
    color: var(--ink-muted);
    font-size: clamp(1rem, 1.25vw, 1.12rem);
    line-height: 1.62;
  }

  .service-section-copy {
    margin-top: 1.4rem;
  }

  .head-meta {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.1rem;
  }

  .citation-example {
    --citation-brand: #4ade80;
    padding: clamp(3rem, 6vw, 5rem) 0;
    background: var(--bg-canvas);
  }

  .citation-mock {
    display: grid;
