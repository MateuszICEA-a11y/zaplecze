---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import CTABand from '../../components/CTABand.astro';
import { AI_MODELS } from '../../data/aiModels';
import { MODEL_CONTENT } from '../../data/aiModelsContent';

export const getStaticPaths = () =>
  AI_MODELS.map((model) => ({
    params: { slug: model.slug },
    props: { model },
  }));

const { model } = Astro.props;
const content = MODEL_CONTENT[model.slug];

const otherModels = AI_MODELS.filter((m) => m.slug !== model.slug);
---

<Layout
  title={`Pozycjonowanie w ${model.name} – widocznosc.ai`}
  description={content.metaDescription}
>
  <Navbar />

  <!-- Hero -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-20">
    <div class="content-container">
      <div class="mx-auto max-w-5xl">
        <!-- Breadcrumb -->
        <div class="mb-8 flex items-center gap-2 text-sm">
          <a href="/pozycjonowanie-ai" class="text-ink-muted hover:text-ink transition">
            Pozycjonowanie AI
          </a>
          <span class="text-ink-muted" aria-hidden="true">/</span>
          <span class="text-ink">{model.name}</span>
        </div>

        <div class="text-center">
          <span class="eyebrow mb-6 inline-block">{model.vendor} · model AI</span>
          <h1 class="display-xl">Pozycjonowanie<br />w&nbsp;<span class="accent">{model.name}</span></h1>
          <p
            class="text-ink mx-auto mt-8 max-w-2xl text-lg leading-relaxed"
            set:html={content.heroSubtitle}
          />
          <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a class="btn-primary" href={`/kontakt?type=audyt-ai&model=${model.slug}`}>
              Zamów audyt pod {model.name}
            </a>
            <a class="btn-secondary" href="/narzedzia/visibility-checker">
              Sprawdź widoczność · 90s
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Jak działa -->
  <section class="relative w-full" aria-labelledby="how-title">
    <div class="content-container py-16 lg:py-20">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <span class="eyebrow mb-4 inline-block">Jak działa</span>
        <h2 id="how-title" class="display-lg mt-2 mb-6">
          Jak {model.name} buduje odpowiedzi
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          content.howItWorks.map((item, i) => (
            <div class="flex flex-col rounded-[15px] p-8 lg:p-10" style="background: var(--bg-surface-1);">
              <div class="display-md text-ink-muted mb-4 leading-none">0{i + 1}</div>
              <h3 class="mb-3 text-xl font-medium" style="font-family: var(--font-display); letter-spacing: -0.5px;">
                {item.title}
              </h3>
              <p class="text-ink-muted text-sm leading-relaxed" set:html={item.desc} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Optymalizacja -->
  <section class="relative w-full" aria-labelledby="opt-title">
    <div class="content-container py-16 lg:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <span class="eyebrow mb-4 inline-block">Optymalizacja</span>
          <h2 id="opt-title" class="display-lg mt-2 mb-6">
            Co konkretnie robimy,<br />żeby {model.name} cytował Twoją markę
          </h2>
          <p class="text-ink mb-8 text-lg leading-relaxed">
            Każdy model ma własne sygnały. Poniżej cztery najważniejsze techniczne i&nbsp;contentowe
            optymalizacje pod {model.name}.
          </p>
          <a class="btn-secondary" href="/kontakt?type=audyt-ai">
            Zamów audyt
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="lg:col-span-7">
          <div class="space-y-3">
            {
              content.optimization.map((item) => (
                <div class="rounded-[15px] p-6 lg:p-7" style="background: var(--bg-surface-1);">
                  <h3 class="mb-2 text-lg font-medium" style="font-family: var(--font-display); letter-spacing: -0.4px;">
                    {item.title}
                  </h3>
                  <p class="text-ink-muted text-sm leading-relaxed" set:html={item.desc} />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sygnały rankingowe -->
  <section class="relative w-full" aria-labelledby="signals-title">
    <div class="content-container py-16 lg:py-20">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 text-center">
          <span class="eyebrow mb-4 inline-block">Sygnały rankingowe</span>
          <h2 id="signals-title" class="display-lg mt-2">
            Top 5 sygnałów dla {model.name}
          </h2>
        </div>
        <ul class="rounded-[15px] divide-y" style="background: var(--bg-surface-1); border-color: var(--hairline-soft);">
          {
            content.signals.map((signal, i) => (
              <li class="flex items-start gap-5 p-6 lg:p-7" style="border-color: var(--hairline-soft);">
                <div class="text-ink-muted flex-shrink-0 text-base font-medium" style="font-variant-numeric: tabular-nums;">
                  0{i + 1}
                </div>
                <div class="text-ink leading-relaxed">{signal}</div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="relative w-full" aria-labelledby="faq-title">
    <div class="content-container py-16 lg:py-20">
      <div class="mx-auto max-w-3xl">
        <div class="mb-10 text-center">
          <span class="eyebrow mb-4 inline-block">FAQ</span>
          <h2 id="faq-title" class="display-lg mt-2">
            Najczęstsze pytania o&nbsp;{model.name}
          </h2>
        </div>
        <div class="space-y-3">
          {
            content.faq.map((qa) => (
              <details class="faq-row group">
                <summary class="text-ink flex cursor-pointer items-start justify-between gap-4 text-base font-medium" style="font-family: var(--font-display); letter-spacing: -0.3px;">
                  <span set:html={qa.q} />
                  <span class="text-ink-muted mt-1 text-xl transition group-open:rotate-45">+</span>
                </summary>
                <p
                  class="text-ink-muted mt-4 leading-relaxed"
                  set:html={qa.a}
                />
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Pozostałe modele -->
  <section class="relative w-full" aria-labelledby="other-title">
    <div class="content-container py-16 lg:py-20">
      <div class="mb-10 flex items-end justify-between gap-6">
        <div>
          <span class="eyebrow mb-3 inline-block">Pozostałe modele</span>
          <h2 id="other-title" class="display-lg mt-2">
            Optymalizacja pod inne silniki AI
          </h2>
        </div>
        <a
          href="/pozycjonowanie-ai"
          class="text-accent-blue hidden items-center gap-2 text-sm transition hover:gap-3 sm:flex"
        >
          Wszystkie modele
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          otherModels.map((m) => (
            <a
              href={m.href}
              class="group flex flex-col rounded-[15px] p-6 transition"
              style="background: var(--bg-surface-1);"
              data-card-template
            >
              <div class="text-ink-muted text-sm">{m.vendor}</div>
              <h3 class="mt-1 text-xl font-medium" style="font-family: var(--font-display); letter-spacing: -0.5px;">
                {m.name}
              </h3>
              <p class="text-ink-muted mt-2 text-sm leading-relaxed">{m.shortDesc}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    eyebrow={`Audyt pod ${model.name}`}
    title={`Sprawdź jak ${model.name} cytuje Twoją markę`}
    subtitle="Bezpłatna konsultacja 30 minut. Pokażemy gdzie marka pojawia się w&nbsp;odpowiedziach, gdzie konkurencja Cię wyprzedza i&nbsp;co realnie zrobić w&nbsp;pierwszych 90 dniach."
    primaryLabel="Zamów audyt AI"
    primaryHref={`/kontakt?type=audyt-ai&model=${model.slug}`}
    ghostLabel="Bezpłatna konsultacja"
    ghostHref="/kontakt?type=konsultacja"
  />

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  [data-card-template]:hover {
    background: var(--bg-surface-2) !important;
  }
</style>
