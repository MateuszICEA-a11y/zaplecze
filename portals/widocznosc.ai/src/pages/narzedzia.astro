---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollUpButton from '../components/ScrollUpButton.astro';
import CTABand from '../components/CTABand.astro';

const tools = [
  {
    id: 'brand-check',
    accent: 'blue',
    eyebrow: 'Marka w AI',
    time: 'ok. 60 s',
    title: 'Widoczność marki w AI',
    desc: 'Sprawdź rozpoznawalność swojej firmy, sentyment wypowiedzi, możliwe halucynacje (zmyślone fakty) oraz konkurentów, których modele polecają zamiast Ciebie.',
    href: '/narzedzia/brand-check',
    cta: 'Sprawdź widoczność',
    bullets: [
      'ChatGPT, Claude, Gemini i Perplexity',
      'Sentyment i rozpoznawalność marki',
      'Polecani konkurenci i źródła',
    ],
    preview: [
      'twojadomena.pl',
      'ChatGPT — Brak danych ✗',
      'Claude — Poleca konkurenta ⚠',
      'Perplexity — Zna · neutralny ✓',
    ],
    crossLabel: 'Jak pozycjonować markę w ChatGPT',
    crossHref: '/pozycjonowanie-ai/chatgpt',
  },
  {
    id: 'url-check',
    accent: 'green',
    eyebrow: 'Treści pod AI',
    time: 'ok. 30 s',
    title: 'Ocena cytowalności strony',
    desc: 'Przeanalizuj pojedynczy adres URL pod kątem struktury odpowiedzi, danych Schema.org, sekcji FAQ, świeżości i nagłówków przydatnych dla modeli AI.',
    href: '/narzedzia/url-check',
    cta: 'Oceń stronę',
    bullets: [
      'Wskaźnik dostosowania do AI (Alignment Score)',
      'Analiza danych strukturalnych i FAQ',
      'Priorytety zmian na stronie',
    ],
    preview: ['/blog/x — 43/100', 'BLUF ▪▪▪▫▫ 60%', 'FAQ ▫▫▫▫▫ 0%', 'Schema ▪▪▫▫▫ 40%'],
    crossLabel: 'Jak tworzyć treści cytowane przez AI',
    crossHref: '/pozycjonowanie-ai/gemini',
  },
  {
    id: 'ai-bots-check',
    accent: 'amber',
    eyebrow: 'Dostęp botów',
    time: 'ok. 5 s',
    title: 'Dostęp botów AI',
    desc: 'Sprawdź plik robots.txt i zobacz, czy GPTBot, ClaudeBot, PerplexityBot, Google-Extended i inne modele w ogóle widzą Twoją domenę.',
    href: '/narzedzia/ai-bots-check',
    cta: 'Sprawdź boty AI',
    bullets: [
      'Weryfikacja 13 botów AI',
      'Zezwolenia i blokady dla poszczególnych systemów',
      'Gotowy szablon naprawy pliku',
    ],
    preview: ['GPTBot ✓ · ClaudeBot ✗', 'Google-Extended ✗', 'PerplexityBot ✓ · CCBot ✗'],
    crossLabel: 'Dlaczego dostęp botów wpływa na cytowania',
    crossHref: '/pozycjonowanie-ai',
  },
  {
    id: 'fanout',
    accent: 'violet',
    eyebrow: 'Rozbicie zapytania',
    time: 'ok. 30 s',
    title: 'Analiza zapytań AI',
    desc: 'Zobacz pomocnicze zapytania generowane w tle przez modele językowe (tzw. Query Fan-out) oraz domeny, z których ostatecznie czerpią wiedzę.',
    href: '/narzedzia/fanout',
    cta: 'Analizuj zapytanie',
    bullets: [
      'Zapytania pomocnicze modelu',
      'Ostatecznie zacytowane domeny',
      'Bezpośredni wgląd w surowe dane',
    ],
    preview: ['„najlepsza agencja SEO"', '↳ 8 pomocniczych zapytań', '↳ 12 cytowanych domen'],
    crossLabel: 'Jak modele wybierają źródła odpowiedzi',
    crossHref: '/pozycjonowanie-ai/perplexity',
  },
];

const siteUrl = 'https://widocznosc.ai';
---

<Layout
  title="Darmowe narzędzia widoczności AI – widocznosc.ai"
  description="Cztery darmowe narzędzia od widocznosc.ai: Widoczność marki w AI, Ocena cytowalności strony, Dostęp botów AI i Analiza zapytań AI."
>
  <Navbar />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      itemListElement: tools.map((tool, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        item: {
          '@type': 'SoftwareApplication',
          name: tool.title,
          applicationCategory: 'BusinessApplication',
          description: tool.desc,
          url: `${siteUrl}${tool.href}`,
          offers: {
            '@type': 'Offer',
            price: 0,
            priceCurrency: 'PLN',
          },
        },
      })),
    })}
  />

  <div>
    <section class="tools-hero">
      <div class="content-container tools-hero-inner">
        <div class="tools-hero-copy">
          <span class="eyebrow tools-eyebrow">Narzędzia widocznosc.ai</span>
          <h1 class="display-xxl">
            <span class="tools-title-line">Darmowe testy</span>
            <span class="tools-title-line">widoczności</span>
            <span class="tools-title-line">w AI</span>
          </h1>
          <p>
            Sprawdź najważniejsze sygnały przed zamówieniem audytu: zobacz, co modele wiedzą o
            Twojej marce, czy Twoje treści nadają się do cytowania, czy boty mają dostęp do strony
            i jakie źródła sztuczna inteligencja pobiera w tle.
          </p>
          <div class="tools-hero-actions">
            <a class="btn-primary" href="/narzedzia/brand-check">Sprawdź markę</a>
            <a class="btn-secondary" href="#tools-title">Zobacz wszystkie narzędzia</a>
          </div>
        </div>
        <aside class="tools-hero-panel" aria-label="Rekomendowana ścieżka testów">
          <div class="tools-panel-top">
            <span class="tools-panel-kicker">Start bez formularza</span>
            <strong>4 testy, które pokazują gdzie AI widzi Twoją markę</strong>
          </div>
          <ol class="tools-panel-flow">
            <li>
              <span>01</span>
              <strong>Widoczność marki w AI</strong>
              <em>rozpoznawalność i konkurenci</em>
            </li>
            <li>
              <span>02</span>
              <strong>Dostęp botów AI</strong>
              <em>dostęp botów do domeny</em>
            </li>
            <li>
              <span>03</span>
              <strong>Ocena cytowalności strony</strong>
              <em>cytowalność konkretnej strony</em>
            </li>
            <li>
              <span>04</span>
              <strong>Analiza zapytań AI</strong>
              <em>zapytania i źródła w tle</em>
            </li>
          </ol>
          <dl class="tools-panel-stats">
            <div>
              <dt>narzędzia</dt>
              <dd>4</dd>
            </div>
            <div>
              <dt>logowania</dt>
              <dd>0</dd>
            </div>
            <div>
              <dt>maks. czas</dt>
              <dd>90s</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="tools-section" aria-labelledby="tools-title">
      <div class="content-container">
        <div class="section-head">
          <div class="head-meta">
            <span class="section-index">T/01</span>
            <span class="eyebrow">Wybierz narzędzie</span>
          </div>
          <h2 id="tools-title" class="display-xl">Szybka diagnoza bez formularza sprzedażowego</h2>
        </div>

        <div class="tool-order" aria-label="Rekomendowana kolejność testów">
          <span class="tool-order-label">Rekomendowana kolejność testów: Zacznij od</span>
          <ol>
            <li><a href="/narzedzia/brand-check">Widoczność marki w AI</a></li>
            <li><a href="/narzedzia/ai-bots-check">Dostęp botów AI</a></li>
            <li><a href="/narzedzia/url-check">Ocena cytowalności strony</a></li>
            <li><a href="/narzedzia/fanout">Analiza zapytań AI</a></li>
          </ol>
        </div>

        <div class="tools-grid">
          {
            tools.map((tool, index) => (
              <article class={`tool-card tool-card--${tool.accent}`} id={tool.id}>
                <a class="tool-card-link" href={tool.href} aria-label={tool.cta}>
                  <div class="tool-card-top">
                    <span class="tool-number">{String(index + 1).padStart(2, '0')}</span>
                    <span class="tool-time">{tool.time}</span>
                  </div>
                  <span class="eyebrow tool-meta">{tool.eyebrow}</span>
                  <h3 class="display-md">{tool.title}</h3>
                  <p class="tool-desc">{tool.desc}</p>
                  <ul class="tool-bullets">
                    {tool.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                  <div class="tool-preview" aria-hidden="true">
                    <span class="tool-preview-label">przykład</span>
                    {tool.preview.map((line) => (
                      <span>{line}</span>
                    ))}
                  </div>
                  <span class="tool-cta">
                    {tool.cta}
                    <span aria-hidden="true">→</span>
                  </span>
                </a>
              </article>
            ))
          }
        </div>

        <p class="tools-cross-strip">
          <span class="tools-cross-strip-label">Czytaj dalej:</span>
          {
            tools.map((tool) => (
              <a href={tool.crossHref}>
                {tool.crossLabel}
                <span aria-hidden="true">→</span>
              </a>
            ))
          }
        </p>
      </div>
    </section>

    <CTABand
      compactTop
      eyebrow="Pełny audyt"
      title="Potrzebujesz pełnego obrazu widoczności w AI?"
      subtitle="Darmowe narzędzia pokazują tylko wycinkowe sygnały. W pełnym audycie łączymy wyniki dla marki, treści, źródeł, działań konkurencji i dostępności technicznej w jeden konkretny plan działania."
      primaryLabel="Porozmawiajmy o audycie"
      primaryHref="/kontakt?type=audyt-ai"
      ghostLabel="Zobacz pozycjonowanie w AI"
      ghostHref="/pozycjonowanie-ai"
      rightLabel="Pełny audyt"
      quote={`„Łączymy wyniki rozpoznawalności, analizy technicznej i zachowania botów w priorytety działań dla Twojej firmy na pierwsze 90 dni."`}
      meta={['4 darmowe testy', 'Pełny audyt', 'Plan 90 dni']}
    />
  </div>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .tools-hero {
    position: relative;
    overflow: hidden;
    padding: 104px 0 84px;
    border-bottom: 1px solid var(--hairline-soft);
    background:
      radial-gradient(
        circle at 28% 16%,
        color-mix(in srgb, var(--accent-blue) 14%, transparent) 0%,
        transparent 34%
      ),
      linear-gradient(180deg, var(--bg-surface-1) 0%, var(--bg-canvas) 78%);
  }

  .tools-hero-inner,
  .tools-section > .content-container {
    box-sizing: border-box;
  }

  .tools-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(var(--hairline-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.14), transparent 64%);
    pointer-events: none;
  }

  .tools-hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(22rem, 0.72fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .tools-eyebrow {
    margin-bottom: 1.45rem;
  }

  .tools-hero h1 {
    max-width: 980px;
    margin: 0;
    color: var(--ink);
    letter-spacing: 0;
    line-height: 0.98;
    text-wrap: balance;
  }

  .tools-title-line {
    display: inline;
  }

  .tools-title-line + .tools-title-line::before {
    content: ' ';
  }

  .tools-hero-copy p {
    max-width: 720px;
    margin: 1.55rem 0 0;
    color: var(--ink);
    font-size: clamp(1.05rem, 1.35vw, 1.22rem);
    line-height: 1.58;
  }

  .tools-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: 2.4rem;
  }

  .tools-hero-panel {
    --panel-accent: #38bdf8;
    display: grid;
    gap: 0.95rem;
    min-width: 0;
    padding: clamp(1rem, 2.4vw, 1.35rem);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background:
      radial-gradient(
        circle at 18% 0%,
        color-mix(in srgb, var(--panel-accent) 18%, transparent) 0%,
        transparent 36%
      ),
      var(--bg-surface-1);
    box-shadow: 0 24px 80px color-mix(in srgb, #000 18%, transparent);
  }

  .tools-panel-top {
    display: grid;
    gap: 0.55rem;
    padding: 1rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-lg);
    background: color-mix(in srgb, var(--bg-surface-2) 76%, transparent);
  }

  .tools-panel-kicker {
    color: var(--panel-accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .tools-panel-top strong {
    color: var(--ink);
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.25;
    text-wrap: balance;
  }

  .tools-panel-flow {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tools-panel-flow li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.15rem 0.7rem;
    align-items: center;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-md);
    background: var(--bg-canvas);
  }

  .tools-panel-flow span {
    grid-row: span 2;
    color: var(--panel-accent);
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 0.78rem;
  }

  .tools-panel-flow strong {
    color: var(--ink);
    font-size: 0.93rem;
    line-height: 1.2;
  }

  .tools-panel-flow em {
    color: var(--ink-muted);
    font-size: 0.82rem;
    font-style: normal;
    line-height: 1.25;
  }

  .tools-panel-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin: 0;
    padding: 0.9rem 0 0;
    border-top: 1px solid var(--hairline-soft);
  }

  .tools-panel-stats div {
    padding: 0 0.75rem;
    border-right: 1px solid var(--hairline-soft);
  }

  .tools-panel-stats div:first-child {
    padding-left: 0;
  }

  .tools-panel-stats div:last-child {
    border-right: 0;
    padding-right: 0;
  }

  .tools-panel-stats dt {
    color: var(--ink-faint);
    font-size: 0.72rem;
    line-height: 1.3;
  }

  .tools-panel-stats dd {
    margin: 0.28rem 0 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.6vw, 2rem);
    line-height: 1;
  }

  .tools-section {
    padding: clamp(3.5rem, 7vw, 6.5rem) 0 clamp(2.25rem, 4vw, 3.5rem);
    background: var(--bg-canvas);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .section-head h2 {
    max-width: 780px;
    margin: 0;
    color: var(--ink);
    text-wrap: balance;
  }

  .tool-order {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0 0 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-lg);
    background: var(--bg-surface-1);
    color: var(--ink-muted);
    font-size: 0.9rem;
  }

  .tool-order-label {
    color: var(--ink);
    font-weight: 600;
    white-space: nowrap;
  }

  .tool-order ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tool-order li {
    display: inline-flex;
    gap: 0.8rem;
    align-items: center;
  }

  .tool-order li + li::before {
    content: '→';
    color: var(--ink-faint);
  }

  .tool-order a {
    color: var(--ink-muted);
    text-decoration: none;
  }

  .tool-order a:hover {
    color: var(--ink);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .tool-card {
    --tool-accent: var(--accent-blue);
    display: flex;
    min-height: 100%;
    flex-direction: column;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background:
      radial-gradient(
        circle at 18% 0%,
        color-mix(in srgb, var(--tool-accent) 18%, transparent) 0%,
        transparent 36%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-surface-1) 92%, var(--tool-accent) 8%) 0%,
        var(--bg-surface-1) 76%
      );
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .tool-card--blue {
    --tool-accent: #38bdf8;
  }

  .tool-card--green {
    --tool-accent: #4ade80;
  }

  .tool-card--amber {
    --tool-accent: #fbbf24;
  }

  .tool-card--violet {
    --tool-accent: #a78bfa;
  }

  :global(:root[data-theme='light']) .tool-card--green {
    --tool-accent: #16a34a;
  }

  :global(:root[data-theme='light']) .tool-card--amber {
    --tool-accent: #d97706;
  }

  :global(:root[data-theme='light']) .tool-card--violet {
    --tool-accent: #7c3aed;
  }

  .tool-card-link {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    padding: clamp(1.25rem, 2.6vw, 2rem);
    border-radius: var(--r-xl);
    color: inherit;
    text-decoration: none;
  }

  .tool-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--tool-accent) 50%, var(--hairline));
  }

  .tool-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.3rem;
  }

  .tool-number {
    color: var(--tool-accent);
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
  }

  .tool-time {
    padding: 0.35rem 0.7rem;
    border-radius: var(--r-pill);
    background: color-mix(in srgb, var(--tool-accent) 12%, var(--bg-surface-2));
    color: var(--ink);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .tool-meta {
    align-self: flex-start;
  }

  .tool-card h3 {
    margin: 0.75rem 0 0;
    color: var(--ink);
  }

  .tool-desc {
    margin: 1rem 0 0;
    color: var(--ink-muted);
    line-height: 1.58;
  }

  .tool-bullets {
    display: grid;
    gap: 0.58rem;
    margin: 1.4rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tool-bullets li {
    color: var(--ink);
    font-size: 0.94rem;
    line-height: 1.35;
  }

  .tool-bullets li::before {
    content: '';
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    margin-right: 0.6rem;
    border-radius: 50%;
    background: var(--tool-accent);
    vertical-align: 0.12rem;
  }

  .tool-preview {
    display: grid;
    gap: 0.42rem;
    margin-top: 1.35rem;
    padding: 0.9rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-md);
    background: color-mix(in srgb, var(--tool-accent) 7%, var(--bg-surface-2));
    color: var(--ink-muted);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    line-height: 1.38;
  }

  .tool-preview span {
    overflow-wrap: anywhere;
  }

  .tool-preview-label {
    width: max-content;
    padding: 0.16rem 0.42rem;
    border: 1px solid color-mix(in srgb, var(--tool-accent) 36%, transparent);
    border-radius: var(--r-pill);
    color: var(--tool-accent);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .tool-preview span:nth-child(2) {
    color: var(--ink);
  }

  .tool-cta {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    margin-top: auto;
    padding-top: 2rem;
    color: var(--tool-accent);
    font-weight: 500;
  }

  .tools-cross-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.9rem;
    align-items: center;
    margin: 1rem 0 0;
    padding: 0.9rem 1rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-lg);
    background: var(--bg-surface-1);
    color: var(--ink-muted);
    font-size: 0.86rem;
    line-height: 1.35;
  }

  .tools-cross-strip-label {
    color: var(--ink);
    font-weight: 600;
  }

  .tools-cross-strip a {
    color: var(--ink-muted);
    font-weight: 500;
    text-decoration: none;
  }

  .tools-cross-strip a:hover {
    color: var(--ink);
  }

  @media (max-width: 980px) {
    .tools-hero-inner {
      grid-template-columns: 1fr;
    }

    .tools-hero-panel {
