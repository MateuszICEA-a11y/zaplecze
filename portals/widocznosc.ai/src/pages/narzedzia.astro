---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollUpButton from '../components/ScrollUpButton.astro';
import CTABand from '../components/CTABand.astro';

const tools = [
  {
    id: 'brand-check',
    eyebrow: 'Marka w AI',
    time: 'ok. 60 s',
    title: 'Co AI wie o Twojej marce',
    desc: 'Sprawdź rozpoznawalność swojej firmy, sentyment wypowiedzi, możliwe halucynacje (zmyślone fakty) oraz konkurentów, których modele polecają zamiast Ciebie.',
    href: '/narzedzia/brand-check',
    cta: 'Sprawdź markę',
    bullets: [
      'ChatGPT, Claude, Gemini i Perplexity',
      'Sentyment i rozpoznawalność marki',
      'Polecani konkurenci i źródła',
    ],
    preview: [
      'twojadomena.pl',
      'ChatGPT — Brak danych ✗',
      'Claude — Poleca konkurenta ⚠',
      'Perplexity — Zna · neutralny ✓',
    ],
    crossLabel: 'Jak pozycjonować markę w ChatGPT',
    crossHref: '/pozycjonowanie-ai/chatgpt',
  },
  {
    id: 'url-check',
    eyebrow: 'Treści pod AI',
    time: 'ok. 30 s',
    title: 'Czy Twój tekst będzie cytowany',
    desc: 'Przeanalizuj pojedynczy adres URL pod kątem struktury odpowiedzi, danych Schema.org, sekcji FAQ, świeżości i nagłówków przydatnych dla modeli AI.',
    href: '/narzedzia/url-check',
    cta: 'Sprawdź URL',
    bullets: [
      'Wskaźnik dostosowania do AI (Alignment Score)',
      'Analiza danych strukturalnych i FAQ',
      'Priorytety zmian na stronie',
    ],
    preview: ['/blog/x — 43/100', 'BLUF ▪▪▪▫▫ 60%', 'FAQ ▫▫▫▫▫ 0%', 'Schema ▪▪▫▫▫ 40%'],
    crossLabel: 'Jak tworzyć treści cytowane przez AI',
    crossHref: '/pozycjonowanie-ai/gemini',
  },
  {
    id: 'ai-bots-check',
    eyebrow: 'Dostęp botów',
    time: 'ok. 5 s',
    title: 'Czy AI może wejść na Twoją stronę',
    desc: 'Sprawdź plik robots.txt i zobacz, czy GPTBot, ClaudeBot, PerplexityBot, Google-Extended i inne modele w ogóle widzą Twoją domenę.',
    href: '/narzedzia/ai-bots-check',
    cta: 'Sprawdź boty',
    bullets: [
      'Weryfikacja 13 botów AI',
      'Zezwolenia i blokady dla poszczególnych systemów',
      'Gotowy szablon naprawy pliku',
    ],
    preview: ['GPTBot ✓ · ClaudeBot ✗', 'Google-Extended ✗', 'PerplexityBot ✓ · CCBot ✗'],
    crossLabel: 'Dlaczego dostęp botów wpływa na cytowania',
    crossHref: '/pozycjonowanie-ai',
  },
  {
    id: 'fanout',
    eyebrow: 'Rozbicie zapytania',
    time: 'ok. 30 s',
    title: 'Jak AI szuka informacji w tle',
    desc: 'Zobacz pomocnicze zapytania generowane w tle przez modele językowe (tzw. Query Fan-out) oraz domeny, z których ostatecznie czerpią wiedzę.',
    href: '/narzedzia/fanout',
    cta: 'Zobacz rozbicie zapytania',
    bullets: [
      'Zapytania pomocnicze modelu',
      'Ostatecznie zacytowane domeny',
      'Bezpośredni wgląd w surowe dane',
    ],
    preview: ['„najlepsza agencja SEO"', '↳ 8 pomocniczych zapytań', '↳ 12 cytowanych domen'],
    crossLabel: 'Jak modele wybierają źródła odpowiedzi',
    crossHref: '/pozycjonowanie-ai/perplexity',
  },
];

const siteUrl = 'https://widocznosc.ai';
---

<Layout
  title="Darmowe narzędzia widoczności AI – widocznosc.ai"
  description="Cztery darmowe narzędzia od widocznosc.ai: Brand Check, URL Check, AI Bots Check i Analiza zapytań (Fan-out). Sprawdź widoczność marki, treści i dostęp botów AI."
>
  <Navbar />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      itemListElement: tools.map((tool, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        item: {
          '@type': 'SoftwareApplication',
          name: tool.title,
          applicationCategory: 'BusinessApplication',
          description: tool.desc,
          url: `${siteUrl}${tool.href}`,
          offers: {
            '@type': 'Offer',
            price: 0,
            priceCurrency: 'PLN',
          },
        },
      })),
    })}
  />

  <main>
    <section class="tools-hero">
      <div class="content-container tools-hero-inner">
        <div class="tools-hero-copy">
          <span class="eyebrow tools-eyebrow">Narzędzia widocznosc.ai</span>
          <h1 class="display-xxl">Darmowe testy widoczności w AI</h1>
          <p>
            Sprawdź najważniejsze sygnały przed zamówieniem audytu: zobacz, co modele wiedzą o
            Twojej marce, czy Twoje treści nadają się do cytowania, czy boty mają dostęp do strony
            i jakie źródła sztuczna inteligencja pobiera w tle.
          </p>
        </div>
        <div class="tools-hero-panel" aria-label="Zakres narzędzi">
          <div>
            <span>4</span>
            <p>darmowe narzędzia</p>
          </div>
          <div>
            <span>0</span>
            <p>logowania</p>
          </div>
          <div>
            <span>90s</span>
            <p>najdłuższy test</p>
          </div>
        </div>
      </div>
    </section>

    <section class="tools-section" aria-labelledby="tools-title">
      <div class="content-container">
        <div class="section-head">
          <div class="head-meta">
            <span class="section-index">T/01</span>
            <span class="eyebrow">Wybierz narzędzie</span>
          </div>
          <h2 id="tools-title" class="display-xl">Szybka diagnoza bez formularza sprzedażowego</h2>
        </div>

        <div class="tool-order" aria-label="Rekomendowana kolejność testów">
          <span class="tool-order-label">Rekomendowana kolejność testów: Zacznij od</span>
          <ol>
            <li><a href="/narzedzia/brand-check">Brand Check</a></li>
            <li><a href="/narzedzia/ai-bots-check">AI Bots Check</a></li>
            <li><a href="/narzedzia/url-check">URL Check</a></li>
            <li><a href="/narzedzia/fanout">Rozbicie zapytania</a></li>
          </ol>
        </div>

        <div class="tools-grid">
          {
            tools.map((tool, index) => (
              <article class="tool-card" id={tool.id}>
                <a class="tool-card-link" href={tool.href} aria-label={tool.cta}>
                  <div class="tool-card-top">
                    <span class="tool-number">{String(index + 1).padStart(2, '0')}</span>
                    <span class="tool-time">{tool.time}</span>
                  </div>
                  <span class="eyebrow tool-meta">{tool.eyebrow}</span>
                  <h3 class="display-md">{tool.title}</h3>
                  <p class="tool-desc">{tool.desc}</p>
                  <ul class="tool-bullets">
                    {tool.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                  <div class="tool-preview" aria-hidden="true">
                    <span class="tool-preview-label">przykład</span>
                    {tool.preview.map((line) => (
                      <span>{line}</span>
                    ))}
                  </div>
                  <span class="tool-cta">
                    {tool.cta}
                    <span aria-hidden="true">→</span>
                  </span>
                </a>
              </article>
            ))
          }
        </div>

        <p class="tools-cross-strip">
          <span class="tools-cross-strip-label">Czytaj dalej:</span>
          {
            tools.map((tool) => (
              <a href={tool.crossHref}>
                {tool.crossLabel}
                <span aria-hidden="true">→</span>
              </a>
            ))
          }
        </p>
      </div>
    </section>

    <CTABand
      eyebrow="Pełny audyt"
      title="Potrzebujesz pełnego obrazu widoczności w AI?"
      subtitle="Darmowe narzędzia pokazują tylko wycinkowe sygnały. W pełnym audycie łączymy wyniki dla marki, treści, źródeł, działań konkurencji i dostępności technicznej w jeden konkretny plan działania."
      primaryLabel="Porozmawiajmy o audycie"
      primaryHref="/kontakt?type=audyt-ai"
      ghostLabel="Zobacz pozycjonowanie w AI"
      ghostHref="/pozycjonowanie-ai"
      rightLabel="Pełny audyt"
      quote={`„Łączymy wyniki rozpoznawalności, analizy technicznej i zachowania botów w priorytety działań dla Twojej firmy na pierwsze 90 dni."`}
      meta={['4 darmowe testy', 'Pełny audyt', 'Plan 90 dni']}
    />
  </main>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .tools-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(6rem, 9vw, 8rem) 0 clamp(2.6rem, 5vw, 4.5rem);
    background:
      radial-gradient(
        circle at 18% 18%,
        color-mix(in srgb, var(--accent-blue) 13%, transparent),
        transparent 34rem
      ),
      linear-gradient(180deg, var(--bg-canvas) 0%, var(--bg-surface-1) 100%);
  }

  .tools-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 0.38fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }

  .tools-eyebrow {
    margin-bottom: 1.1rem;
  }

  .tools-hero h1 {
    max-width: 780px;
    margin: 0;
    color: var(--ink);
    text-wrap: balance;
  }

  .tools-hero-copy p {
    max-width: 680px;
    margin: 1.35rem 0 0;
    color: var(--ink-muted);
    font-size: clamp(1rem, 1.25vw, 1.12rem);
    line-height: 1.6;
  }

  .tools-hero-panel {
    display: grid;
    gap: 0.55rem;
    padding: 0.7rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background: color-mix(in srgb, var(--bg-surface-2) 78%, transparent);
  }

  .tools-hero-panel div {
    padding: 0.85rem 0.95rem;
    border-radius: var(--r-md);
    background: var(--bg-canvas);
  }

  .tools-hero-panel span {
    display: block;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.4vw, 2.15rem);
    line-height: 1;
  }

  .tools-hero-panel p {
    margin: 0.45rem 0 0;
    color: var(--ink-muted);
    font-size: 0.84rem;
    line-height: 1.35;
  }

  .tools-section {
    padding: clamp(3.5rem, 7vw, 6.5rem) 0;
    background: var(--bg-canvas);
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: end;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .section-head h2 {
    max-width: 780px;
    margin: 0;
    color: var(--ink);
    text-wrap: balance;
  }

  .tool-order {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0 0 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-lg);
    background: var(--bg-surface-1);
    color: var(--ink-muted);
    font-size: 0.9rem;
  }

  .tool-order-label {
    color: var(--ink);
    font-weight: 600;
    white-space: nowrap;
  }

  .tool-order ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tool-order li {
    display: inline-flex;
    gap: 0.8rem;
    align-items: center;
  }

  .tool-order li + li::before {
    content: '→';
    color: var(--ink-faint);
  }

  .tool-order a {
    color: var(--ink-muted);
    text-decoration: none;
  }

  .tool-order a:hover {
    color: var(--ink);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .tool-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background: var(--bg-surface-1);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .tool-card-link {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    padding: clamp(1.25rem, 2.6vw, 2rem);
    border-radius: var(--r-xl);
    color: inherit;
    text-decoration: none;
  }

  .tool-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent-blue) 40%, var(--hairline));
    background: color-mix(in srgb, var(--bg-surface-1) 78%, var(--accent-blue) 6%);
  }

  .tool-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.3rem;
  }

  .tool-number {
    color: var(--accent-blue);
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
  }

  .tool-time {
    padding: 0.35rem 0.7rem;
    border-radius: var(--r-pill);
    background: var(--bg-surface-2);
    color: var(--ink-muted);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .tool-meta {
    align-self: flex-start;
  }

  .tool-card h3 {
    margin: 0.75rem 0 0;
    color: var(--ink);
  }

  .tool-desc {
    margin: 1rem 0 0;
    color: var(--ink-muted);
    line-height: 1.58;
  }

  .tool-bullets {
    display: grid;
    gap: 0.58rem;
    margin: 1.4rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tool-bullets li {
    color: var(--ink);
    font-size: 0.94rem;
    line-height: 1.35;
  }

  .tool-bullets li::before {
    content: '';
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    margin-right: 0.6rem;
    border-radius: 50%;
    background: var(--accent-blue);
    vertical-align: 0.12rem;
  }

  .tool-preview {
    display: grid;
    gap: 0.42rem;
    margin-top: 1.35rem;
    padding: 0.9rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-md);
    background: var(--bg-surface-2);
    color: var(--ink-muted);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    line-height: 1.38;
  }

  .tool-preview span {
    overflow-wrap: anywhere;
  }

  .tool-preview-label {
    width: max-content;
    padding: 0.16rem 0.42rem;
    border: 1px solid color-mix(in srgb, var(--accent-blue) 28%, transparent);
    border-radius: var(--r-pill);
    color: var(--accent-blue);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .tool-preview span:nth-child(2) {
    color: var(--ink);
  }

  .tool-cta {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    margin-top: auto;
    padding-top: 2rem;
    color: var(--ink);
    font-weight: 500;
  }

  .tools-cross-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.9rem;
    align-items: center;
    margin: 1rem 0 0;
    padding: 0.9rem 1rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-lg);
    background: var(--bg-surface-1);
    color: var(--ink-muted);
    font-size: 0.86rem;
    line-height: 1.35;
  }

  .tools-cross-strip-label {
    color: var(--ink);
    font-weight: 600;
  }

  .tools-cross-strip a {
    color: var(--ink-muted);
    font-weight: 500;
    text-decoration: none;
  }

  .tools-cross-strip a:hover {
    color: var(--ink);
  }

  @media (max-width: 980px) {
    .tools-hero-inner {
      grid-template-columns: 1fr;
    }

    .tools-hero-panel {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 760px) {
    .tools-hero {
      padding-top: 5.5rem;
    }

    .tools-hero-panel,
    .tools-grid {
      grid-template-columns: 1fr;
    }

    .section-head {
      display: block;
    }

    .section-head h2 {
      margin-top: 0.75rem;
    }

    .tool-order {
      display: block;
    }

    .tool-order ol {
      margin-top: 0.65rem;
    }
  }
</style>
