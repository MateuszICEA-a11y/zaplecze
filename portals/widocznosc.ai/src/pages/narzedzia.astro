---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollUpButton from '../components/ScrollUpButton.astro';

const tools = [
  {
    id: 'brand-check',
    eyebrow: 'Marka w AI',
    time: 'ok. 60 s',
    title: 'Co AI wie o Twojej marce',
    desc:
      'Sprawdź rozpoznawalność marki, sentyment, możliwe halucynacje i konkurentów polecanych zamiast Ciebie.',
    href: '/narzedzia/brand-check',
    cta: 'Sprawdź markę',
    bullets: ['ChatGPT, Claude, Gemini i Perplexity', 'Sentyment i rozpoznawalność', 'Konkurenci i źródła'],
  },
  {
    id: 'url-check',
    eyebrow: 'Content pod AI',
    time: 'ok. 30 s',
    title: 'Czy Twój content jest cytowalny',
    desc:
      'Przeanalizuj pojedynczy URL pod kątem BLUF, FAQ, schema, świeżości, nagłówków i sygnałów przydatnych dla modeli AI.',
    href: '/narzedzia/url-check',
    cta: 'Sprawdź URL',
    bullets: ['AI SEO Alignment Score', 'Schema i FAQ', 'Priorytety zmian'],
  },
  {
    id: 'ai-bots-check',
    eyebrow: 'Dostęp botów',
    time: 'ok. 5 s',
    title: 'Czy boty AI mają dostęp do strony',
    desc:
      'Sprawdź robots.txt i zobacz, czy GPTBot, ClaudeBot, PerplexityBot, Google-Extended i inne boty mogą wejść na domenę.',
    href: '/narzedzia/ai-bots-check',
    cta: 'Sprawdź boty',
    bullets: ['13 user-agentów AI', 'Allow / disallow per bot', 'Gotowy szablon naprawy'],
  },
  {
    id: 'fanout',
    eyebrow: 'Fan-out',
    time: 'ok. 30 s',
    title: 'Jak AI rozbija zapytanie',
    desc:
      'Zobacz zapytania wyszukiwania ujawnione przez model oraz domeny, które pojawiły się jako cytowane źródła.',
    href: '/narzedzia/fanout',
    cta: 'Pokaż fan-out',
    bullets: ['Zapytania wyszukiwania', 'Cytowane domeny', 'Bez automatycznego raportu'],
  },
];
---

<Layout
  title="Darmowe narzędzia AI SEO – widocznosc.ai"
  description="Cztery darmowe narzędzia widocznosc.ai: Brand Check, URL Check, AI Bots Check i Fan-out ChatGPT. Sprawdź widoczność marki, content i dostęp botów AI."
>
  <Navbar />

  <main>
    <section class="tools-hero">
      <div class="content-container tools-hero-inner">
        <div class="tools-hero-copy">
          <span class="eyebrow tools-eyebrow">Narzędzia widocznosc.ai</span>
          <h1>Darmowe testy widoczności w AI</h1>
          <p>
            Sprawdź najważniejsze sygnały przed audytem: co modele wiedzą o marce,
            czy content nadaje się do cytowania, czy boty mają dostęp do strony i jakie źródła pojawiają się w fan-oucie.
          </p>
        </div>
        <div class="tools-hero-panel" aria-label="Zakres narzędzi">
          <div>
            <span>4</span>
            <p>darmowe narzędzia</p>
          </div>
          <div>
            <span>0</span>
            <p>logowania</p>
          </div>
          <div>
            <span>AI</span>
            <p>marka, content, dostęp i źródła</p>
          </div>
        </div>
      </div>
    </section>

    <section class="tools-section" aria-labelledby="tools-title">
      <div class="content-container">
        <div class="section-head">
          <span class="section-kicker">Wybierz narzędzie</span>
          <h2 id="tools-title">Szybka diagnoza bez formularza sprzedażowego</h2>
        </div>

        <div class="tools-grid">
          {tools.map((tool, index) => (
            <article class="tool-card" id={tool.id}>
              <a class="tool-card-link" href={tool.href} aria-label={tool.cta}>
                <div class="tool-card-top">
                  <span class="tool-number">{String(index + 1).padStart(2, '0')}</span>
                  <span class="tool-time">{tool.time}</span>
                </div>
                <div class="tool-meta">{tool.eyebrow}</div>
                <h3>{tool.title}</h3>
                <p class="tool-desc">{tool.desc}</p>
                <ul class="tool-bullets">
                  {tool.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
                <span class="tool-cta">
                  {tool.cta}
                  <span aria-hidden="true">→</span>
                </span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="audit-cta" aria-labelledby="audit-title">
      <div class="content-container audit-cta-inner">
        <div>
          <span class="section-kicker">Pełny audyt</span>
          <h2 id="audit-title">Potrzebujesz pełnego obrazu widoczności w AI?</h2>
          <p>
            Darmowe narzędzia pokazują pojedyncze sygnały. W audycie łączymy wyniki dla marki,
            contentu, źródeł, konkurencji i dostępności technicznej w konkretny plan działań.
          </p>
        </div>
        <a class="btn-primary audit-button" href="/kontakt?type=audyt-ai">
          Porozmawiajmy o audycie
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .tools-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(6rem, 9vw, 8rem) 0 clamp(2.6rem, 5vw, 4.5rem);
    background:
      radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--accent-blue) 13%, transparent), transparent 34rem),
      linear-gradient(180deg, var(--bg-canvas) 0%, var(--bg-surface-1) 100%);
  }

  .tools-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 0.38fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }

  .tools-eyebrow {
    margin-bottom: 1.1rem;
  }

  .tools-hero h1 {
    max-width: 780px;
    margin: 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(2.9rem, 6.4vw, 5.9rem);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .tools-hero-copy p {
    max-width: 680px;
    margin: 1.35rem 0 0;
    color: var(--ink-muted);
    font-size: clamp(1rem, 1.25vw, 1.12rem);
    line-height: 1.6;
  }

  .tools-hero-panel {
    display: grid;
    gap: 0.55rem;
    padding: 0.7rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background: color-mix(in srgb, var(--bg-surface-2) 78%, transparent);
  }

  .tools-hero-panel div {
    padding: 0.85rem 0.95rem;
    border-radius: var(--r-md);
    background: var(--bg-canvas);
  }

  .tools-hero-panel span {
    display: block;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.4vw, 2.15rem);
    line-height: 1;
  }

  .tools-hero-panel p {
    margin: 0.45rem 0 0;
    color: var(--ink-muted);
    font-size: 0.84rem;
    line-height: 1.35;
  }

  .tools-section {
    padding: clamp(3.5rem, 7vw, 6.5rem) 0;
    background: var(--bg-canvas);
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: end;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .section-kicker {
    display: inline-flex;
    color: var(--accent-blue);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-head h2,
  .audit-cta h2 {
    max-width: 780px;
    margin: 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.8vw, 4.7rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .tool-card {
    min-height: 100%;
  }

  .tool-card-link {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    padding: clamp(1.25rem, 2.6vw, 2rem);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background: var(--bg-surface-1);
    color: inherit;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .tool-card-link:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent-blue) 40%, var(--hairline));
    background: color-mix(in srgb, var(--bg-surface-1) 78%, var(--accent-blue) 6%);
  }

  .tool-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.3rem;
  }

  .tool-number {
    color: var(--accent-blue);
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
  }

  .tool-time {
    padding: 0.35rem 0.7rem;
    border-radius: var(--r-pill);
    background: var(--bg-surface-2);
    color: var(--ink-muted);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .tool-meta {
    color: var(--accent-blue);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tool-card h3 {
    margin: 0.75rem 0 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 3.1rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0;
  }

  .tool-desc {
    margin: 1rem 0 0;
    color: var(--ink-muted);
    line-height: 1.58;
  }

  .tool-bullets {
    display: grid;
    gap: 0.58rem;
    margin: 1.4rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tool-bullets li {
    color: var(--ink);
    font-size: 0.94rem;
    line-height: 1.35;
  }

  .tool-bullets li::before {
    content: '';
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    margin-right: 0.6rem;
    border-radius: 50%;
    background: var(--accent-blue);
    vertical-align: 0.12rem;
  }

  .tool-cta {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    margin-top: auto;
    padding-top: 2rem;
    color: var(--ink);
    font-weight: 800;
  }

  .audit-cta {
    padding: 0 0 clamp(4rem, 8vw, 7rem);
    background: var(--bg-canvas);
  }

  .audit-cta-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
    padding: clamp(1.5rem, 4vw, 3rem);
    border: 1px solid color-mix(in srgb, var(--accent-blue) 24%, var(--hairline));
    border-radius: var(--r-xl);
    background:
      radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent-blue) 16%, transparent), transparent 24rem),
      var(--bg-surface-1);
  }

  .audit-cta p {
    max-width: 720px;
    margin: 1rem 0 0;
    color: var(--ink-muted);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .audit-button {
    align-self: end;
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .tools-hero-inner,
    .audit-cta-inner {
      grid-template-columns: 1fr;
    }

    .tools-hero-panel {
      grid-template-columns: repeat(3, 1fr);
    }

    .audit-button {
      justify-self: start;
    }
  }

  @media (max-width: 760px) {
    .tools-hero {
      padding-top: 5.5rem;
    }

    .tools-hero h1 {
      font-size: clamp(2.7rem, 11vw, 4.1rem);
    }

    .tools-hero-panel,
    .tools-grid {
      grid-template-columns: 1fr;
    }

    .section-head {
      display: block;
    }

    .section-head h2 {
      margin-top: 0.75rem;
    }
  }
</style>
