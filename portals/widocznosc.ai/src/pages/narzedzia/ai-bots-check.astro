---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import { AI_BOTS, CATEGORY_LABELS, CATEGORY_DESCRIPTIONS } from '../../../functions/_lib/ai-bots';

const categories = ['training', 'search', 'on-demand', 'common-crawl'] as const;
---

<Layout
  title="AI Bots Check – czy boty AI mają dostęp do Twojej strony?"
  description="Sprawdź w 5 sekund, które z 13 robotów AI (m.in. GPTBot, ClaudeBot, PerplexityBot, Google-Extended) mają dostęp do Twojej strony. Diagnoza pliku robots.txt i lista konkretnych zmian. Darmowe, bez logowania."
>
  <Navbar />

  <main class="flex-grow">
    <section class="tool-hero">
      <div class="content-container tool-hero-inner">
        <!-- Hero -->
        <nav class="tool-breadcrumb" aria-label="Ścieżka nawigacji">
          <a href="/narzedzia" class="tool-breadcrumb-link">Narzędzia</a>
          <span class="tool-breadcrumb-sep" aria-hidden="true">/</span>
          <span class="tool-breadcrumb-current">AI Bots Check</span>
        </nav>
        <header class="text-center">
          <span class="eyebrow tool-eyebrow"> Narzędzie · bezpłatne </span>
          <h1 class="tool-hero-title">
            Czy <span class="tool-hero-accent">boty AI</span> mają dostęp do Twojej strony?
          </h1>
          <p class="tool-hero-copy">
            Sprawdzamy Twój plik <code class="font-mono text-sm">robots.txt</code> pod kątem 13
            najważniejszych robotów skanujących sztucznej inteligencji (m.in. GPTBot, ClaudeBot,
            PerplexityBot, Google-Extended, CCBot). Odbierz wynik w&nbsp;5 sekund, bez konieczności
            logowania.
          </p>
        </header>

        <!-- Form -->
        <form
          id="check-form"
          class="check-form mx-auto mt-12 flex flex-col gap-3 sm:flex-row"
          novalidate
        >
          <label class="sr-only" for="domain-input">Domena lub URL</label>
          <input
            id="domain-input"
            name="url"
            type="text"
            required
            autocomplete="off"
            spellcheck="false"
            placeholder="Wpisz domenę lub URL"
            class="check-input flex-1"
          />
          <button type="submit" class="btn-primary check-submit">
            <span class="check-submit-label">Sprawdź dostęp</span>
            <span class="check-submit-spinner" aria-hidden="true"></span>
          </button>
        </form>
        <p class="check-note mx-auto mt-3 max-w-2xl text-center text-sm">
          Pobieramy jedynie publicznie dostępny plik <code class="font-mono">robots.txt</code> – nie
          wykonujemy żadnych zmian na Twojej stronie i nie zapisujemy Twoich danych.
        </p>

        <!-- Results placeholder -->
        <section id="results" class="mt-14 hidden" aria-live="polite"></section>
      </div>
    </section>

    <!-- Default bots overview – pokazane PRZED submit -->
    <section id="default-overview" class="tool-overview">
      <div class="content-container">
        <h2 class="display-lg tool-overview-title">13 botów AI w 4 kategoriach funkcjonalnych</h2>
        <p class="text-ink tool-overview-copy mt-6 max-w-3xl text-lg leading-relaxed">
          Każdy z robotów AI ma własny identyfikator sieciowy (tzw. <code
            class="font-mono text-sm">User-agent</code
          >) i zupełnie inaczej wpływa na widoczność Twojej marki. Roboty wyszukiwawcze decydują o
          tym, czy AI zacytuje Cię w swoich odpowiedziach, natomiast roboty treningowe pobierają
          Twoje teksty, by uczyć na nich swoje modele.
        </p>
        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          {
            categories.map((cat) => {
              const botsInCat = AI_BOTS.filter((b) => b.category === cat);
              return (
                <div class="bot-category-card">
                  <div class="bot-category-header">
                    <span class="bot-category-label">{CATEGORY_LABELS[cat]}</span>
                    <span class="bot-category-count">
                      {botsInCat.length} {botsInCat.length === 1 ? 'bot' : 'boty'}
                    </span>
                  </div>
                  <p class="bot-category-desc">{CATEGORY_DESCRIPTIONS[cat]}</p>
                  <ul class="bot-category-list">
                    {botsInCat.map((bot) => (
                      <li class="bot-category-item">
                        <span class="bot-name">{bot.name}</span>
                        <span class="bot-owner">{bot.owner}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .tool-hero {
    position: relative;
    overflow: hidden;
    padding: 104px 0 88px;
    background:
      radial-gradient(
        circle at 50% 12%,
        color-mix(in srgb, var(--accent-blue) 12%, transparent) 0%,
        transparent 34%
      ),
      linear-gradient(180deg, var(--bg-surface-1) 0%, var(--bg-canvas) 78%);
    border-bottom: 1px solid var(--hairline-soft);
  }

  .tool-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(var(--hairline-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.16), transparent 62%);
    pointer-events: none;
  }

  .tool-hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .tool-breadcrumb {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 36px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-muted);
  }

  .tool-breadcrumb-link {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .tool-breadcrumb-link:hover {
    color: var(--ink);
  }

  .tool-breadcrumb-sep {
    color: var(--ink-faint);
  }

  .tool-breadcrumb-current {
    color: var(--ink);
  }

  .tool-eyebrow {
    margin-bottom: 28px;
  }

  /* Hero – accent na "boty AI" */
  .tool-hero-title {
    max-width: 980px;
    margin: 0 auto;
    font-family: var(--font-display);
    font-size: clamp(48px, 6.4vw, 86px);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: -0.045em;
    color: var(--ink);
    text-wrap: balance;
  }

  .tool-hero-accent {
    color: var(--accent-blue);
  }

  .tool-hero-copy {
    max-width: 780px;
    margin: 28px auto 0;
    font-family: var(--font-sans);
    font-size: clamp(17px, 1.4vw, 21px);
    line-height: 1.55;
    letter-spacing: -0.018em;
    color: var(--ink);
  }

  .tool-overview {
    padding: 72px 0 80px;
  }

  .tool-overview-title {
    max-width: 960px;
  }

  .tool-overview-copy {
    font-size: 17px;
    line-height: 1.62;
  }

  /* Form input – wyróżniony, parity z url-check */
  .check-form {
    width: min(100%, 840px);
  }

  .check-input {
    flex: 1 1 auto;
    min-width: 0;
    height: 56px;
    padding: 0 22px;
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--ink);
    background: var(--bg-surface-2);
    border: 1px solid var(--hairline);
    border-radius: var(--r-md);
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }
  .check-input::placeholder {
    color: var(--ink-muted);
  }
  .check-input:hover {
    border-color: var(--accent-blue);
  }
  .check-input:focus {
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(56, 130, 246, 0.15);
  }

  .check-submit {
    height: 56px;
    min-width: 210px;
    justify-content: center;
    position: relative;
  }

  .check-note {
    color: var(--ink-muted);
  }

  .check-submit[aria-busy='true'] .check-submit-label {
    opacity: 0;
  }
  .check-submit-spinner {
    position: absolute;
    width: 18px;
    height: 18px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    opacity: 0;
    animation: spin 0.7s linear infinite;
  }
  .check-submit[aria-busy='true'] .check-submit-spinner {
    opacity: 1;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Bot category cards (pre-check) */
  .bot-category-card {
    background: var(--bg-surface-1);
    border: 1px solid color-mix(in srgb, var(--hairline) 78%, var(--ink) 22%);
    border-radius: var(--r-lg);
    padding: 24px 24px 28px;
    box-shadow: 0 16px 44px rgb(15 23 42 / 0.04);
  }
  .bot-category-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .bot-category-label {
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 650;
    letter-spacing: 0;
  }
  .bot-category-count {
    color: var(--ink);
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    background: var(--bg-surface-2);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
  }
  .bot-category-desc {
    color: var(--ink-muted);
    font-size: 15px;
    line-height: 1.55;
    margin-bottom: 18px;
    max-width: 42rem;
  }
  .bot-category-list {
    display: grid;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .bot-category-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    min-height: 46px;
    padding: 10px 14px 10px 16px;
    background: var(--bg-surface-2);
    border: 1px solid var(--hairline);
    border-radius: var(--r-sm);
    font-family: var(--font-mono, ui-monospace, 'SF Mono', monospace);
    font-size: 13px;
  }
  .bot-category-item::before {
    content: '';
    width: 6px;
    height: 6px;
    flex: none;
    border-radius: 50%;
    background: var(--accent-blue);
    opacity: 0.75;
  }
  .bot-name {
    flex: 1;
    min-width: 0;
    color: var(--ink);
    font-weight: 650;
    overflow-wrap: anywhere;
  }
  .bot-owner {
    flex: none;
    color: var(--ink);
    background: var(--bg-canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    padding: 3px 8px;
    font-size: 11.5px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  /* Results section – styled in JS via inline classes */
  :global(.results-card) {
    background: var(--bg-surface-1);
    border-radius: var(--r-lg);
    padding: 28px;
  }

  :global(.results-summary) {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    margin-bottom: 24px;
  }

  :global(.results-stat) {
    background: var(--bg-canvas);
    border-radius: var(--r-md);
    padding: 16px 20px;
  }
  :global(.results-stat-value) {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -1px;
    color: var(--ink);
  }
  :global(.results-stat-value.is-good) {
    color: var(--success-green);
  }
  :global(.results-stat-value.is-bad) {
    color: #ef4444;
  }
  :global(.results-stat-label) {
    color: var(--ink-muted);
    font-size: 12px;
    margin-top: 6px;
  }

  :global(.results-meta) {
    color: var(--ink-muted);
    font-size: 13px;
    margin-top: 12px;
    margin-bottom: 24px;
  }
  :global(.results-meta a) {
    color: var(--accent-blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  :global(.results-meta a:hover) {
    opacity: 0.85;
  }

  :global(.bot-result-grid) {
    display: grid;
    gap: 8px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    :global(.bot-result-grid) {
      grid-template-columns: 1fr 1fr;
    }
  }

  :global(.bot-result-row) {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 12px 16px;
    background: var(--bg-canvas);
    border-radius: var(--r-md);
  }
  :global(.bot-result-row.is-blocked) {
    background: rgb(239 68 68 / 0.08);
  }
  :global(.bot-result-row.is-blocked-critical) {
    background: rgb(239 68 68 / 0.14);
  }
  :global(.bot-result-status) {
    width: 22px;
    height: 22px;
    flex: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
  }
  :global(.bot-result-status.is-allowed) {
    background: rgb(26 170 85 / 0.18);
    color: var(--success-green);
  }
  :global(.bot-result-status.is-blocked) {
    background: rgb(239 68 68 / 0.18);
    color: #ef4444;
  }
  :global(.bot-result-name) {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }
  :global(.bot-result-owner) {
    color: var(--ink-muted);
    font-size: 11px;
    letter-spacing: 0.02em;
    margin-top: 2px;
  }
  :global(.bot-result-tag) {
    color: var(--ink-muted);
    font-size: 11px;
    padding: 4px 10px;
    background: var(--bg-surface-2);
    border-radius: var(--r-pill);
  }

  :global(.action-items) {
    margin-top: 24px;
    display: grid;
    gap: 10px;
  }
  :global(.action-item) {
    border-left: 3px solid var(--hairline);
    padding: 14px 16px 14px 18px;
    background: var(--bg-canvas);
    border-radius: 0 8px 8px 0;
  }
  :global(.action-item.is-p0) {
    border-left-color: #ef4444;
  }
  :global(.action-item.is-p1) {
    border-left-color: #fbbf24;
  }
  :global(.action-item.is-p2) {
    border-left-color: var(--success-green);
  }
  :global(.action-item-priority) {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 8px;
  }
  :global(.action-item.is-p0 .action-item-priority) {
    background: rgb(239 68 68 / 0.15);
    color: #ef4444;
  }
  :global(.action-item.is-p1 .action-item-priority) {
    background: rgb(251 191 36 / 0.15);
    color: #fbbf24;
  }
  :global(.action-item.is-p2 .action-item-priority) {
    background: rgb(26 170 85 / 0.15);
    color: var(--success-green);
  }
  :global(.action-item-title) {
    color: var(--ink);
    font-weight: 600;
    margin-bottom: 6px;
    font-size: 15px;
  }
  :global(.action-item-desc) {
    color: var(--ink-muted);
    font-size: 14px;
    line-height: 1.55;
  }

  :global(.results-error) {
    background: rgb(239 68 68 / 0.1);
    border-radius: var(--r-md);
    padding: 16px 20px;
    color: #ef4444;
    font-size: 14px;
  }

  @media (max-width: 640px) {
    .tool-hero {
      padding: 72px 0 64px;
    }

    .tool-hero-inner {
      align-items: flex-start;
      text-align: left;
    }

    .tool-breadcrumb {
      justify-content: flex-start;
      margin-bottom: 28px;
      font-size: 13px;
    }

    .tool-eyebrow {
      margin-bottom: 22px;
    }

    .tool-hero-title {
      max-width: 100%;
      font-size: clamp(42px, 12vw, 52px);
      line-height: 0.98;
      letter-spacing: -0.043em;
      overflow-wrap: anywhere;
    }

    .tool-hero-copy {
      max-width: 100%;
      margin-top: 24px;
      font-size: 17px;
      line-height: 1.5;
    }

    .check-form {
      width: 100%;
    }

    .check-input {
      flex: none;
      width: 100%;
      height: 62px;
      font-size: 15px;
      padding-inline: 20px;
      background: var(--bg-surface-1);
      border-color: color-mix(in srgb, var(--hairline) 68%, var(--ink) 32%);
      border-radius: var(--r-lg);
      box-shadow: inset 0 0.5px 0 rgba(255, 255, 255, 0.08);
    }

    .check-input::placeholder {
      color: var(--ink);
      opacity: 0.72;
    }

    .check-submit {
      height: 58px;
      min-width: 0;
      width: 100%;
      margin-top: 2px;
      font-size: 15px;
    }

    .check-note {
      max-width: 100%;
      margin-top: 14px;
      color: var(--ink);
      font-size: 14px;
      line-height: 1.45;
      text-align: left;
      opacity: 0.78;
    }

    .tool-overview {
      padding: 56px 0 64px;
    }

    .tool-overview-title {
      font-size: clamp(34px, 10vw, 44px);
      line-height: 1;
      letter-spacing: -0.04em;
    }
  }
</style>

<script>
  type CheckResponse = {
    domain: string;
    checkedPath: string;
    robotsUrl: string;
    fetchedAt: string;
    status: 'ok' | 'no-robots' | 'fetch-error' | 'cloudflare-blocked';
    statusCode?: number;
    summary: {
      allowed: number;
      blocked: number;
      criticalBlocked: number;
      total: number;
    };
    bots: Array<{
      name: string;
      userAgent: string;
      owner: string;
      category: string;
      categoryLabel: string;
      purpose: string;
      impact: string;
      critical: boolean;
      allowed: boolean;
      matchedUserAgent: string | null;
    }>;
    actionItems: Array<{
      priority: 'P0' | 'P1' | 'P2';
      title: string;
      description: string;
    }>;
  };

  const escapeHtml = (s: string): string =>
    s.replace(/[&<>"']/g, (c) => {
      const map: Record<string, string> = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      };
      return map[c]!;
    });

  const renderResults = (data: CheckResponse): string => {
    const { summary, bots, actionItems, domain, checkedPath, robotsUrl, status, statusCode } = data;

    const summaryHtml = `
      <div class="results-summary">
        <div class="results-stat">
          <div class="results-stat-value ${summary.allowed === summary.total ? 'is-good' : ''}">${summary.allowed}</div>
          <div class="results-stat-label">Dopuszczonych</div>
        </div>
        <div class="results-stat">
          <div class="results-stat-value ${summary.blocked > 0 ? 'is-bad' : ''}">${summary.blocked}</div>
          <div class="results-stat-label">Zablokowanych</div>
        </div>
        <div class="results-stat">
          <div class="results-stat-value ${summary.criticalBlocked > 0 ? 'is-bad' : ''}">${summary.criticalBlocked}</div>
          <div class="results-stat-label">Krytycznych zablok.</div>
        </div>
        <div class="results-stat">
          <div class="results-stat-value">${summary.total}</div>
          <div class="results-stat-label">Razem botów</div>
        </div>
      </div>
    `;

    let metaText = '';
    if (status === 'ok') {
      metaText = `Status: <strong>OK ${statusCode}</strong> · Ścieżka: <code>${escapeHtml(checkedPath)}</code> · Sprawdzono <a href="${escapeHtml(robotsUrl)}" target="_blank" rel="noopener">robots.txt</a>`;
    } else if (status === 'no-robots') {
      metaText = `Status: <strong>${statusCode}</strong> – brak pliku robots.txt na <a href="${escapeHtml(robotsUrl)}" target="_blank" rel="noopener">${escapeHtml(robotsUrl)}</a>. W praktyce wszystkie boty są dopuszczone (konwencja).`;
    } else if (status === 'cloudflare-blocked') {
      metaText = `<strong style="color:#ef4444">Cloudflare zablokował dostęp</strong> do robots.txt – boty AI też tego nie przejdą.`;
    } else if (status === 'fetch-error') {
      metaText = `<strong style="color:#ef4444">Nie można potwierdzić dostępu</strong> · HTTP ${statusCode} dla <a href="${escapeHtml(robotsUrl)}" target="_blank" rel="noopener">robots.txt</a>`;
    }

    const botsHtml = bots
      .map((bot) => {
        const rowClass = !bot.allowed ? (bot.critical ? 'is-blocked-critical' : 'is-blocked') : '';
        const statusClass = bot.allowed ? 'is-allowed' : 'is-blocked';
        const statusSym = bot.allowed ? '✓' : '✗';
        const matched =
          bot.matchedUserAgent === '*'
            ? 'reguła *'
            : bot.matchedUserAgent
              ? `match: ${bot.matchedUserAgent}`
              : 'brak reguły';
        return `
          <div class="bot-result-row ${rowClass}">
            <div class="bot-result-status ${statusClass}">${statusSym}</div>
            <div>
              <div class="bot-result-name">${escapeHtml(bot.name)}${bot.critical ? ' <span style="color:#ef4444;font-size:10px;font-weight:600">★ KRYT.</span>' : ''}</div>
              <div class="bot-result-owner">${escapeHtml(bot.owner)} · ${escapeHtml(matched)}</div>
            </div>
            <span class="bot-result-tag">${escapeHtml(bot.categoryLabel)}</span>
          </div>
        `;
      })
      .join('');

    const actionsHtml = actionItems
      .map(
        (item) => `
          <div class="action-item is-${item.priority.toLowerCase()}">
            <span class="action-item-priority">${item.priority}</span>
            <div class="action-item-title">${escapeHtml(item.title)}</div>
            <div class="action-item-desc">${escapeHtml(item.description)}</div>
          </div>
        `
      )
      .join('');

    return `
      <div class="results-card">
        <h2 class="display-md mb-3">
          Wynik dla <span class="font-mono text-ink-muted">${escapeHtml(domain)}</span>
        </h2>
        <div class="results-meta">${metaText}</div>
        ${summaryHtml}
        <div class="bot-result-grid">${botsHtml}</div>
        <div class="action-items">${actionsHtml}</div>
      </div>
    `;
  };

  const initForm = () => {
    const form = document.getElementById('check-form') as HTMLFormElement | null;
    const input = document.getElementById('domain-input') as HTMLInputElement | null;
    const resultsEl = document.getElementById('results') as HTMLElement | null;
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const overviewEl = document.getElementById('default-overview');
    if (!form || !input || !resultsEl || !submitBtn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const value = input.value.trim();
      if (!value) {
        input.focus();
        return;
      }

      submitBtn.setAttribute('aria-busy', 'true');
      submitBtn.disabled = true;
      resultsEl.classList.remove('hidden');
      resultsEl.innerHTML = `<div class="results-card"><div class="results-meta">Sprawdzam ${escapeHtml(value)}…</div></div>`;
      overviewEl?.classList.add('hidden');

      try {
        const response = await fetch('/api/tools/ai-bots-check', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url: value }),
        });

        if (!response.ok) {
          const errBody = await response.json().catch(() => null);
          const msg =
            (errBody && typeof errBody === 'object' && 'error' in errBody && errBody.error) ||
            `Błąd ${response.status}`;
          resultsEl.innerHTML = `<div class="results-error">${escapeHtml(String(msg))}</div>`;
          return;
        }

        const data = (await response.json()) as CheckResponse;
        resultsEl.innerHTML = renderResults(data);
        resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch (err) {
        const msg = err instanceof Error ? err.message : 'Błąd sieci';
        resultsEl.innerHTML = `<div class="results-error">${escapeHtml(msg)}</div>`;
      } finally {
        submitBtn.setAttribute('aria-busy', 'false');
        submitBtn.disabled = false;
      }
    });
  };

  document.addEventListener('astro:page-load', initForm);
  if (document.readyState !== 'loading') initForm();
  else document.addEventListener('DOMContentLoaded', initForm);
</script>
