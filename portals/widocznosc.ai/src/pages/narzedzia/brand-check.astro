---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
---

<Layout
  title="Widoczność marki w AI – co modele wiedzą o Twojej marce?"
  description="Sprawdź, jak ChatGPT, Claude, Gemini i Perplexity opisują Twoją markę. Zbadaj sentyment, wykryj zmyślone fakty (halucynacje) i sprawdź, kogo AI poleca zamiast Ciebie."
>
  <Navbar />

  <main class="flex-grow">
    <section class="tool-hero">
      <div class="content-container tool-hero-inner">
        <nav class="tool-breadcrumb" aria-label="Ścieżka nawigacji">
          <a href="/narzedzia" class="tool-breadcrumb-link">Narzędzia</a>
          <span class="tool-breadcrumb-sep" aria-hidden="true">/</span>
          <span class="tool-breadcrumb-current">Widoczność marki w AI</span>
        </nav>

        <header class="text-center">
          <span class="eyebrow tool-eyebrow">Narzędzie · audyt marki</span>
          <h1 class="tool-hero-title display-xxl">
            Co AI wie o&nbsp;<span class="tool-hero-accent">Twojej marce</span>?
          </h1>
          <p class="tool-hero-copy">
            Sprawdzamy, jak najpopularniejsze modele AI opisują Twoją firmę, czy poprawnie cytują
            Twoją domenę, jakie błędy powtarzają i których konkurentów podpowiadają zamiast Ciebie.
          </p>
        </header>

        <form id="brand-form" class="brand-form" novalidate>
          <div class="field-grid">
            <label class="field">
              <span>Nazwa marki</span>
              <input
                id="brand-input"
                name="brand"
                type="text"
                required
                autocomplete="organization"
                placeholder="np. ICEA"
              />
            </label>
            <label class="field">
              <span>Domena</span>
              <input
                id="domain-input"
                name="domain"
                type="text"
                autocomplete="url"
                spellcheck="false"
                placeholder="np. grupa-icea.pl"
              />
            </label>
            <label class="field">
              <span>Kategoria</span>
              <input
                id="category-input"
                name="category"
                type="text"
                autocomplete="off"
                placeholder="np. agencja SEO"
              />
            </label>
            <label class="field">
              <span>Rynek</span>
              <input id="market-input" name="market" type="text" value="Polska" />
            </label>
          </div>

          <button type="submit" class="btn-primary check-submit">
            <span class="check-submit-label">Sprawdź markę</span>
            <span class="check-submit-spinner" aria-hidden="true"></span>
          </button>
          <p class="check-note">
            Test trwa zazwyczaj od 30 do 60 sekund. Wszystkie modele AI są odpytywane niezależnie,
            dzięki czemu raport generuje się płynnie nawet w przypadku chwilowych obciążeń
            poszczególnych systemów.
          </p>
        </form>

        <section id="results" class="results-wrap hidden" aria-live="polite"></section>
      </div>
    </section>

    <section id="default-overview" class="tool-overview">
      <div class="content-container">
        <h2 class="display-xl tool-overview-title">Co mierzy Widoczność marki w AI?</h2>
        <div class="overview-grid">
          <article class="overview-card">
            <span class="overview-num">01</span>
            <h3>Rozpoznawalność</h3>
            <p>
              Sprawdzamy, czy sztuczna inteligencja w ogóle kojarzy Twoją firmę, zna ją tylko
              częściowo, czy musi zgadywać Twoją ofertę na podstawie szczątkowych danych w sieci.
            </p>
          </article>
          <article class="overview-card">
            <span class="overview-num">02</span>
            <h3>Sentyment</h3>
            <p>
              Weryfikujemy, czy wydźwięk opisu Twojej marki jest pozytywny, neutralny, czy może
              poszczególne modele mają na Twój temat zupełnie sprzeczne informacje.
            </p>
          </article>
          <article class="overview-card">
            <span class="overview-num">03</span>
            <h3>Halucynacje (zmyślone fakty)</h3>
            <p>
              Wykrywamy, czy sztuczna inteligencja nie przypisuje Ci błędnych usług, niewłaściwych
              lokalizacji lub fałszywych twierdzeń, które mogą wprowadzać Twoich klientów w błąd.
            </p>
          </article>
          <article class="overview-card">
            <span class="overview-num">04</span>
            <h3>Polecani konkurenci</h3>
            <p>
              Sprawdzamy, jakie inne firmy i alternatywy modele AI podsuwają użytkownikom zamiast
              analizowanej marki (i do kogo możesz tracić potencjalnych klientów).
            </p>
          </article>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .tool-hero {
    position: relative;
    overflow: hidden;
    padding: 104px 0 88px;
    background:
      radial-gradient(
        circle at 50% 12%,
        color-mix(in srgb, var(--accent-blue) 12%, transparent) 0%,
        transparent 34%
      ),
      linear-gradient(180deg, var(--bg-surface-1) 0%, var(--bg-canvas) 78%);
    border-bottom: 1px solid var(--hairline-soft);
  }

  .tool-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(var(--hairline-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.16), transparent 62%);
    pointer-events: none;
  }

  .tool-hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .tool-breadcrumb {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 36px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-muted);
  }

  .tool-breadcrumb-link {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .tool-breadcrumb-link:hover {
    color: var(--ink);
  }

  .tool-breadcrumb-sep {
    color: var(--ink-faint);
  }

  .tool-breadcrumb-current {
    color: var(--ink);
  }

  .tool-eyebrow {
    margin-bottom: 28px;
  }

  .tool-hero-title {
    max-width: 980px;
    margin: 0 auto;
    font-size: clamp(36px, 4.1vw, 56px);
    line-height: 0.96;
    letter-spacing: -0.045em;
    color: var(--ink);
    text-wrap: balance;
  }

  .tool-hero-accent {
    color: var(--accent-blue);
  }

  .tool-hero-copy {
    max-width: 820px;
    margin: 28px auto 0;
    font-family: var(--font-sans);
    font-size: clamp(17px, 1.4vw, 21px);
    line-height: 1.55;
    letter-spacing: -0.018em;
    color: var(--ink);
  }

  .brand-form {
    width: min(100%, 980px);
    margin: 48px auto 0;
    padding: 24px;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    text-align: left;
  }

  .field-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  @media (min-width: 768px) {
    .field-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .field span {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 650;
    color: var(--ink-muted);
  }

  .field input {
    width: 100%;
    height: 54px;
    padding: 0 18px;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
    background: var(--bg-surface-2);
    border: 1px solid var(--hairline);
    border-radius: var(--r-md);
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }

  .field input::placeholder {
    color: var(--ink-muted);
  }

  .field input:focus {
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(56, 130, 246, 0.15);
  }

  .check-submit {
    position: relative;
    width: 100%;
    justify-content: center;
    height: 56px;
    margin-top: 18px;
  }

  .check-note {
    margin: 12px 0 0;
    color: var(--ink-muted);
    font-size: 13px;
    line-height: 1.5;
    text-align: center;
  }

  .check-submit[aria-busy='true'] .check-submit-label {
    opacity: 0;
  }

  .check-submit-spinner {
    position: absolute;
    width: 18px;
    height: 18px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    opacity: 0;
    animation: spin 0.7s linear infinite;
  }

  .check-submit[aria-busy='true'] .check-submit-spinner {
    opacity: 1;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  :global(.brand-loading-card) {
    width: min(100%, 820px);
    margin-inline: auto;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    padding: clamp(22px, 3vw, 32px);
    box-shadow: 0 20px 56px rgb(15 23 42 / 0.06);
  }

  :global(.brand-loading-header) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 22px;
  }

  :global(.brand-loading-kicker) {
    color: var(--accent-blue);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  :global(.brand-loading-title) {
    font-family: var(--font-display);
    font-size: clamp(26px, 3.2vw, 40px);
    line-height: 1.05;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.025em;
    margin: 0;
  }

  :global(.brand-loading-copy) {
    color: var(--ink-muted);
    font-size: 14px;
    line-height: 1.55;
    margin: 10px 0 0;
    max-width: 560px;
  }

  :global(.brand-loading-orb) {
    width: 42px;
    height: 42px;
    flex: none;
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--accent-blue) 18%, transparent);
    border-top-color: var(--accent-blue);
    animation: spin 0.8s linear infinite;
  }

  :global(.brand-loading-track) {
    position: relative;
    height: 8px;
    overflow: hidden;
    border-radius: var(--r-pill);
    background: var(--bg-surface-2);
    margin: 20px 0 22px;
  }

  :global(.brand-loading-bar) {
    position: absolute;
    inset: 0 auto 0 0;
    width: 42%;
    border-radius: inherit;
    background: var(--accent-blue);
    animation: loading-slide 1.45s ease-in-out infinite;
  }

  @keyframes loading-slide {
    0% {
      transform: translateX(-105%);
    }
    55% {
      transform: translateX(70%);
    }
    100% {
      transform: translateX(245%);
    }
  }

  :global(.brand-loading-steps) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  :global(.brand-loading-step) {
    min-width: 0;
    padding: 12px 13px;
    border-radius: var(--r-md);
    background: var(--bg-canvas);
    border: 1px solid color-mix(in srgb, var(--hairline) 74%, transparent);
  }

  :global(.brand-loading-step-name) {
    color: var(--ink);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.2;
  }

  :global(.brand-loading-step-status) {
    color: var(--ink-muted);
    font-size: 11.5px;
    line-height: 1.25;
    margin-top: 5px;
  }

  .tool-overview {
    padding: 72px 0 80px;
  }

  .tool-overview-title {
    max-width: 960px;
    font-size: clamp(30px, 3.2vw, 44px);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 36px;
  }

  @media (min-width: 768px) {
    .overview-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1120px) {
    .overview-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .overview-card {
    background: var(--bg-surface-1);
    border: 1px solid color-mix(in srgb, var(--hairline) 78%, var(--ink) 22%);
    border-radius: var(--r-lg);
    padding: 24px 24px 28px;
    box-shadow: 0 16px 44px rgb(15 23 42 / 0.04);
  }

  .overview-num {
    display: block;
    font-family: var(--font-display);
    font-size: 24px;
    line-height: 1;
    color: var(--accent-blue);
    margin-bottom: 18px;
  }

  .overview-card h3 {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 650;
    color: var(--ink);
    margin: 0 0 10px;
  }

  .overview-card p {
    color: var(--ink-muted);
    font-size: 15px;
    line-height: 1.55;
    margin: 0;
  }

  .results-wrap {
    width: min(100%, 1080px);
    margin-top: 54px;
    text-align: left;
  }

  .hidden {
    display: none;
  }

  :global(.brand-results) {
    display: grid;
    gap: 20px;
  }

  :global(.brand-score-card) {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 28px;
    align-items: center;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    padding: 30px;
  }

  :global(.brand-score-circle) {
    width: 132px;
    height: 132px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at center, var(--bg-surface-1) 56%, transparent 58%),
      conic-gradient(var(--accent-blue) calc(var(--score) * 1%), var(--bg-surface-2) 0);
  }

  :global(.brand-score-num) {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.04em;
  }

  :global(.brand-score-meta) {
    min-width: 0;
  }

  :global(.brand-score-kicker) {
    color: var(--accent-blue);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  :global(.brand-score-title) {
    font-family: var(--font-sans);
    font-size: 22px !important;
    font-weight: 700;
    line-height: 1.18 !important;
    color: var(--ink);
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }

  :global(.brand-score-copy) {
    color: var(--ink-muted);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }

  :global(.brand-stats) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
  }

  :global(.brand-stat) {
    background: var(--bg-surface-1);
    border-radius: var(--r-lg);
    padding: 18px 20px;
  }

  :global(.brand-stat-value) {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--ink);
  }

  :global(.brand-stat-label) {
    color: var(--ink-muted);
    font-size: 12px;
    margin-top: 4px;
  }

  :global(.brand-panel) {
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    padding: clamp(20px, 3vw, 30px);
  }

  :global(.brand-panel-head) {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    padding-bottom: 24px;
    margin-bottom: 4px;
  }

  :global(.brand-panel-title) {
    font-family: var(--font-sans);
    font-size: 22px !important;
    line-height: 1.18 !important;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
  }

  :global(.brand-panel-note) {
    max-width: 420px;
    color: var(--ink-muted);
    font-size: 13px;
    line-height: 1.45;
    margin: 0;
  }

  :global(.brand-model-grid) {
    display: grid;
    gap: 16px;
  }

  :global(.brand-model-row) {
    display: grid;
    grid-template-columns: minmax(132px, 180px) 1fr;
    gap: 22px;
    padding: 20px 22px;
    background: var(--bg-canvas);
    border-radius: var(--r-lg);
    border: 1px solid color-mix(in srgb, var(--hairline) 74%, transparent);
  }

  :global(.brand-model-name) {
    color: var(--ink);
    font-weight: 700;
    font-size: 15px;
  }

  :global(.brand-model-pill) {
    display: inline-flex;
    width: fit-content;
    margin-top: 8px;
    padding: 4px 9px;
    border-radius: var(--r-pill);
    background: var(--bg-surface-2);
    color: var(--ink-muted);
    font-size: 11px;
    line-height: 1.25;
    overflow-wrap: anywhere;
  }

  :global(.brand-model-summary) {
    color: var(--ink);
    font-size: 15px;
    line-height: 1.58;
    margin: 0 0 12px;
  }

  :global(.brand-model-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  :global(.brand-tag) {
    display: inline-flex;
    padding: 4px 9px;
    border-radius: var(--r-pill);
    font-size: 11px;
    font-weight: 650;
    color: var(--ink);
    background: var(--bg-surface-2);
  }

  :global(.brand-tag.good) {
    color: var(--success-green);
    background: rgb(26 170 85 / 0.14);
  }

  :global(.brand-tag.warn) {
    color: #fbbf24;
    background: rgb(251 191 36 / 0.14);
  }

  :global(.brand-tag.bad) {
    color: #ef4444;
    background: rgb(239 68 68 / 0.14);
  }

  :global(.brand-tag.negative) {
    color: #ef4444;
    background: rgb(239 68 68 / 0.14);
  }

  :global(.brand-tag.positive) {
    color: var(--success-green);
    background: rgb(26 170 85 / 0.14);
  }

  :global(.brand-list-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  :global(.brand-competitor-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  :global(.brand-competitor-card) {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px;
    align-items: start;
    background: var(--bg-canvas);
    border: 1px solid color-mix(in srgb, var(--hairline) 74%, transparent);
    border-radius: var(--r-lg);
    padding: 16px 18px;
  }

  :global(.brand-competitor-rank) {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--bg-surface-2);
    color: var(--accent-blue);
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
  }

  :global(.brand-competitor-name) {
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 14px !important;
    font-weight: 700;
    line-height: 1.25 !important;
    margin: 0 0 5px;
    letter-spacing: -0.01em;
  }

  :global(.brand-competitor-context) {
    color: var(--ink-muted);
    font-size: 13px;
    line-height: 1.45;
    margin: 0;
  }

  :global(.brand-competitor-count) {
    align-self: center;
    white-space: nowrap;
    padding: 5px 10px;
    border-radius: var(--r-pill);
    background: color-mix(in srgb, var(--accent-blue) 12%, transparent);
    color: var(--accent-blue);
    font-size: 11px;
    font-weight: 700;
  }

  :global(.brand-list-card) {
    background: var(--bg-canvas);
    border: 1px solid color-mix(in srgb, var(--hairline) 74%, transparent);
    border-radius: var(--r-md);
    padding: 16px 18px;
    color: var(--ink-muted);
    font-size: 14px;
    line-height: 1.55;
  }

  :global(.brand-list-card strong) {
    color: var(--ink);
  }

  :global(.brand-insight-card) {
    display: grid;
    gap: 9px;
    min-width: 0;
    padding: 14px 16px;
    background: var(--bg-canvas);
    border: 1px solid color-mix(in srgb, var(--hairline) 74%, transparent);
    border-radius: var(--r-md);
  }

  :global(.brand-insight-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }

  :global(.brand-insight-chip) {
    display: inline-flex;
    width: fit-content;
    padding: 4px 8px;
    border-radius: var(--r-pill);
    background: var(--bg-surface-2);
    color: var(--ink-muted);
    font-size: 11px;
    font-weight: 650;
    line-height: 1.1;
  }

  :global(.brand-insight-chip--risk) {
    color: #fbbf24;
    background: rgb(251 191 36 / 0.13);
  }

  :global(.brand-insight-claim) {
    margin: 0;
    color: var(--ink);
    font-size: 14px;
    font-weight: 650;
    line-height: 1.42;
  }

  :global(.brand-insight-detail) {
    margin: 0;
    color: var(--ink-muted);
    font-size: 13px;
    line-height: 1.48;
  }

  :global(.brand-action-card) {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
  }

  :global(.brand-action-priority) {
    display: inline-flex;
    padding: 4px 8px;
    border-radius: var(--r-sm);
    background: color-mix(in srgb, var(--accent-blue) 12%, transparent);
    color: var(--accent-blue);
    font-size: 11px;
    font-weight: 750;
    line-height: 1;
  }

  :global(.brand-sources-grid) {
    display: grid;
    gap: 8px;
  }

  :global(.brand-source-link) {
    display: grid;
    gap: 4px;
    padding: 14px 16px;
    background: var(--bg-canvas);
    border: 1px solid color-mix(in srgb, var(--hairline) 74%, transparent);
    border-radius: var(--r-md);
    color: var(--ink);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.35;
  }

  :global(.brand-source-link:hover) {
    color: var(--accent-blue);
  }

  :global(.brand-source-domain) {
    color: var(--ink-muted);
    font-size: 12px;
  }

  :global(.results-error) {
    background: rgb(239 68 68 / 0.1);
    border-radius: var(--r-md);
    padding: 16px 20px;
    color: #ef4444;
    font-size: 14px;
  }

  @media (max-width: 640px) {
    .tool-hero {
      padding: 72px 0 64px;
    }

    .tool-hero-inner {
      align-items: flex-start;
      text-align: left;
    }

    .tool-breadcrumb {
      justify-content: flex-start;
      margin-bottom: 28px;
      font-size: 13px;
    }

    .tool-hero-title {
      overflow-wrap: anywhere;
    }

    .tool-hero-copy {
      font-size: 17px;
    }

    .brand-form {
      padding: 18px;
      border-radius: var(--r-lg);
    }

    :global(.brand-score-card),
    :global(.brand-model-row) {
      grid-template-columns: 1fr;
    }

    :global(.brand-loading-header) {
      align-items: flex-start;
    }

    :global(.brand-loading-orb) {
      width: 34px;
      height: 34px;
    }

    :global(.brand-loading-steps) {
      grid-template-columns: 1fr 1fr;
    }

    :global(.brand-panel-head) {
      display: block;
      padding-bottom: 18px;
    }

    :global(.brand-panel-note) {
      margin-top: 8px;
    }

    :global(.brand-competitor-card) {
      grid-template-columns: auto 1fr;
    }

    :global(.brand-competitor-count) {
      grid-column: 2;
      justify-self: start;
    }
  }
</style>

<script>
  const initBrandCheck = () => {
    const form = document.getElementById('brand-form');
    const results = document.getElementById('results');
    const overview = document.getElementById('default-overview');
    if (!form || !results) return;

    const submit = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const payload = {
        brand: String(data.get('brand') || '').trim(),
        domain: String(data.get('domain') || '').trim(),
        category: String(data.get('category') || '').trim(),
        market: String(data.get('market') || '').trim() || 'Polska',
      };

      if (!payload.brand) {
        renderError('Podaj nazwę marki.');
        return;
      }

      setLoading(true);
      results.classList.remove('hidden');
      results.innerHTML = renderLoading(payload.brand);
      overview?.classList.add('hidden');

      try {
        const response = await fetch('/api/tools/brand-check', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const body = await response.json();
        if (!response.ok) throw new Error(body.error || `HTTP ${response.status}`);
        renderResults(body);
      } catch (error) {
        renderError(error instanceof Error ? error.message : 'Nie udało się wykonać testu.');
      } finally {
        setLoading(false);
      }
    });

    function setLoading(isLoading) {
      if (!submit) return;
      submit.disabled = isLoading;
      submit.setAttribute('aria-busy', isLoading ? 'true' : 'false');
    }

    function renderLoading(brand) {
      return `
        <div class="brand-loading-card">
          <div class="brand-loading-header">
            <div>
              <div class="brand-loading-kicker">Analiza w toku</div>
              <h2 class="brand-loading-title">Sprawdzamy ${escapeHtml(brand)}</h2>
              <p class="brand-loading-copy">
                Zbieramy cytowania, sentyment, konkurentów oraz możliwe błędy w opisach marki.
                Wynik pojawi się po zakończeniu odpowiedzi modeli.
              </p>
            </div>
            <div class="brand-loading-orb" aria-hidden="true"></div>
          </div>
          <div class="brand-loading-track" aria-hidden="true">
            <div class="brand-loading-bar"></div>
          </div>
          <div class="brand-loading-steps">
            ${['ChatGPT', 'Claude', 'Gemini', 'Perplexity']
              .map(
                (model) => `
                  <div class="brand-loading-step">
                    <div class="brand-loading-step-name">${model}</div>
                    <div class="brand-loading-step-status">oczekiwanie na odpowiedź</div>
                  </div>
                `
              )
              .join('')}
          </div>
        </div>
      `;
    }

    function renderError(message) {
      results.classList.remove('hidden');
      results.innerHTML = `<div class="results-error">${escapeHtml(message)}</div>`;
    }

    function renderResults(report) {
      const score = report.summary?.score ?? 0;
      const competitors = report.summary?.competitors || [];
      const competitorItems = collectCompetitors(report.models || [], competitors);
      const hallucinations = (report.models || []).flatMap((model) =>
        (model.hallucinations || []).map((item) => ({ ...item, model: model.label }))
      );
      const sources = collectSources(report.models || []);
      const modelRows = (report.models || []).map(renderModelRow).join('');

      results.innerHTML = `
        <div class="brand-results">
          <section class="brand-score-card">
            <div class="brand-score-circle" style="--score: ${Number(score) || 0}">
              <div class="brand-score-num">${escapeHtml(String(score))}</div>
            </div>
            <div class="brand-score-meta">
              <div class="brand-score-kicker">Brand Visibility Score</div>
              <h2 class="brand-score-title">${escapeHtml(report.brand)} w odpowiedziach AI</h2>
              <p class="brand-score-copy">
                ${escapeHtml(report.summary.knownBy)} z ${escapeHtml(report.summary.totalModels)} modeli zna markę bezpośrednio.
                Własna domena pojawiła się w źródłach ${escapeHtml(report.summary.ownDomainCitedBy)} razy.
                Sentyment: ${escapeHtml(sentimentLabel(report.summary.sentiment))}.
              </p>
            </div>
          </section>

          <section class="brand-stats">
            <div class="brand-stat">
              <div class="brand-stat-value">${escapeHtml(String(report.summary.ownDomainCitedBy))}/${escapeHtml(String(report.summary.totalModels))}</div>
              <div class="brand-stat-label">modele cytujące Twoją domenę</div>
            </div>
            <div class="brand-stat">
              <div class="brand-stat-value">${escapeHtml(String(report.summary.hallucinations))}</div>
              <div class="brand-stat-label">możliwe halucynacje</div>
            </div>
            <div class="brand-stat">
              <div class="brand-stat-value">${escapeHtml(String(competitors.length))}</div>
              <div class="brand-stat-label">konkurenci w odpowiedziach</div>
            </div>
            <div class="brand-stat">
              <div class="brand-stat-value">${escapeHtml(report.status === 'ok' ? '4/4' : 'częściowo')}</div>
              <div class="brand-stat-label">status modeli</div>
            </div>
          </section>

          <section class="brand-panel brand-panel--models">
            <div class="brand-panel-head">
              <h2 class="brand-panel-title">Wyniki per model</h2>
              <p class="brand-panel-note">Każdy model oceniamy osobno, bo odpowiedzi i cytowane źródła potrafią się różnić.</p>
            </div>
            <div class="brand-model-grid">${modelRows}</div>
          </section>

          <section class="brand-panel brand-panel--competitors">
            <div class="brand-panel-head">
              <h2 class="brand-panel-title">Konkurenci polecani zamiast marki</h2>
              <p class="brand-panel-note">Lista pokazuje marki, które pojawiają się jako alternatywy lub punkty porównania.</p>
            </div>
            ${renderCompetitors(competitorItems)}
          </section>

          <section class="brand-panel brand-panel--hallucinations">
            <div class="brand-panel-head">
              <h2 class="brand-panel-title">Możliwe halucynacje</h2>
              <p class="brand-panel-note">To twierdzenia, które warto sprawdzić ręcznie przed użyciem raportu w komunikacji.</p>
            </div>
            ${renderHallucinations(hallucinations)}
          </section>

          <section class="brand-panel brand-panel--sources">
            <div class="brand-panel-head">
              <h2 class="brand-panel-title">Źródła cytowane przez modele</h2>
              <p class="brand-panel-note">Pokazujemy domeny, z których modele korzystały przy odpowiedziach.</p>
            </div>
            ${renderSources(sources)}
          </section>

          <section class="brand-panel brand-panel--actions">
            <div class="brand-panel-head">
              <h2 class="brand-panel-title">Priorytety działań</h2>
              <p class="brand-panel-note">Najkrótsza lista zmian, które mogą poprawić widoczność i spójność marki w AI.</p>
            </div>
            ${renderActions(report.actionItems || [])}
          </section>
        </div>
      `;
    }

    function renderModelRow(model) {
      if (model.status === 'error') {
        return `
          <article class="brand-model-row">
            <div>
              <div class="brand-model-name">${escapeHtml(model.label)}</div>
              <span class="brand-model-pill">błąd</span>
            </div>
            <div>
              <p class="brand-model-summary">${escapeHtml(model.error || 'Model nie zwrócił odpowiedzi.')}</p>
              <div class="brand-model-meta"><span class="brand-tag bad">brak wyniku</span></div>
            </div>
          </article>
        `;
      }

      return `
        <article class="brand-model-row">
          <div>
            <div class="brand-model-name">${escapeHtml(model.label)}</div>
            <span class="brand-model-pill">${escapeHtml(model.model)}</span>
          </div>
          <div>
            <p class="brand-model-summary">${escapeHtml(model.summary)}</p>
            <div class="brand-model-meta">
              <span class="brand-tag ${model.knowsBrand === 'yes' ? 'good' : model.knowsBrand === 'partial' ? 'warn' : 'bad'}">${escapeHtml(knowsLabel(model.knowsBrand))}</span>
              <span class="brand-tag ${sentimentTone(model.sentiment)}">${escapeHtml(sentimentLabel(model.sentiment))}</span>
              <span class="brand-tag ${model.citedOwnDomain ? 'good' : 'warn'}">${model.citedOwnDomain ? 'cytuje domenę' : 'nie cytuje domeny'}</span>
            </div>
          </div>
        </article>
      `;
    }

    function renderCompetitors(items) {
      if (!items.length) {
        return '<div class="brand-list-card">Modele nie wskazały wyraźnych konkurentów.</div>';
      }
      return `<div class="brand-competitor-grid">${items
        .map(
          (item, index) => `
            <article class="brand-competitor-card">
              <div class="brand-competitor-rank">${String(index + 1).padStart(2, '0')}</div>
              <div>
                <h3 class="brand-competitor-name">${escapeHtml(item.name)}</h3>
                <p class="brand-competitor-context">${escapeHtml(item.context)}</p>
              </div>
              <div class="brand-competitor-count">${escapeHtml(String(item.count))} modele</div>
            </article>
          `
        )
        .join('')}</div>`;
    }

    function renderHallucinations(items) {
      if (!items.length) {
        return '<div class="brand-list-card">Nie wykryto oczywistych halucynacji w odpowiedziach modeli.</div>';
      }
      return `<div class="brand-list-grid">${items
        .map(
          (item) => `
            <article class="brand-insight-card">
              <div class="brand-insight-meta">
                <span class="brand-insight-chip">${escapeHtml(item.model)}</span>
                <span class="brand-insight-chip brand-insight-chip--risk">${escapeHtml(severityLabel(item.severity))}</span>
              </div>
              <p class="brand-insight-claim">${escapeHtml(item.claim)}</p>
              <p class="brand-insight-detail">${escapeHtml(item.why)}</p>
            </article>
          `
        )
        .join('')}</div>`;
    }

    function renderSources(sources) {
      if (!sources.length) {
        return '<div class="brand-list-card">Modele nie zwróciły źródeł w formacie możliwym do pokazania w raporcie.</div>';
      }
      return `<div class="brand-sources-grid">${sources
        .map(
          (source) => `
            <a class="brand-source-link" href="${escapeAttr(source.url)}" target="_blank" rel="nofollow noopener noreferrer">
              <span>${escapeHtml(source.title)}</span>
              <span class="brand-source-domain">${escapeHtml(source.domain)}</span>
            </a>
          `
        )
        .join('')}</div>`;
    }

    function renderActions(actions) {
      if (!actions.length) return '<div class="brand-list-card">Brak rekomendacji.</div>';
      return `<div class="brand-list-grid">${actions
        .map(
          (item) => `
            <article class="brand-list-card brand-action-card">
              <span class="brand-action-priority">${escapeHtml(item.priority)}</span>
              <div>
                <strong>${escapeHtml(item.title)}</strong><br />
                ${escapeHtml(item.description)}
              </div>
            </article>
          `
        )
        .join('')}</div>`;
    }

    function collectSources(models) {
      const map = new Map();
      for (const model of models) {
        for (const citation of model.citations || []) {
          if (!map.has(citation.url)) map.set(citation.url, citation);
        }
      }
      return Array.from(map.values()).slice(0, 16);
    }

    function collectCompetitors(models, fallbackNames) {
      const map = new Map();
      for (const model of models) {
        for (const competitor of model.competitors || []) {
          const name = String(competitor.name || '').trim();
          if (!name) continue;
          const key = name.toLowerCase();
          const current = map.get(key) || { name, count: 0, contexts: [] };
          current.count += 1;
          if (competitor.context) current.contexts.push(String(competitor.context));
          map.set(key, current);
        }
      }

      for (const name of fallbackNames || []) {
        const key = String(name).toLowerCase();
        if (!map.has(key)) map.set(key, { name, count: 1, contexts: [] });
      }

      return Array.from(map.values())
        .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'pl'))
        .slice(0, 8)
        .map((item) => ({
          name: item.name,
          count: item.count,
          context:
            item.contexts[0] ||
            'Pojawia się jako alternatywa lub punkt porównania w odpowiedziach modeli.',
        }));
    }

    function knowsLabel(value) {
      if (value === 'yes') return 'zna markę';
      if (value === 'partial') return 'zna częściowo';
      return 'nie zna marki';
    }

    function sentimentLabel(value) {
      if (value === 'positive') return 'pozytywny';
      if (value === 'negative') return 'negatywny';
      if (value === 'mixed') return 'mieszany';
      if (value === 'unknown') return 'nieznany';
      return 'neutralny';
    }

    function sentimentTone(value) {
      if (value === 'positive') return 'positive';
      if (value === 'negative') return 'negative';
      return '';
    }

    function severityLabel(value) {
      if (value === 'high') return 'wysokie ryzyko błędu';
      if (value === 'low') return 'niskie ryzyko błędu';
      return 'średnie ryzyko błędu';
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function escapeAttr(value) {
      return escapeHtml(value).replaceAll('`', '&#96;');
    }
  };

  document.addEventListener('astro:page-load', initBrandCheck);
  if (document.readyState !== 'loading') initBrandCheck();
</script>
