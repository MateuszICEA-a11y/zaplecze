---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';

const examples = [
  'najlepszy system CRM dla małej firmy',
  'ranking kont firmowych 2026',
  'jak wybrać platformę e-commerce B2B',
];
---

<Layout
  title="Analiza zapytań (Fan-out) – jak ChatGPT szuka informacji i cytuje domeny"
  description="Sprawdź, na jakie mniejsze pytania ChatGPT rozbija Twoją frazę i jakie źródła pobiera w tle. Bezpłatne narzędzie widocznosc.ai do analizy zapytań AI."
>
  <Navbar />

  <main class="flex-grow">
    <section class="tool-hero">
      <div class="content-container tool-hero-inner">
        <nav class="tool-breadcrumb" aria-label="Ścieżka nawigacji">
          <a href="/narzedzia" class="tool-breadcrumb-link">Narzędzia</a>
          <span class="tool-breadcrumb-sep" aria-hidden="true">/</span>
          <span class="tool-breadcrumb-current">Analiza zapytań (Fan-out)</span>
        </nav>

        <header class="text-center">
          <span class="eyebrow tool-eyebrow">Narzędzie · bezpłatne</span>
          <h1 class="tool-hero-title">
            Sprawdź, jak ChatGPT szuka informacji w&nbsp;tle
          </h1>
          <p class="tool-hero-copy">
            Wpisz interesującą Cię frazę, a my pokażemy, jak model rozbija ją na mniejsze pytania
            pomocnicze (tzw. Query Fan-out) oraz z jakich domen i źródeł ostatecznie czerpie
            wiedzę. To idealna wskazówka, pod jakie frazy optymalizować swoje teksty.
          </p>
        </header>

        <form id="fanout-form" class="fanout-form" novalidate>
          <label class="fanout-field">
            <span>Zapytanie</span>
            <input
              id="fanout-input"
              name="query"
              type="text"
              required
              maxlength="300"
              autocomplete="off"
              placeholder="np. najlepszy system CRM dla małej firmy"
            />
          </label>
          <button type="submit" class="btn-primary fanout-submit">Zobacz rozbicie zapytania</button>
          <div class="fanout-examples" aria-label="Przykładowe zapytania">
            {examples.map((ex) => (
              <button type="button" class="fanout-example" data-query={ex}>{ex}</button>
            ))}
          </div>
        </form>

        <div id="fanout-results" class="fanout-results hidden" aria-live="polite"></div>

        <p class="fanout-note">
          Wynik prezentuje dane dla tej konkretnej sesji wyszukiwania. Pamiętaj, że odpowiedzi
          modeli AI są generowane dynamicznie i mogą się nieznacznie różnić w czasie.
        </p>
      </div>
    </section>
  </main>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .tool-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3.5rem, 8vw, 7rem) 0 clamp(4rem, 8vw, 7.5rem);
    background:
      radial-gradient(circle at 20% 12%, color-mix(in srgb, var(--accent-blue) 12%, transparent), transparent 34rem),
      linear-gradient(180deg, color-mix(in srgb, var(--bg-canvas) 94%, var(--accent-blue) 6%), var(--bg-canvas));
  }

  .tool-hero-inner {
    position: relative;
    z-index: 1;
  }

  .tool-breadcrumb {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    color: var(--ink-muted);
    font-size: 0.86rem;
  }

  .tool-breadcrumb-link {
    color: inherit;
    text-decoration: none;
  }

  .tool-breadcrumb-link:hover {
    color: var(--accent-blue);
  }

  .tool-breadcrumb-current {
    color: var(--ink);
    font-weight: 700;
  }

  .tool-eyebrow {
    margin-bottom: 1rem;
  }

  .tool-hero-title {
    max-width: 980px;
    margin: 0 auto;
    color: var(--ink);
    font-size: clamp(3rem, 7vw, 6.75rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .tool-hero-accent {
    color: var(--accent-blue);
  }

  .tool-hero-copy {
    max-width: 760px;
    margin: 1.4rem auto 0;
    color: var(--ink-muted);
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.55;
  }

  .fanout-form {
    max-width: 820px;
    margin: 2.75rem auto 0;
    padding: clamp(1rem, 2.4vw, 1.5rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.85rem;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-radius: 1.25rem;
    background: color-mix(in srgb, var(--bg-surface-1) 92%, white 8%);
    box-shadow: 0 24px 70px color-mix(in srgb, var(--ink) 8%, transparent);
  }

  .fanout-field { display: flex; flex-direction: column; gap: 0.45rem; text-align: left; font-weight: 700; }
  .fanout-field input {
    width: 100%;
    min-height: 3.35rem;
    padding: 0.9rem 1rem;
    border-radius: 0.85rem;
    border: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
    background: var(--bg-canvas);
    color: var(--ink);
    font-size: 1rem;
  }

  .fanout-field input:focus {
    outline: 2px solid color-mix(in srgb, var(--accent-blue) 28%, transparent);
    outline-offset: 2px;
  }

  .fanout-submit {
    align-self: end;
    min-height: 3.35rem;
    white-space: nowrap;
  }

  .fanout-examples {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.1rem;
  }

  .fanout-example {
    font-size: 0.86rem;
    padding: 0.42rem 0.78rem;
    border-radius: 999px;
    cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
    background: color-mix(in srgb, var(--accent-blue) 8%, transparent);
    color: var(--ink);
  }

  .fanout-example:hover {
    border-color: color-mix(in srgb, var(--accent-blue) 40%, transparent);
  }

  .fanout-results {
    max-width: 1080px;
    margin: 2.75rem auto 0;
    text-align: left;
    display: grid;
    gap: 1rem;
  }
  .fanout-results.hidden { display: none; }

  :global(.fanout-panel) {
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-radius: 1.15rem;
    padding: clamp(1.15rem, 2.3vw, 1.75rem);
    background: color-mix(in srgb, var(--bg-surface-1) 94%, white 6%);
  }

  :global(.fanout-panel h2) {
    margin: 0;
    color: var(--ink);
    font-size: clamp(1.18rem, 2vw, 1.55rem);
    line-height: 1.15;
  }

  :global(.fanout-panel--empty) {
    max-width: 780px;
    margin: 0 auto;
  }

  :global(.fanout-panel-copy) {
    margin: 0.45rem 0 1.15rem;
    color: var(--ink-muted);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  :global(.fanout-grid) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.68fr);
    gap: 1rem;
  }

  :global(.fanout-answer) {
    color: var(--ink);
    font-size: 1rem;
    line-height: 1.65;
  }

  :global(.fanout-list) { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.65rem; }
  :global(.fanout-list li) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.7rem;
    align-items: start;
    padding: 0.78rem 0.9rem;
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--accent-blue) 7%, transparent);
    color: var(--ink);
    font-size: 0.94rem;
    line-height: 1.45;
  }

  :global(.fanout-index) {
    display: inline-flex;
    width: 1.75rem;
    height: 1.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-blue) 16%, white 84%);
    color: var(--accent-blue);
    font-size: 0.78rem;
    font-weight: 800;
  }

  :global(.domain-list) {
    display: grid;
    gap: 0.65rem;
  }

  :global(.domain-card) {
    padding: 0.85rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
    border-radius: 0.85rem;
    background: color-mix(in srgb, var(--bg-canvas) 78%, white 22%);
  }

  :global(.domain-row) { display: flex; align-items: center; gap: 0.75rem; }
  :global(.domain-name) { font-weight: 800; color: var(--ink); }
  :global(.domain-count) {
    margin-left: auto;
    flex: 0 0 auto;
    font-size: 0.78rem;
    font-weight: 800;
    padding: 0.2rem 0.62rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-blue) 14%, transparent);
    color: var(--accent-blue);
  }

  :global(.domain-urls) { display: grid; gap: 0.32rem; margin: 0.62rem 0 0; }
  :global(.domain-urls a) {
    color: var(--ink-muted);
    font-size: 0.82rem;
    line-height: 1.35;
    word-break: break-all;
  }

  :global(.source-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  :global(.source-link) {
    display: block;
    padding: 0.72rem 0.82rem;
    border: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--bg-canvas) 78%, white 22%);
    color: var(--ink-muted);
    font-size: 0.84rem;
    line-height: 1.35;
    word-break: break-all;
  }

  :global(.fanout-loading-card) {
    width: min(100%, 820px);
    margin-inline: auto;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    padding: clamp(22px, 3vw, 32px);
    box-shadow: 0 20px 56px rgb(15 23 42 / 0.06);
  }

  :global(.fanout-loading-header) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 22px;
  }

  :global(.fanout-loading-kicker) {
    color: var(--accent-blue);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  :global(.fanout-loading-title) {
    font-family: var(--font-display);
    font-size: clamp(26px, 3.2vw, 40px);
    line-height: 1.05;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0;
    margin: 0;
  }

  :global(.fanout-loading-copy) {
    color: var(--ink-muted);
    font-size: 14px;
    line-height: 1.55;
    margin: 10px 0 0;
    max-width: 560px;
  }

  :global(.fanout-loading-orb) {
    width: 42px;
    height: 42px;
    flex: none;
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--accent-blue) 18%, transparent);
    border-top-color: var(--accent-blue);
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  :global(.fanout-loading-track) {
    position: relative;
    height: 8px;
    overflow: hidden;
    border-radius: var(--r-pill);
    background: var(--bg-surface-2);
    margin: 20px 0 22px;
  }

  :global(.fanout-loading-bar) {
    position: absolute;
    inset: 0 auto 0 0;
    width: 42%;
    border-radius: inherit;
    background: var(--accent-blue);
    animation: fanout-progress 1.45s ease-in-out infinite;
  }

  @keyframes fanout-progress {
    0% { transform: translateX(-105%); }
    55% { transform: translateX(95%); }
    100% { transform: translateX(250%); }
  }

  :global(.fanout-loading-steps) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  :global(.fanout-loading-step) {
    min-width: 0;
    padding: 12px 13px;
    border-radius: var(--r-md);
    background: var(--bg-canvas);
    border: 1px solid color-mix(in srgb, var(--hairline) 74%, transparent);
  }

  :global(.fanout-loading-step-name) {
    color: var(--ink);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.2;
  }

  :global(.fanout-loading-step-status) {
    color: var(--ink-muted);
    font-size: 11.5px;
    line-height: 1.25;
    margin-top: 5px;
  }

  :global(.fanout-error) { padding: 1rem 1.25rem; border-radius: 0.75rem; background: color-mix(in srgb, #ef4444 14%, transparent); color: #b91c1c; }
  :global(.fanout-cta) { margin-top: 0.75rem; }
  :global(.fanout-note),
  .fanout-note { margin-top: 1.25rem; text-align: center; font-size: 0.8rem; opacity: 0.6; }

  @media (max-width: 780px) {
    .tool-hero {
      padding-top: 2.8rem;
    }

    .tool-hero-title {
      font-size: clamp(2.65rem, 14vw, 4.2rem);
    }

    .fanout-form,
    :global(.fanout-grid),
    :global(.source-grid) {
      grid-template-columns: 1fr;
    }

    .fanout-submit {
      width: 100%;
      justify-content: center;
    }

    :global(.fanout-loading-header) {
      gap: 16px;
    }

    :global(.fanout-loading-orb) {
      width: 34px;
      height: 34px;
    }

    :global(.fanout-loading-steps) {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const initFanout = () => {
    const form = document.getElementById('fanout-form');
    const input = document.getElementById('fanout-input');
    const results = document.getElementById('fanout-results');
    if (!form || !results || !input) return;

    const submit = form.querySelector('button[type="submit"]');

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function countLabel(count, one, few, many) {
      const value = Number(count);
      if (value === 1) return one;
      if (value > 1 && value < 5) return few;
      return many;
    }

    function cleanUrlLabel(url) {
      try {
        const parsed = new URL(String(url));
        return `${parsed.hostname.replace(/^www\./i, '')}${parsed.pathname === '/' ? '' : parsed.pathname}`;
      } catch {
        return String(url);
      }
    }

    function setLoading(isLoading) {
      if (!submit) return;
      submit.disabled = isLoading;
      submit.setAttribute('aria-busy', isLoading ? 'true' : 'false');
    }

    function renderError(message) {
      results.classList.remove('hidden');
      results.innerHTML = `<div class="fanout-error">${escapeHtml(message)}</div>`;
    }

    function renderResults(data) {
      if (data.status === 'no-search') {
        results.innerHTML = `
          <div class="fanout-panel fanout-panel--empty">
            <h2>Brak zapytań wyszukiwania</h2>
            <p class="fanout-panel-copy">W tym przebiegu model nie ujawnił osobnego wyszukiwania w sieci. Spróbuj frazy rankingowej, porównawczej albo aktualnego pytania branżowego.</p>
          </div>`;
        return;
      }

      const fanouts = (data.fanoutQueries || [])
        .map((q, index) => `<li><span class="fanout-index">${String(index + 1).padStart(2, '0')}</span><span>${escapeHtml(q)}</span></li>`)
        .join('');
      const domains = (data.citedDomains || [])
        .map((d) => {
          const count = Number(d.count) || 0;
          return `
          <div class="domain-card">
            <div class="domain-row">
              <span class="domain-name">${escapeHtml(d.domain)}</span>
              <span class="domain-count">${escapeHtml(String(count))} ${countLabel(count, 'cytowanie', 'cytowania', 'cytowań')}</span>
            </div>
            <div class="domain-urls">
              ${(d.urls || [])
                .filter((u) => /^https?:\/\//i.test(String(u)))
                .slice(0, 4)
                .map((u) => `<a href="${escapeHtml(u)}" target="_blank" rel="nofollow noopener">${escapeHtml(cleanUrlLabel(u))}</a>`)
                .join('')}
            </div>
          </div>`;
        })
        .join('');
      const remaining = data.usage?.remaining;
      const ctaHtml = Number.isFinite(remaining) && remaining <= 0
        ? `<p class="fanout-cta"><a class="btn-primary" href="/kontakt">Chcesz pełny audyt widoczności w AI? Napisz do nas</a></p>`
        : Number.isFinite(remaining)
          ? `<p class="fanout-note">Pozostały Ci dziś ${escapeHtml(String(remaining))} zapytania.</p>`
          : '';

      results.innerHTML = `
        <section class="fanout-panel">
          <h2>Zapytania wyszukiwania (${escapeHtml(String((data.fanoutQueries || []).length))})</h2>
          <p class="fanout-panel-copy">Frazy ujawnione przez model w tym przebiegu dla: „${escapeHtml(data.query)}”.</p>
          <ul class="fanout-list">${fanouts || '<li>brak</li>'}</ul>
        </section>
        <section class="fanout-panel">
          <h2>Cytowane domeny</h2>
          <p class="fanout-panel-copy">Domeny, które trafiły do finalnej odpowiedzi modelu.</p>
          <div class="domain-list">${domains || '<p class="fanout-panel-copy">Brak cytowań w odpowiedzi.</p>'}</div>
        </section>
        ${ctaHtml}
      `;
    }

    form.querySelectorAll('.fanout-example').forEach((btn) => {
      btn.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        input.value = btn.getAttribute('data-query') || '';
        input.focus();
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const query = String(input.value || '').trim();
      if (query.length < 3) { renderError('Podaj zapytanie (min. 3 znaki).'); return; }

      setLoading(true);
      results.classList.remove('hidden');
      results.innerHTML = `
        <div class="fanout-loading-card">
          <div class="fanout-loading-header">
            <div>
              <div class="fanout-loading-kicker">Analiza w toku</div>
              <h2 class="fanout-loading-title">Sprawdzamy zapytanie</h2>
              <p class="fanout-loading-copy">
                Model przygotowuje odpowiedź, uruchamia wyszukiwanie i zwraca źródła dla: „${escapeHtml(query)}”.
              </p>
            </div>
            <div class="fanout-loading-orb" aria-hidden="true"></div>
          </div>
          <div class="fanout-loading-track" aria-hidden="true">
            <div class="fanout-loading-bar"></div>
          </div>
          <div class="fanout-loading-steps">
            <div class="fanout-loading-step">
              <div class="fanout-loading-step-name">Zapytania</div>
              <div class="fanout-loading-step-status">oczekiwanie na wynik</div>
            </div>
            <div class="fanout-loading-step">
              <div class="fanout-loading-step-name">Źródła</div>
              <div class="fanout-loading-step-status">zbieranie cytowań</div>
            </div>
            <div class="fanout-loading-step">
              <div class="fanout-loading-step-name">Domeny</div>
              <div class="fanout-loading-step-status">agregacja widoczności</div>
            </div>
          </div>
        </div>`;

      try {
        const response = await fetch('/api/tools/fanout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query }),
        });
        const body = await response.json();
        if (!response.ok) throw new Error(body.error || `HTTP ${response.status}`);
        renderResults(body);
      } catch (error) {
        renderError(error instanceof Error ? error.message : 'Nie udało się wykonać zapytania.');
      } finally {
        setLoading(false);
      }
    });
  };

  document.addEventListener('astro:page-load', initFanout);
</script>
