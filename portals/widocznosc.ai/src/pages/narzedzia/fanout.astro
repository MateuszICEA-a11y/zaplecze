---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';

const examples = [
  'najlepsza agencja SEO w Polsce',
  'jak wybrać system CRM dla firmy',
  'najlepszy bank dla firmy 2026',
];
---

<Layout
  title="Fan-out ChatGPT – zapytania wyszukiwania i cytowane domeny"
  description="Sprawdź, jakie zapytania wyszukiwania i źródła pojawiają się w odpowiedzi ChatGPT dla Twojej frazy. Bezpłatne narzędzie widocznosc.ai."
>
  <Navbar />

  <main class="flex-grow">
    <section class="tool-hero">
      <div class="content-container tool-hero-inner">
        <nav class="tool-breadcrumb" aria-label="Ścieżka nawigacji">
          <a href="/narzedzia" class="tool-breadcrumb-link">Narzędzia</a>
          <span class="tool-breadcrumb-sep" aria-hidden="true">/</span>
          <span class="tool-breadcrumb-current">Fan-out ChatGPT</span>
        </nav>

        <header class="text-center">
          <span class="eyebrow tool-eyebrow">Narzędzie · bezpłatne</span>
          <h1 class="tool-hero-title">
            Sprawdź zapytania i&nbsp;<span class="tool-hero-accent">źródła ChatGPT</span>
          </h1>
          <p class="tool-hero-copy">
            Wpisz frazę, a&nbsp;zobaczysz zapytania wyszukiwania ujawnione przez model,
            domeny cytowane w odpowiedzi i źródła, które pojawiły się w warstwie wyszukiwania.
          </p>
        </header>

        <form id="fanout-form" class="fanout-form" novalidate>
          <label class="fanout-field">
            <span>Zapytanie</span>
            <input
              id="fanout-input"
              name="query"
              type="text"
              required
              maxlength="300"
              autocomplete="off"
              placeholder="np. najlepsza agencja SEO w Polsce"
            />
          </label>
          <button type="submit" class="btn-primary fanout-submit">Pokaż fan-out</button>
          <div class="fanout-examples" aria-label="Przykładowe zapytania">
            {examples.map((ex) => (
              <button type="button" class="fanout-example" data-query={ex}>{ex}</button>
            ))}
          </div>
        </form>

        <div id="fanout-results" class="fanout-results hidden" aria-live="polite"></div>

        <p class="fanout-note">
          Limit: 3 zapytania dziennie. Wynik pokazuje dane zwrócone w konkretnym przebiegu wyszukiwania.
        </p>
      </div>
    </section>
  </main>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .tool-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3.5rem, 8vw, 7rem) 0 clamp(4rem, 8vw, 7.5rem);
    background:
      radial-gradient(circle at 20% 12%, color-mix(in srgb, var(--accent-blue) 12%, transparent), transparent 34rem),
      linear-gradient(180deg, color-mix(in srgb, var(--bg-canvas) 94%, var(--accent-blue) 6%), var(--bg-canvas));
  }

  .tool-hero-inner {
    position: relative;
    z-index: 1;
  }

  .tool-breadcrumb {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    color: var(--ink-muted);
    font-size: 0.86rem;
  }

  .tool-breadcrumb-link {
    color: inherit;
    text-decoration: none;
  }

  .tool-breadcrumb-link:hover {
    color: var(--accent-blue);
  }

  .tool-breadcrumb-current {
    color: var(--ink);
    font-weight: 700;
  }

  .tool-eyebrow {
    margin-bottom: 1rem;
  }

  .tool-hero-title {
    max-width: 980px;
    margin: 0 auto;
    color: var(--ink);
    font-size: clamp(3rem, 7vw, 6.75rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .tool-hero-accent {
    color: var(--accent-blue);
  }

  .tool-hero-copy {
    max-width: 760px;
    margin: 1.4rem auto 0;
    color: var(--ink-muted);
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.55;
  }

  .fanout-form {
    max-width: 820px;
    margin: 2.75rem auto 0;
    padding: clamp(1rem, 2.4vw, 1.5rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.85rem;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-radius: 1.25rem;
    background: color-mix(in srgb, var(--bg-surface-1) 92%, white 8%);
    box-shadow: 0 24px 70px color-mix(in srgb, var(--ink) 8%, transparent);
  }

  .fanout-field { display: flex; flex-direction: column; gap: 0.45rem; text-align: left; font-weight: 700; }
  .fanout-field input {
    width: 100%;
    min-height: 3.35rem;
    padding: 0.9rem 1rem;
    border-radius: 0.85rem;
    border: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
    background: var(--bg-canvas);
    color: var(--ink);
    font-size: 1rem;
  }

  .fanout-field input:focus {
    outline: 2px solid color-mix(in srgb, var(--accent-blue) 28%, transparent);
    outline-offset: 2px;
  }

  .fanout-submit {
    align-self: end;
    min-height: 3.35rem;
    white-space: nowrap;
  }

  .fanout-examples {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.1rem;
  }

  .fanout-example {
    font-size: 0.86rem;
    padding: 0.42rem 0.78rem;
    border-radius: 999px;
    cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
    background: color-mix(in srgb, var(--accent-blue) 8%, transparent);
    color: var(--ink);
  }

  .fanout-example:hover {
    border-color: color-mix(in srgb, var(--accent-blue) 40%, transparent);
  }

  .fanout-results {
    max-width: 1080px;
    margin: 2.75rem auto 0;
    text-align: left;
    display: grid;
    gap: 1rem;
  }
  .fanout-results.hidden { display: none; }

  .fanout-panel {
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-radius: 1.15rem;
    padding: clamp(1.15rem, 2.3vw, 1.75rem);
    background: color-mix(in srgb, var(--bg-surface-1) 94%, white 6%);
  }

  .fanout-panel h2 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(1.18rem, 2vw, 1.55rem);
    line-height: 1.15;
  }

  .fanout-panel-copy {
    margin: 0.45rem 0 1.15rem;
    color: var(--ink-muted);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .fanout-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.68fr);
    gap: 1rem;
  }

  .fanout-answer {
    color: var(--ink);
    font-size: 1rem;
    line-height: 1.65;
  }

  .fanout-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.65rem; }
  .fanout-list li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.7rem;
    align-items: start;
    padding: 0.78rem 0.9rem;
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--accent-blue) 7%, transparent);
    color: var(--ink);
    font-size: 0.94rem;
    line-height: 1.45;
  }

  .fanout-index {
    display: inline-flex;
    width: 1.75rem;
    height: 1.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-blue) 16%, white 84%);
    color: var(--accent-blue);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .domain-list {
    display: grid;
    gap: 0.65rem;
  }

  .domain-card {
    padding: 0.85rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
    border-radius: 0.85rem;
    background: color-mix(in srgb, var(--bg-canvas) 78%, white 22%);
  }

  .domain-row { display: flex; align-items: center; gap: 0.75rem; }
  .domain-name { font-weight: 800; color: var(--ink); }
  .domain-count {
    margin-left: auto;
    flex: 0 0 auto;
    font-size: 0.78rem;
    font-weight: 800;
    padding: 0.2rem 0.62rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-blue) 14%, transparent);
    color: var(--accent-blue);
  }

  .domain-urls { display: grid; gap: 0.32rem; margin: 0.62rem 0 0; }
  .domain-urls a {
    color: var(--ink-muted);
    font-size: 0.82rem;
    line-height: 1.35;
    word-break: break-all;
  }

  .source-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .source-link {
    display: block;
    padding: 0.72rem 0.82rem;
    border: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--bg-canvas) 78%, white 22%);
    color: var(--ink-muted);
    font-size: 0.84rem;
    line-height: 1.35;
    word-break: break-all;
  }

  .fanout-loading {
    overflow: hidden;
  }

  .fanout-loading-bar {
    position: relative;
    height: 0.42rem;
    margin-top: 1.2rem;
    overflow: hidden;
    border-radius: 999px;
    background: color-mix(in srgb, var(--ink) 10%, transparent);
  }

  .fanout-loading-bar::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 42%;
    border-radius: inherit;
    background: var(--accent-blue);
    animation: fanout-progress 1.45s ease-in-out infinite;
  }

  @keyframes fanout-progress {
    0% { transform: translateX(-105%); }
    55% { transform: translateX(95%); }
    100% { transform: translateX(250%); }
  }

  .fanout-error { padding: 1rem 1.25rem; border-radius: 0.75rem; background: color-mix(in srgb, #ef4444 14%, transparent); color: #b91c1c; }
  .fanout-cta { margin-top: 0.75rem; }
  .fanout-note { margin-top: 1.25rem; text-align: center; font-size: 0.8rem; opacity: 0.6; }

  @media (max-width: 780px) {
    .tool-hero {
      padding-top: 2.8rem;
    }

    .tool-hero-title {
      font-size: clamp(2.65rem, 14vw, 4.2rem);
    }

    .fanout-form,
    .fanout-grid,
    .source-grid {
      grid-template-columns: 1fr;
    }

    .fanout-submit {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const initFanout = () => {
    const form = document.getElementById('fanout-form');
    const input = document.getElementById('fanout-input');
    const results = document.getElementById('fanout-results');
    if (!form || !results || !input) return;

    const submit = form.querySelector('button[type="submit"]');

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function countLabel(count, one, few, many) {
      const value = Number(count);
      if (value === 1) return one;
      if (value > 1 && value < 5) return few;
      return many;
    }

    function cleanUrlLabel(url) {
      try {
        const parsed = new URL(String(url));
        return `${parsed.hostname.replace(/^www\./i, '')}${parsed.pathname === '/' ? '' : parsed.pathname}`;
      } catch {
        return String(url);
      }
    }

    function setLoading(isLoading) {
      if (!submit) return;
      submit.disabled = isLoading;
      submit.setAttribute('aria-busy', isLoading ? 'true' : 'false');
    }

    function renderError(message) {
      results.classList.remove('hidden');
      results.innerHTML = `<div class="fanout-error">${escapeHtml(message)}</div>`;
    }

    function renderResults(data) {
      if (data.status === 'no-search') {
        const answer = data.answer
          ? `<p class="fanout-panel-copy">${escapeHtml(data.answer)}</p>`
          : '';
        results.innerHTML = `
          <div class="fanout-panel">
            <h2>Brak zapytań wyszukiwania</h2>
            ${answer}
            <p class="fanout-panel-copy">W tym przebiegu model nie ujawnił osobnego wyszukiwania w sieci. Spróbuj frazy rankingowej, porównawczej albo aktualnego pytania branżowego.</p>
          </div>`;
        return;
      }

      const fanouts = (data.fanoutQueries || [])
        .map((q, index) => `<li><span class="fanout-index">${String(index + 1).padStart(2, '0')}</span><span>${escapeHtml(q)}</span></li>`)
        .join('');
      const domains = (data.citedDomains || [])
        .map((d) => {
          const count = Number(d.count) || 0;
          return `
          <div class="domain-card">
            <div class="domain-row">
              <span class="domain-name">${escapeHtml(d.domain)}</span>
              <span class="domain-count">${escapeHtml(String(count))} ${countLabel(count, 'cytowanie', 'cytowania', 'cytowań')}</span>
            </div>
            <div class="domain-urls">
              ${(d.urls || [])
                .filter((u) => /^https?:\/\//i.test(String(u)))
                .slice(0, 4)
                .map((u) => `<a href="${escapeHtml(u)}" target="_blank" rel="nofollow noopener">${escapeHtml(cleanUrlLabel(u))}</a>`)
                .join('')}
            </div>
          </div>`;
        })
        .join('');
      const searchedDomains = (data.searchedDomains || [])
        .map((d) => {
          const count = Number(d.count) || 0;
          return `
          <div class="domain-card">
            <div class="domain-row">
              <span class="domain-name">${escapeHtml(d.domain)}</span>
              <span class="domain-count">${escapeHtml(String(count))} ${countLabel(count, 'URL', 'URL-e', 'URL-i')}</span>
            </div>
          </div>`;
        })
        .join('');
      const sources = (data.searchedSources || [])
        .filter((source) => /^https?:\/\//i.test(String(source.url)))
        .slice(0, 12)
        .map((source) => `<a class="source-link" href="${escapeHtml(source.url)}" target="_blank" rel="nofollow noopener">${escapeHtml(cleanUrlLabel(source.url))}</a>`)
        .join('');
      const answer = data.answer
        ? `<section class="fanout-panel">
            <h2>Odpowiedź modelu</h2>
            <p class="fanout-panel-copy">Kontekst, w którym pojawiły się cytowania i zapytania.</p>
            <div class="fanout-answer">${escapeHtml(data.answer)}</div>
          </section>`
        : '';

      const remaining = data.usage?.remaining ?? 0;
      const ctaHtml = remaining <= 0
        ? `<p class="fanout-cta"><a class="btn-primary" href="/kontakt">Chcesz pełny audyt widoczności w AI? Napisz do nas</a></p>`
        : `<p class="fanout-note">Pozostały Ci dziś ${escapeHtml(String(remaining))} zapytania.</p>`;

      results.innerHTML = `
        ${answer}
        <section class="fanout-panel">
          <h2>Zapytania wyszukiwania (${escapeHtml(String((data.fanoutQueries || []).length))})</h2>
          <p class="fanout-panel-copy">Frazy ujawnione przez model w tym przebiegu dla: „${escapeHtml(data.query)}”.</p>
          <ul class="fanout-list">${fanouts || '<li>brak</li>'}</ul>
        </section>
        <div class="fanout-grid">
          <section class="fanout-panel">
            <h2>Cytowane domeny</h2>
            <p class="fanout-panel-copy">Domeny, które trafiły do finalnej odpowiedzi modelu.</p>
            <div class="domain-list">${domains || '<p class="fanout-panel-copy">Brak cytowań w odpowiedzi.</p>'}</div>
          </section>
          <section class="fanout-panel">
            <h2>Źródła wyszukiwania</h2>
            <p class="fanout-panel-copy">Adresy i domeny zwrócone przez warstwę wyszukiwania, jeśli API je udostępniło.</p>
            <div class="domain-list">${searchedDomains || '<p class="fanout-panel-copy">Brak dodatkowych źródeł w odpowiedzi API.</p>'}</div>
          </section>
        </div>
        ${sources ? `
          <section class="fanout-panel">
            <h2>Sprawdzone URL-e</h2>
            <p class="fanout-panel-copy">Lista źródeł z wyszukiwania. Linki są oznaczone jako nofollow.</p>
            <div class="source-grid">${sources}</div>
          </section>
        ` : ''}
        ${ctaHtml}
      `;
    }

    form.querySelectorAll('.fanout-example').forEach((btn) => {
      btn.addEventListener('click', () => {
        input.value = btn.getAttribute('data-query') || '';
        form.requestSubmit();
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const query = String(input.value || '').trim();
      if (query.length < 3) { renderError('Podaj zapytanie (min. 3 znaki).'); return; }

      setLoading(true);
      results.classList.remove('hidden');
      results.innerHTML = `
        <div class="fanout-panel fanout-loading">
          <h2>Sprawdzamy: „${escapeHtml(query)}”</h2>
          <p class="fanout-panel-copy">Model generuje odpowiedź, uruchamia wyszukiwanie i zwraca cytowane źródła. To zwykle trwa kilkanaście sekund.</p>
          <div class="fanout-loading-bar" aria-hidden="true"></div>
        </div>`;

      try {
        const response = await fetch('/api/tools/fanout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query }),
        });
        const body = await response.json();
        if (!response.ok) throw new Error(body.error || `HTTP ${response.status}`);
        renderResults(body);
      } catch (error) {
        renderError(error instanceof Error ? error.message : 'Nie udało się wykonać zapytania.');
      } finally {
        setLoading(false);
      }
    });
  };

  document.addEventListener('astro:page-load', initFanout);
</script>
