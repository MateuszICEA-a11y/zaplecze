---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollUpButton from '../components/ScrollUpButton.astro';
import AuthorsStrip from '../components/AuthorsStrip.astro';
import CTABand from '../components/CTABand.astro';
import StatsBand from '../components/StatsBand.astro';
import { getCollection } from 'astro:content';

const principles = [
  {
    title: 'Mierzymy cytowania, nie wirtualne pozycje',
    desc: 'Pozycja numer 1 w ChatGPT czy Perplexity nie istnieje – każda odpowiedź jest generowana na żywo. Dlatego liczymy twarde dane: ile razy Twoja marka pojawia się w odpowiedziach na zapytania branżowe, kto jest cytowany zamiast Ciebie i z jakich źródeł AI korzysta najczęściej.',
  },
  {
    title: 'Pięć modeli, nie jeden',
    desc: 'ChatGPT, Claude, Gemini, Perplexity i Bing Copilot w zupełnie inny sposób budują swoje odpowiedzi. ChatGPT łączy dane treningowe z wyszukiwaniem na żywo, Gemini bazuje na indeksie Google, a Perplexity stawia na transparentne linkowanie do źródeł. Optymalizacja pod tylko jeden model to dziś za mało.',
  },
  {
    title: 'Sygnały rankingowe dobierane pod konkretny silnik',
    desc: 'Każdy asystent AI zwraca uwagę na inne elementy: gęstość faktów, precyzyjną strukturę nagłówków, wdrożone dane strukturalne (Schema) czy autorytet Twojej domeny w bazach treningowych dla sztucznej inteligencji. Audytujemy i optymalizujemy stronę oddzielnie pod każdy model, ponieważ uniwersalne "najlepsze praktyki GEO" po prostu nie istnieją.',
  },
  {
    title: 'Tradycyjne SEO za nami, GEO przed nami',
    desc: 'Zespół ICEA skutecznie pozycjonuje strony od kilkunastu lat. Doskonale wiemy, jak Google ocenia witryny, dlatego świetnie rozumiemy, gdzie kończy się klasyczne SEO, a zaczyna optymalizacja pod AI. Łączymy doświadczenie z ponad 200 wdrożeń z nowoczesną metodyką dedykowaną wyszukiwarkom generatywnym.',
  },
];

const antiPractices = [
  {
    title: 'Nie obiecujemy "pierwszego miejsca" w ChatGPT',
    desc: 'W modelach generatywnych nie ma jednej stałej pozycji. Zamiast tego raportujemy realny udział Twojej marki w odpowiedziach, liczbę cytowań, sentyment wypowiedzi AI oraz pokazujemy konkurentów, którzy pojawiają się w Twoim miejscu.',
  },
  {
    title: 'Nie sprzedajemy sztucznych rankingów',
    desc: 'Nasz Wskaźnik Widoczności (Visibility Score) opiera się na analizie realnych odpowiedzi z pięciu modeli, a nie na arbitralnych, wymyślonych tabelkach. Każda liczba w naszym raporcie ma biznesowy kontekst i rzetelną metodologię.',
  },
  {
    title: 'Nie generujemy spamu z użyciem AI',
    desc: 'Nie zalewamy Twojego serwisu masą tekstów pisanych przez boty. Zamiast tego wdrażamy twarde fakty, sekcje FAQ, odpowiednią strukturę danych i konkretne źródła. Robimy to po to, aby modele AI uznały Twój tekst za wartościowy i miały co zacytować.',
  },
  {
    title: 'Nie chowamy autorów za logiem marki',
    desc: 'Każdy artykuł i każda rekomendacja, którą od nas otrzymasz, ma autora z nazwiskiem, określoną rolą i profilem eksperta ICEA. Wiesz, z kim rozmawiasz i czyje wnioski czytasz. Co więcej, algorytmy AI (takie jak Gemini) weryfikują autorytet twórców, więc jest to również wymóg techniczny.',
  },
];

const authorOrder = [
  'tomasz-czechowski',
  'anna-jelonek',
  'michal-ziach',
  'piotr-wicenciak',
  'mateusz-wisniewski',
];
const allAuthors = await getCollection('authors');
const authors = authorOrder
  .map((slug) => allAuthors.find((author) => author.id === slug))
  .filter((author): author is NonNullable<typeof author> => Boolean(author));

const siteUrl = 'https://widocznosc.ai';
---

<Layout
  title="O nas – widocznosc.ai"
  description="Zespół ICEA od kilkunastu lat pozycjonuje strony w Google. Teraz pomagamy markom być widocznymi w wyszukiwarkach AI: ChatGPT, Claude, Gemini, Perplexity, Bing Copilot."
>
  <Navbar />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'AboutPage',
      name: 'O nas – widocznosc.ai',
      url: `${siteUrl}/o-nas`,
      about: {
        '@type': 'Organization',
        name: 'widocznosc.ai',
        url: siteUrl,
        description:
          'Projekt ICEA skoncentrowany na widoczności marek w wyszukiwarkach AI: ChatGPT, Claude, Gemini, Perplexity i Bing Copilot.',
        foundingDate: '2026',
        parentOrganization: {
          '@type': 'Organization',
          name: 'ICEA',
          url: 'https://grupa-icea.pl',
        },
        employee: authors.map((author) => ({
          '@type': 'Person',
          name: author.data.name,
          jobTitle: author.data.role,
          worksFor: {
            '@type': 'Organization',
            name: 'ICEA',
          },
          knowsAbout: [
            'SEO',
            'Generative Engine Optimization',
            'AI Search',
            ...author.data.expertise,
          ],
          sameAs: [author.data.linkedin, author.data.iceaProfile].filter(Boolean),
        })),
      },
    })}
  />

  <section class="about-hero" aria-labelledby="about-hero-title">
    <div class="content-container about-hero-inner">
      <div class="about-hero-copy">
        <span class="eyebrow about-eyebrow">O widocznosc.ai</span>
        <h1 id="about-hero-title" class="display-xxl">
          <span>Łączymy SEO</span>
          <span>z widocznością</span>
          <span>w <span class="accent">AI Search</span></span>
        </h1>
        <p>
          widocznosc.ai to flagowy projekt
          <a href="https://grupa-icea.pl" target="_blank" rel="noopener noreferrer"
            >grupa-icea.pl</a
          >
          dla marek, które chcą być cytowane przez ChatGPT, Claude, Gemini, Perplexity i Bing
          Copilot. Mierzymy realne odpowiedzi modeli, źródła i sentyment, a nie sztuczne pozycje w
          tabelce.
        </p>
        <div class="about-hero-actions">
          <a class="btn-primary" href="/kontakt?type=audyt-ai">Zamów audyt AI</a>
          <a class="btn-secondary" href="/narzedzia/brand-check">Sprawdź widoczność · 60s</a>
        </div>
      </div>

      <aside class="about-hero-panel" aria-label="Zakres pracy zespołu widocznosc.ai">
        <div class="about-panel-top">
          <span>ICEA + GEO</span>
          <strong>Strategia widoczności dla klasycznych wyników i odpowiedzi generatywnych</strong>
        </div>
        <dl class="about-panel-stats">
          <div>
            <dt>eksperci</dt>
            <dd>5</dd>
          </div>
          <div>
            <dt>projekty SEO</dt>
            <dd>500+</dd>
          </div>
          <div>
            <dt>modele w audycie</dt>
            <dd>5</dd>
          </div>
        </dl>
        <ul class="about-panel-list">
          <li><span>01</span> Audyt cytowań i źródeł w modelach AI</li>
          <li><span>02</span> Techniczne SEO, dane strukturalne i dostęp botów</li>
          <li><span>03</span> Content i encje budujące autorytet marki</li>
        </ul>
      </aside>
    </div>
  </section>

  <StatsBand />

  <!-- Cztery zasady GEO -->
  <section class="principles-section" aria-labelledby="principles-title">
    <div class="content-container">
      <div class="principles-head">
        <div class="principles-meta">
          <span class="section-index">A/01</span>
          <span class="eyebrow">Zasady, którymi się kierujemy</span>
        </div>
        <h2 id="principles-title" class="display-xl">
          Cztery rzeczy, w&nbsp;które wierzymy bezkompromisowo
        </h2>
        <p>
          GEO (Generative Engine Optimization) to zupełnie nowa dyscyplina. Widoczność w sztucznej
          inteligencji buduje się inaczej niż w klasycznym SEO. Poniższe cztery zasady tłumaczą,
          jak podchodzimy do naszej pracy.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {
          principles.map((p, i) => (
            <div class="principle-card">
              <div class="principle-number">0{i + 1}</div>
              <h3
                class="mb-3 text-xl font-medium"
                style="font-family: var(--font-display); letter-spacing: -0.5px;"
              >
                {p.title}
              </h3>
              <p class="text-ink-muted text-sm leading-relaxed">{p.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ICEA + GEO – differentiators -->
  <section class="relative w-full" aria-labelledby="differentiators-title">
    <div class="content-container py-16 lg:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <div class="head-meta">
            <span class="section-index">A/02</span>
            <span class="eyebrow">ICEA + GEO</span>
          </div>
          <h2 id="differentiators-title" class="display-xl mt-2 mb-6">
            Czego nie robimy<br />w audycie AI
          </h2>
          <p class="text-ink mb-6 text-lg leading-relaxed">
            Od kilkunastu lat dążymy do perfekcji w SEO. Tę samą rygorystyczność – mierzalność,
            transparentność i powtarzalną metodologię – przenosimy teraz do GEO.
          </p>
          <p class="text-ink-muted leading-relaxed">
            Lista rzeczy, których <strong>NIE robimy</strong>, jest dla nas równie ważna jak nasze
            obietnice. Pokazujemy, czego świadomie unikamy, bo to właśnie tam najczęściej zaczyna
            się marketingowy szum i wprowadzanie klienta w błąd.
          </p>
        </div>

        <div class="lg:col-span-7">
          <div class="space-y-3">
            {
              antiPractices.map((d) => (
                <div class="anti-card">
                  <h3
                    class="mb-2 text-lg font-medium"
                    style="font-family: var(--font-display); letter-spacing: -0.4px;"
                  >
                    {d.title}
                  </h3>
                  <p class="text-ink-muted text-sm leading-relaxed">{d.desc}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Zespół (AuthorsStrip z homepage) -->
  <AuthorsStrip
    eyebrow="Zespół"
    sectionIndex="A/03"
    title='Pięć osób, <span class="accent">15+ lat doświadczenia</span>'
    subtitle="Każdy artykuł na stronie widocznosc.ai oraz każda rekomendacja w naszych audytach są podpisane imieniem i nazwiskiem. Wiesz, z kim rozmawiasz, kogo uwiarygadniają znaczniki strukturalne na stronie i czyje wieloletnie doświadczenie stoi za proponowaną strategią."
    limit={5}
  />

  <CTABand
    eyebrow="Pierwszy krok"
    title="Sprawdźmy, gdzie jesteś dziś"
    subtitle="Zarezerwuj bezpłatną, 30-minutową konsultację z ekspertem ICEA. Pokażemy Ci, gdzie Twoja marka jest już cytowana, w jakich obszarach wyprzedza Cię konkurencja i jaki realny plan na pierwsze 90 dni przyniesie największy zwrot w Twojej branży."
    primaryLabel="Zamów audyt AI"
    primaryHref="/kontakt?type=audyt-ai"
    ghostLabel="Bezpłatna konsultacja"
    ghostHref="/kontakt?type=konsultacja"
  />

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .about-hero {
    position: relative;
    overflow: hidden;
    padding: 112px 0 72px;
    border-bottom: 1px solid var(--hairline-soft);
    background:
      radial-gradient(
        circle at 16% 18%,
        color-mix(in srgb, var(--accent-blue) 17%, transparent) 0%,
        transparent 34%
      ),
      radial-gradient(circle at 88% 18%, rgba(167, 139, 250, 0.16) 0%, transparent 32%),
      linear-gradient(180deg, var(--bg-surface-1) 0%, var(--bg-canvas) 82%);
  }

  .about-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(var(--hairline-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.16), transparent 68%);
    pointer-events: none;
  }

  .about-hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(22rem, 0.62fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .about-eyebrow {
    margin-bottom: 1.45rem;
  }

  .about-hero h1 {
    max-width: 800px;
    margin: 0;
    color: var(--ink);
    letter-spacing: 0;
    line-height: 0.97;
    text-wrap: balance;
  }

  .about-hero h1 > span {
    display: block;
  }

  .about-hero-copy p {
    max-width: 720px;
    margin: 1.55rem 0 0;
    color: var(--ink);
    font-size: clamp(1.05rem, 1.35vw, 1.22rem);
    line-height: 1.58;
  }

  .about-hero-copy a {
    color: var(--accent-blue);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .about-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: 2.4rem;
  }

  .about-hero-copy .about-hero-actions a.btn-primary,
  .about-hero-copy .about-hero-actions a.btn-secondary {
    text-decoration: none;
    text-underline-offset: 0;
  }

  .about-hero-copy .about-hero-actions a.btn-primary {
    color: var(--bg-canvas);
  }

  .about-hero-copy .about-hero-actions a.btn-secondary {
    color: var(--ink);
  }

  .about-hero-panel {
    --panel-accent: #38bdf8;
    display: grid;
    gap: 0.95rem;
    min-width: 0;
    padding: clamp(1rem, 2.4vw, 1.35rem);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background:
      radial-gradient(
        circle at 18% 0%,
        color-mix(in srgb, var(--panel-accent) 18%, transparent) 0%,
        transparent 36%
      ),
      var(--bg-surface-1);
    box-shadow: 0 24px 80px color-mix(in srgb, #000 18%, transparent);
  }

  .about-panel-top {
    display: grid;
    gap: 0.55rem;
    padding: 1rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-lg);
    background: color-mix(in srgb, var(--bg-surface-2) 76%, transparent);
  }

  .about-panel-top span {
    color: var(--panel-accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .about-panel-top strong {
    color: var(--ink);
    font-size: clamp(1.05rem, 1.45vw, 1.3rem);
    line-height: 1.25;
    text-wrap: balance;
  }

  .about-panel-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin: 0;
    padding: 0.15rem 0 0.95rem;
    border-bottom: 1px solid var(--hairline-soft);
  }

  .about-panel-stats div {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 0 0.75rem;
    border-right: 1px solid var(--hairline-soft);
    text-align: center;
  }

  .about-panel-stats div:first-child {
    padding-left: 0.75rem;
  }

  .about-panel-stats div:last-child {
    border-right: 0;
    padding-right: 0.75rem;
  }

  .about-panel-stats dt {
    color: var(--ink-faint);
    font-size: 0.72rem;
    line-height: 1.3;
  }

  .about-panel-stats dd {
    margin: 0.28rem 0 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.6vw, 2rem);
    line-height: 1;
  }

  .about-panel-list {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .about-panel-list li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.7rem;
    align-items: center;
    padding: 0.85rem 0.9rem;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-md);
    background: var(--bg-canvas);
    color: var(--ink);
    font-size: 0.9rem;
    line-height: 1.35;
  }

  .about-panel-list span {
    color: var(--panel-accent);
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 0.78rem;
  }

  .principles-section {
    position: relative;
    width: 100%;
    padding: clamp(5.25rem, 8vw, 7rem) 0 clamp(4.5rem, 7vw, 6.25rem);
  }

  .principles-head {
    max-width: 880px;
    margin: 0 auto clamp(3.5rem, 6vw, 4.75rem);
    text-align: center;
  }

  .principles-meta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: clamp(1.15rem, 2vw, 1.55rem);
  }

  .principles-meta .section-index,
  .principles-meta .eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 650;
    line-height: 1;
    letter-spacing: 0.06em;
  }

  .principles-meta .eyebrow {
    color: var(--ink-muted);
  }

  .principles-meta .eyebrow::before {
    width: 0.5rem;
    height: 0.5rem;
  }

  .principles-head h2 {
    max-width: 760px;
    margin: 0 auto;
    line-height: 1.04;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .principles-head p {
    max-width: 740px;
    margin: clamp(1.35rem, 2.4vw, 1.8rem) auto 0;
    color: var(--ink-muted);
    font-size: clamp(1.05rem, 1.45vw, 1.22rem);
    line-height: 1.72;
    text-wrap: pretty;
  }

  .principle-card,
  .anti-card {
    --card-accent: var(--accent-blue);
    position: relative;
    overflow: hidden;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background:
      radial-gradient(
        circle at 12% 0%,
        color-mix(in srgb, var(--card-accent) 13%, transparent) 0%,
        transparent 34%
      ),
      var(--bg-surface-1);
  }

  .principle-card {
    min-height: 100%;
    padding: clamp(1.75rem, 3vw, 2.5rem);
  }

  .principle-card:nth-child(2) {
    --card-accent: #4ade80;
  }

  .principle-card:nth-child(3) {
    --card-accent: #fbbf24;
  }

  .principle-card:nth-child(4) {
    --card-accent: #a78bfa;
  }

  :global(:root[data-theme='light']) .principle-card:nth-child(2) {
    --card-accent: #16a34a;
  }

  :global(:root[data-theme='light']) .principle-card:nth-child(3) {
    --card-accent: #d97706;
  }

  :global(:root[data-theme='light']) .principle-card:nth-child(4) {
    --card-accent: #7c3aed;
  }

  .principle-number {
    margin-bottom: 1rem;
    color: var(--card-accent);
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    line-height: 1;
  }

  .anti-card {
    padding: clamp(1.45rem, 2.5vw, 1.75rem);
  }

  .anti-card:nth-child(2) {
    --card-accent: #4ade80;
  }

  .anti-card:nth-child(3) {
    --card-accent: #fbbf24;
  }

  .anti-card:nth-child(4) {
    --card-accent: #a78bfa;
  }

  @media (max-width: 980px) {
    .about-hero-inner {
      grid-template-columns: 1fr;
    }

    .about-hero-panel {
      width: min(100%, 680px);
    }
  }

  @media (max-width: 760px) {
    .about-hero {
      padding: 5.5rem 0 3.8rem;
    }

    .about-hero h1 {
      font-size: clamp(2.05rem, 8.8vw, 2.45rem);
      line-height: 1.04;
      text-wrap: pretty;
    }

    .about-hero-copy p {
      max-width: 34ch;
    }

    .about-hero-actions {
      justify-content: center;
      margin-top: 1.65rem;
    }

    .about-hero-actions a {
      box-sizing: border-box;
      width: min(100%, 22rem);
      max-width: 22rem;
      justify-content: center;
      white-space: normal;
    }

    .about-panel-stats {
      grid-template-columns: 1fr;
    }

    .principles-section {
      padding: 4.5rem 0 4rem;
    }

    .principles-head {
      margin-bottom: 2.5rem;
    }

    .principles-meta {
      align-items: center;
      flex-wrap: wrap;
      row-gap: 0.55rem;
      margin-bottom: 1rem;
    }

    .principles-head h2 {
      max-width: 11.5em;
      line-height: 1.08;
    }

    .principles-head p {
      max-width: 34rem;
      font-size: 1rem;
      line-height: 1.68;
    }

    .about-panel-stats div {
      padding: 0.75rem 0;
      border-right: 0;
      border-bottom: 1px solid var(--hairline-soft);
    }

    .about-panel-stats div:first-child {
      padding-top: 0;
    }

    .about-panel-stats div:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }
  }
</style>
