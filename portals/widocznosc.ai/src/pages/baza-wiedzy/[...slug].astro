---
import ArticleLayout from '@layouts/ArticleLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }: any) => !data.draft);
  return articles.map((entry: any) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as any;
const { Content, headings } = await entry.render();
const url = `${Astro.site}baza-wiedzy/${entry.slug}/`;
const primaryAuthor = entry.data.authors[0];
const authorEntry = await getEntry('authors', primaryAuthor.id);
---
<ArticleLayout
  frontmatter={entry.data}
  headings={headings}
  url={url}
  authorSlug={primaryAuthor.id}
  authorData={{
    name: authorEntry!.data.name,
    iceaProfile: authorEntry!.data.iceaProfile,
  }}
>
  <Content />
</ArticleLayout>
