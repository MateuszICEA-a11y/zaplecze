---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Article from '../../components/Article.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { PILLAR_LABELS } from '../../content.config';

export const getStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const [pillar, slug] = post.id.split('/');
    return { params: { pillar, slug }, props: { post } };
  });
};

const { post } = Astro.props;
const { Content } = await render(post);

const [pillar] = post.id.split('/');

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => {
    const aSamePillar = a.data.pillar === pillar ? 1 : 0;
    const bSamePillar = b.data.pillar === pillar ? 1 : 0;

    if (aSamePillar !== bSamePillar) {
      return bSamePillar - aSamePillar;
    }

    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 6);

const authors = await getCollection('authors');
const authorEntry = authors.find((author) => author.data.name === post.data.author.name);
const authorArticleCount = allPosts.filter(
  (p) => p.data.author.name === post.data.author.name && p.id !== post.id
).length;

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });

const articleData = {
  title: post.data.title,
  subtitle: post.data.subtitle,
  date: formatDate(post.data.date),
  image: post.data.image.src,
  author: {
    name: post.data.author.name,
    role: post.data.author.role,
    avatar: post.data.author.avatar.src,
  },
  readTime: post.data.readTime,
  tags: post.data.tags,
};
---

<Layout
  title={`${post.data.title} – widocznosc.ai`}
  description={post.data.description}
  ogType="article"
  articleMeta={{
    publishedTime: post.data.date.toISOString(),
    author: post.data.author.name,
    tags: post.data.tags,
  }}
>
  <Navbar />
  <Article articleData={articleData}>
    <nav slot="breadcrumb" class="article-breadcrumb" aria-label="Ścieżka nawigacji">
      <a href="/blog/" class="article-breadcrumb-link">Baza wiedzy</a>
      <span class="article-breadcrumb-sep" aria-hidden="true">›</span>
      <a href={`/${pillar}/`} class="article-breadcrumb-link"
        >{PILLAR_LABELS[pillar as keyof typeof PILLAR_LABELS]}</a
      >
      <span class="article-breadcrumb-sep" aria-hidden="true">›</span>
      <span class="article-breadcrumb-current">{post.data.title}</span>
    </nav>
    <Content />
    {
      authorEntry && (
        <AuthorBox
          author={authorEntry.data}
          articleCount={authorArticleCount}
          authorSlug={authorEntry.id}
        />
      )
    }
  </Article>

  <!-- Related posts -->
  <section class="related-section">
    <div class="related-container">
      <div class="display-md related-title">Zobacz również</div>
      <div class="related-grid">
        {
          relatedPosts.map((related) => (
            <a href={`/${related.id}/`} class="related-card">
              <div class="related-card-media">
                <Image
                  src={related.data.image}
                  alt={related.data.title}
                  class="related-card-image"
                  loading="lazy"
                />
              </div>
              <div class="related-card-body">
                <div class="related-card-meta">
                  <span>{PILLAR_LABELS[related.data.pillar]}</span>
                  <span>{formatDate(related.data.date)}</span>
                </div>
                <div class="related-card-title">{related.data.title}</div>
                <p class="related-card-desc">{related.data.subtitle}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .related-section {
    background: var(--bg-canvas);
    padding: 0 0 96px 0;
  }

  .related-container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 64px 30px 0 30px;
    border-top: 1px solid var(--hairline-soft);
  }

  .related-title {
    color: var(--ink);
    margin: 0 0 32px 0;
  }

  .related-grid {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(280px, 82vw);
    gap: 16px;
    margin-inline: -30px;
    padding-inline: 30px;
    overflow-x: auto;
    scroll-padding-inline: 30px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .related-grid::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 768px) {
    .related-grid {
      grid-auto-flow: initial;
      grid-auto-columns: initial;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      margin-inline: 0;
      padding-inline: 0;
      overflow: visible;
      scroll-snap-type: none;
    }
  }

  @media (min-width: 1180px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  .related-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    overflow: hidden;
    text-decoration: none;
    scroll-snap-align: start;
    border: 1px solid var(--hairline-soft);
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
    height: 100%;
  }

  .related-card:hover {
    background: var(--bg-surface-2);
    border-color: var(--hairline);
    transform: translateY(-2px);
  }

  .related-card-media {
    aspect-ratio: 16 / 9;
    background: var(--bg-canvas);
    margin: 10px;
    border-radius: var(--r-md);
    overflow: hidden;
  }

  .related-card-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .related-card:hover .related-card-image {
    transform: scale(1.035);
  }

  .related-card-body {
    padding: 10px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-grow: 1;
  }

  .related-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 10px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .related-card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.7vw, 1.625rem);
    line-height: 1.08;
    letter-spacing: var(--ls-headline);
    color: var(--ink);
    margin: 0;
  }

  .related-card-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.5;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    margin: 0;
  }
</style>
