---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Article from '../../components/Article.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import { getCollection, render } from 'astro:content';
import { PILLAR_LABELS } from '../../content.config';

export const getStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const [pillar, slug] = post.id.split('/');
    return { params: { pillar, slug }, props: { post } };
  });
};

const { post } = Astro.props;
const { Content } = await render(post);

const [pillar] = post.id.split('/');

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const authors = await getCollection('authors');
const authorEntry = authors.find((author) => author.data.name === post.data.author.name);
const authorArticleCount = allPosts.filter(
  (p) => p.data.author.name === post.data.author.name && p.id !== post.id,
).length;

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });

const articleData = {
  title: post.data.title,
  subtitle: post.data.subtitle,
  date: formatDate(post.data.date),
  image: post.data.image.src,
  author: {
    name: post.data.author.name,
    role: post.data.author.role,
    avatar: post.data.author.avatar.src,
  },
  readTime: post.data.readTime,
  tags: post.data.tags,
};
---

<Layout
  title={`${post.data.title} – widocznosc.ai`}
  description={post.data.description}
  ogType="article"
  articleMeta={{
    publishedTime: post.data.date.toISOString(),
    author: post.data.author.name,
    tags: post.data.tags,
  }}
>
  <Navbar />
  <Article articleData={articleData}>
    <nav slot="breadcrumb" class="article-breadcrumb" aria-label="Ścieżka nawigacji">
      <a href="/blog" class="article-breadcrumb-link">Baza wiedzy</a>
      <span class="article-breadcrumb-sep" aria-hidden="true">›</span>
      <a href={`/${pillar}/`} class="article-breadcrumb-link">{PILLAR_LABELS[pillar as keyof typeof PILLAR_LABELS]}</a>
      <span class="article-breadcrumb-sep" aria-hidden="true">›</span>
      <span class="article-breadcrumb-current">{post.data.title}</span>
    </nav>
    <Content />
    {
      authorEntry && (
        <AuthorBox
          author={authorEntry.data}
          articleCount={authorArticleCount}
          authorSlug={authorEntry.id}
        />
      )
    }
  </Article>

  <!-- Related posts -->
  <section class="related-section">
    <div class="related-container">
      <h2 class="display-md related-title">Zobacz również</h2>
      <div class="related-grid">
        {
          relatedPosts.map((related) => (
            <a href={`/${related.id}`} class="related-card">
              <div class="related-card-icon-wrap">
                <svg
                  class="related-card-icon"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  viewBox="0 0 24 24"
                  set:html={related.data.icon}
                />
              </div>
              <div class="related-card-body">
                <div class="related-card-date">{formatDate(related.data.date)}</div>
                <h3 class="related-card-title">{related.data.title}</h3>
                <p class="related-card-desc">{related.data.subtitle}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .related-section {
    background: var(--bg-canvas);
    padding: 0 0 96px 0;
  }

  .related-container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 64px 30px 0 30px;
    border-top: 1px solid var(--hairline-soft);
  }

  .related-title {
    color: var(--ink);
    margin: 0 0 32px 0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    overflow: hidden;
    text-decoration: none;
    transition: background 0.2s ease;
    height: 100%;
  }

  .related-card:hover {
    background: var(--bg-surface-2);
  }

  .related-card-icon-wrap {
    aspect-ratio: 3 / 2;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-canvas);
    margin: 12px;
    border-radius: var(--r-md);
  }

  .related-card-icon {
    width: 64px;
    height: 64px;
    color: var(--ink-muted);
  }

  .related-card-body {
    padding: 8px 24px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .related-card-date {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .related-card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-headline);
    line-height: 1.2;
    letter-spacing: var(--ls-headline);
    color: var(--ink);
    margin: 0;
  }

  .related-card-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.5;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    margin: 0;
  }
</style>
