---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { PILLAR_LABELS } from '../../content.config';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];

const usedPillars = Array.from(new Set(posts.map((p) => p.data.pillar))).sort();
const pillarCounts = posts.reduce(
  (counts, post) => {
    counts[post.data.pillar] = (counts[post.data.pillar] ?? 0) + 1;
    return counts;
  },
  {} as Record<string, number>
);
const totalPosts = posts.length;
const siteUrl = 'https://widocznosc.ai';
const starterPosts = ['geo/przewodnik', 'modele-llm/chatgpt', 'geo/audyt-widocznosci-marki']
  .map((id) => posts.find((post) => post.id === id))
  .filter((post): post is NonNullable<typeof post> => Boolean(post));
const popularTags = ['ChatGPT', 'llms.txt', 'AI Overviews', 'Schema.org', 'RAG'];

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title="Baza wiedzy – widocznosc.ai"
  description="Wiedza o pozycjonowaniu marek w wyszukiwarkach AI – ChatGPT, Claude, Gemini, Perplexity. Od fundamentów GEO po techniczne deep-dive."
>
  <Navbar />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Blog',
      name: 'Baza wiedzy widocznosc.ai',
      url: `${siteUrl}/blog`,
      blogPost: posts.map((post) => ({
        '@type': 'BlogPosting',
        headline: post.data.title,
        description: post.data.description || post.data.subtitle,
        datePublished: post.data.date.toISOString(),
        author: {
          '@type': 'Person',
          name: post.data.author.name,
          jobTitle: post.data.author.role,
        },
        keywords: post.data.tags.join(', '),
        url: `${siteUrl}/${post.id}`,
        image: `${siteUrl}${post.data.image.src}`,
      })),
    })}
  />

  <main class="blog-listing-main" data-blog-listing>
    <!-- Hero – pure canvas, display-xxl + lead -->
    <section class="blog-hero">
      <div class="blog-hero-container">
        <div class="head-meta blog-hero-meta">
          <span class="section-index">B/01</span>
          <span class="eyebrow blog-hero-eyebrow">Baza wiedzy</span>
        </div>
        <h1 class="display-xxl blog-hero-title">Pozycjonowanie marek w wyszukiwarkach AI</h1>
        <p class="blog-hero-lead">
          Definicje, case studies i&nbsp;poradniki o&nbsp;pozycjonowaniu marki w&nbsp;ChatGPT,
          Claude, Gemini, Perplexity i&nbsp;Bing Copilot. Od fundamentów GEO po techniczne
          deep-dive.
        </p>
      </div>
    </section>

    <!-- Featured artykuł – card-mockup full-width -->
    {
      featuredPost && (
        <section class="blog-featured-section">
          <div class="blog-featured-container">
            <a href={`/${featuredPost.id}`} class="blog-featured">
              <div class="blog-featured-image">
                <Image
                  src={featuredPost.data.image}
                  alt={featuredPost.data.title}
                  widths={[640, 960, 1280]}
                  sizes="(min-width: 1024px) 60vw, 100vw"
                  loading="eager"
                />
              </div>
              <div class="blog-featured-body">
                <div class="blog-featured-meta">
                  <span class="blog-featured-category">
                    {PILLAR_LABELS[featuredPost.data.pillar]}
                  </span>
                  <span class="blog-featured-date">{formatDate(featuredPost.data.date)}</span>
                </div>
                <h2 class="blog-featured-title display-lg">{featuredPost.data.title}</h2>
                <p class="blog-featured-desc">{featuredPost.data.subtitle}</p>
                <span class="blog-featured-cta">
                  Czytaj artykuł
                  <span aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          </div>
        </section>
      )
    }

    {
      starterPosts.length > 0 && (
        <section class="blog-starter-section" aria-labelledby="blog-starter-title">
          <div class="blog-grid-container">
            <div class="blog-starter">
              <div class="blog-starter-head">
                <span class="eyebrow">Nowy w temacie?</span>
                <h2 id="blog-starter-title" class="display-xl">
                  Zacznij od trzech artykułów
                </h2>
              </div>
              <div class="blog-starter-grid">
                {starterPosts.map((post) => (
                  <a class="blog-starter-card" href={`/${post.id}`}>
                    <span class="eyebrow">{PILLAR_LABELS[post.data.pillar]}</span>
                    <strong>{post.data.title}</strong>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </section>
      )
    }

    <!-- Grid section – wszystkie artykuły -->
    <section class="blog-grid-section">
      <div class="blog-grid-container">
        <header class="blog-grid-header">
          <h2 class="display-xl blog-grid-title">Wszystkie artykuły</h2>

          <div class="blog-controls">
            <label class="blog-search">
              <span class="eyebrow">Szukaj artykułu</span>
              <input
                type="search"
                placeholder="np. ChatGPT, llms.txt, schema"
                autocomplete="off"
                data-blog-search
              />
            </label>

            <div class="blog-popular-tags" aria-label="Polecane tematy">
              <span>Polecane:</span>
              {
                popularTags.map((tag) => (
                  <button
                    type="button"
                    class="tab-pill tab-pill--ghost"
                    data-tag-query={tag}
                    aria-pressed="false"
                  >
                    #{tag}
                  </button>
                ))
              }
            </div>

            <div class="blog-grid-filters" role="group" aria-label="Filtruj według kategorii">
              <button
                type="button"
                class="tab-pill is-active"
                data-category="all"
                aria-pressed="true"
              >
                <span>Wszystkie</span>
                <span class="filter-count">{totalPosts}</span>
              </button>
              {
                usedPillars.map((pillar) => (
                  <button
                    type="button"
                    class="tab-pill"
                    data-category={pillar}
                    aria-pressed="false"
                  >
                    <span>{PILLAR_LABELS[pillar]}</span>
                    <span class="filter-count">{pillarCounts[pillar] ?? 0}</span>
                  </button>
                ))
              }
            </div>
          </div>
        </header>

        <div class="blog-grid" id="posts-grid">
          {
            posts.map((post) => (
              <a
                href={`/${post.id}`}
                class="post-card"
                data-category={post.data.pillar}
                data-search={`${post.data.title} ${post.data.subtitle} ${post.data.tags.join(' ')} ${PILLAR_LABELS[post.data.pillar]} ${post.data.author.name}`}
              >
                <div class="post-card-image">
                  <Image
                    src={post.data.image}
                    alt={post.data.title}
                    widths={[480, 720, 960]}
                    sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                    loading="lazy"
                  />
                </div>
                <div class="post-card-body">
                  <div class="post-card-meta">
                    <span class="post-card-category">{PILLAR_LABELS[post.data.pillar]}</span>
                    <span class="post-card-date">{formatDate(post.data.date)}</span>
                  </div>
                  <h3 class="post-card-title display-md">{post.data.title}</h3>
                  <div class="post-card-footer">
                    <span class="post-card-author">
                      <img
                        src={post.data.author.avatar.src}
                        alt=""
                        width={32}
                        height={32}
                        loading="lazy"
                      />
                      <span>{post.data.author.name}</span>
                    </span>
                    <span>{post.data.readTime ?? '–'} czytania</span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>

        <div class="blog-empty" data-blog-empty hidden>
          <h3>Brak artykułów dla tego filtra</h3>
          <p>
            Spróbuj wybrać inną kategorię, zmienić wyszukiwanie albo przejrzeć wszystkie teksty.
          </p>
          <button class="tab-pill" type="button" data-clear-filter>Pokaż wszystkie</button>
        </div>

        <div class="blog-load-more-wrap">
          <button class="btn-secondary" type="button" data-load-more>Pokaż kolejne 12</button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .blog-listing-main {
    flex-grow: 1;
  }

  /* Hero */
  .blog-hero {
    background: var(--bg-canvas);
    padding: 128px 0 64px 0;
  }

  @media (min-width: 1024px) {
    .blog-hero {
      padding: 160px 0 80px 0;
    }
  }

  .blog-hero-container {
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
    padding: 0 30px;
  }

  .blog-hero-meta {
    margin-bottom: 16px;
  }

  .blog-hero-title {
    color: var(--ink);
    margin: 0 0 24px 0;
    text-wrap: balance;
    max-width: 880px;
  }

  .blog-hero-lead {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink-muted);
    margin: 0;
    max-width: 640px;
  }

  /* Featured */
  .blog-featured-section {
    background: var(--bg-canvas);
    padding: 0 0 64px 0;
  }

  .blog-featured-container {
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
    padding: 0 30px;
  }

  .blog-featured {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    overflow: hidden;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .blog-featured:hover {
    background: var(--bg-surface-2);
  }

  @media (min-width: 1024px) {
    .blog-featured {
      grid-template-columns: 1.4fr 1fr;
    }
  }

  .blog-featured-image {
    overflow: hidden;
  }

  .blog-featured-image img {
    aspect-ratio: 16 / 9;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  @media (min-width: 1024px) {
    .blog-featured-image img {
      aspect-ratio: auto;
      min-height: 100%;
    }
  }

  .blog-featured:hover .blog-featured-image img {
    transform: scale(1.02);
  }

  .blog-featured-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .blog-featured-body {
      padding: 48px;
    }
  }

  .blog-featured-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .blog-featured-category {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    background: var(--bg-surface-2);
    border-radius: var(--r-pill);
    font-family: var(--font-sans);
    font-size: var(--fs-micro);
    font-weight: 500;
    letter-spacing: -0.12px;
    color: var(--ink);
  }

  .blog-featured-date {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .blog-featured-title {
    color: var(--ink);
    margin: 0;
    text-wrap: balance;
  }

  .blog-featured-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    line-height: 1.5;
    letter-spacing: var(--ls-body);
    color: var(--ink-muted);
    margin: 0;
  }

  .blog-featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    color: var(--accent-blue);
    transition: gap 0.15s ease;
  }

  .blog-featured:hover .blog-featured-cta {
    gap: 10px;
  }

  /* Starter */
  .blog-starter-section {
    background: var(--bg-canvas);
    padding: 0 0 64px 0;
  }

  .blog-starter {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 24px;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background: var(--bg-surface-1);
  }

  @media (min-width: 1024px) {
    .blog-starter {
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
      align-items: end;
      padding: 32px;
    }
  }

  .blog-starter-head {
    display: grid;
    gap: 14px;
  }

  .blog-starter-head h2 {
    max-width: 560px;
    margin: 0;
    color: var(--ink);
  }

  .blog-starter-grid {
    display: grid;
    gap: 10px;
  }

  .blog-starter-card {
    display: grid;
    gap: 8px;
    padding: 16px;
    border-radius: var(--r-md);
    background: var(--bg-canvas);
    color: inherit;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .blog-starter-card:hover {
    background: var(--bg-surface-2);
  }

  .blog-starter-card .eyebrow {
    color: var(--ink-muted);
    font-size: var(--fs-caption);
  }

  .blog-starter-card strong {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: var(--fs-body-lg);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: var(--ls-body-lg);
  }

  /* Grid section */
  .blog-grid-section {
    background: var(--bg-canvas);
    padding: 64px 0 96px 0;
    border-top: 1px solid var(--hairline-soft);
  }

  .blog-grid-container {
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
    padding: 0 30px;
  }

  @media (max-width: 639px) {
    .blog-hero-container,
    .blog-featured-container,
    .blog-grid-container {
      padding-inline: 20px;
    }
  }

  .blog-grid-header {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 48px;
    padding-top: 64px;
  }

  @media (min-width: 1024px) {
    .blog-grid-header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 32px;
    }
  }

  .blog-grid-title {
    color: var(--ink);
    margin: 0;
  }

  .blog-controls {
    display: grid;
    gap: 14px;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .blog-controls {
      width: min(100%, 680px);
      justify-items: end;
    }
  }

  .blog-search {
    display: grid;
    gap: 8px;
    width: 100%;
  }

  .blog-search .eyebrow {
    color: var(--ink-muted);
  }

  .blog-search input {
    width: 100%;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-pill);
    background: var(--bg-surface-1);
    color: var(--ink);
    font: inherit;
    font-size: var(--fs-body-sm);
    padding: 12px 16px;
    outline: none;
  }

  .blog-search input:focus {
    border-color: color-mix(in srgb, var(--accent-blue) 42%, var(--hairline-soft));
  }

  .blog-popular-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    color: var(--ink-faint);
    font-size: var(--fs-caption);
  }

  .blog-popular-tags button {
    min-height: 32px;
  }

  .tab-pill--ghost {
    padding: 6px 12px;
    border: 1px solid var(--hairline-soft);
    background: transparent;
    font-size: 13px;
  }

  .tab-pill--ghost:hover,
  .tab-pill--ghost.is-active {
    border-color: var(--hairline);
    background: var(--bg-surface-1);
    color: var(--ink);
  }

  .blog-grid-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.45rem;
    height: 1.45rem;
    margin-left: 0.45rem;
    border-radius: var(--r-pill);
    background: var(--bg-surface-2);
    color: var(--ink-muted);
    font-size: var(--fs-micro);
    line-height: 1;
  }

  .tab-pill.is-active .filter-count {
    background: var(--bg-canvas);
    color: var(--ink);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Post card */
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    overflow: hidden;
    text-decoration: none;
    transition: background 0.2s ease;
    height: 100%;
  }

  .post-card:hover {
    background: var(--bg-surface-2);
  }

  .post-card[data-hidden='true'] {
    display: none;
  }

  .post-card-image {
    overflow: hidden;
  }

  .post-card-image img {
    aspect-ratio: 16 / 9;
    width: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .post-card:hover .post-card-image img {
    transform: scale(1.03);
  }

  .post-card-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px;
    flex-grow: 1;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .post-card-category {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    background: var(--bg-surface-2);
    border-radius: var(--r-pill);
    font-family: var(--font-sans);
    font-size: var(--fs-micro);
    font-weight: 500;
    letter-spacing: -0.12px;
    color: var(--ink);
  }

  .post-card-date {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .post-card-title {
    color: var(--ink);
    margin: 0;
    flex-grow: 1;
  }

  .post-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--hairline-soft);
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .post-card-author {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: 8px;
  }

  .post-card-author img {
    width: 24px;
    height: 24px;
    flex: 0 0 auto;
    border-radius: 50%;
    object-fit: cover;
  }

  .post-card-author span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .blog-empty {
    margin-top: 24px;
    padding: 32px;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background: var(--bg-surface-1);
    text-align: center;
  }

  .blog-empty h3 {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: var(--fs-display-md);
    font-weight: 500;
    letter-spacing: var(--ls-display-md);
  }

  .blog-empty p {
    max-width: 520px;
    margin: 12px auto 20px;
    color: var(--ink-muted);
    line-height: 1.55;
  }

  .blog-load-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }

  .blog-load-more-wrap[hidden],
  .blog-empty[hidden] {
    display: none;
  }
</style>

<script>
  const initFilters = () => {
    const root = document.querySelector<HTMLElement>('[data-blog-listing]');
    if (!root || root.dataset.blogListingReady === 'true') return;
    root.dataset.blogListingReady = 'true';

    const pageSize = 12;
    let visibleLimit = pageSize;
    let activeCategory = 'all';
    let searchQuery = '';

    const filters = root.querySelectorAll<HTMLButtonElement>('.blog-grid-filters .tab-pill');
    const cards = Array.from(root.querySelectorAll<HTMLElement>('.post-card'));
    const searchInput = root.querySelector<HTMLInputElement>('[data-blog-search]');
    const emptyState = root.querySelector<HTMLElement>('[data-blog-empty]');
    const clearButton = root.querySelector<HTMLButtonElement>('[data-clear-filter]');
    const loadMoreButton = root.querySelector<HTMLButtonElement>('[data-load-more]');
    const tagButtons = root.querySelectorAll<HTMLButtonElement>('[data-tag-query]');
    let activeTagQuery = '';

    const normalize = (value: string) =>
      value
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '');

    const updateActiveFilter = () => {
      filters.forEach((button) => {
        const isActive = (button.dataset.category || 'all') === activeCategory;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
    };

    const updateActiveTags = () => {
      tagButtons.forEach((button) => {
        const isActive = button.dataset.tagQuery === activeTagQuery;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
    };

    const applyFilters = () => {
      const normalizedQuery = normalize(searchQuery.trim());
      let matched = 0;
      let shown = 0;

      cards.forEach((card) => {
        const categoryMatch = activeCategory === 'all' || card.dataset.category === activeCategory;
        const haystack = normalize(card.dataset.search || '');
        const searchMatch = !normalizedQuery || haystack.includes(normalizedQuery);
        const matches = categoryMatch && searchMatch;

        if (matches) matched += 1;
        const shouldShow = matches && shown < visibleLimit;
        if (shouldShow) shown += 1;
        card.dataset.hidden = shouldShow ? 'false' : 'true';
      });

      if (emptyState) emptyState.hidden = matched > 0;
      if (loadMoreButton) {
        const hasMore = matched > visibleLimit;
        loadMoreButton.hidden = !hasMore;
        loadMoreButton.textContent = hasMore
          ? `Pokaż kolejne ${Math.min(pageSize, matched - visibleLimit)}`
          : 'Pokaż kolejne 12';
      }
    };

    const resetVisibleLimit = () => {
      visibleLimit = pageSize;
    };

    const clearFilters = () => {
      activeCategory = 'all';
      searchQuery = '';
      activeTagQuery = '';
      if (searchInput) searchInput.value = '';
      resetVisibleLimit();
      updateActiveFilter();
      updateActiveTags();
      applyFilters();
    };

    let debounceTimer: number | undefined;

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.category || 'all';
        resetVisibleLimit();
        updateActiveFilter();
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', () => {
      activeTagQuery = '';
      updateActiveTags();
      window.clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => {
        searchQuery = searchInput.value;
        resetVisibleLimit();
        applyFilters();
      }, 150);
    });

    tagButtons.forEach((button) => {
      button.addEventListener('click', () => {
        searchQuery = button.dataset.tagQuery || '';
        activeTagQuery = searchQuery;
        if (searchInput) searchInput.value = searchQuery;
        resetVisibleLimit();
        updateActiveTags();
        applyFilters();
      });
    });

    clearButton?.addEventListener('click', clearFilters);

    loadMoreButton?.addEventListener('click', () => {
      visibleLimit += pageSize;
      applyFilters();
    });

    updateActiveFilter();
    updateActiveTags();
    applyFilters();
  };

  document.addEventListener('astro:page-load', initFilters);
  if (document.readyState !== 'loading') initFilters();
  else document.addEventListener('DOMContentLoaded', initFilters);
</script>
