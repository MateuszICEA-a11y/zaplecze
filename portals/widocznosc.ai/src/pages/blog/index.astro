---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredPost = posts[0];
const sidebarPosts = posts.slice(1, 5);
const gridPosts = posts.slice(1);

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title="Baza wiedzy – widocznosc.ai"
  description="Latest insights, trends, and updates from the Tailcast team."
>
  <Navbar />
  <section class="bg-bgDark2 pt-32 pb-20 lg:pt-36">
    <div class="content-container">
      <div class="fade-in">
        <!-- Featured + sidebar -->
        <div class="mb-16 flex flex-col gap-8 lg:flex-row">
          <!-- Featured post (left) -->
          <a href={`/blog/${featuredPost.id}`} class="group lg:w-3/5">
            <article
              class="card flex h-full flex-col overflow-hidden rounded-3xl transition lg:min-h-full"
            >
              <div class="p-4 lg:flex-grow">
                <div
                  class="bg-bgDark1Lighter flex aspect-[16/9] items-center justify-center rounded-2xl lg:aspect-auto lg:h-full"
                >
                  <svg
                    class="text-accent/30 h-32 w-32"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="0.5"
                    viewBox="0 0 24 24"
                    set:html={featuredPost.data.icon}
                  />
                </div>
              </div>
              <div class="px-6 pt-2 pb-3 sm:px-8 sm:pt-3 sm:pb-4">
                <div class="meta mb-2">
                  {formatDate(featuredPost.data.date)}
                </div>
                <h2
                  class="text-ink font-display text-2xl font-semibold tracking-tight transition group-hover:text-accent sm:text-3xl"
                >
                  {featuredPost.data.title}
                </h2>
                <p class="text-secondaryText mt-2 hidden text-sm leading-relaxed sm:block">
                  {featuredPost.data.subtitle}
                </p>
              </div>
            </article>
          </a>

          <!-- Sidebar posts (right) -->
          <div class="flex flex-col gap-4 lg:w-2/5">
            {
              sidebarPosts.map((post) => (
                <a
                  href={`/blog/${post.id}`}
                  class="group card flex items-center gap-4 p-4 transition"
                >
                  <div class="bg-bgDark1Lighter flex h-20 w-20 shrink-0 items-center justify-center rounded-xl">
                    <svg
                      class="text-accent/40 h-8 w-8"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      viewBox="0 0 24 24"
                      set:html={post.data.icon}
                    />
                  </div>
                  <div>
                    <h3 class="text-ink font-display leading-snug font-semibold tracking-tight transition group-hover:text-accent">
                      {post.data.title}
                    </h3>
                    <div class="meta mt-2">{formatDate(post.data.date)}</div>
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <!-- All posts grid -->
        <h2 class="text-ink font-display mb-8 text-3xl font-semibold tracking-tight md:text-4xl">
          Wszystkie artykuły
        </h2>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {
            gridPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="group">
                <article class="card flex h-full flex-col overflow-hidden rounded-3xl transition">
                  <div class="p-4">
                    <div class="bg-bgDark1Lighter flex aspect-[3/2] items-center justify-center overflow-hidden rounded-2xl">
                      <svg
                        class="text-accent/30 h-16 w-16"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.75"
                        viewBox="0 0 24 24"
                        set:html={post.data.icon}
                      />
                    </div>
                  </div>
                  <div class="flex grow flex-col px-6 pt-2 pb-8">
                    <div class="meta mb-3">{formatDate(post.data.date)}</div>
                    <h2 class="text-ink font-display mb-3 text-xl font-semibold tracking-tight transition group-hover:text-accent">
                      {post.data.title}
                    </h2>
                    <p class="text-ink-soft text-sm leading-relaxed">{post.data.subtitle}</p>
                  </div>
                </article>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
  <Footer />
  <ScrollUpButton />
</Layout>
