---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import CTABand from '../../components/CTABand.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { PILLAR_LABELS } from '../../content.config';
import {
  buildGraph,
  personNode,
  profilePageNode,
  breadcrumbNode,
  SITE_URL,
  personIdFor,
} from '../../lib/schema';

export const getStaticPaths = async () => {
  const authors = await getCollection('authors');
  return authors.map((author) => ({
    params: { slug: author.id },
    props: { author },
  }));
};

const { author } = Astro.props;
const data = author.data;

// Artykuły autora – jak frontmatter blog ma author.name == data.name
const allPosts = await getCollection('blog');
const authorPosts = allPosts
  .filter((post) => post.data.author?.name === data.name)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const otherAuthors = (await getCollection('authors'))
  .filter((a) => a.id !== author.id)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });

const initials = (name: string) =>
  name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .slice(0, 2);

// Schema – ProfilePage + Person (z alumniOf, hasCredential, knowsAbout, sameAs)
// + ItemList artykułów autora + BreadcrumbList. Person cross-ref przez @id.
const authorArticlesItemList = {
  '@type': 'ItemList',
  '@id': `${SITE_URL}/autor/${author.id}/#articles`,
  name: `Artykuły autora ${data.name}`,
  numberOfItems: authorPosts.length,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  itemListElement: authorPosts.map((post, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${SITE_URL}/${post.id}/`,
    item: {
      '@type': 'BlogPosting',
      '@id': `${SITE_URL}/${post.id}/#article`,
      headline: post.data.title,
      url: `${SITE_URL}/${post.id}/`,
      datePublished: post.data.date.toISOString(),
      author: { '@id': personIdFor(author.id) },
      inLanguage: 'pl-PL',
    },
  })),
};

const profileSchema = buildGraph(
  personNode(author.id, data),
  profilePageNode(author.id, data, authorPosts.length),
  authorArticlesItemList,
  breadcrumbNode([
    { name: 'Strona główna', path: '/' },
    { name: 'O nas', path: '/o-nas/' },
    { name: data.name, path: `/autor/${author.id}/` },
  ]),
);
---

<Layout
  title={`${data.name} – ${data.role} – widocznosc.ai`}
  description={data.shortBio}
  ogType="article"
>
  <script type="application/ld+json" is:inline set:html={profileSchema} />

  <Navbar />

  <!-- Hero -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-20">
    <div class="content-container">
      <!-- Breadcrumb -->
      <div class="mb-8 flex items-center gap-2 text-sm">
        <a href="/o-nas/" class="text-ink-muted hover:text-ink transition">O nas</a>
        <span class="text-ink-muted" aria-hidden="true">/</span>
        <span class="text-ink">{data.name}</span>
      </div>

      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:items-center lg:gap-16">
        <!-- Photo -->
        <div class="lg:col-span-4">
          <div
            class="relative mx-auto aspect-square w-48 overflow-hidden rounded-[20px] sm:w-56 lg:w-full lg:max-w-sm"
            style="background: var(--bg-surface-1);"
          >
            {
              data.photo ? (
                <img
                  src={data.photo}
                  alt={data.name}
                  class="h-full w-full object-cover"
                  loading="eager"
                />
              ) : (
                <div
                  class="text-ink flex h-full w-full items-center justify-center text-6xl font-medium"
                  style="background: var(--bg-surface-2); font-family: var(--font-display); letter-spacing: -3px;"
                  aria-hidden="true"
                >
                  {initials(data.name)}
                </div>
              )
            }
          </div>
        </div>

        <!-- Bio -->
        <div class="lg:col-span-8">
          <span class="eyebrow mb-6 inline-flex">{data.role} · {data.company}</span>
          <h1 class="author-hero-title display-xxl mt-2">{data.name}</h1>
          <p class="text-ink mb-8 text-lg leading-relaxed">{data.bio}</p>

          <!-- Expertise pills -->
          <div class="mb-8">
            <div class="text-ink-muted mb-3 text-sm">Specjalizacje</div>
            <div class="flex flex-wrap gap-2">
              {
                data.expertise.map((skill) => (
                  <span class="badge-neutral">{skill}</span>
                ))
              }
            </div>
          </div>

          <!-- Links -->
          <div class="flex flex-wrap items-center gap-4">
            {
              data.iceaProfile && (
                <a
                  href={data.iceaProfile}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-secondary"
                >
                  Profil ICEA
                  <span aria-hidden="true">↗</span>
                </a>
              )
            }
            {
              data.linkedin && (
                <a
                  href={data.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-ink-muted hover:text-ink flex items-center gap-2 text-sm transition"
                >
                  LinkedIn
                  <span aria-hidden="true">↗</span>
                </a>
              )
            }
            {
              data.twitter && (
                <a
                  href={data.twitter}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-ink-muted hover:text-ink flex items-center gap-2 text-sm transition"
                >
                  Twitter / X
                  <span aria-hidden="true">↗</span>
                </a>
              )
            }
            {
              data.email && (
                <a
                  href={`mailto:${data.email}`}
                  class="text-ink-muted hover:text-ink flex items-center gap-2 text-sm transition"
                >
                  E-mail
                  <span aria-hidden="true">↗</span>
                </a>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles by author -->
  <section class="relative w-full" aria-labelledby="articles-title">
    <div class="content-container py-16 lg:py-20">
      <div class="mb-10 flex items-end justify-between gap-6">
        <div>
          <span class="eyebrow mb-6 inline-flex">Artykuły · {authorPosts.length}</span>
          <h2 id="articles-title" class="display-xl mt-2">
            {authorPosts.length > 0 ? `Artykuły ${data.name.split(' ')[0]}a` : 'Artykuły wkrótce'}
          </h2>
        </div>
        <a
          href="/blog/"
          class="text-accent-blue hidden items-center gap-2 text-sm transition hover:gap-3 sm:flex"
        >
          Cała baza wiedzy
          <span aria-hidden="true">→</span>
        </a>
      </div>

      {
        authorPosts.length === 0 ? (
          <div class="rounded-[20px] p-10 text-center" style="background: var(--bg-surface-1);">
            <p class="text-ink-muted text-lg leading-relaxed">
              Pierwsze artykuły tej osoby pojawią się wkrótce.
              <br />
              <a class="text-accent-blue underline underline-offset-2 hover:opacity-85" href="/blog/">
                Zobacz aktualną bazę wiedzy →
              </a>
            </p>
          </div>
        ) : (
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {authorPosts.map((post) => (
              <a
                href={`/${post.id}/`}
                class="group flex h-full flex-col overflow-hidden rounded-[20px] transition"
                style="background: var(--bg-surface-1);"
                data-card-template
              >
                <div class="p-4">
                  <div class="flex aspect-[3/2] items-center justify-center rounded-[15px]" style="background: var(--bg-canvas);">
                    {
                      post.data.image ? (
                        <Image
                          src={post.data.image}
                          alt={post.data.title}
                          widths={[320, 480, 640]}
                          sizes="(min-width: 1024px) 28vw, (min-width: 768px) 45vw, 100vw"
                          class="author-article-image"
                          loading="lazy"
                        />
                      ) : (
                        <svg
                          class="text-ink-muted h-16 w-16 opacity-40"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="0.75"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                          set:html={post.data.icon}
                        />
                      )
                    }
                  </div>
                </div>
                <div class="flex grow flex-col px-6 pt-2 pb-6">
                  <div class="mb-3 flex items-center gap-3">
                    <span class="badge-neutral">{PILLAR_LABELS[post.data.pillar]}</span>
                    <span class="text-ink-muted text-sm">{formatDate(post.data.date)}</span>
                  </div>
                  <h3 class="text-ink mb-2 text-lg font-medium" style="font-family: var(--font-display); letter-spacing: -0.4px;">
                    {post.data.title}
                  </h3>
                  <p class="text-ink-muted text-sm leading-relaxed">{post.data.subtitle}</p>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- Pozostali autorzy -->
  <section class="relative w-full" aria-labelledby="other-authors-title">
    <div class="content-container py-16 lg:py-20">
      <div class="mb-10 text-center">
        <span class="eyebrow mb-6 inline-flex">Zespół</span>
        <h2 id="other-authors-title" class="display-xl mt-2">Pozostali eksperci ICEA</h2>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        {
          otherAuthors.map((other) => (
            <a
              href={`/autor/${other.id}/`}
              class="group flex flex-col items-center rounded-[15px] p-8 text-center transition"
              style="background: var(--bg-surface-1);"
              data-card-template
            >
              {other.data.photo ? (
                <img
                  src={other.data.photo}
                  alt={other.data.name}
                  class="mb-4 h-20 w-20 rounded-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div
                  class="text-ink mb-4 flex h-20 w-20 items-center justify-center rounded-full text-xl font-medium"
                  style="background: var(--bg-surface-2); font-family: var(--font-display); letter-spacing: -1px;"
                  aria-hidden="true"
                >
                  {initials(other.data.name)}
                </div>
              )}
              <div class="text-ink text-base font-medium" style="font-family: var(--font-display); letter-spacing: -0.3px;">
                {other.data.name}
              </div>
              <div class="text-ink-muted mt-1 text-sm">
                {other.data.role} · {other.data.company}
              </div>
              <p class="text-ink-muted mt-3 text-sm leading-relaxed">{other.data.shortBio}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Konsultacja"
    title={`Porozmawiaj z ekspertem ICEA`}
    subtitle={`Bezpłatna konsultacja 30 minut z ${data.name.split(' ')[0]}em lub innym specjalistą zespołu. Bez sprzedaży, bez zobowiązań.`}
    primaryLabel="Zamów audyt AI"
    primaryHref="/kontakt/?type=audyt-ai"
    ghostLabel="Bezpłatna konsultacja"
    ghostHref="/kontakt/?type=konsultacja"
  />

  <Footer />
  <ScrollUpButton />
</Layout>

<style>
  .author-hero-title {
    margin-bottom: 0.8rem;
    line-height: 0.95;
  }

  .author-article-image {
    width: 100%;
    height: 100%;
    min-height: 100%;
    border-radius: 15px;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  [data-card-template]:hover .author-article-image {
    transform: scale(1.035);
  }

  [data-card-template]:hover {
    background: var(--bg-surface-2) !important;
  }
</style>
