---
/**
 * Differentiators – 4 punkty czemu widocznosc.ai a nie inna agencja.
 * Framer DNA: 4-up grid charcoal cards (surface-1), no orange icons.
 */

interface Diff {
  title: string;
  desc: string;
}

const diffs: Diff[] = [
  {
    title: 'Pięć silników AI razem',
    desc: 'Nie tylko ChatGPT. W&nbsp;jednym raporcie sprawdzamy Claude, Gemini, Perplexity i&nbsp;Copilot – bo Twoi klienci pytają w każdym z&nbsp;nich.',
  },
  {
    title: 'Trzy dni, nie cztery tygodnie',
    desc: 'Standard rynkowy to&nbsp;miesięczny audyt. My zamykamy się w&nbsp;3 dniach roboczych – bez kompromisów na głębokości analizy.',
  },
  {
    title: 'Plan, nie tylko diagnoza',
    desc: 'Każdy audyt kończy się listą 20+ konkretnych zmian z&nbsp;priorytetem P0/P1/P2 i&nbsp;roadmapą 30/60/90 dni – nie ogólnikami.',
  },
  {
    title: 'Polskie marki w&nbsp;polskim AI',
    desc: 'Wiemy, jak LLM-y widzą polskie firmy w&nbsp;porównaniu do&nbsp;zachodnich. Robimy audyty dwujęzyczne (PL+EN) i&nbsp;sprawdzamy spójność marki we&nbsp;wszystkich źródłach, z&nbsp;których korzystają wyszukiwarki AI.',
  },
];
---

<section class="diffs-section" aria-labelledby="diffs-title">
  <div class="diffs-container">

    <header class="diffs-header">
      <span class="eyebrow diffs-eyebrow">Co nas wyróżnia</span>
      <h2 id="diffs-title" class="display-lg diffs-title">
        Czemu widocznosc.ai a&nbsp;nie inna agencja
      </h2>
      <p class="diffs-lead">
        Cztery rzeczy, które naprawdę robimy inaczej &ndash; nie marketingowe slogany.
      </p>
    </header>

    <div class="diffs-grid">
      {
        diffs.map((d, i) => (
          <article class="diffs-card">
            <div class="diffs-card-num">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="diffs-card-title">
              <Fragment set:html={d.title} />
            </h3>
            <p class="diffs-card-desc">
              <Fragment set:html={d.desc} />
            </p>
          </article>
        ))
      }
    </div>

  </div>
</section>

<style>
  .diffs-section {
    background: var(--bg-canvas);
    padding: 96px 0;
  }

  .diffs-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 0 30px;
  }

  .diffs-header {
    max-width: 720px;
    margin: 0 auto 64px auto;
    text-align: center;
  }

  .diffs-eyebrow {
    margin-bottom: 16px;
  }

  .diffs-title {
    color: var(--ink);
    margin: 0 0 16px 0;
    text-wrap: balance;
  }

  .diffs-lead {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink);
    margin: 0;
  }

  .diffs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .diffs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .diffs-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .diffs-card {
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    padding: 24px;
    transition: background 0.2s ease;
  }

  .diffs-card:hover {
    background: var(--bg-surface-2);
  }

  .diffs-card-num {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-display-md);
    line-height: 1;
    letter-spacing: var(--ls-display-md);
    color: var(--ink-muted);
    margin-bottom: 16px;
  }

  .diffs-card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-headline);
    line-height: 1.2;
    letter-spacing: var(--ls-headline);
    color: var(--ink);
    margin: 0 0 12px 0;
  }

  .diffs-card-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.5;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    margin: 0;
  }
</style>
