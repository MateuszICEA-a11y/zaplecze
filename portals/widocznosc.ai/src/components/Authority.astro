---
/**
 * Authority – landing redesign 2026-05-09 (handoff).
 * Section-head editorial 5fr/4fr + 4-col grid 4 research cards.
 * Per card: display-56 number + sup unit (%, ×), label + italic sublabel,
 * source paragraph, mono link bottom (top-bordered hairline).
 */

interface Stat {
  num: string;
  sup: string;
  label: string;
  sublabel: string;
  source: string;
  link: string;
  href: string;
}

const stats: Stat[] = [
  {
    num: '+40',
    sup: '%',
    label: 'Princeton · KDD 2024',
    sublabel: 'Aggarwal et al., GEO Paper',
    source:
      'Wzrost widoczności w odpowiedziach silników AI przy zastosowaniu metodyki GEO. Pierwsze peer-reviewed badanie z ACM SIGKDD definiujące samą dyscyplinę – nie marketing, tylko akademicki framework.',
    link: 'arxiv.org/abs/2311.09735',
    href: 'https://arxiv.org/abs/2311.09735',
  },
  {
    num: '8',
    sup: '×',
    label: 'Google · patent 2024',
    sublabel: 'query fan-out, passage retrieval',
    source:
      'Tyle różnych podzapytań Google generuje z jednego pytania użytkownika. Indeksowanie odbywa się na poziomie pojedynczych fragmentów, nie całych stron – optymalizacja na poziomie strony już nie wystarcza.',
    link: 'searchengineland.com/how-ai-mode-ai-overviews-work',
    href: 'https://searchengineland.com/how-ai-mode-ai-overviews-work-patents-456346',
  },
  {
    num: '+357',
    sup: '%',
    label: 'TechCrunch · Authoritas',
    sublabel: '13 miesięcy danych ruchu AI',
    source:
      'Wzrost ruchu z silników AI rok do roku dla najpopularniejszych stron. Marki aktywnie optymalizujące pod cytowania AI notują nawet +800% wzrostu ruchu z LLM.',
    link: 'searchengineland.com/llm-traffic-growth-470115',
    href: 'https://searchengineland.com/what-13-months-of-data-reveals-about-llm-traffic-growth-and-conversions-470115',
  },
  {
    num: '84',
    sup: '%',
    label: 'Previsible · 2025',
    sublabel: '1,96 mln sesji LLM',
    source:
      'Rekomendacji w silnikach AI pochodzi z ChatGPT (rośnie 3,26× YoY). Copilot rośnie 25,2×, Claude 12,8× – każdy silnik wymaga innej taktyki cytowania.',
    link: 'previsible.io/seo-strategy/ai-seo-study-2025',
    href: 'https://previsible.io/seo-strategy/ai-seo-study-2025/',
  },
];
---

<section class="authority-section" aria-labelledby="authority-title">
  <div class="container">

    <header class="section-head">
      <div class="head-left">
        <div class="head-meta">
          <span class="section-index">S/05 · Źródła i badania</span>
          <span class="eyebrow">Źródła i&nbsp;badania</span>
        </div>
        <h2 id="authority-title" class="display-xl">
          Nie wymyślamy GEO &ndash; <span class="accent">opieramy się na&nbsp;badaniach</span>
        </h2>
      </div>
      <div class="head-right">
        <p class="subhead">
          Każda rekomendacja w&nbsp;naszym audycie ma źródło &ndash; akademickie badania, patenty Google,
          dane rynkowe albo nasze własne testy. Zero marketingowego bełkotu.
        </p>
      </div>
    </header>

    <div class="research-grid">
      {
        stats.map((s) => (
          <article class="research-card">
            <div class="research-num">
              {s.num}<sup>{s.sup}</sup>
            </div>
            <div class="research-label">{s.label}</div>
            <div class="research-sublabel">{s.sublabel}</div>
            <p class="research-source">{s.source}</p>
            <a
              href={s.href}
              class="research-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Źródło: ${s.label}`}
            >
              → {s.link}
            </a>
          </article>
        ))
      }
    </div>

    <p class="process-footer">
      Plus 15+ lat doświadczenia ICEA w&nbsp;klasycznym SEO &ndash; te same fundamenty
      (autorytet, semantyka, struktura) działają w&nbsp;AI inaczej, ale rygor pracy zostaje ten sam.
    </p>

  </div>
</section>

<style>
  .authority-section {
    padding: 96px 0;
    background: var(--bg-canvas);
  }

  @media (min-width: 980px) {
    .authority-section { padding: 120px 0; }
  }

  .research-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 640px) {
    .research-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 980px) {
    .research-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .research-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    padding: 24px;
    min-height: 220px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .research-card:hover { border-color: var(--hairline); }

  .research-num {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 0.95;
    color: var(--ink);
  }

  .research-num sup {
    font-size: 22px;
    vertical-align: super;
    color: var(--ink-muted);
    margin-left: 4px;
    font-weight: 500;
  }

  .research-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    margin-top: 4px;
  }

  .research-sublabel {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: -0.11px;
    font-style: italic;
  }

  .research-source {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--ink-muted);
    letter-spacing: -0.12px;
    line-height: 1.5;
    margin: 0;
    flex-grow: 1;
  }

  .research-link {
    display: inline-block;
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--ink-faint);
    margin-top: 8px;
    letter-spacing: 0.02em;
    word-break: break-all;
    border-top: 1px solid var(--hairline-soft);
    padding-top: 10px;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .research-link:hover { color: var(--accent-blue); }
</style>
