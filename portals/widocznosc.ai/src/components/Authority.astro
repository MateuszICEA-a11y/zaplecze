---
/**
 * Authority – 4 data-points z research'u jako proof że GEO ≠ marketing buzz.
 * Framer DNA: 4 stat-cards charcoal, accent-blue dla source links.
 */

interface Stat {
  value: string;
  unit?: string;
  source: string;
  sample: string;
  desc: string;
  href?: string;
}

const stats: Stat[] = [
  {
    value: '+30',
    unit: '%',
    source: 'Princeton · KDD 2024',
    sample: 'Aggarwal et al.',
    desc: 'wzrost widoczności w&nbsp;LLM po&nbsp;dodaniu cytowań źródeł i&nbsp;statystyk. Keyword stuffing dawał -10% (akademicka odwrotność klasycznego SEO).',
    href: 'https://arxiv.org/abs/2311.09735',
  },
  {
    value: '44',
    unit: '%',
    source: 'Kevin Indig · Growth Memo',
    sample: '1,2 mln cytowań ChatGPT',
    desc: 'cytowań w&nbsp;ChatGPT pochodzi z&nbsp;pierwszych 30% tekstu. "Front-loading" nie jest opcją – to&nbsp;wymóg techniczny.',
  },
  {
    value: '89',
    unit: '%',
    source: 'BrightEdge · 2025',
    sample: 'analiza AI Overviews',
    desc: 'cytowań w&nbsp;Google AI Overviews to&nbsp;wyniki rankingowane poniżej pozycji 100. Klasyczny ranking nie gwarantuje cytacji.',
  },
  {
    value: '4,4',
    unit: '×',
    source: 'Semrush · 2025',
    sample: 'analiza ruchu LLM',
    desc: 'wyższa konwersja użytkowników przychodzących z&nbsp;LLM vs&nbsp;klasyczny organic. Lead z&nbsp;AI to&nbsp;lead z&nbsp;już zbudowaną intencją.',
  },
];
---

<section class="authority-section" aria-labelledby="authority-title">
  <div class="authority-container">

    <header class="authority-header">
      <span class="eyebrow authority-eyebrow">Na czym to się opiera</span>
      <h2 id="authority-title" class="display-lg authority-title">
        Nie wymyślamy GEO &mdash; opieramy się na&nbsp;badaniach
      </h2>
      <p class="authority-lead">
        Każda rekomendacja w&nbsp;naszym audycie ma źródło – akademickie, branżowe albo nasze
        własne testy. Zero marketing-buzz.
      </p>
    </header>

    <div class="authority-grid">
      {
        stats.map((s) => (
          <article class="authority-card">
            <div class="authority-card-num">
              <span class="authority-card-value">{s.value}</span>
              {s.unit && <span class="authority-card-unit">{s.unit}</span>}
            </div>

            <div class="authority-card-source">
              <div class="authority-card-source-name">{s.source}</div>
              <div class="authority-card-source-sample">{s.sample}</div>
            </div>

            <p class="authority-card-desc">
              <Fragment set:html={s.desc} />
            </p>

            {s.href && (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="authority-card-link"
                aria-label={`Zobacz badanie: ${s.source}`}
              >
                Zobacz badanie <span aria-hidden="true">↗</span>
              </a>
            )}
          </article>
        ))
      }
    </div>

    <p class="authority-footer">
      Plus 15+ lat doświadczenia ICEA w&nbsp;klasycznym SEO &mdash; te same fundamenty
      (autorytet, semantyka, struktura) działają w&nbsp;AI inaczej, ale rygor pracy zostaje ten&nbsp;sam.
    </p>

  </div>
</section>

<style>
  .authority-section {
    background: var(--bg-canvas);
    padding: 96px 0;
  }

  .authority-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 0 30px;
  }

  .authority-header {
    max-width: 720px;
    margin: 0 auto 64px auto;
    text-align: center;
  }

  .authority-eyebrow {
    margin-bottom: 16px;
  }

  .authority-title {
    color: var(--ink);
    margin: 0 0 16px 0;
    text-wrap: balance;
  }

  .authority-lead {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink);
    margin: 0;
  }

  .authority-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .authority-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .authority-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .authority-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    padding: 24px;
    transition: background 0.2s ease;
  }

  .authority-card:hover {
    background: var(--bg-surface-2);
  }

  .authority-card-num {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 16px;
  }

  .authority-card-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-display-md);
    line-height: 1;
    letter-spacing: var(--ls-display-md);
    color: var(--ink);
  }

  @media (min-width: 1024px) {
    .authority-card-value {
      font-size: var(--fs-display-lg);
      letter-spacing: var(--ls-display-lg);
    }
  }

  .authority-card-unit {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-headline);
    color: var(--ink-muted);
    letter-spacing: -0.02em;
  }

  .authority-card-source {
    margin-bottom: 16px;
    padding-left: 12px;
    border-left: 1px solid var(--hairline);
  }

  .authority-card-source-name {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink);
  }

  .authority-card-source-sample {
    font-family: var(--font-sans);
    font-size: var(--fs-micro);
    letter-spacing: -0.12px;
    color: var(--ink-muted);
    margin-top: 2px;
  }

  .authority-card-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.5;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    margin: 0;
    flex-grow: 1;
  }

  .authority-card-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 20px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--accent-blue);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .authority-card-link:hover {
    opacity: 0.85;
  }

  .authority-footer {
    max-width: 640px;
    margin: 56px auto 0 auto;
    padding-top: 32px;
    border-top: 1px solid var(--hairline-soft);
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    line-height: 1.5;
    letter-spacing: var(--ls-body);
    color: var(--ink-muted);
  }
</style>
