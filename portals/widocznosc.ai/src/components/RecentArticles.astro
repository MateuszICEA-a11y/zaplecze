---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS } from '../content.config';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  limit?: number;
}

const {
  eyebrow = 'Baza wiedzy',
  title = 'Najnowsze z bazy wiedzy GEO',
  subtitle = 'Definicje, case studies i poradniki o pozycjonowaniu marki w wyszukiwarkach AI.',
  limit = 3,
} = Astro.props;

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, limit);

const [hero, ...rest] = posts;

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });
---

<section class="recent-section">
  <div class="recent-container">
    <header class="recent-header">
      <div class="recent-header-text">
        <span class="eyebrow recent-eyebrow">{eyebrow}</span>
        <h2 class="display-lg recent-title">{title}</h2>
        <p class="recent-lead">{subtitle}</p>
      </div>
      <a href="/blog" class="recent-all-link">
        Wszystkie artykuły
        <span aria-hidden="true">→</span>
      </a>
    </header>

    {
      hero && (
        <div class="recent-grid">
          <a href={`/blog/${hero.id}`} class="recent-featured">
            <div class="recent-featured-image">
              <Image
                src={hero.data.image}
                alt={hero.data.title}
                widths={[640, 960, 1280]}
                sizes="(min-width: 1024px) 66vw, 100vw"
                loading="lazy"
              />
            </div>
            <div class="recent-featured-body">
              <div class="recent-card-meta">
                <span class="recent-card-category">{CATEGORY_LABELS[hero.data.category]}</span>
                <span class="recent-card-date">{formatDate(hero.data.date)}</span>
              </div>
              <h3 class="recent-featured-title">{hero.data.title}</h3>
              <p class="recent-featured-desc">{hero.data.subtitle}</p>
            </div>
          </a>

          <div class="recent-rest">
            {rest.map((post) => (
              <a href={`/blog/${post.id}`} class="recent-thumb">
                <div class="recent-thumb-image">
                  <Image
                    src={post.data.image}
                    alt={post.data.title}
                    widths={[192, 288]}
                    sizes="96px"
                    loading="lazy"
                  />
                </div>
                <div class="recent-thumb-body">
                  <span class="recent-card-category">{CATEGORY_LABELS[post.data.category]}</span>
                  <h3 class="recent-thumb-title">{post.data.title}</h3>
                  <div class="recent-card-date">{formatDate(post.data.date)}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )
    }

    <div class="recent-mobile-link">
      <a href="/blog" class="recent-all-link">
        Wszystkie artykuły
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .recent-section {
    background: var(--bg-canvas);
    padding: 96px 0;
    border-top: 1px solid var(--hairline-soft);
  }

  .recent-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 0 30px;
  }

  .recent-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
  }

  .recent-header-text {
    max-width: 640px;
  }

  .recent-eyebrow {
    display: inline-block;
    margin-bottom: 12px;
  }

  .recent-title {
    color: var(--ink);
    margin: 0 0 12px 0;
    text-wrap: balance;
  }

  .recent-lead {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink-muted);
    margin: 0;
  }

  .recent-all-link {
    display: none;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    color: var(--accent-blue);
    text-decoration: none;
    transition: gap 0.15s ease;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .recent-all-link {
      display: inline-flex;
    }
  }

  .recent-all-link:hover {
    gap: 10px;
  }

  .recent-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 1024px) {
    .recent-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  /* Featured */
  .recent-featured {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    overflow: hidden;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .recent-featured:hover {
    background: var(--bg-surface-2);
  }

  .recent-featured-image {
    overflow: hidden;
  }

  .recent-featured-image img {
    aspect-ratio: 16 / 9;
    width: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .recent-featured:hover .recent-featured-image img {
    transform: scale(1.02);
  }

  .recent-featured-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
  }

  @media (min-width: 1024px) {
    .recent-featured-body {
      padding: 32px;
    }
  }

  .recent-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 4px;
  }

  .recent-card-category {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    background: var(--bg-canvas);
    border-radius: var(--r-pill);
    font-family: var(--font-sans);
    font-size: var(--fs-micro);
    font-weight: 500;
    letter-spacing: -0.12px;
    color: var(--ink);
  }

  .recent-card-date {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .recent-featured-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem);
    line-height: 1.13;
    letter-spacing: var(--ls-display-md);
    color: var(--ink);
    margin: 0;
  }

  .recent-featured-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    line-height: 1.5;
    letter-spacing: var(--ls-body);
    color: var(--ink-muted);
    margin: 0;
  }

  /* Thumbs */
  .recent-rest {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .recent-thumb {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--bg-surface-1);
    border-radius: var(--r-lg);
    padding: 12px;
    text-decoration: none;
    transition: background 0.2s ease;
    flex: 1;
  }

  .recent-thumb:hover {
    background: var(--bg-surface-2);
  }

  .recent-thumb-image {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    border-radius: var(--r-md);
    overflow: hidden;
  }

  .recent-thumb-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .recent-thumb:hover .recent-thumb-image img {
    transform: scale(1.05);
  }

  .recent-thumb-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .recent-thumb-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-body-lg);
    line-height: 1.25;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink);
    margin: 0;
  }

  .recent-mobile-link {
    margin-top: 32px;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .recent-mobile-link {
      display: none;
    }
  }
</style>
