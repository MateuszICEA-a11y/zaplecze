---
/**
 * RecentArticles / Knowledge Base – landing redesign 2026-05-09 (handoff).
 * Compact 4-card knowledge grid. Every article gets a visual thumbnail,
 * stable card dimensions and dense metadata for better use of the wider container.
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { PILLAR_LABELS } from '../content.config';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const homepagePillars = ['geo', 'modele-llm', 'ai-w-biznesie', 'rag'] as const;
const posts = homepagePillars
  .map((pillar) => allPosts.find((post) => post.data.pillar === pillar))
  .filter((post): post is NonNullable<typeof post> => Boolean(post));

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });
---

<section class="kb-section" id="wiedza" aria-labelledby="kb-title">
  <div class="container">
    <header class="section-head">
      <div class="head-left">
        <div class="head-meta">
          <span class="section-index">S/07</span>
          <span class="eyebrow">Centrum wiedzy</span>
        </div>
        <h2 id="kb-title" class="display-xl">
          Jak działają <span class="accent">modele AI</span>?
        </h2>
      </div>
      <div class="head-right">
        <p class="subhead">
          Definicje, case studies i&nbsp;poradniki &ndash; dowiedz się, jak modele językowe
          syntezują odpowiedzi i&nbsp;co decyduje o&nbsp;cytowalności Twojej marki w&nbsp;świecie
          AI.
        </p>
        <a href="/blog" class="btn-secondary kb-all-link">
          Wszystkie artykuły <span aria-hidden="true">→</span>
        </a>
      </div>
    </header>

    {
      posts.length > 0 && (
        <div class="kb-grid">
          {posts.map((post) => (
            <a href={`/${post.id}`} class="kb-card" data-category={post.data.pillar}>
              <div class="kb-card-img">
                <Image
                  src={post.data.image}
                  alt={post.data.title}
                  widths={[320, 480, 640]}
                  sizes="(min-width: 1180px) 23vw, (min-width: 700px) 45vw, 100vw"
                  loading="lazy"
                  class="kb-card-photo"
                />
              </div>
              <div class="kb-card-body">
                <div class="kb-meta">
                  <span>{PILLAR_LABELS[post.data.pillar]}</span>
                  <span class="dot">·</span>
                  <span>{post.data.readTime}</span>
                  <span class="dot kb-date-dot">·</span>
                  <span class="kb-date">{formatDate(post.data.date)}</span>
                </div>
                <h3 class="kb-card-title">{post.data.title}</h3>
                {post.data.subtitle && <p class="kb-excerpt">{post.data.subtitle}</p>}
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .kb-section {
    padding: 80px 0;
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline-soft);
  }

  @media (min-width: 980px) {
    .kb-section {
      padding: 104px 0;
    }
  }

  .kb-all-link {
    align-self: flex-start;
  }

  .kb-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  @media (min-width: 700px) {
    .kb-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 980px) {
    .kb-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .kb-card {
    --kb-accent: var(--accent-blue);
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
    position: relative;
    overflow: hidden;
    min-height: 100%;
  }

  .kb-card[data-category='agenci-ai'] {
    --kb-accent: #22d3ee;
  }

  .kb-card[data-category='ai-w-biznesie'] {
    --kb-accent: #4ade80;
  }

  .kb-card[data-category='modele-llm'] {
    --kb-accent: #a78bfa;
  }

  .kb-card[data-category='prompty'] {
    --kb-accent: #f472b6;
  }

  .kb-card[data-category='rag'] {
    --kb-accent: #fbbf24;
  }

  :global(:root[data-theme='light']) .kb-card[data-category='agenci-ai'] {
    --kb-accent: #0891b2;
  }

  :global(:root[data-theme='light']) .kb-card[data-category='ai-w-biznesie'] {
    --kb-accent: #16a34a;
  }

  :global(:root[data-theme='light']) .kb-card[data-category='modele-llm'] {
    --kb-accent: #7c3aed;
  }

  :global(:root[data-theme='light']) .kb-card[data-category='prompty'] {
    --kb-accent: #db2777;
  }

  :global(:root[data-theme='light']) .kb-card[data-category='rag'] {
    --kb-accent: #d97706;
  }

  .kb-card:hover {
    transform: translateY(-2px);
    background: var(--bg-surface-2);
    border-color: var(--hairline);
  }

  .kb-card-img {
    aspect-ratio: 4 / 3;
    background:
      radial-gradient(
        circle at 18% 0%,
        color-mix(in srgb, var(--kb-accent) 24%, transparent) 0%,
        transparent 42%
      ),
      var(--bg-surface-2);
    border-bottom: 1px solid var(--hairline-soft);
    position: relative;
    overflow: hidden;
  }

  .kb-card-img::after {
    position: absolute;
    inset: 0;
    content: '';
    background:
      linear-gradient(180deg, transparent 45%, rgba(0, 0, 0, 0.18) 100%),
      linear-gradient(90deg, color-mix(in srgb, var(--kb-accent) 16%, transparent), transparent 55%);
    pointer-events: none;
  }

  :root[data-theme='light'] .kb-card-img::after {
    background:
      linear-gradient(180deg, transparent 45%, rgba(5, 18, 32, 0.08) 100%),
      linear-gradient(90deg, color-mix(in srgb, var(--kb-accent) 12%, transparent), transparent 55%);
  }

  .kb-card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .kb-card:hover .kb-card-photo {
    transform: scale(1.035);
  }

  .kb-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 12px;
    padding: 18px;
  }

  .kb-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .kb-meta span:first-child {
    color: var(--kb-accent);
  }

  .kb-meta .dot {
    color: var(--ink-faint);
  }

  h3.kb-card-title {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.22;
    color: var(--ink);
    margin: 0;
    text-wrap: balance;
  }

  .kb-excerpt {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  @media (max-width: 1179px) {
    .kb-date,
    .kb-date-dot {
      display: none;
    }
  }

  @media (max-width: 699px) {
    h3.kb-card-title {
      font-size: 18px;
    }

    .kb-card-img {
      aspect-ratio: 16 / 9;
    }
  }
</style>
