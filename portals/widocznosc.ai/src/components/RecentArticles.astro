---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS } from '../content.config';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  limit?: number;
}

const {
  eyebrow = 'Baza wiedzy',
  title = 'Najnowsze z bazy wiedzy GEO',
  subtitle = 'Definicje, case studies i poradniki o pozycjonowaniu marki w wyszukiwarkach AI.',
  limit = 3,
} = Astro.props;

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, limit);

const [hero, ...rest] = posts;

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });
---

<section class="relative w-full" style="background: var(--bg-alt);">
  <div class="content-container py-20 lg:py-28">
    <div class="mb-12 flex items-end justify-between gap-6">
      <div class="max-w-2xl">
        <span class="meta mb-3 inline-block">{eyebrow}</span>
        <h2
          class="text-ink font-display mt-2 mb-4 text-3xl font-semibold tracking-[-0.03em] sm:text-4xl lg:text-5xl"
        >
          {title}
        </h2>
        <p class="text-ink-soft text-lg leading-relaxed">{subtitle}</p>
      </div>
      <a
        href="/blog"
        class="text-accent hidden items-center gap-2 font-mono text-[11px] tracking-wider uppercase transition hover:gap-3 sm:flex"
      >
        Wszystkie artykuły
        <span aria-hidden="true">→</span>
      </a>
    </div>

    {
      hero && (
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
          <a
            href={`/blog/${hero.id}`}
            class="group border-rule bg-bg-card hover:border-accent/35 flex flex-col overflow-hidden rounded-2xl border transition lg:col-span-2"
          >
            <div class="overflow-hidden">
              <Image
                src={hero.data.image}
                alt={hero.data.title}
                widths={[640, 960, 1280]}
                sizes="(min-width: 1024px) 66vw, 100vw"
                class="aspect-[16/9] w-full object-cover transition duration-500 group-hover:scale-[1.02]"
                loading="lazy"
              />
            </div>
            <div class="flex flex-col gap-3 p-6 lg:p-8">
              <div class="flex items-center gap-3">
                <span class="chip">{CATEGORY_LABELS[hero.data.category]}</span>
                <span class="meta">{formatDate(hero.data.date)}</span>
              </div>
              <h3
                class="text-ink font-display text-2xl font-semibold tracking-tight transition group-hover:text-accent lg:text-3xl"
              >
                {hero.data.title}
              </h3>
              <p class="text-ink-soft leading-relaxed">{hero.data.subtitle}</p>
            </div>
          </a>

          <div class="flex flex-col gap-6">
            {rest.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="group border-rule bg-bg-card hover:border-accent/35 flex flex-1 items-center gap-4 overflow-hidden rounded-2xl border p-4 transition"
              >
                <div class="h-24 w-24 shrink-0 overflow-hidden rounded-xl">
                  <Image
                    src={post.data.image}
                    alt={post.data.title}
                    widths={[192, 288]}
                    sizes="96px"
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.05]"
                    loading="lazy"
                  />
                </div>
                <div class="min-w-0">
                  <span class="chip mb-2 inline-block">{CATEGORY_LABELS[post.data.category]}</span>
                  <h3 class="text-ink font-display leading-snug font-semibold tracking-tight transition group-hover:text-accent">
                    {post.data.title}
                  </h3>
                  <div class="meta mt-2">{formatDate(post.data.date)}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )
    }

    <div class="mt-10 flex justify-center sm:hidden">
      <a
        href="/blog"
        class="text-accent flex items-center gap-2 font-mono text-[11px] tracking-wider uppercase transition hover:gap-3"
      >
        Wszystkie artykuły
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
