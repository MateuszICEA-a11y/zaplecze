---
/**
 * Audits – landing redesign 2026-05-09 (handoff).
 * Section-head editorial 5fr/4fr + 3 darmowe testy w 3-col grid +
 * pełny raport GEO jako orange spotlight (radial gradient + ::before).
 *
 * Mock UI: monospaced font, surface canvas inset, status pills (.ok/.warn/.bad/.faint),
 * progress bars 4px (.dim/.accent variants).
 */
---

<section class="audits-section" id="audyty" aria-labelledby="audyty-title">
  <div class="container">
    <header class="section-head">
      <div class="head-left">
        <div class="head-meta">
          <span class="section-index">S/02</span>
          <span class="eyebrow">Co dostajesz</span>
        </div>
        <h2 id="audyty-title" class="display-xl">
          Trzy darmowe testy i&nbsp;<span class="accent">pełny raport GEO</span>
        </h2>
      </div>
      <div class="head-right">
        <p class="subhead">
          Zacznij od&nbsp;trzech szybkich testów &ndash; bez logowania, każdy w&nbsp;kilka sekund.
          Gdy chcesz głębszy obraz, zamów rozbudowany raport GEO ze&nbsp;skanem 25&ndash;50 URL-i
          Twojej domeny.
        </p>
      </div>
    </header>

    <!-- Grid 3 darmowych testów -->
    <div class="services-grid">
      <!-- 01 – Brand check -->
      <article id="brand-check" class="audit-card">
        <div class="service-head">
          <span class="card-eyebrow">01 / 04</span>
          <span class="card-eyebrow accent">darmowe · instant</span>
        </div>
        <h3 class="card-title">Co AI wie o&nbsp;Twojej marce</h3>
        <p class="card-body">
          Odpytujemy ChatGPT, Claude, Gemini i&nbsp;Perplexity o&nbsp;Twoją firmę. Dostajesz
          sentyment, listę halucynacji i&nbsp;konkurentów, których AI poleca zamiast Ciebie.
        </p>

        <div class="service-mock">
          <div class="mock-line muted">
            <span>Przykładowy wynik</span>
          </div>
          <div class="mock-line">
            <span>twojadomena.pl</span>
            <span class="accent">● live</span>
          </div>
          <div class="mock-row">
            <span>ChatGPT</span><span class="mock-pill warn">Myli ofertę</span>
          </div>
          <div class="mock-row">
            <span>Claude</span><span class="mock-pill faint">Brak danych</span>
          </div>
          <div class="mock-row">
            <span>Gemini</span><span class="mock-pill warn">Poleca konkurenta</span>
          </div>
          <div class="mock-row">
            <span>Perplexity</span><span class="mock-pill ok">Zna · neutralny</span>
          </div>
        </div>

        <a
          class="service-link"
          href="/narzedzia/brand-check"
          aria-label="Sprawdź, co AI wie o Twojej marce"
        >
          Sprawdź markę <span aria-hidden="true">→</span>
        </a>
      </article>

      <!-- 02 – URL check -->
      <article id="url-check" class="audit-card">
        <div class="service-head">
          <span class="card-eyebrow">02 / 04</span>
          <span class="card-eyebrow accent">darmowe · instant</span>
        </div>
        <h3 class="card-title">Czy Twój content jest cytowalny</h3>
        <p class="card-body">
          Wskazujesz jeden URL. Wynik 0&ndash;100 + lista 5 priorytetowych zmian według badań
          Princeton i&nbsp;Indiga (1,2 mln cytowań ChatGPT).
        </p>

        <div class="service-mock">
          <div class="mock-line muted">
            <span>Przykładowy wynik</span>
          </div>
          <div class="mock-line">
            <span>/blog/jak-wybrac-saas</span>
            <span class="tabular">43 / 100</span>
          </div>
          <div class="mock-line"><span>Front-load</span><span class="tabular">78%</span></div>
          <div class="mock-bar"><div class="mock-bar-fill" style="width:78%"></div></div>
          <div class="mock-line"><span>Schema</span><span class="tabular">25%</span></div>
          <div class="mock-bar"><div class="mock-bar-fill dim" style="width:25%"></div></div>
          <div class="mock-line"><span>Cytowania</span><span class="tabular">12%</span></div>
          <div class="mock-bar"><div class="mock-bar-fill dim" style="width:12%"></div></div>
        </div>

        <a
          class="service-link"
          href="/narzedzia/url-check"
          aria-label="Sprawdź content jednego URL"
        >
          Sprawdź URL <span aria-hidden="true">→</span>
        </a>
      </article>

      <!-- 03 – AI bots check -->
      <article id="ai-bots-check" class="audit-card">
        <div class="service-head">
          <span class="card-eyebrow">03 / 04</span>
          <span class="card-eyebrow accent">darmowe · instant</span>
        </div>
        <h3 class="card-title">Czy AI ma dostęp do&nbsp;Twojej strony</h3>
        <p class="card-body">
          Sprawdzamy <code>robots.txt</code>: czy GPTBot, ClaudeBot, PerplexityBot, Google-Extended
          i&nbsp;9 innych botów AI ma dostęp do&nbsp;Twojej strony.
        </p>

        <div class="service-mock">
          <div class="mock-line muted">
            <span>Przykładowy wynik</span>
          </div>
          <div class="mock-line">
            <span>twojadomena.pl/robots.txt</span>
            <span class="tabular">8 / 13</span>
          </div>
          <div class="mock-row"><span>GPTBot</span><span class="mock-pill ok">✓</span></div>
          <div class="mock-row"><span>ClaudeBot</span><span class="mock-pill bad">✗</span></div>
          <div class="mock-row"><span>PerplexityBot</span><span class="mock-pill ok">✓</span></div>
          <div class="mock-row">
            <span>Google-Extended</span><span class="mock-pill bad">✗</span>
          </div>
          <div class="mock-row"><span>CCBot</span><span class="mock-pill bad">✗</span></div>
          <div class="mock-line muted" style="justify-content:center; margin-top:4px">
            <span>+ 8 innych botów</span>
          </div>
        </div>

        <a
          class="service-link"
          href="/narzedzia/ai-bots-check"
          aria-label="Sprawdź dostęp botów AI do Twojej strony"
        >
          Sprawdź dostęp <span aria-hidden="true">→</span>
        </a>
      </article>
    </div>

    <!-- 04 – Pełny raport GEO – orange spotlight -->
    <article id="pelny-raport" class="cta-card on-gradient">
      <div class="cta-card-copy">
        <div class="cta-tabs">
          <span class="cta-tab active">Pełny raport</span>
          <span class="cta-tab">25&ndash;50 URL-i</span>
          <span class="cta-tab cta-tab--filled">Polecane</span>
        </div>

        <h3 class="cta-headline">Rozbudowany raport GEO dla Twojej domeny</h3>

        <p class="cta-lead">
          Skanujemy 25&ndash;50 URL-i z&nbsp;Twojej domeny i&nbsp;analizujemy cztery obszary:
          spójność tematyczną, sygnały autorytetu, dostępność dla AI oraz widoczność
          w&nbsp;wyszukiwarkach AI.
        </p>

        <ul class="cta-bullets">
          <li>Wynik GEO dla każdego URL-a z&nbsp;konkretnymi problemami i&nbsp;rekomendacjami</li>
          <li>Mapa luk w&nbsp;treści pod konwersacyjne zapytania AI</li>
          <li>Plan działań ułożony wg&nbsp;priorytetu (krytyczne / ważne / średnie)</li>
          <li>Wnioski i&nbsp;kierunek działań w&nbsp;dłuższym horyzoncie</li>
        </ul>

        <div class="cta-actions">
          <a
            class="btn-primary"
            href="/kontakt?type=full-report"
            aria-label="Zamów pełny raport GEO"
          >
            Zamów pełny raport <span aria-hidden="true">→</span>
          </a>
          <a
            class="btn-translucent"
            href="/raport-przyklad"
            aria-label="Zobacz przykładowy raport PDF"
          >
            Zobacz przykładowy PDF
          </a>
        </div>
      </div>

      <!-- Glass panel z mock UI raportu -->
      <div class="cta-panel" aria-hidden="true">
        <div class="cta-panel-head">
          <span>Raport GEO · podgląd</span>
          <span>PDF · 47 stron</span>
        </div>

        <div class="cta-panel-domain">
          <span class="cta-panel-label">GEO Score · twojadomena.pl</span>
          <span class="cta-bignum">38<span>%</span><sup>13 / 25 URL-i</sup></span>
        </div>

        <div class="cta-mini-rows">
          <div class="cta-mini-row">
            <span class="cta-mini-label">Spójność tematyczna</span>
            <span class="cta-mini-bar"><i style="width:56%"></i></span>
            <span class="tabular">56%</span>
          </div>
          <div class="cta-mini-row">
            <span class="cta-mini-label">Sygnały autorytetu</span>
            <span class="cta-mini-bar"><i style="width:42%"></i></span>
            <span class="tabular">42%</span>
          </div>
          <div class="cta-mini-row">
            <span class="cta-mini-label">Dostępność dla AI</span>
            <span class="cta-mini-bar"><i style="width:68%"></i></span>
            <span class="tabular">68%</span>
          </div>
          <div class="cta-mini-row">
            <span class="cta-mini-label">Widoczność w&nbsp;AI</span>
            <span class="cta-mini-bar"><i style="width:30%"></i></span>
            <span class="tabular">30%</span>
          </div>
        </div>

        <div class="cta-plan">
          <div class="cta-plan-head"><span>Plan działań</span><span>23 zadania</span></div>
          <div class="cta-plan-row">
            <span class="prio p0">P0</span><span>Schema FAQ na&nbsp;12 podstronach kategorii</span>
          </div>
          <div class="cta-plan-row">
            <span class="prio p0">P0</span><span>Pillar /porownanie-[marka]-vs-konkurencja</span>
          </div>
          <div class="cta-plan-row">
            <span class="prio p1">P1</span><span>Spójność danych marki w&nbsp;sieci</span>
          </div>
          <div class="cta-plan-row faint"><span>+ 20 więcej w&nbsp;raporcie</span></div>
        </div>
      </div>
    </article>
  </div>
</section>

<style>
  .audits-section {
    padding: 80px 0;
    background: var(--bg-canvas);
  }

  @media (min-width: 980px) {
    .audits-section {
      padding: 104px 0;
    }
  }

  /* ============================================================
     Service cards (3 darmowe)
     ============================================================ */

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 48px;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .audit-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    padding: 24px;
    min-height: 280px;
    color: var(--ink);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      background 0.2s ease;
  }

  .audit-card:hover {
    border-color: var(--hairline);
  }

  .service-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }

  .card-eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .card-eyebrow.accent {
    color: var(--accent-blue);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ink);
    margin: 0;
  }

  .card-body {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.5;
    margin: 0;
  }

  .card-body code {
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 0.9em;
    color: var(--ink);
    background: var(--bg-canvas);
    padding: 1px 4px;
    border-radius: 3px;
  }

  /* Mock UI panel */
  .service-mock {
    background: var(--bg-canvas);
    border-radius: var(--r-md);
    padding: 16px;
    border: 1px solid var(--hairline-soft);
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: auto;
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 11px;
  }

  .service-link {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-muted);
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
    text-decoration: none;
    transition:
      color 0.15s ease,
      gap 0.15s ease;
  }

  .service-link:hover {
    color: var(--ink);
    gap: 10px;
  }

  /* ============================================================
     Premium GEO report – orange spotlight (radial 3-stop + overlay)
     ============================================================ */

  .cta-card {
    background: var(--grad-orange);
    border-radius: var(--r-xxl);
    padding: 32px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    box-shadow: 0 40px 100px -30px rgba(255, 90, 26, 0.45);
  }

  @media (min-width: 980px) {
    .cta-card {
      grid-template-columns: 1.2fr 1fr;
      gap: 48px;
      padding: 56px;
    }
  }

  .cta-card-copy {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Tabs row */
  .cta-tabs {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    background: rgba(0, 0, 0, 0.18);
    border-radius: var(--r-pill);
    align-self: flex-start;
    margin-bottom: 22px;
  }

  .cta-tab {
    font-family: var(--font-sans);
    font-size: 12px;
    padding: 6px 14px;
    border-radius: var(--r-pill);
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
    letter-spacing: -0.12px;
  }

  .cta-tab.active {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .cta-tab--filled {
    background: #fff;
    color: #1a1a1a;
  }

  .cta-headline {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.4vw, 48px);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1.02;
    color: #fff;
    margin: 0 0 22px;
    max-width: 16ch;
    text-wrap: balance;
  }

  .cta-lead {
    font-family: var(--font-sans);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
    margin: 0 0 22px;
    max-width: 44ch;
  }

  .cta-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 26px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.45;
  }

  .cta-bullets li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .cta-bullets li::before {
    content: '→';
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
    flex-shrink: 0;
  }

  .cta-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* Glass panel z mock report */
  .cta-panel {
    background: rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--r-xl);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-self: center;
    font-family: var(--font-sans);
  }

  .cta-panel-head {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.6);
    display: flex;
    justify-content: space-between;
  }

  .cta-panel-domain {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .cta-panel-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.6);
  }

  .cta-bignum {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 500;
    letter-spacing: -0.04em;
    color: #fff;
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
  }

  .cta-bignum > span {
    font-size: 26px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    margin-left: 2px;
  }

  .cta-bignum sup {
    font-size: 11px;
    vertical-align: top;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-left: 12px;
    align-self: center;
  }

  .cta-mini-rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.85);
  }

  .cta-mini-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .cta-mini-label {
    min-width: 120px;
    flex-shrink: 0;
  }

  .cta-mini-bar {
    flex: 1;
    height: 4px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.15);
    overflow: hidden;
  }

  .cta-mini-bar i {
    display: block;
    height: 100%;
    background: #fff;
  }

  .cta-plan {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 8px;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .cta-plan-head {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 4px;
  }

  .cta-plan-row {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: -0.12px;
  }

  .cta-plan-row.faint {
    color: rgba(255, 255, 255, 0.5);
    padding-left: 36px;
    font-style: italic;
  }

  .prio {
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 6px;
    border-radius: 4px;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    width: 26px;
    text-align: center;
  }

  .prio.p0 {
    background: rgba(255, 90, 26, 0.85);
    color: #fff;
  }
  .prio.p1 {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
  }
</style>
