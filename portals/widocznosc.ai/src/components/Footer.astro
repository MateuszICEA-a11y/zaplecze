---
import FacebookIcon from '../assets/icons/FacebookIcon.astro';
import InstagramIcon from '../assets/icons/InstagramIcon.astro';
import TwitterIcon from '../assets/icons/TwitterIcon.astro';

const footerData = [
  {
    title: 'Modele AI',
    items: [
      { label: 'ChatGPT', href: '/pozycjonowanie-ai/chatgpt' },
      { label: 'Claude', href: '/pozycjonowanie-ai/claude' },
      { label: 'Gemini', href: '/pozycjonowanie-ai/gemini' },
      { label: 'Perplexity', href: '/pozycjonowanie-ai/perplexity' },
      { label: 'Bing Copilot', href: '/pozycjonowanie-ai/bing-copilot' },
    ],
  },
  {
    title: 'Narzędzia',
    items: [
      { label: 'Visibility Checker', href: '/narzedzia#visibility-checker' },
      { label: 'Kompleksowy audyt AI', href: '/narzedzia#audyt-ai' },
      { label: 'Audyt contentu pod AI', href: '/narzedzia#audyt-content-ai' },
      { label: 'Baza wiedzy', href: '/blog' },
    ],
  },
  {
    title: 'Firma',
    items: [
      { label: 'O nas', href: '/o-nas' },
      { label: 'Kontakt', href: '/kontakt' },
      { label: 'ICEA', href: 'https://grupa-icea.pl', external: true },
      { label: 'Polityka prywatności', href: '/polityka-prywatnosci' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer aria-label="Stopka serwisu" class="border-rule border-t" style="background: var(--bg);">
  <div class="content-container pt-16 pb-12 lg:pt-20 lg:pb-16">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12">
      <!-- Brand + newsletter -->
      <div class="lg:col-span-5">
        <a href="/" aria-label="widoczność.ai – strona główna" class="flex items-center gap-3">
          <div class="logo-mark" aria-hidden="true">w</div>
          <div class="text-ink text-2xl font-semibold tracking-tight">
            widoczność<span class="text-accent">.ai</span>
          </div>
        </a>
        <p class="text-ink-soft mt-5 max-w-md leading-relaxed">
          Pozycjonowanie marek w wyszukiwarkach AI. Audyt widoczności w&nbsp;ChatGPT, Claude,
          Gemini i&nbsp;Perplexity. Część ICEA – agencji SEO i&nbsp;AI.
        </p>

        <div class="mt-8">
          <div class="text-ink-mute mb-3 font-mono text-[11px] tracking-[0.12em] uppercase">
            Newsletter · co 2 tyg.
          </div>
          <form class="flex w-full max-w-md gap-2" aria-label="Zapis do newslettera">
            <label for="footer-email" class="sr-only">Adres e-mail</label>
            <input
              type="email"
              id="footer-email"
              placeholder="twoj@email.pl"
              class="form-input h-11 flex-1 py-0 text-sm"
              required
            />
            <button class="btn-primary !py-3 !px-5 !text-sm" type="submit" aria-label="Zapisz się do newslettera">
              Zapisz
            </button>
          </form>
        </div>
      </div>

      <!-- Sitemap columns -->
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-3 lg:col-span-7">
        {
          footerData.map((section) => (
            <div>
              <h3 class="text-ink-mute mb-5 font-mono text-[11px] tracking-[0.12em] uppercase">
                {section.title}
              </h3>
              <ul class="space-y-3">
                {section.items.map((item) => (
                  <li>
                    <a
                      class="text-ink-soft hover:text-accent text-sm transition"
                      href={item.href}
                      {...(item.external
                        ? { target: '_blank', rel: 'noopener noreferrer' }
                        : {})}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="border-rule mt-14 flex flex-col items-center justify-between gap-6 border-t pt-8 sm:flex-row"
    >
      <div class="text-ink-mute font-mono text-[11px] tracking-[0.12em] uppercase">
        © {year} widoczność.ai · ICEA
      </div>
      <div class="flex items-center gap-2">
        <a
          href="https://www.linkedin.com/company/icea/"
          target="_blank"
          rel="noopener noreferrer"
          class="border-rule text-ink-soft hover:text-accent hover:border-accent flex h-10 w-10 items-center justify-center rounded-lg border transition"
          aria-label="LinkedIn ICEA"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M16 8C17.5913 8 19.1174 8.63214 20.2426 9.75736C21.3679 10.8826 22 12.4087 22 14V21H18V14C18 13.4696 17.7893 12.9609 17.4142 12.5858C17.0391 12.2107 16.5304 12 16 12C15.4696 12 14.9609 12.2107 14.5858 12.5858C14.2107 12.9609 14 13.4696 14 14V21H10V14C10 12.4087 10.6321 10.8826 11.7574 9.75736C12.8826 8.63214 14.4087 8 16 8Z"
            ></path>
            <rect x="2" y="9" width="4" height="12"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
        <a
          href="#"
          class="border-rule text-ink-soft hover:text-accent hover:border-accent flex h-10 w-10 items-center justify-center rounded-lg border transition"
          aria-label="Twitter / X"
        >
          <TwitterIcon />
        </a>
        <a
          href="#"
          class="border-rule text-ink-soft hover:text-accent hover:border-accent flex h-10 w-10 items-center justify-center rounded-lg border transition"
          aria-label="Facebook"
        >
          <FacebookIcon />
        </a>
        <a
          href="#"
          class="border-rule text-ink-soft hover:text-accent hover:border-accent flex h-10 w-10 items-center justify-center rounded-lg border transition"
          aria-label="Instagram"
        >
          <InstagramIcon />
        </a>
      </div>
    </div>
  </div>
</footer>
