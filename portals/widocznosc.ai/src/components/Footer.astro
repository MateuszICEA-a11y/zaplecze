---
import FacebookIcon from '../assets/icons/FacebookIcon.astro';
import InstagramIcon from '../assets/icons/InstagramIcon.astro';
import TwitterIcon from '../assets/icons/TwitterIcon.astro';

const footerData = [
  {
    title: 'Modele AI',
    items: [
      { label: 'ChatGPT', href: '/pozycjonowanie-ai/chatgpt' },
      { label: 'Claude', href: '/pozycjonowanie-ai/claude' },
      { label: 'Gemini', href: '/pozycjonowanie-ai/gemini' },
      { label: 'Perplexity', href: '/pozycjonowanie-ai/perplexity' },
      { label: 'Bing Copilot', href: '/pozycjonowanie-ai/bing-copilot' },
    ],
  },
  {
    title: 'Narzędzia',
    items: [
      { label: 'Visibility Checker', href: '/narzedzia#visibility-checker' },
      { label: 'Kompleksowy audyt AI', href: '/narzedzia#audyt-ai' },
      { label: 'Audyt contentu pod AI', href: '/narzedzia#audyt-content-ai' },
      { label: 'Baza wiedzy', href: '/blog' },
    ],
  },
  {
    title: 'Firma',
    items: [
      { label: 'O nas', href: '/o-nas' },
      { label: 'Kontakt', href: '/kontakt' },
      { label: 'ICEA', href: 'https://grupa-icea.pl', external: true },
      { label: 'Polityka prywatności', href: '/polityka-prywatnosci' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="footer-section" aria-label="Stopka serwisu">
  <div class="footer-container">

    <div class="footer-grid">

      <!-- Brand + newsletter -->
      <div class="footer-brand">
        <a href="/" aria-label="widocznosc.ai – strona główna" class="logo-wordmark footer-logo">
          widocznosc.ai
        </a>
        <p class="footer-brand-desc">
          Pozycjonowanie marek w wyszukiwarkach AI. Audyt widoczności w&nbsp;ChatGPT, Claude,
          Gemini i&nbsp;Perplexity. Część ICEA – agencji SEO i&nbsp;AI.
        </p>

        <div class="footer-newsletter">
          <div class="footer-newsletter-label">Newsletter · co 2 tyg.</div>
          <form class="footer-newsletter-form" aria-label="Zapis do newslettera">
            <label for="footer-email" class="sr-only">Adres e-mail</label>
            <input
              type="email"
              id="footer-email"
              placeholder="twoj@email.pl"
              class="text-input footer-newsletter-input"
              required
            />
            <button class="btn-primary footer-newsletter-btn" type="submit" aria-label="Zapisz się do newslettera">
              Zapisz
            </button>
          </form>
        </div>
      </div>

      <!-- Sitemap columns -->
      <div class="footer-cols">
        {
          footerData.map((section) => (
            <div class="footer-col">
              <h3 class="footer-col-title">{section.title}</h3>
              <ul class="footer-col-list">
                {section.items.map((item) => (
                  <li>
                    <a
                      class="footer-link"
                      href={item.href}
                      {...(item.external
                        ? { target: '_blank', rel: 'noopener noreferrer' }
                        : {})}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <div class="footer-copy">© {year} widocznosc.ai · ICEA</div>
      <div class="footer-social">
        <a
          href="https://www.linkedin.com/company/icea/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-icon-circular"
          aria-label="LinkedIn ICEA"
        >
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M16 8C17.5913 8 19.1174 8.63214 20.2426 9.75736C21.3679 10.8826 22 12.4087 22 14V21H18V14C18 13.4696 17.7893 12.9609 17.4142 12.5858C17.0391 12.2107 16.5304 12 16 12C15.4696 12 14.9609 12.2107 14.5858 12.5858C14.2107 12.9609 14 13.4696 14 14V21H10V14C10 12.4087 10.6321 10.8826 11.7574 9.75736C12.8826 8.63214 14.4087 8 16 8Z"></path>
            <rect x="2" y="9" width="4" height="12"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
        <a href="#" class="btn-icon-circular" aria-label="Twitter / X">
          <TwitterIcon />
        </a>
        <a href="#" class="btn-icon-circular" aria-label="Facebook">
          <FacebookIcon />
        </a>
        <a href="#" class="btn-icon-circular" aria-label="Instagram">
          <InstagramIcon />
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline-soft);
  }

  .footer-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 64px 30px 48px 30px;
  }

  @media (min-width: 1024px) {
    .footer-container {
      padding: 80px 40px 64px 40px;
    }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 5fr 7fr;
    }
  }

  .footer-logo {
    font-size: 22px;
    margin-bottom: 20px;
  }

  .footer-brand-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.5;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    max-width: 440px;
    margin: 0 0 32px 0;
  }

  .footer-newsletter-label {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-bottom: 12px;
  }

  .footer-newsletter-form {
    display: flex;
    gap: 8px;
    max-width: 440px;
  }

  .footer-newsletter-input {
    flex: 1;
    height: 40px;
  }

  .footer-newsletter-btn {
    flex-shrink: 0;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 640px) {
    .footer-cols {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .footer-col-title {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin: 0 0 20px 0;
  }

  .footer-col-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: var(--ink);
  }

  .footer-bottom {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--hairline-soft);
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
    }
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 8px;
  }
</style>
