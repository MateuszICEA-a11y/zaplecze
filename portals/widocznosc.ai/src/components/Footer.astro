---
/**
 * Footer – landing redesign 2026-05-09 (handoff).
 * 5-col grid (1.4fr + 4 equal): brand+newsletter | 4 link columns.
 * Newsletter form: pill-shaped row z dark submit button.
 * Bottom bar (hairline-top): copyright + 4 social pills (32px circles).
 */
import FacebookIcon from '../assets/icons/FacebookIcon.astro';
import InstagramIcon from '../assets/icons/InstagramIcon.astro';
import TwitterIcon from '../assets/icons/TwitterIcon.astro';

const footerData = [
  {
    title: 'Modele AI',
    items: [
      { label: 'ChatGPT', href: '/pozycjonowanie-ai/chatgpt' },
      { label: 'Claude', href: '/pozycjonowanie-ai/claude' },
      { label: 'Gemini', href: '/pozycjonowanie-ai/gemini' },
      { label: 'Perplexity', href: '/pozycjonowanie-ai/perplexity' },
      { label: 'Bing Copilot', href: '/pozycjonowanie-ai/bing-copilot' },
    ],
  },
  {
    title: 'Narzędzia',
    items: [
      { label: 'Brand Check', href: '/narzedzia/brand-check' },
      { label: 'AI Bots Check', href: '/narzedzia/ai-bots-check' },
      { label: 'Visibility Checker', href: '/narzedzia#visibility-checker' },
      { label: 'Kompleksowy audyt AI', href: '/narzedzia#audyt-ai' },
      { label: 'Audyt treści pod AI', href: '/narzedzia#audyt-content-ai' },
      { label: 'Baza wiedzy', href: '/blog' },
    ],
  },
  {
    title: 'Firma',
    items: [
      { label: 'O nas', href: '/o-nas' },
      { label: 'Kontakt', href: '/kontakt' },
      { label: 'ICEA ↗', href: 'https://grupa-icea.pl', external: true },
      { label: 'Polityka prywatności', href: '/polityka-prywatnosci' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="footer-section" id="kontakt" aria-label="Stopka serwisu">
  <div class="container">
    <div class="footer-top">
      <!-- Brand + newsletter -->
      <div class="footer-brand">
        <a href="/" aria-label="widocznosc.ai – strona główna" class="nav-logo footer-logo">
          <span class="nav-logo-mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" focusable="false">
              <path
                d="M 24.49 7.51 A 12 12 0 1 0 24.49 24.49"
                stroke="currentColor"
                stroke-width="2.75"
                fill="none"
                stroke-linecap="round"></path>
              <circle
                cx="16"
                cy="16"
                r="5"
                stroke="var(--accent-blue)"
                stroke-width="1.75"
                fill="none"></circle>
              <circle cx="16" cy="16" r="3" fill="var(--accent-blue)"></circle>
              <circle cx="16" cy="16" r="1" fill="var(--bg-canvas)"></circle>
            </svg>
          </span>
          <span class="nav-logo-text">widocznosc<span class="accent">.ai</span></span>
        </a>
        <p class="footer-brand-tag">
          Pozycjonowanie marek w&nbsp;wyszukiwarkach AI. Audyt widoczności w&nbsp;ChatGPT, Claude,
          Gemini i&nbsp;Perplexity. Część ICEA &ndash; agencji SEO i&nbsp;AI.
        </p>

        <form class="footer-newsletter" aria-label="Zapis do newslettera">
          <span class="footer-news-label">Newsletter · co 2 tyg.</span>
          <div class="footer-news-row">
            <label for="footer-email" class="sr-only">Adres e-mail</label>
            <input type="email" id="footer-email" placeholder="twoj@email.pl" required />
            <button
              type="submit"
              class="btn-primary footer-news-btn"
              aria-label="Zapisz się do newslettera"
            >
              Zapisz
            </button>
          </div>
        </form>
      </div>

      <!-- Sitemap columns -->
      {
        footerData.map((section) => (
          <div class="footer-col">
            <h4 class="footer-col-title">{section.title}</h4>
            <ul class="footer-col-list">
              {section.items.map((item) => (
                <li>
                  <a
                    class="footer-link"
                    href={item.href}
                    {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <span class="footer-copy">© {year} widocznosc.ai · ICEA</span>
      <div class="footer-socials">
        <a
          href="https://www.linkedin.com/company/icea/"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social"
          aria-label="LinkedIn ICEA"
        >
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M16 8C17.5913 8 19.1174 8.63214 20.2426 9.75736C21.3679 10.8826 22 12.4087 22 14V21H18V14C18 13.4696 17.7893 12.9609 17.4142 12.5858C17.0391 12.2107 16.5304 12 16 12C15.4696 12 14.9609 12.2107 14.5858 12.5858C14.2107 12.9609 14 13.4696 14 14V21H10V14C10 12.4087 10.6321 10.8826 11.7574 9.75736C12.8826 8.63214 14.4087 8 16 8Z"
            ></path>
            <rect x="2" y="9" width="4" height="12"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
        <a href="#" class="footer-social" aria-label="Twitter / X"><TwitterIcon /></a>
        <a href="#" class="footer-social" aria-label="Facebook"><FacebookIcon /></a>
        <a href="#" class="footer-social" aria-label="Instagram"><InstagramIcon /></a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    padding: 64px 0 32px;
    border-top: 1px solid var(--hairline-soft);
    background: var(--bg-canvas);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    padding-bottom: 48px;
  }

  @media (min-width: 640px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 980px) {
    .footer-top {
      grid-template-columns: 1.4fr repeat(3, 1fr);
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-logo {
    font-size: 16px;
  }

  .footer-brand-tag {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-muted);
    max-width: 320px;
    line-height: 1.5;
    margin: 0;
  }

  /* Newsletter pill row */
  .footer-newsletter {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 14px;
    max-width: 360px;
  }

  .footer-news-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }

  .footer-news-row {
    display: flex;
    gap: 6px;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-pill);
    padding: 4px 4px 4px 14px;
    align-items: center;
  }

  .footer-news-row input {
    flex: 1;
    background: transparent;
    border: 0;
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 13px;
    outline: none;
    min-width: 0;
  }

  .footer-news-row input::placeholder {
    color: var(--ink-faint);
  }

  .footer-news-btn {
    min-height: 32px;
    padding: 6px 14px;
    font-size: 12px;
  }

  /* Footer columns */
  .footer-col-title {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    margin: 0 0 14px;
  }

  .footer-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-muted);
    letter-spacing: -0.13px;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: var(--ink);
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-content: space-between;
    align-items: flex-start;
    padding-top: 24px;
    border-top: 1px solid var(--hairline-soft);
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      align-items: center;
    }
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-socials {
    display: flex;
    gap: 6px;
  }

  .footer-social {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--bg-surface-1);
    display: grid;
    place-items: center;
    color: var(--ink-muted);
    transition:
      background 0.18s ease,
      color 0.18s ease;
    text-decoration: none;
  }

  .footer-social :global(svg) {
    width: 14px;
    height: 14px;
  }

  .footer-social:hover {
    background: var(--bg-surface-2);
    color: var(--ink);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
