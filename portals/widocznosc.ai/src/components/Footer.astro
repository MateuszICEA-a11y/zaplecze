---
/**
 * Footer – landing redesign 2026-05-09 (handoff).
 * Bottom bar (hairline-top): copyright + 4 social pills (32px circles).
 */
import FacebookIcon from '../assets/icons/FacebookIcon.astro';
import InstagramIcon from '../assets/icons/InstagramIcon.astro';
import YouTubeIcon from '../assets/icons/YouTubeIcon.astro';

const footerData = [
  {
    title: 'Modele AI',
    items: [
      { label: 'ChatGPT', href: '/pozycjonowanie-ai/chatgpt/' },
      { label: 'Claude', href: '/pozycjonowanie-ai/claude/' },
      { label: 'Gemini', href: '/pozycjonowanie-ai/gemini/' },
      { label: 'Perplexity', href: '/pozycjonowanie-ai/perplexity/' },
      { label: 'Bing Copilot', href: '/pozycjonowanie-ai/bing-copilot/' },
    ],
  },
  {
    title: 'Narzędzia',
    items: [
      { label: 'Widoczność marki w AI', href: '/narzedzia/brand-check/' },
      { label: 'Ocena cytowalności strony', href: '/narzedzia/url-check/' },
      { label: 'Dostęp botów AI', href: '/narzedzia/ai-bots-check/' },
      { label: 'Analiza zapytań AI', href: '/narzedzia/fanout/' },
      { label: 'Baza wiedzy', href: '/blog/' },
    ],
  },
  {
    title: 'Firma',
    items: [
      { label: 'O nas', href: '/o-nas/' },
      { label: 'Kontakt', href: '/kontakt/' },
      { label: 'ICEA ↗', href: 'https://grupa-icea.pl', external: true },
      { label: 'Polityka prywatności', href: '/polityka-prywatnosci/' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="footer-section" id="kontakt" aria-label="Stopka serwisu">
  <div class="container">
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" aria-label="widocznosc.ai – strona główna" class="nav-logo footer-logo">
          <span class="nav-logo-mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" focusable="false">
              <path
                d="M 24.49 7.51 A 12 12 0 1 0 24.49 24.49"
                stroke="currentColor"
                stroke-width="2.75"
                fill="none"
                stroke-linecap="round"></path>
              <circle
                cx="16"
                cy="16"
                r="5"
                stroke="var(--accent-blue)"
                stroke-width="1.75"
                fill="none"></circle>
              <circle cx="16" cy="16" r="3" fill="var(--accent-blue)"></circle>
              <circle cx="16" cy="16" r="1" fill="var(--bg-canvas)"></circle>
            </svg>
          </span>
          <span class="nav-logo-text">widocznosc<span class="accent">.ai</span></span>
        </a>
        <p class="footer-brand-tag">
          Pozycjonujemy marki w&nbsp;wyszukiwarkach AI. Zbadamy Twoją widoczność w&nbsp;ChatGPT,
          Claude, Gemini i&nbsp;Perplexity. Jesteśmy częścią ICEA (agencja SEO &amp; AI).
        </p>
      </div>

      <!-- Sitemap columns – na mobile rozwijane (accordion), na desktopie zawsze otwarte -->
      {
        footerData.map((section) => (
          <details class="footer-col" data-footer-accordion>
            <summary class="footer-col-title">
              <span>{section.title}</span>
              <svg
                class="footer-col-chevron"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <ul class="footer-col-list">
              {section.items.map((item) => (
                <li>
                  <a
                    class="footer-link"
                    href={item.href}
                    {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <span class="footer-copy">© {year} widocznosc.ai · ICEA</span>
      <div class="footer-socials">
        <a
          href="https://www.linkedin.com/company/iceagroup/"
          target="_blank"
          rel="me noopener noreferrer"
          class="footer-social"
          aria-label="LinkedIn ICEA"
        >
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M16 8C17.5913 8 19.1174 8.63214 20.2426 9.75736C21.3679 10.8826 22 12.4087 22 14V21H18V14C18 13.4696 17.7893 12.9609 17.4142 12.5858C17.0391 12.2107 16.5304 12 16 12C15.4696 12 14.9609 12.2107 14.5858 12.5858C14.2107 12.9609 14 13.4696 14 14V21H10V14C10 12.4087 10.6321 10.8826 11.7574 9.75736C12.8826 8.63214 14.4087 8 16 8Z"
            ></path>
            <rect x="2" y="9" width="4" height="12"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/iCEAGroup/"
          target="_blank"
          rel="me noopener noreferrer"
          class="footer-social"
          aria-label="Facebook ICEA"><FacebookIcon /></a>
        <a
          href="https://www.instagram.com/icea.pl/"
          target="_blank"
          rel="me noopener noreferrer"
          class="footer-social"
          aria-label="Instagram ICEA"><InstagramIcon /></a>
        <a
          href="https://www.youtube.com/@GRUPA_ICEA"
          target="_blank"
          rel="me noopener noreferrer"
          class="footer-social"
          aria-label="YouTube ICEA"><YouTubeIcon /></a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    padding: 64px 0 32px;
    border-top: 1px solid var(--hairline-soft);
    background: var(--bg-canvas);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding-bottom: 48px;
  }

  .footer-brand {
    padding-bottom: 8px;
  }

  @media (min-width: 640px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    .footer-brand {
      padding-bottom: 0;
    }
  }

  @media (min-width: 980px) {
    .footer-top {
      grid-template-columns: 1.4fr repeat(3, 1fr);
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-logo {
    font-size: 16px;
  }

  .footer-brand-tag {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-muted);
    max-width: 320px;
    line-height: 1.5;
    margin: 0;
  }

  /* Footer columns – mobile: accordion (<details>); desktop: zawsze otwarte */
  .footer-col {
    border-top: 1px solid var(--hairline-soft);
  }

  .footer-col-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    margin: 0;
    padding: 16px 0;
    cursor: pointer;
    list-style: none;
  }

  .footer-col-title::-webkit-details-marker {
    display: none;
  }

  .footer-col-chevron {
    flex-shrink: 0;
    color: var(--ink-faint);
    transition: transform 0.2s ease;
  }

  .footer-col[open] .footer-col-chevron {
    transform: rotate(180deg);
  }

  .footer-col-list {
    list-style: none;
    padding: 0 0 18px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  @media (min-width: 640px) {
    .footer-col {
      border-top: 0;
    }

    .footer-col-title {
      margin: 0 0 14px;
      padding: 0;
      cursor: default;
      pointer-events: none;
    }

    .footer-col-chevron {
      display: none;
    }

    .footer-col-list {
      padding: 0;
    }
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-muted);
    letter-spacing: -0.13px;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: var(--ink);
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-content: space-between;
    align-items: flex-start;
    padding-top: 24px;
    border-top: 1px solid var(--hairline-soft);
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      align-items: center;
    }
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-socials {
    display: flex;
    gap: 6px;
  }

  .footer-social {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--bg-surface-1);
    display: grid;
    place-items: center;
    color: var(--ink-muted);
    transition:
      background 0.18s ease,
      color 0.18s ease;
    text-decoration: none;
  }

  .footer-social :global(svg) {
    width: 14px;
    height: 14px;
  }

  .footer-social:hover {
    background: var(--bg-surface-2);
    color: var(--ink);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  // Footer columns: rozwinięte na desktopie, zwijane (accordion) na mobile.
  const syncFooterAccordion = () => {
    const isDesktop = window.matchMedia('(min-width: 640px)').matches;
    document
      .querySelectorAll('[data-footer-accordion]')
      .forEach((el) => ((el as HTMLDetailsElement).open = isDesktop));
  };
  syncFooterAccordion();
  window.matchMedia('(min-width: 640px)').addEventListener('change', syncFooterAccordion);
  document.addEventListener('astro:page-load', syncFooterAccordion);
</script>
