---
type Stat = {
  value: string;
  label: string;
  caption?: string;
};

interface Props {
  items?: Stat[];
  eyebrow?: string;
}

const {
  eyebrow,
  items = [
    { value: '15+', label: 'lat doświadczenia', caption: 'ICEA · agencja SEO i AI' },
    { value: '5', label: 'wyszukiwarek AI', caption: 'ChatGPT · Claude · Gemini · Perplexity · Bing Copilot' },
    { value: '500+', label: 'projektów SEO', caption: 'wdrożonych przez zespół' },
    { value: '#1', label: 'SEMKRK 2024', caption: 'najwyżej oceniona prezentacja' },
  ],
} = Astro.props;
---

<section class="statsband-section" aria-label="Liczby widocznosc.ai">
  <div class="statsband-container">
    {eyebrow && (
      <div class="statsband-eyebrow-wrap">
        <span class="eyebrow">{eyebrow}</span>
      </div>
    )}
    <dl class="statsband-grid">
      {
        items.map((stat) => (
          <div class="statsband-item">
            <dt class="sr-only">{stat.label}</dt>
            <dd class="statsband-value">{stat.value}</dd>
            <div class="statsband-label">{stat.label}</div>
            {stat.caption && <div class="statsband-caption">{stat.caption}</div>}
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .statsband-section {
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline-soft);
    border-bottom: 1px solid var(--hairline-soft);
  }

  .statsband-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 64px 30px;
  }

  @media (min-width: 1024px) {
    .statsband-container {
      padding: 80px 40px;
    }
  }

  .statsband-eyebrow-wrap {
    text-align: center;
    margin-bottom: 40px;
  }

  .statsband-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px 24px;
    margin: 0;
  }

  @media (min-width: 768px) {
    .statsband-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }

  .statsband-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .statsband-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.5rem, 5vw + 0.5rem, 3.875rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0;
  }

  .statsband-label {
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    font-weight: 500;
    letter-spacing: var(--ls-body);
    color: var(--ink);
    margin-top: 12px;
    line-height: 1.3;
  }

  .statsband-caption {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-top: 4px;
    line-height: 1.4;
  }
</style>
