---
/**
 * StatsBand – landing redesign 2026-05-09 (handoff).
 * 4 cells z mono index + display number 48→84px clamp + label.
 * Vertical 1px hairline dividers (right border na każdej z wyjątkiem last).
 * Mobile 2x2 grid.
 */

interface Stat {
  idx: string;
  value: string;
  label: string;
  caption: string;
}

const stats: Stat[] = [
  { idx: '01', value: '15+',  label: 'lat doświadczenia', caption: 'ICEA · agencja SEO i AI' },
  { idx: '02', value: '5',    label: 'wyszukiwarek AI',   caption: 'ChatGPT · Claude · Gemini · Perplexity · Copilot' },
  { idx: '03', value: '500+', label: 'projektów SEO',     caption: 'wdrożonych przez zespół' },
  { idx: '04', value: '#1',   label: 'SEMKRK 2024',       caption: 'najwyżej oceniona prezentacja' },
];
---

<section class="stats-section" aria-label="Liczby widocznosc.ai">
  <div class="container">
    <dl class="stats-grid">
      {
        stats.map((stat) => (
          <div class="stat-cell">
            <div class="stat-idx">{stat.idx}</div>
            <dd class="stat-num">{stat.value}</dd>
            <div class="stat-label">
              <strong>{stat.label}</strong>
              <span class="stat-caption">{stat.caption}</span>
            </div>
            <dt class="sr-only">{stat.label}</dt>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .stats-section {
    padding: 64px 0;
    border-bottom: 1px solid var(--hairline-soft);
    background: var(--bg-canvas);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 16px;
    margin: 0;
  }

  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
  }

  .stat-cell {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0;
  }

  /* Desktop: vertical hairline dividers between cells */
  @media (min-width: 768px) {
    .stat-cell {
      padding: 0 28px;
      border-right: 1px solid var(--hairline-soft);
    }
    .stat-cell:first-child { padding-left: 0; }
    .stat-cell:last-child { border-right: 0; padding-right: 0; }
  }

  /* Mobile 2x2: subtle column divider on odd cells */
  @media (max-width: 767px) {
    .stat-cell:nth-child(odd) {
      padding-right: 16px;
      border-right: 1px solid var(--hairline-soft);
    }
  }

  .stat-idx {
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 84px);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 0.95;
    color: var(--ink);
    margin: 0;
  }

  .stat-label {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-muted);
    letter-spacing: -0.13px;
    line-height: 1.4;
    max-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-label strong {
    color: var(--ink);
    font-weight: 500;
  }

  .stat-caption {
    color: var(--ink-faint);
    font-size: 12px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
