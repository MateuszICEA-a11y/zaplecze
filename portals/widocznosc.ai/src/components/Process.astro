---
/**
 * Process – jak wygląda pełny audyt widoczności AI (4 kroki, 3 dni delivery).
 * Framer DNA: numery display-lg ink, hairline connector, monochrome stepper.
 */

interface Step {
  num: string;
  title: string;
  duration: string;
  desc: string;
  bullets: string[];
}

const steps: Step[] = [
  {
    num: '01',
    title: 'Mapa pytań',
    duration: 'Dzień 1',
    desc: 'Wybieramy 30–50 zapytań, które reprezentują rzeczywistych klientów Twojej branży – od research-stage po decyzję zakupową.',
    bullets: [
      'Analiza buyer persona i ścieżki zakupowej',
      'Long-tail i komparatywne ("X vs Y", "najlepsze X dla…")',
      'Lista zaakceptowana przez Ciebie przed startem',
    ],
  },
  {
    num: '02',
    title: 'Test 5 silników AI',
    duration: 'Dzień 1–2',
    desc: 'Odpytujemy ChatGPT, Claude, Gemini, Perplexity i Copilot każdym pytaniem. Zbieramy pełne odpowiedzi, cytowane źródła, listy konkurentów.',
    bullets: [
      'Mention rate i Citation rate per platforma',
      'Share of Voice vs 3–5 głównych konkurentów',
      'Sentiment, halucynacje, błędne dane o marce',
    ],
  },
  {
    num: '03',
    title: 'Audyt techniczny + content',
    duration: 'Dzień 2',
    desc: 'Sprawdzamy, czy boty AI mają dostęp do strony, jak strukturyzowany jest content i co blokuje cytowania według badań Princeton/Indig.',
    bullets: [
      'robots.txt + dostęp dla 13 botów AI',
      'Schema.org, llms.txt, markdown wersje',
      'Front-loading, podzielna struktura, cytowania źródeł',
    ],
  },
  {
    num: '04',
    title: 'Raport + plan 30/60/90',
    duration: 'Dzień 3',
    desc: 'Dostajesz raport PDF (40–60 stron), dashboard z danymi i 60-min sesję prezentacyjną z konkretnym planem działania na 90 dni.',
    bullets: [
      'Lista 20+ zmian z priorytetem P0/P1/P2',
      'Quick-wins do wdrożenia od ręki (schema, llms.txt)',
      '60-min sesja Q&A z ekspertem ICEA',
    ],
  },
];
---

<section class="process-section" aria-labelledby="process-title">
  <div class="process-container">

    <header class="process-header">
      <span class="eyebrow process-eyebrow">Jak to działa</span>
      <h2 id="process-title" class="display-lg process-title">
        Pełny audyt w&nbsp;3&nbsp;dni &ndash; krok po&nbsp;kroku
      </h2>
      <p class="process-lead">
        Bez tygodni czekania, bez "wracamy z&nbsp;raportem za miesiąc". Cztery kroki,
        konkretny deliverable na&nbsp;końcu każdego.
      </p>
    </header>

    <ol class="process-grid">
      <div class="process-connector" aria-hidden="true"></div>
      {
        steps.map((step) => (
          <li class="process-step">
            <div class="process-step-num">{step.num}</div>
            <div class="process-step-duration">{step.duration}</div>
            <h3 class="process-step-title">{step.title}</h3>
            <p class="process-step-desc">{step.desc}</p>
            <ul class="process-step-bullets">
              {step.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>

    <p class="process-footer">
      Faktura, NDA i&nbsp;dane ICEA &mdash; wszystko gotowe przed startem · Bez ukrytych kosztów
    </p>

  </div>
</section>

<style>
  .process-section {
    background: var(--bg-canvas);
    padding: 96px 0;
  }

  .process-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 0 30px;
  }

  .process-header {
    max-width: 720px;
    margin: 0 auto 64px auto;
    text-align: center;
  }

  .process-eyebrow {
    display: inline-block;
    margin-bottom: 16px;
  }

  .process-title {
    color: var(--ink);
    margin: 0 0 16px 0;
    text-wrap: balance;
  }

  .process-lead {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink);
    margin: 0;
  }

  .process-grid {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media (min-width: 1024px) {
    .process-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
  }

  /* Connector line – hairline, tylko desktop */
  .process-connector {
    display: none;
  }

  @media (min-width: 1024px) {
    .process-connector {
      display: block;
      position: absolute;
      top: 30px;
      left: 12%;
      right: 12%;
      height: 1px;
      background: var(--hairline);
      pointer-events: none;
    }
  }

  .process-step {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .process-step-num {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-display-lg);
    line-height: 1;
    letter-spacing: var(--ls-display-lg);
    color: var(--ink);
    margin-bottom: 8px;
    background: var(--bg-canvas);
    padding-right: 16px;
    width: fit-content;
    position: relative;
    z-index: 1;
  }

  .process-step-duration {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-bottom: 16px;
  }

  .process-step-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-headline);
    line-height: 1.2;
    letter-spacing: var(--ls-headline);
    color: var(--ink);
    margin: 0 0 12px 0;
  }

  .process-step-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.5;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    margin: 0 0 16px 0;
  }

  .process-step-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .process-step-bullets li {
    position: relative;
    padding-left: 16px;
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.5;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
  }

  .process-step-bullets li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: var(--ink);
  }

  .process-footer {
    text-align: center;
    margin-top: 64px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }
</style>
