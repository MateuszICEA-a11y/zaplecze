---
/**
 * Process – landing redesign 2026-05-09 (handoff).
 * 4 radial-gradient atmosphere cards z ::before inner-light overlay.
 * Tones: 01 violet → 02 cyan → 03 green → 04 blue.
 * Section-head editorial 5fr/4fr.
 */

interface Step {
  tone: 'violet' | 'cyan' | 'green' | 'blue';
  num: string;
  label: string;
  title: string;
  body: string;
  list: string[];
}

const steps: Step[] = [
  {
    tone: 'violet',
    num: '01',
    label: 'Etap 1',
    title: 'Mapa pytań',
    body: 'Tworzymy 32–48 zapytań z trzech warstw – brandowych, ogólnych i porównawczych. Lista wynika z Twojej kategorii, nie z generatora.',
    list: [
      'Spotkanie strategiczne z zespołem',
      'Analiza intencji kupujących',
      'Lista benchmarkowych konkurentów',
    ],
  },
  {
    tone: 'cyan',
    num: '02',
    label: 'Etap 2',
    title: 'Test 5 silników AI',
    body: 'Zapytania trafiają równolegle do ChatGPT, Claude, Gemini, Perplexity i Copilot – ze świeżymi sesjami i bez personalizacji.',
    list: ['Standaryzacja promptów', 'Wielokrotne sesje', 'Pomiar wariancji odpowiedzi'],
  },
  {
    tone: 'green',
    num: '03',
    label: 'Etap 3',
    title: 'Audyt techniczny + content',
    body: 'Analiza struktury, schema, llms.txt i danych źródłowych. Mapujemy luki contentu pod konwersacyjne zapytania.',
    list: ['Schema & semantyka', 'Audyt llms.txt', 'Mapowanie luk treści'],
  },
  {
    tone: 'blue',
    num: '04',
    label: 'Etap 4',
    title: 'Raport + kierunek dalszych działań',
    body: 'Raport z wnioskami i konkretnymi rekomendacjami. Pokazujemy, gdzie marka jest dziś, gdzie może być za pół roku i jakie kroki nas tam zaprowadzą.',
    list: [
      'Warsztat z omówieniem wyników',
      'Strategia na budowanie widoczności',
      'Lista briefów na treści',
    ],
  },
];
---

<section class="process-section" id="proces" aria-labelledby="process-title">
  <div class="container">
    <header class="section-head">
      <div class="head-left">
        <div class="head-meta">
          <span class="section-index">S/03</span>
          <span class="eyebrow">Jak działamy</span>
        </div>
        <h2 id="process-title" class="display-lg">
          Cztery etapy budowania widoczności <span class="accent">w&nbsp;AI</span>
        </h2>
      </div>
      <div class="head-right">
        <p class="subhead">
          Pokazujemy, gdzie Twoja marka jest dziś w&nbsp;wyszukiwarkach AI i&nbsp;jakie kroki mogą
          zwiększyć jej widoczność. Co dalej &ndash; decydujesz sam.
        </p>
      </div>
    </header>

    <ol class="process-grid">
      {
        steps.map((step) => (
          <li class:list={['process-card', 'on-gradient', `process-card--${step.tone}`]}>
            <div class="process-num">
              {step.num}
              <small>{step.label}</small>
            </div>
            <h3 class="process-title">{step.title}</h3>
            <p class="process-body">{step.body}</p>
            <ul class="process-list">
              {step.list.map((item) => (
                <li>· {item}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>

    <p class="process-footer">
      Każdy etap z&nbsp;konkretnym rezultatem. Po audycie sam decydujesz, jakiej formy współpracy
      potrzebujesz.
    </p>
  </div>
</section>

<style>
  .process-section {
    padding: 96px 0;
    background: var(--bg-canvas);
  }

  @media (min-width: 980px) {
    .process-section {
      padding: 120px 0;
    }
  }

  .process-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 580px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 980px) {
    .process-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Atmosphere cards – każdy step swój radial gradient + ::before overlay
     z .on-gradient (Theme.css). Box-shadow tinted do dominującego koloru. */
  .process-card {
    border-radius: var(--r-xxl);
    padding: 28px;
    min-height: 380px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    transition: transform 0.25s ease;
  }

  .process-card:hover {
    transform: translateY(-3px);
  }

  .process-card--violet {
    background: var(--grad-violet);
    box-shadow: 0 24px 56px -22px rgba(110, 40, 240, 0.45);
  }

  .process-card--cyan {
    background: var(--grad-cyan);
    box-shadow: 0 24px 56px -22px rgba(6, 182, 212, 0.45);
  }

  .process-card--green {
    background: var(--grad-green);
    box-shadow: 0 24px 56px -22px rgba(34, 197, 94, 0.4);
  }

  .process-card--blue {
    background: var(--grad-blue);
    box-shadow: 0 24px 56px -22px rgba(59, 130, 246, 0.45);
  }

  .process-num {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 1;
    color: #fff;
  }

  .process-num small {
    display: block;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    margin-top: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .process-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: #fff;
    margin: 0;
  }

  .process-body {
    font-family: var(--font-sans);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.45;
    margin: 0;
  }

  .process-list {
    list-style: none;
    margin: auto 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.85);
  }

  .process-list li {
    display: flex;
    gap: 6px;
    padding: 8px 12px;
    background: rgba(0, 0, 0, 0.18);
    border-radius: var(--r-md);
    letter-spacing: -0.12px;
  }
</style>
