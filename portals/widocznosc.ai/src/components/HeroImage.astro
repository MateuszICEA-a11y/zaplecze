---
import Image from './Image.astro';
interface Props {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---
<Image
  src={src}
  alt={alt}
  caption={caption}
  width={1600}
  height={900}
  loading="eager"
  class="my-8 overflow-hidden rounded-2xl"
/>
