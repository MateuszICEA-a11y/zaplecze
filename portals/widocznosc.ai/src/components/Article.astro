---
const { articleData } = Astro.props;
const { title, subtitle, date, image, author, readTime, tags } = articleData;
---

<div class="bg-bgDark2 pt-36 pb-20">
  <article class="fade-in mx-auto w-full" style="max-width: 1280px; padding-inline: 1.25rem;">

    <!-- Back link -->
    <a
      href="/blog"
      class="text-ink-soft hover:text-ink mb-10 inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.15em] uppercase transition"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Wróć do bazy wiedzy
    </a>

    <!-- Header -->
    <header class="mx-auto mb-12 max-w-4xl">
      {
        tags && (
          <div class="mb-6 flex flex-wrap items-center gap-2">
            {tags.map((tag: string) => (
              <span class="text-accent inline-flex items-center rounded-md border border-[color:var(--accent-edge)] bg-[color:var(--accent-soft)] px-2.5 py-1 font-mono text-[10px] tracking-[0.15em] uppercase">
                {tag}
              </span>
            ))}
          </div>
        )
      }
      <h1 class="text-ink font-display mb-6 text-[2rem] leading-[1.1] font-semibold tracking-[-0.03em] sm:text-4xl lg:text-[3rem]">
        {title}
      </h1>
      {subtitle && (
        <p class="text-ink-soft mb-8 text-lg leading-relaxed lg:text-xl">{subtitle}</p>
      )}
      <div class="text-ink-mute flex flex-col items-start gap-4 text-sm sm:flex-row sm:items-center">
        {
          author && (
            <div class="flex items-center gap-3">
              {author.avatar ? (
                <img
                  src={author.avatar}
                  alt={author.name}
                  class="h-10 w-10 rounded-full object-cover"
                  loading="eager"
                  decoding="sync"
                />
              ) : (
                <div class="bg-accent/20 text-accent flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold">
                  {author.name.split(' ').map((n: string) => n[0]).join('')}
                </div>
              )}
              <div class="text-left">
                <div class="text-ink font-medium">{author.name}</div>
                {author.role && <div class="text-ink-mute text-xs">{author.role}</div>}
              </div>
            </div>
          )
        }
        {author && <div class="hidden h-8 w-px sm:block" style="background: var(--rule);" />}
        <div class="flex items-center gap-4 font-mono text-[11px] tracking-[0.12em] uppercase">
          <span>{date}</span>
          {readTime && (
            <>
              <div class="bg-accent h-1 w-1 rounded-full" />
              <span>{readTime} czytania</span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Hero image (full width within container) -->
    <div class="mb-16">
      <img
        src={image}
        alt={title}
        class="aspect-[16/9] w-full rounded-2xl object-cover shadow-lg"
      />
    </div>

    <!-- Body grid: content + sidebar -->
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_320px] lg:gap-14">

      <!-- Content -->
      <section class="article-content min-w-0 text-[1.0625rem] leading-[1.75] text-[color:var(--ink-soft)]">
        <slot />
      </section>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 flex flex-col gap-6">

          <!-- Author card -->
          {author && (
            <div class="border-rule rounded-2xl border p-6" style="background: var(--bg-card);">
              <div class="text-ink-mute mb-4 font-mono text-[10px] tracking-[0.18em] uppercase">
                Autor
              </div>
              <div class="flex items-center gap-4">
                {author.avatar ? (
                  <img
                    src={author.avatar}
                    alt={author.name}
                    class="h-14 w-14 rounded-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="bg-accent/20 text-accent flex h-14 w-14 items-center justify-center rounded-full text-base font-bold">
                    {author.name.split(' ').map((n: string) => n[0]).join('')}
                  </div>
                )}
                <div class="min-w-0">
                  <div class="text-ink truncate font-semibold">{author.name}</div>
                  {author.role && <div class="text-ink-mute truncate text-xs">{author.role}</div>}
                </div>
              </div>
            </div>
          )}

          <!-- CTA: darmowe testy -->
          <div class="border-rule rounded-2xl border p-6" style="background: var(--bg-card);">
            <div class="text-accent mb-4 font-mono text-[10px] tracking-[0.18em] uppercase">
              Sprawdź swoją markę
            </div>
            <h3 class="text-ink font-display mb-4 text-lg font-semibold tracking-tight">
              Trzy darmowe testy widoczności w&nbsp;AI
            </h3>
            <ul class="mb-5 space-y-3">
              <li>
                <a href="/narzedzia/brand-check" class="text-ink-soft hover:text-accent group flex items-start gap-3 text-sm transition">
                  <span class="text-accent mt-0.5 font-mono">→</span>
                  <span>Co AI wie o&nbsp;Twojej marce</span>
                </a>
              </li>
              <li>
                <a href="/narzedzia/url-check" class="text-ink-soft hover:text-accent group flex items-start gap-3 text-sm transition">
                  <span class="text-accent mt-0.5 font-mono">→</span>
                  <span>Czy Twój content jest cytowalny</span>
                </a>
              </li>
              <li>
                <a href="/narzedzia/ai-bots-check" class="text-ink-soft hover:text-accent group flex items-start gap-3 text-sm transition">
                  <span class="text-accent mt-0.5 font-mono">→</span>
                  <span>Czy AI ma dostęp do&nbsp;strony</span>
                </a>
              </li>
            </ul>
            <a class="btn-primary w-full justify-center" href="/kontakt?type=full-audit" style="display: inline-flex;">
              Zamów pełny audyt
            </a>
          </div>

          <!-- Share box -->
          <div class="border-rule rounded-2xl border p-6" style="background: var(--bg-card);">
            <div class="text-ink-mute mb-4 font-mono text-[10px] tracking-[0.18em] uppercase">
              Udostępnij
            </div>
            <div class="flex items-center gap-3">
              <a href="#" class="bg-bg-elevated hover:bg-accent/10 text-ink-soft hover:text-accent flex h-10 w-10 items-center justify-center rounded-lg transition" aria-label="Udostępnij na X">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2H21.5l-7.5 8.564L22.5 22h-6.94l-5.43-7.108L3.86 22H.604l8.04-9.18L0 2h7.108l4.91 6.5L18.244 2zm-1.213 17.998h1.864L7.07 4H5.06l11.97 15.998z"/></svg>
              </a>
              <a href="#" class="bg-bg-elevated hover:bg-accent/10 text-ink-soft hover:text-accent flex h-10 w-10 items-center justify-center rounded-lg transition" aria-label="Udostępnij na LinkedIn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14M8.5 18V10H6v8h2.5M7.25 8.875a1.45 1.45 0 1 0 0-2.9 1.45 1.45 0 0 0 0 2.9M18 18v-4.74c0-2.45-1.59-3.26-3.07-3.26-1.34 0-2.27.78-2.6 1.36V10H10v8h2.34v-4.5c0-1.21.79-1.81 1.6-1.81.78 0 1.56.39 1.56 1.81V18H18Z"/></svg>
              </a>
              <button class="bg-bg-elevated hover:bg-accent/10 text-ink-soft hover:text-accent flex h-10 w-10 items-center justify-center rounded-lg transition" aria-label="Skopiuj link" id="copy-link-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              </button>
            </div>
          </div>

        </div>
      </aside>
    </div>

  </article>
</div>

<style is:global>
  /* ============================================================
     Article content styling – typography for markdown body
     ============================================================ */
  .article-content > * + * {
    margin-top: 1.5rem;
  }

  /* Paragraphs */
  .article-content p {
    line-height: 1.75;
    color: var(--ink-soft);
  }

  /* Headings */
  .article-content h2 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-family: var(--font-display, 'Inter Tight'), sans-serif;
    font-size: 1.875rem;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--ink);
  }
  .article-content h2:first-child {
    margin-top: 0;
  }

  .article-content h3 {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-display, 'Inter Tight'), sans-serif;
    font-size: 1.375rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
  }

  /* Strong = highlight */
  .article-content strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* Lists */
  .article-content ul,
  .article-content ol {
    padding-left: 1.5rem;
    line-height: 1.75;
  }
  .article-content ul {
    list-style-type: disc;
  }
  .article-content ol {
    list-style-type: decimal;
  }
  .article-content li {
    margin-top: 0.5rem;
    color: var(--ink-soft);
  }
  .article-content li::marker {
    color: var(--accent);
  }
  .article-content li > strong:first-child {
    color: var(--ink);
  }
  .article-content li > p {
    margin: 0;
  }

  /* Links */
  .article-content a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.15s ease;
  }
  .article-content a:hover {
    color: var(--accent-bright);
  }

  /* Inline code */
  .article-content code {
    font-family: var(--font-mono, 'JetBrains Mono'), monospace;
    font-size: 0.875em;
    color: var(--accent);
    background: var(--bg-elevated);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    border: 1px solid var(--rule);
  }

  /* Code blocks */
  .article-content pre {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    line-height: 1.6;
    font-size: 0.9rem;
  }
  .article-content pre code {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--ink);
    font-size: inherit;
  }

  /* Blockquote – callout */
  .article-content blockquote {
    border-left: 3px solid var(--accent);
    background: var(--bg-card);
    border-radius: 0 0.75rem 0.75rem 0;
    padding: 1.25rem 1.5rem;
    color: var(--ink);
    font-size: 1.0625rem;
    line-height: 1.65;
  }
  .article-content blockquote p {
    color: var(--ink);
    margin: 0;
  }
  .article-content blockquote p + p {
    margin-top: 0.75rem;
  }

  /* Tables */
  .article-content table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border: 1px solid var(--rule);
    border-radius: 0.75rem;
    overflow: hidden;
    font-size: 0.95rem;
  }
  .article-content thead {
    background: var(--bg-elevated);
  }
  .article-content th,
  .article-content td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--rule);
    line-height: 1.55;
  }
  .article-content th {
    color: var(--ink);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: var(--font-mono, 'JetBrains Mono'), monospace;
  }
  .article-content tr:last-child td {
    border-bottom: none;
  }
  .article-content td {
    color: var(--ink-soft);
  }

  /* Images in content */
  .article-content img {
    border-radius: 0.75rem;
    border: 1px solid var(--rule);
    width: 100%;
    height: auto;
  }
  .article-content figure {
    margin: 2rem 0;
  }
  .article-content figcaption {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--ink-mute);
    text-align: center;
    font-family: var(--font-mono, 'JetBrains Mono'), monospace;
    letter-spacing: 0.05em;
  }

  /* Horizontal rule */
  .article-content hr {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 2.5rem 0;
  }

  /* First paragraph after H2 – slightly larger lead */
  .article-content h2 + p {
    font-size: 1.125rem;
    color: var(--ink);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('copy-link-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        btn.setAttribute('aria-label', 'Skopiowano!');
        setTimeout(() => btn.setAttribute('aria-label', 'Skopiuj link'), 1500);
      });
    });
  });
</script>
