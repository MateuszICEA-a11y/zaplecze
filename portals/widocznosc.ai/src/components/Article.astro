---
const { articleData, variant, toc, heroOverlay } = Astro.props;
const { title, subtitle, date, updated, image, author, readTime, tags } = articleData;
const showToc = Array.isArray(toc) && toc.length >= 3;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(Astro.url.href);
const xShareUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
---

<div class="article-page">
  <!-- Pasek postępu czytania – wypełnia się względem zakresu artykułu -->
  <div class="reading-progress" aria-hidden="true">
    <span class="reading-progress-bar" data-reading-progress></span>
  </div>

  <article class="article-shell">
    <!-- Optional breadcrumb (named slot) -->
    <slot name="breadcrumb" />

    <!-- Header. heroOverlay (blog): banner w stylu Moz – tekst na firmowym
         gradiencie po lewej, obraz wtopiony maską po prawej. Domyślnie
         (news): tytuł nad obrazkiem. -->
    {
      heroOverlay ? (
        <header class="article-header article-header--banner">
          <div class="article-banner">
            <div class="article-banner-text">
              {tags && (
                <div class="article-banner-eyebrow">
                  {tags.map((tag: string, i: number) => (
                    <>
                      {i > 0 && (
                        <span class="article-banner-eyebrow-sep" aria-hidden="true">
                          |
                        </span>
                      )}
                      <span>{tag}</span>
                    </>
                  ))}
                </div>
              )}
              <h1 class="article-title display-xxl">{title}</h1>
              {subtitle && <p class="article-banner-deck">{subtitle}</p>}
              <div class="article-banner-rule" />
              <div class="article-meta">
                <span class="article-meta-item">
                  <svg
                    class="article-meta-icon"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <path d="M16 2v4M8 2v4M3 10h18" />
                  </svg>
                  {date}
                </span>
                {updated && (
                  <>
                    <span class="article-meta-dot" aria-hidden="true">
                      ·
                    </span>
                    <span class="article-meta-updated">Aktualizacja: {updated}</span>
                  </>
                )}
                {readTime && (
                  <>
                    <span class="article-meta-dot" aria-hidden="true">
                      ·
                    </span>
                    <span class="article-meta-item">
                      <svg
                        class="article-meta-icon"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <circle cx="12" cy="12" r="9" />
                        <path d="M12 7v5l3 2" />
                      </svg>
                      {readTime} czytania
                    </span>
                  </>
                )}
              </div>
              {author && (
                <>
                  <div class="article-banner-rule" />
                  <div class="article-author">
                    {author.avatar ? (
                      <img
                        src={author.avatar}
                        alt={author.name}
                        class="article-author-avatar"
                        loading="eager"
                        decoding="sync"
                      />
                    ) : (
                      <div class="article-author-avatar article-author-avatar-initials">
                        {author.name
                          .split(' ')
                          .map((n: string) => n[0])
                          .join('')}
                      </div>
                    )}
                    <div>
                      <div class="article-author-name">{author.name}</div>
                      {author.role && <div class="article-author-role">{author.role}</div>}
                    </div>
                  </div>
                </>
              )}
            </div>
            <div class="article-banner-media">
              <img src={image} alt={title} />
            </div>
          </div>
        </header>
      ) : (
        <>
          <header class="article-header">
            {tags && (
              <div class="article-tags">
                {tags.map((tag: string) => (
                  <span class="article-tag">{tag}</span>
                ))}
              </div>
            )}
            <h1 class="article-title display-xxl">{title}</h1>
            {subtitle && <p class="article-subtitle">{subtitle}</p>}

            <div class="article-byline">
              {author && (
                <div class="article-author">
                  {author.avatar ? (
                    <img
                      src={author.avatar}
                      alt={author.name}
                      class="article-author-avatar"
                      loading="eager"
                      decoding="sync"
                    />
                  ) : (
                    <div class="article-author-avatar article-author-avatar-initials">
                      {author.name
                        .split(' ')
                        .map((n: string) => n[0])
                        .join('')}
                    </div>
                  )}
                  <div>
                    <div class="article-author-name">{author.name}</div>
                    {author.role && <div class="article-author-role">{author.role}</div>}
                  </div>
                </div>
              )}
              {author && <div class="article-byline-rule" />}
              <div class="article-meta">
                <span>{date}</span>
                {updated && (
                  <>
                    <span class="article-meta-dot" aria-hidden="true">
                      ·
                    </span>
                    <span class="article-meta-updated">Aktualizacja: {updated}</span>
                  </>
                )}
                {readTime && (
                  <>
                    <span class="article-meta-dot" aria-hidden="true">
                      ·
                    </span>
                    <span>{readTime} czytania</span>
                  </>
                )}
              </div>
            </div>
          </header>

          <div class="article-hero">
            <img src={image} alt={title} />
          </div>
        </>
      )
    }

    <!-- Body: spis treści (lewo, gdy ≥3 H2) + treść + sidebar (prawo) -->
    <div class:list={['article-body-grid', showToc && 'article-body-grid--with-toc']}>
      {
        showToc && (
          <aside class="article-toc-rail">
            <nav class="article-toc-sticky" aria-label="Spis treści">
              <div class="article-toc-rail-label">Spis treści</div>
              <ul class="article-toc-list">
                {toc.map((item: { slug: string; text: string }) => (
                  <li>
                    <a class="article-toc-link" href={`#${item.slug}`} data-toc-link={item.slug}>
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )
      }

      <section class:list={['article-content', variant && `article-content--${variant}`]}>
        {
          showToc && (
            <details class="article-toc-mobile">
              <summary class="article-toc-mobile-summary">
                <span>Spis treści</span>
                <span class="article-toc-mobile-chevron" aria-hidden="true" />
              </summary>
              <ul class="article-toc-list">
                {toc.map((item: { slug: string; text: string }) => (
                  <li>
                    <a class="article-toc-link" href={`#${item.slug}`} data-toc-link={item.slug}>
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          )
        }
        <slot />
      </section>

      <aside class="article-sidebar">
        <div class="article-sidebar-sticky">
          {
            author && (
              <div class="article-sidebar-card">
                <div class="article-sidebar-label">Autor</div>
                <div class="article-sidebar-author">
                  {author.avatar ? (
                    <img src={author.avatar} alt={author.name} loading="lazy" />
                  ) : (
                    <div class="article-sidebar-author-initials">
                      {author.name
                        .split(' ')
                        .map((n: string) => n[0])
                        .join('')}
                    </div>
                  )}
                  <div>
                    <div class="article-sidebar-author-name">{author.name}</div>
                    {author.role && <div class="article-sidebar-author-role">{author.role}</div>}
                  </div>
                </div>
              </div>
            )
          }

          <div class="article-sidebar-card">
            <div class="article-sidebar-label">Sprawdź swoją markę</div>
            <div class="article-sidebar-title">Trzy darmowe testy widoczności w&nbsp;AI</div>
            <ul class="article-sidebar-list">
              <li><a href="/narzedzia/brand-check/">Widoczność marki w&nbsp;AI</a></li>
              <li><a href="/narzedzia/url-check/">Ocena cytowalności strony</a></li>
              <li><a href="/narzedzia/ai-bots-check/">Dostęp botów AI</a></li>
            </ul>
            <a class="btn-primary article-sidebar-cta" href="/kontakt/?type=full-report">
              Zamów pełny raport
            </a>
          </div>

          <div class="article-sidebar-card">
            <div class="article-sidebar-label">Udostępnij</div>
            <div class="article-sidebar-share">
              <a
                href={xShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-icon-circular"
                aria-label="Udostępnij na X"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
                  ><path
                    d="M18.244 2H21.5l-7.5 8.564L22.5 22h-6.94l-5.43-7.108L3.86 22H.604l8.04-9.18L0 2h7.108l4.91 6.5L18.244 2zm-1.213 17.998h1.864L7.07 4H5.06l11.97 15.998z"
                  ></path></svg
                >
              </a>
              <a
                href={linkedinShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-icon-circular"
                aria-label="Udostępnij na LinkedIn"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
                  ><path
                    d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14M8.5 18V10H6v8h2.5M7.25 8.875a1.45 1.45 0 1 0 0-2.9 1.45 1.45 0 0 0 0 2.9M18 18v-4.74c0-2.45-1.59-3.26-3.07-3.26-1.34 0-2.27.78-2.6 1.36V10H10v8h2.34v-4.5c0-1.21.79-1.81 1.6-1.81.78 0 1.56.39 1.56 1.81V18H18Z"
                  ></path></svg
                >
              </a>
              <button class="btn-icon-circular js-copy-link" aria-label="Skopiuj link">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                  ></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                  ></path></svg
                >
              </button>
            </div>
          </div>
        </div>
      </aside>
    </div>

    <!-- Udostępnianie na mobile (sidebar ukryty <1024px) -->
    <div class="article-mobile-share" aria-label="Udostępnij">
      <span class="article-mobile-share-label">Udostępnij</span>
      <a
        href={xShareUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-icon-circular"
        aria-label="Udostępnij na X"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M18.244 2H21.5l-7.5 8.564L22.5 22h-6.94l-5.43-7.108L3.86 22H.604l8.04-9.18L0 2h7.108l4.91 6.5L18.244 2zm-1.213 17.998h1.864L7.07 4H5.06l11.97 15.998z"
          ></path></svg
        >
      </a>
      <a
        href={linkedinShareUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-icon-circular"
        aria-label="Udostępnij na LinkedIn"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14M8.5 18V10H6v8h2.5M7.25 8.875a1.45 1.45 0 1 0 0-2.9 1.45 1.45 0 0 0 0 2.9M18 18v-4.74c0-2.45-1.59-3.26-3.07-3.26-1.34 0-2.27.78-2.6 1.36V10H10v8h2.34v-4.5c0-1.21.79-1.81 1.6-1.81.78 0 1.56.39 1.56 1.81V18H18Z"
          ></path></svg
        >
      </a>
      <button class="btn-icon-circular js-copy-link" aria-label="Skopiuj link">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
          ></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
          ></path></svg
        >
      </button>
    </div>
  </article>
</div>

<style>
  .article-page {
    background: var(--bg-canvas);
    /* Responsywny padding – mobile ~88px (mniejsza przerwa pod menu),
       desktop 144px. Jedna reguła w scoped bloku, by uniknąć konfliktu
       specyficzności z regułą w is:global (która nie dostaje cid). */
    padding: clamp(88px, 12vw, 144px) 0 clamp(64px, 8vw, 80px);
  }

  /* ── Pasek postępu czytania ───────────────────────────────── */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 60;
    background: transparent;
    pointer-events: none;
  }

  .reading-progress-bar {
    display: block;
    height: 100%;
    width: 0;
    background: var(--accent-blue);
    transform-origin: left center;
    transition: width 0.1s linear;
  }

  /* ── Spis treści (TOC) ─────────────────────────────────────── */
  .article-toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .article-toc-link {
    display: block;
    padding: 7px 12px;
    border-radius: var(--r-md);
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.4;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .article-toc-link:hover {
    color: var(--ink);
    background: var(--bg-surface-2);
  }

  .article-toc-link.is-active {
    color: var(--accent-blue);
    font-weight: 600;
    background: color-mix(in srgb, var(--accent-blue) 10%, transparent);
    border-left-color: var(--accent-blue);
  }

  /* TOC mobilny – zwijany, tylko < 1024px (sidebar ukryty) */
  .article-toc-mobile {
    display: block;
    margin: 0 0 28px 0;
    border: 1px solid var(--hairline);
    border-radius: var(--r-lg);
    background: var(--bg-surface-1);
    overflow: hidden;
  }

  .article-toc-mobile-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
  }

  .article-toc-mobile-summary::-webkit-details-marker {
    display: none;
  }

  .article-toc-mobile-chevron {
    width: 9px;
    height: 9px;
    border-right: 2px solid var(--ink-muted);
    border-bottom: 2px solid var(--ink-muted);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
  }

  .article-toc-mobile[open] .article-toc-mobile-chevron {
    transform: rotate(-135deg);
  }

  .article-toc-mobile .article-toc-list {
    padding: 4px 10px 12px;
  }

  @media (min-width: 1024px) {
    .article-toc-mobile {
      display: none;
    }
  }

  .article-shell {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Breadcrumb — wąska kolumna 1040px, wyrównana do szerokości .article-header */
  :global(.article-breadcrumb) {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 auto 32px auto;
    max-width: 1360px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
  }

  :global(.article-breadcrumb-link) {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  :global(.article-breadcrumb-link:hover) {
    color: var(--ink);
  }

  :global(.article-breadcrumb-sep) {
    color: var(--ink-faint);
    font-size: 13px;
    line-height: 1;
  }

  :global(.article-breadcrumb-current) {
    color: var(--ink);
  }

  .article-header {
    max-width: 1040px;
    margin: 0 auto 48px auto;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .article-tag {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    background: var(--bg-surface-1);
    border-radius: var(--r-pill);
    font-family: var(--font-sans);
    font-size: var(--fs-micro);
    font-weight: 500;
    letter-spacing: -0.12px;
    color: var(--ink-muted);
  }

  .article-title {
    color: var(--ink);
    margin: 0 0 24px 0;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .article-subtitle {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink-muted);
    margin: 0 0 32px 0;
  }

  @media (min-width: 1024px) {
    .article-subtitle {
      font-size: 20px;
    }
  }

  .article-byline {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .article-byline {
      flex-direction: row;
      align-items: center;
    }
  }

  .article-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .article-author-avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--r-full);
    object-fit: cover;
  }

  .article-author-avatar-initials {
    background: var(--bg-surface-1);
    color: var(--ink-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 500;
  }

  .article-author-name {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink);
  }

  .article-author-role {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-top: 2px;
  }

  .article-byline-rule {
    display: none;
    width: 1px;
    height: 32px;
    background: var(--hairline);
  }

  @media (min-width: 640px) {
    .article-byline-rule {
      display: block;
    }
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .article-meta-dot {
    color: var(--ink-muted);
  }

  .article-meta-updated {
    color: var(--ink);
  }

  /* Hero image – „scena": tło = tło strony, obraz z radialną maską
     wygaszającą krawędzie (wtapia się w stronę na obu motywach),
     poświata pod spodem, 1px adaptacyjna obwódka (::after niżej). */
  .article-hero {
    position: relative;
    max-width: 1360px;
    margin: 0 auto 64px auto;
    aspect-ratio: 16 / 9;
    background: var(--bg-canvas);
    border-radius: var(--r-xl);
    --hero-glow: rgba(38, 103, 255, 0.4);
  }
  :root[data-theme='dark'] .article-hero {
    --hero-glow: rgba(92, 139, 255, 0.55);
  }
  .article-hero::before {
    content: '';
    position: absolute;
    inset: 4% 6%;
    border-radius: 50%;
    background: radial-gradient(50% 50% at 50% 50%, var(--hero-glow) 0%, transparent 75%);
    filter: blur(30px);
    z-index: 0;
  }

  .article-hero img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: var(--r-xl);
    object-fit: cover;
    display: block;
    -webkit-mask-image: radial-gradient(
      130% 130% at 50% 50%,
      #000 65%,
      rgba(0, 0, 0, 0.85) 85%,
      rgba(0, 0, 0, 0.4) 100%
    );
    mask-image: radial-gradient(
      130% 130% at 50% 50%,
      #000 65%,
      rgba(0, 0, 0, 0.85) 85%,
      rgba(0, 0, 0, 0.4) 100%
    );
  }

  /* ── Hero banner (styl Moz w naszym motywie, blog) ─────────── */
  .article-header--banner {
    max-width: 1360px;
    margin: 0 auto 56px auto;
  }

  .article-banner {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: stretch;
    min-height: clamp(320px, 30vw, 440px);
    border-radius: var(--r-xl);
    overflow: hidden;
    border: 1px solid var(--hairline);
    /* Firmowy gradient – jasny akcent w light, głęboki w dark. Tekst
       to var(--ink), więc czytelność trzyma się na obu motywach. */
    background:
      radial-gradient(
        120% 120% at 0% 0%,
        color-mix(in srgb, var(--accent-blue) 24%, var(--bg-surface-1)) 0%,
        transparent 60%
      ),
      linear-gradient(
        110deg,
        color-mix(in srgb, var(--accent-blue) 16%, var(--bg-surface-1)) 0%,
        var(--bg-surface-1) 58%
      );
  }

