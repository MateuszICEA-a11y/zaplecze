<script>
  const enhanceArticleFaq = () => {
    const isFaqBoundary = (node: Element) =>
      node.tagName === 'H2' ||
      node.classList.contains('author-box') ||
      node.classList.contains('article-related') ||
      node.classList.contains('article-cta');

    document.querySelectorAll('.article-content').forEach((content) => {
      const headings = Array.from(content.querySelectorAll('h2'));

      headings.forEach((heading) => {
        const title = heading.textContent?.trim() ?? '';
        if (
          !/(^faq\b|faq\s+[–-]|faq\s+o\b|często zadawane pytania|czesto zadawane pytania|najczęstsze pytania|najczestsze pytania)/i.test(
            title
          )
        ) {
          return;
        }

        let current = heading.nextElementSibling;
        let scan = current;
        while (scan && !isFaqBoundary(scan)) {
          if (scan.classList.contains('article-faq-list')) return;
          scan = scan.nextElementSibling;
        }

        const faqList = document.createElement('div');
        faqList.className = 'article-faq-list';
        let hasQuestions = false;

        while (current && !isFaqBoundary(current)) {
          if (current.tagName !== 'H3') {
            current = current.nextElementSibling;
            continue;
          }

          if (!hasQuestions) {
            current.insertAdjacentElement('beforebegin', faqList);
            hasQuestions = true;
          }

          const question = current;
          const details = document.createElement('details');
          details.className = 'article-faq-item';

          const summary = document.createElement('summary');
          summary.className = 'article-faq-question';

          const summaryHeading = document.createElement('h3');
          summaryHeading.className = 'article-faq-heading';
          summaryHeading.innerHTML = question.innerHTML;

          const toggle = document.createElement('span');
          toggle.className = 'article-faq-toggle';
          toggle.setAttribute('aria-hidden', 'true');

          summary.append(summaryHeading, toggle);

          const answer = document.createElement('div');
          answer.className = 'article-faq-answer';

          const nextAfterQuestion = question.nextElementSibling;
          question.remove();
          current = nextAfterQuestion;

          while (current && !isFaqBoundary(current) && current.tagName !== 'H3') {
            const next = current.nextElementSibling;
            answer.appendChild(current);
            current = next;
          }

          details.append(summary, answer);
          faqList.appendChild(details);
        }
      });
    });
  };

  document.addEventListener('astro:page-load', () => {
    enhanceArticleFaq();

    document.querySelectorAll('.js-copy-link').forEach((btn) => {
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
          btn.setAttribute('aria-label', 'Skopiowano!');
          setTimeout(() => btn.setAttribute('aria-label', 'Skopiuj link'), 1500);
        });
      });
    });
  });

  enhanceArticleFaq();
</script>

<script>
  // Scroll-spy spisu treści – podświetla aktywną sekcję (H2) wg pozycji scrolla.
  let tocScrollHandler: (() => void) | null = null;

  const setupTocSpy = () => {
    if (tocScrollHandler) {
      window.removeEventListener('scroll', tocScrollHandler);
      tocScrollHandler = null;
    }

    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')
    );
    const headings = Array.from(
      document.querySelectorAll<HTMLElement>('.article-content h2[id]')
    );
    if (!links.length || !headings.length) return;

    let current = '';
    let ticking = false;

    const update = () => {
      ticking = false;
      // Zgrane z scroll-margin-top nagłówków (100) – sekcja staje się
      // aktywna, gdy jej nagłówek dochodzi tuż pod navbar.
      const threshold = 112;
      let activeId = headings[0].id;
      for (const h of headings) {
        if (h.getBoundingClientRect().top <= threshold) activeId = h.id;
        else break;
      }
      if (activeId === current) return;
      current = activeId;
      links.forEach((l) =>
        l.classList.toggle('is-active', l.getAttribute('data-toc-link') === activeId)
      );
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    tocScrollHandler = onScroll;
    window.addEventListener('scroll', onScroll, { passive: true });
    update();
  };

  document.addEventListener('astro:page-load', setupTocSpy);
  setupTocSpy();
</script>

<script>
  // Pasek postępu czytania – wypełnia się względem zakresu artykułu.
  let progressScrollHandler: (() => void) | null = null;

  const setupReadingProgress = () => {
    if (progressScrollHandler) {
      window.removeEventListener('scroll', progressScrollHandler);
      window.removeEventListener('resize', progressScrollHandler);
      progressScrollHandler = null;
    }

    const bar = document.querySelector<HTMLElement>('[data-reading-progress]');
    const article = document.querySelector<HTMLElement>('.article-content');
    if (!bar || !article) return;

    let ticking = false;

    const update = () => {
      ticking = false;
      const rect = article.getBoundingClientRect();
      const start = rect.top + window.scrollY;
      const total = article.offsetHeight;
      const scrolled = window.scrollY + window.innerHeight - start;
      const p = Math.min(Math.max(scrolled / total, 0), 1);
      bar.style.width = `${(p * 100).toFixed(2)}%`;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    progressScrollHandler = onScroll;
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  };

  document.addEventListener('astro:page-load', setupReadingProgress);
  setupReadingProgress();
</script>

<script>
  // Lightbox – kliknięcie w obraz treści powiększa go na cały ekran.
  // Avatar w opinii eksperta (.callout-icon) jest celowo pominięty.
  const setupImageLightbox = () => {
    let overlay = document.querySelector<HTMLDivElement>('.lightbox-overlay');

    if (!overlay) {
      overlay = document.createElement('div');
      overlay.className = 'lightbox-overlay';
      overlay.setAttribute('role', 'dialog');
      overlay.setAttribute('aria-modal', 'true');
      overlay.setAttribute('aria-label', 'Powiększony obraz');

      const lightboxImg = document.createElement('img');
      lightboxImg.className = 'lightbox-img';
      lightboxImg.alt = '';
      overlay.appendChild(lightboxImg);
      document.body.appendChild(overlay);

      const close = () => {
        overlay?.classList.remove('is-open');
        document.body.classList.remove('lightbox-locked');
      };

      overlay.addEventListener('click', close);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    }

    const lightboxImg = overlay.querySelector<HTMLImageElement>('.lightbox-img');
    if (!lightboxImg) return;

    document.querySelectorAll<HTMLImageElement>('.article-content img').forEach((img) => {
      if (img.closest('.callout-icon')) return;
      if (img.dataset.lightboxBound) return;
      img.dataset.lightboxBound = 'true';
      img.classList.add('js-zoomable');

      img.addEventListener('click', () => {
        lightboxImg.src = img.currentSrc || img.src;
        lightboxImg.alt = img.alt || '';
        overlay?.classList.add('is-open');
        document.body.classList.add('lightbox-locked');
      });
    });
  };

  document.addEventListener('astro:page-load', setupImageLightbox);
  setupImageLightbox();
</script>
