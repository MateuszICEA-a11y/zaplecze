    .article-content aside.callout-expert {
      grid-template-columns: 1fr;
      padding: 18px;
    }

    .article-content table {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
      font-size: 14px;
    }

    .article-content th,
    .article-content td {
      padding: 12px 14px;
    }

    .article-content .article-faq-question {
