---
const { articleData } = Astro.props;
const { title, subtitle, date, image, author, readTime, tags } = articleData;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(Astro.url.href);
const xShareUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
---

<div class="article-page">
  <article class="article-shell">
    <!-- Optional breadcrumb (named slot) -->
    <slot name="breadcrumb" />

    <!-- Header -->
    <header class="article-header">
      {
        tags && (
          <div class="article-tags">
            {tags.map((tag: string) => (
              <span class="article-tag">{tag}</span>
            ))}
          </div>
        )
      }
      <h1 class="article-title display-xxl">{title}</h1>
      {subtitle && <p class="article-subtitle">{subtitle}</p>}

      <div class="article-byline">
        {
          author && (
            <div class="article-author">
              {author.avatar ? (
                <img
                  src={author.avatar}
                  alt={author.name}
                  class="article-author-avatar"
                  loading="eager"
                  decoding="sync"
                />
              ) : (
                <div class="article-author-avatar article-author-avatar-initials">
                  {author.name
                    .split(' ')
                    .map((n: string) => n[0])
                    .join('')}
                </div>
              )}
              <div>
                <div class="article-author-name">{author.name}</div>
                {author.role && <div class="article-author-role">{author.role}</div>}
              </div>
            </div>
          )
        }
        {author && <div class="article-byline-rule" />}
        <div class="article-meta">
          <span>{date}</span>
          {
            readTime && (
              <>
                <span class="article-meta-dot" aria-hidden="true">
                  ·
                </span>
                <span>{readTime} czytania</span>
              </>
            )
          }
        </div>
      </div>
    </header>

    <!-- Hero image -->
    <div class="article-hero">
      <img src={image} alt={title} />
    </div>

    <!-- Body grid: content + sidebar -->
    <div class="article-body-grid">
      <section class="article-content">
        <slot />
      </section>

      <aside class="article-sidebar">
        <div class="article-sidebar-sticky">
          {
            author && (
              <div class="article-sidebar-card">
                <div class="article-sidebar-label">Autor</div>
                <div class="article-sidebar-author">
                  {author.avatar ? (
                    <img src={author.avatar} alt={author.name} loading="lazy" />
                  ) : (
                    <div class="article-sidebar-author-initials">
                      {author.name
                        .split(' ')
                        .map((n: string) => n[0])
                        .join('')}
                    </div>
                  )}
                  <div>
                    <div class="article-sidebar-author-name">{author.name}</div>
                    {author.role && <div class="article-sidebar-author-role">{author.role}</div>}
                  </div>
                </div>
              </div>
            )
          }

          <div class="article-sidebar-card">
            <div class="article-sidebar-label">Sprawdź swoją markę</div>
            <div class="article-sidebar-title">Trzy darmowe testy widoczności w&nbsp;AI</div>
            <ul class="article-sidebar-list">
              <li><a href="/narzedzia/brand-check">Widoczność marki w&nbsp;AI</a></li>
              <li><a href="/narzedzia/url-check">Ocena cytowalności strony</a></li>
              <li><a href="/narzedzia/ai-bots-check">Dostęp botów AI</a></li>
            </ul>
            <a class="btn-primary article-sidebar-cta" href="/kontakt?type=full-report">
              Zamów pełny raport
            </a>
          </div>

          <div class="article-sidebar-card">
            <div class="article-sidebar-label">Udostępnij</div>
            <div class="article-sidebar-share">
              <a
                href={xShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-icon-circular"
                aria-label="Udostępnij na X"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
                  ><path
                    d="M18.244 2H21.5l-7.5 8.564L22.5 22h-6.94l-5.43-7.108L3.86 22H.604l8.04-9.18L0 2h7.108l4.91 6.5L18.244 2zm-1.213 17.998h1.864L7.07 4H5.06l11.97 15.998z"
                  ></path></svg
                >
              </a>
              <a
                href={linkedinShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-icon-circular"
                aria-label="Udostępnij na LinkedIn"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
                  ><path
                    d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14M8.5 18V10H6v8h2.5M7.25 8.875a1.45 1.45 0 1 0 0-2.9 1.45 1.45 0 0 0 0 2.9M18 18v-4.74c0-2.45-1.59-3.26-3.07-3.26-1.34 0-2.27.78-2.6 1.36V10H10v8h2.34v-4.5c0-1.21.79-1.81 1.6-1.81.78 0 1.56.39 1.56 1.81V18H18Z"
                  ></path></svg
                >
              </a>
              <button class="btn-icon-circular" aria-label="Skopiuj link" id="copy-link-btn">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                  ></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                  ></path></svg
                >
              </button>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </article>
</div>

<style>
  .article-page {
    background: var(--bg-canvas);
    padding: 144px 0 80px 0;
  }

  .article-shell {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Breadcrumb — wąska kolumna 1040px, wyrównana do szerokości .article-header */
  :global(.article-breadcrumb) {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 auto 32px auto;
    max-width: 1040px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
  }

  :global(.article-breadcrumb-link) {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  :global(.article-breadcrumb-link:hover) {
    color: var(--ink);
  }

  :global(.article-breadcrumb-sep) {
    color: var(--ink-faint);
    font-size: 13px;
    line-height: 1;
  }

  :global(.article-breadcrumb-current) {
    color: var(--ink);
  }

  .article-header {
    max-width: 1040px;
    margin: 0 auto 48px auto;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .article-tag {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    background: var(--bg-surface-1);
    border-radius: var(--r-pill);
    font-family: var(--font-sans);
    font-size: var(--fs-micro);
    font-weight: 500;
    letter-spacing: -0.12px;
    color: var(--ink-muted);
  }

  .article-title {
    color: var(--ink);
    margin: 0 0 24px 0;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .article-subtitle {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink-muted);
    margin: 0 0 32px 0;
  }

  @media (min-width: 1024px) {
    .article-subtitle {
      font-size: 20px;
    }
  }

  .article-byline {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .article-byline {
      flex-direction: row;
      align-items: center;
    }
  }

  .article-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .article-author-avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--r-full);
    object-fit: cover;
  }

  .article-author-avatar-initials {
    background: var(--bg-surface-1);
    color: var(--ink-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 500;
  }

  .article-author-name {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink);
  }

  .article-author-role {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-top: 2px;
  }

  .article-byline-rule {
    display: none;
    width: 1px;
    height: 32px;
    background: var(--hairline);
  }

  @media (min-width: 640px) {
    .article-byline-rule {
      display: block;
    }
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .article-meta-dot {
    color: var(--ink-muted);
  }

  /* Hero image – „scena": tło = tło strony, obraz z radialną maską
     wygaszającą krawędzie (wtapia się w stronę na obu motywach),
     poświata pod spodem, 1px adaptacyjna obwódka (::after niżej). */
  .article-hero {
    position: relative;
    max-width: 1360px;
    margin: 0 auto 64px auto;
    aspect-ratio: 16 / 9;
    background: var(--bg-canvas);
    border-radius: var(--r-xl);
    --hero-glow: rgba(38, 103, 255, 0.4);
  }
  :root[data-theme='dark'] .article-hero {
    --hero-glow: rgba(92, 139, 255, 0.55);
  }
  .article-hero::before {
    content: '';
    position: absolute;
    inset: 4% 6%;
    border-radius: 50%;
    background: radial-gradient(50% 50% at 50% 50%, var(--hero-glow) 0%, transparent 75%);
    filter: blur(30px);
    z-index: 0;
  }

  .article-hero img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: var(--r-xl);
    object-fit: cover;
    display: block;
    -webkit-mask-image: radial-gradient(
      130% 130% at 50% 50%,
      #000 65%,
      rgba(0, 0, 0, 0.85) 85%,
      rgba(0, 0, 0, 0.4) 100%
    );
    mask-image: radial-gradient(
      130% 130% at 50% 50%,
      #000 65%,
      rgba(0, 0, 0, 0.85) 85%,
      rgba(0, 0, 0, 0.4) 100%
    );
  }

  /* Body grid */
  .article-body-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    max-width: 1240px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .article-body-grid {
      grid-template-columns: minmax(0, 820px) 340px;
      gap: 80px;
    }
  }

  .article-content {
    min-width: 0;
    max-width: 820px;
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.65;
    letter-spacing: -0.18px;
    color: var(--ink);
  }

  /* Sidebar */
  .article-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .article-sidebar {
      display: block;
      align-self: start;
    }
  }

  .article-sidebar-sticky {
    position: sticky;
    top: 96px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .article-sidebar-card {
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    padding: 24px;
  }

  .article-sidebar-label {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-bottom: 16px;
  }

  .article-sidebar-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .article-sidebar-author img {
    width: 48px;
    height: 48px;
    border-radius: var(--r-full);
    object-fit: cover;
  }

  .article-sidebar-author-initials {
    width: 48px;
    height: 48px;
    border-radius: var(--r-full);
    background: var(--bg-surface-2);
    color: var(--ink-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
  }

  .article-sidebar-author-name {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink);
  }

  .article-sidebar-author-role {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-top: 2px;
  }

  .article-sidebar-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-body-lg);
    line-height: 1.25;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink);
    margin: 0 0 16px 0;
  }

  .article-sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .article-sidebar-list a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .article-sidebar-list a::before {
    content: '→';
    color: var(--ink);
    opacity: 0.5;
    transition: opacity 0.15s ease;
  }

  .article-sidebar-list a:hover {
    color: var(--ink);
  }

  .article-sidebar-list a:hover::before {
    opacity: 1;
  }

  .article-sidebar-cta {
    width: 100%;
  }

  .article-sidebar-share {
    display: flex;
    align-items: center;
    gap: 8px;
  }
</style>

<style is:global>
  /* ============================================================
     Article content – Framer premium long-form (820px / 17px / 1.65)
     ============================================================ */
  .article-content > * + * {
    margin-top: 1.5rem;
  }

  .article-content p {
    line-height: 1.65;
    color: var(--ink);
    font-size: 17px;
    letter-spacing: -0.18px;
  }

  /* Headings */
  .article-page .article-body-grid .article-content h2 {
    margin-top: 3rem;
    margin-bottom: 0.875rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: -0.5px;
    color: var(--ink);
  }
  .article-page .article-body-grid .article-content h2:first-child {
    margin-top: 0;
  }

  .article-page .article-body-grid .article-content h3 {
    margin-top: 2.25rem;
    margin-bottom: 0.625rem;
    font-family: var(--font-display);
    font-size: 1.1875rem;
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: -0.4px;
    color: var(--ink);
  }

  /* Strong */
  .article-content strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* Lists – zwykły bullet, brak orange ::marker */
  .article-content ul,
  .article-content ol {
    padding-left: 1.5rem;
    line-height: 1.65;
  }
  .article-content ul {
    list-style-type: disc;
  }
  .article-content ol {
    list-style-type: decimal;
  }
  .article-content li {
    margin-top: 0.5rem;
    color: var(--ink);
    font-size: 17px;
    letter-spacing: -0.18px;
  }
  .article-content li::marker {
    color: var(--ink-muted);
  }
  .article-content li > p {
    margin: 0;
  }

  /* Links – accent-blue, underline */
  .article-content a {
    color: var(--accent-blue);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: opacity 0.15s ease;
  }
  .article-content a:hover {
    opacity: 0.85;
  }

  /* Inline code */
  .article-content code {
    font-family: 'JetBrains Mono', ui-monospace, 'SF Mono', monospace;
    font-size: 0.875em;
    color: var(--ink);
    background: var(--bg-surface-1);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  /* Code blocks – terminal style z neutral dots */
  .article-content pre {
    position: relative;
    background: var(--bg-surface-1);
    border-radius: var(--r-md);
    padding: 2.75rem 1.5rem 1.5rem 1.5rem;
    overflow-x: auto;
    line-height: 1.65;
    font-size: 0.875rem;
  }
  .article-content pre::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2.25rem;
    background: var(--bg-surface-2);
    border-radius: var(--r-md) var(--r-md) 0 0;
  }
  .article-content pre::after {
    content: '';
    position: absolute;
    top: 0.875rem;
    left: 1rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--ink-muted);
    box-shadow:
      1rem 0 0 var(--ink-muted),
      2rem 0 0 var(--ink-muted);
    opacity: 0.6;
  }
  .article-content pre code {
    background: transparent;
    padding: 0;
    color: var(--ink);
    font-size: inherit;
    font-family: 'JetBrains Mono', ui-monospace, 'SF Mono', monospace;
    line-height: inherit;
  }
  .article-content pre code .line {
    display: block;
  }

  /* Callouts */
  .article-content aside.callout-fact,
  .article-content aside.callout-expert {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    margin: 34px 0;
    padding: 24px;
    border: 1px solid var(--hairline);
    border-radius: var(--r-xl);
    background: var(--bg-surface-1);
  }

  .article-content aside.callout-fact .callout-icon {
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border-radius: var(--r-full);
    background: var(--bg-surface-2);
    color: var(--accent-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }

  .article-content aside.callout-expert {
    border-left: 3px solid var(--accent-blue);
    border-radius: var(--r-xl);
  }

  .article-content aside.callout-expert .callout-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: var(--r-full);
    overflow: hidden;
  }

  .article-content aside.callout-expert .callout-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--r-full);
    border: none;
  }

  .article-content aside .callout-body {
    min-width: 0;
  }

  .article-content aside .callout-label {
    font-family: var(--font-sans);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    margin-bottom: 8px;
    font-weight: 600;
  }

  .article-content aside .callout-author {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-top: 8px;
  }

  .article-content aside p {
    margin: 0;
    color: var(--ink);
    line-height: 1.62;
    font-size: 16px;
  }

  .article-content aside p + p {
    margin-top: 8px;
  }

  .article-content aside.callout-fact p {
    font-style: normal;
    line-height: 1.62;
    color: var(--ink);
  }

  .article-content aside.callout-fact p strong {
    font-style: normal;
    color: var(--ink);
    font-weight: 600;
  }

  /* Blockquote */
  .article-content blockquote {
    border-left: 1px solid var(--hairline);
    background: var(--bg-surface-1);
    border-radius: 0 var(--r-md) var(--r-md) 0;
    padding: 20px 24px;
    color: var(--ink);
    font-size: 17px;
    line-height: 1.55;
    margin-left: 0;
  }
  .article-content blockquote p {
    color: var(--ink);
    margin: 0;
  }
  .article-content blockquote p + p {
    margin-top: 12px;
  }

  /* Tables */
  .article-content table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 32px 0;
    border: 1px solid var(--hairline);
    border-radius: var(--r-xl);
    overflow: hidden;
    font-size: 15px;
    background: var(--bg-surface-1);
  }
  .article-content thead {
    background: var(--bg-surface-2);
  }
  .article-content th,
  .article-content td {
    padding: 14px 18px;
    text-align: left;
    border-bottom: 1px solid var(--hairline-soft);
    line-height: 1.55;
    vertical-align: top;
  }
  .article-content th + th,
  .article-content td + td {
    border-left: 1px solid var(--hairline-soft);
  }
  .article-content th {
    color: var(--ink);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: -0.01em;
    text-transform: none;
  }
  .article-content tr:last-child td {
    border-bottom: none;
  }
  .article-content td {
    color: var(--ink-muted);
  }
  .article-content td:first-child {
    color: var(--ink);
    font-weight: 600;
  }
  .article-content tbody tr {
    transition: background 0.15s ease;
  }
  .article-content tbody tr:hover {
    background: var(--bg-surface-2);
  }

  /* Article FAQ accordion */
  .article-content .article-faq-list {
    display: grid;
    gap: 10px;
    margin: 24px 0 40px;
  }

  .article-content .article-faq-item {
    border: 1px solid var(--hairline);
    border-radius: var(--r-lg);
    background: var(--bg-surface-1);
    overflow: hidden;
  }

  .article-content .article-faq-question {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 18px;
    align-items: center;
    padding: 18px 20px;
    cursor: pointer;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.02em;
    list-style: none;
  }

  .article-content .article-faq-heading {
    margin: 0;
    color: inherit;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    letter-spacing: inherit;
  }

  .article-content .article-faq-question::-webkit-details-marker {
    display: none;
  }

  .article-content .article-faq-toggle {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-full);
    background: var(--bg-surface-2);
    color: var(--ink);
    position: relative;
    transition:
      transform 0.18s ease,
      background 0.18s ease;
  }

  .article-content .article-faq-toggle::before,
  .article-content .article-faq-toggle::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 12px;
    height: 1.5px;
    border-radius: var(--r-full);
    background: currentColor;
    transform: translate(-50%, -50%);
  }

  .article-content .article-faq-toggle::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .article-content .article-faq-item[open] .article-faq-toggle {
    transform: rotate(45deg);
    background: var(--accent-blue);
    color: white;
  }

  .article-content .article-faq-answer {
    padding: 0 20px 20px;
    color: var(--ink);
  }

  .article-content .article-faq-answer > *:first-child {
    margin-top: 0;
  }

  .article-content .article-faq-answer p,
  .article-content .article-faq-answer li {
    font-size: 16px;
    line-height: 1.62;
  }

  /* Images */
  .article-content img {
    border-radius: var(--r-xl);
    width: 100%;
    height: auto;
  }

  /* Hero – 1px adaptacyjna obwódka (definicja kadru na obu motywach) */
  .article-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--r-xl);
    pointer-events: none;
    z-index: 2;
    box-shadow: inset 0 0 0 1px var(--hairline);
  }

  /* Infografika w treści – opt-in dla ciemnych diagramów. Nie odwracamy
     zwykłych zdjęć ani screenów w treści, bo light mode zrobiłby negatyw. */
  :root[data-theme='light'] .article-content img.invert-on-light,
  :root[data-theme='light'] .article-content figure.infographic img,
  :root[data-theme='light'] .article-content img[src*='infographic-'] {
    filter: invert(1) hue-rotate(180deg);
  }
  .article-content figure {
    margin: 40px 0;
  }
  .article-content figcaption {
    margin-top: 12px;
    font-size: var(--fs-caption);
    color: var(--ink-muted);
    text-align: center;
    font-family: var(--font-sans);
    letter-spacing: var(--ls-caption);
    line-height: 1.4;
  }

  /* Infographic */
  .article-content figure.infographic {
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    padding: 24px;
  }
  .article-content figure.infographic svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .article-content figure.infographic figcaption {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--hairline-soft);
    text-align: center;
