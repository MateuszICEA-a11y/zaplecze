  .article-page .article-body-grid .article-content .article-faq-question .article-faq-heading {
    margin: 0;
    color: inherit;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    letter-spacing: inherit;
  }
</style>

<script>
  const enhanceArticleFaq = () => {
    const isFaqBoundary = (node: Element) =>
      node.tagName === 'H2' ||
      node.classList.contains('author-box') ||
      node.classList.contains('article-related') ||
      node.classList.contains('article-cta');

    document.querySelectorAll('.article-content').forEach((content) => {
      const headings = Array.from(content.querySelectorAll('h2'));

      headings.forEach((heading) => {
        const title = heading.textContent?.trim() ?? '';
        if (
          !/(^faq\b|faq\s+[–-]|faq\s+o\b|często zadawane pytania|czesto zadawane pytania|najczęstsze pytania|najczestsze pytania)/i.test(
            title
          )
        ) {
          return;
        }

        let current = heading.nextElementSibling;
        let scan = current;
        while (scan && !isFaqBoundary(scan)) {
          if (scan.classList.contains('article-faq-list')) return;
          scan = scan.nextElementSibling;
        }

        const faqList = document.createElement('div');
        faqList.className = 'article-faq-list';
        let hasQuestions = false;

        while (current && !isFaqBoundary(current)) {
          if (current.tagName !== 'H3') {
            current = current.nextElementSibling;
            continue;
          }

          if (!hasQuestions) {
            current.insertAdjacentElement('beforebegin', faqList);
            hasQuestions = true;
          }

          const question = current;
          const details = document.createElement('details');
          details.className = 'article-faq-item';

          const summary = document.createElement('summary');
          summary.className = 'article-faq-question';

          const summaryHeading = document.createElement('h3');
          summaryHeading.className = 'article-faq-heading';
          summaryHeading.innerHTML = question.innerHTML;

          const toggle = document.createElement('span');
          toggle.className = 'article-faq-toggle';
          toggle.setAttribute('aria-hidden', 'true');

          summary.append(summaryHeading, toggle);

          const answer = document.createElement('div');
          answer.className = 'article-faq-answer';

          const nextAfterQuestion = question.nextElementSibling;
          question.remove();
          current = nextAfterQuestion;

          while (current && !isFaqBoundary(current) && current.tagName !== 'H3') {
            const next = current.nextElementSibling;
            answer.appendChild(current);
            current = next;
          }

          details.append(summary, answer);
          faqList.appendChild(details);
        }
      });
    });
  };

  document.addEventListener('astro:page-load', () => {
    enhanceArticleFaq();

    const btn = document.getElementById('copy-link-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        btn.setAttribute('aria-label', 'Skopiowano!');
        setTimeout(() => btn.setAttribute('aria-label', 'Skopiuj link'), 1500);
      });
    });
  });

  enhanceArticleFaq();
</script>
