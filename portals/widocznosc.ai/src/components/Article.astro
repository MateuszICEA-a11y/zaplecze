---
const { articleData } = Astro.props;
const { title, subtitle, date, image, author, readTime, tags } = articleData;
---

<div class="article-page">
  <article class="article-shell">
    <!-- Back link -->
    <a href="/blog" class="article-back-link">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M19 12H5M5 12L12 19M5 12L12 5"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      Wróć do bazy wiedzy
    </a>

    <!-- Optional breadcrumb (named slot) -->
    <slot name="breadcrumb" />

    <!-- Header -->
    <header class="article-header">
      {
        tags && (
          <div class="article-tags">
            {tags.map((tag: string) => (
              <span class="article-tag">{tag}</span>
            ))}
          </div>
        )
      }
      <h1 class="article-title">{title}</h1>
      {subtitle && <p class="article-subtitle">{subtitle}</p>}

      <div class="article-byline">
        {
          author && (
            <div class="article-author">
              {author.avatar ? (
                <img
                  src={author.avatar}
                  alt={author.name}
                  class="article-author-avatar"
                  loading="eager"
                  decoding="sync"
                />
              ) : (
                <div class="article-author-avatar article-author-avatar-initials">
                  {author.name
                    .split(' ')
                    .map((n: string) => n[0])
                    .join('')}
                </div>
              )}
              <div>
                <div class="article-author-name">{author.name}</div>
                {author.role && <div class="article-author-role">{author.role}</div>}
              </div>
            </div>
          )
        }
        {author && <div class="article-byline-rule" />}
        <div class="article-meta">
          <span>{date}</span>
          {
            readTime && (
              <>
                <span class="article-meta-dot" aria-hidden="true">
                  ·
                </span>
                <span>{readTime} czytania</span>
              </>
            )
          }
        </div>
      </div>
    </header>

    <!-- Hero image -->
    <div class="article-hero">
      <img src={image} alt={title} />
    </div>

    <!-- Body grid: content + sidebar -->
    <div class="article-body-grid">
      <section class="article-content">
        <slot />
      </section>

      <aside class="article-sidebar">
        <div class="article-sidebar-sticky">
          {
            author && (
              <div class="article-sidebar-card">
                <div class="article-sidebar-label">Autor</div>
                <div class="article-sidebar-author">
                  {author.avatar ? (
                    <img src={author.avatar} alt={author.name} loading="lazy" />
                  ) : (
                    <div class="article-sidebar-author-initials">
                      {author.name
                        .split(' ')
                        .map((n: string) => n[0])
                        .join('')}
                    </div>
                  )}
                  <div>
                    <div class="article-sidebar-author-name">{author.name}</div>
                    {author.role && <div class="article-sidebar-author-role">{author.role}</div>}
                  </div>
                </div>
              </div>
            )
          }

          <div class="article-sidebar-card">
            <div class="article-sidebar-label">Sprawdź swoją markę</div>
            <h3 class="article-sidebar-title">Trzy darmowe testy widoczności w&nbsp;AI</h3>
            <ul class="article-sidebar-list">
              <li><a href="/narzedzia/brand-check">Co AI wie o&nbsp;Twojej marce</a></li>
              <li><a href="/narzedzia/url-check">Czy Twój content jest cytowalny</a></li>
              <li><a href="/narzedzia/ai-bots-check">Czy AI ma dostęp do&nbsp;strony</a></li>
            </ul>
            <a class="btn-primary article-sidebar-cta" href="/kontakt?type=full-report">
              Zamów pełny raport
            </a>
          </div>

          <div class="article-sidebar-card">
            <div class="article-sidebar-label">Udostępnij</div>
            <div class="article-sidebar-share">
              <a href="#" class="btn-icon-circular" aria-label="Udostępnij na X">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
                  ><path
                    d="M18.244 2H21.5l-7.5 8.564L22.5 22h-6.94l-5.43-7.108L3.86 22H.604l8.04-9.18L0 2h7.108l4.91 6.5L18.244 2zm-1.213 17.998h1.864L7.07 4H5.06l11.97 15.998z"
                  ></path></svg
                >
              </a>
              <a href="#" class="btn-icon-circular" aria-label="Udostępnij na LinkedIn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
                  ><path
                    d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14M8.5 18V10H6v8h2.5M7.25 8.875a1.45 1.45 0 1 0 0-2.9 1.45 1.45 0 0 0 0 2.9M18 18v-4.74c0-2.45-1.59-3.26-3.07-3.26-1.34 0-2.27.78-2.6 1.36V10H10v8h2.34v-4.5c0-1.21.79-1.81 1.6-1.81.78 0 1.56.39 1.56 1.81V18H18Z"
                  ></path></svg
                >
              </a>
              <button class="btn-icon-circular" aria-label="Skopiuj link" id="copy-link-btn">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                  ></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                  ></path></svg
                >
              </button>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </article>
</div>

<style>
  .article-page {
    background: var(--bg-canvas);
    padding: 144px 0 80px 0;
  }

  .article-shell {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .article-back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 40px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .article-back-link:hover {
    color: var(--ink);
  }

  /* Breadcrumb */
  :global(.article-breadcrumb) {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 32px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
  }

  :global(.article-breadcrumb-link) {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  :global(.article-breadcrumb-link:hover) {
    color: var(--ink);
  }

  :global(.article-breadcrumb-sep) {
    color: var(--ink-faint);
    font-size: 13px;
    line-height: 1;
  }

  :global(.article-breadcrumb-current) {
    color: var(--ink);
  }

  .article-header {
    max-width: 880px;
    margin: 0 auto 48px auto;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .article-tag {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    background: var(--bg-surface-1);
    border-radius: var(--r-pill);
    font-family: var(--font-sans);
    font-size: var(--fs-micro);
    font-weight: 500;
    letter-spacing: -0.12px;
    color: var(--ink-muted);
  }

  .article-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 4vw + 0.5rem, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 24px 0;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .article-subtitle {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink-muted);
    margin: 0 0 32px 0;
  }

  @media (min-width: 1024px) {
    .article-subtitle {
      font-size: 20px;
    }
  }

  .article-byline {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .article-byline {
      flex-direction: row;
      align-items: center;
    }
  }

  .article-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .article-author-avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--r-full);
    object-fit: cover;
  }

  .article-author-avatar-initials {
    background: var(--bg-surface-1);
    color: var(--ink-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 500;
  }

  .article-author-name {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink);
  }

  .article-author-role {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-top: 2px;
  }

  .article-byline-rule {
    display: none;
    width: 1px;
    height: 32px;
    background: var(--hairline);
  }

  @media (min-width: 640px) {
    .article-byline-rule {
      display: block;
    }
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .article-meta-dot {
    color: var(--ink-muted);
  }

  /* Hero image */
  .article-hero {
    max-width: 1080px;
    margin: 0 auto 64px auto;
  }

  .article-hero img {
    aspect-ratio: 16 / 9;
    width: 100%;
    border-radius: var(--r-xl);
    object-fit: cover;
  }

  /* Body grid */
  .article-body-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    max-width: 1080px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .article-body-grid {
      grid-template-columns: 1fr 320px;
      gap: 56px;
    }
  }

  .article-content {
    min-width: 0;
    max-width: 720px;
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.65;
    letter-spacing: -0.18px;
    color: var(--ink);
  }

  /* Sidebar */
  .article-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .article-sidebar {
      display: block;
      align-self: start;
    }
  }

  .article-sidebar-sticky {
    position: sticky;
    top: 96px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .article-sidebar-card {
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    padding: 24px;
  }

  .article-sidebar-label {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-bottom: 16px;
  }

  .article-sidebar-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .article-sidebar-author img {
    width: 48px;
    height: 48px;
    border-radius: var(--r-full);
    object-fit: cover;
  }

  .article-sidebar-author-initials {
    width: 48px;
    height: 48px;
    border-radius: var(--r-full);
    background: var(--bg-surface-2);
    color: var(--ink-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
  }

  .article-sidebar-author-name {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink);
  }

  .article-sidebar-author-role {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-top: 2px;
  }

  .article-sidebar-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-body-lg);
    line-height: 1.25;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink);
    margin: 0 0 16px 0;
  }

  .article-sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .article-sidebar-list a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .article-sidebar-list a::before {
    content: '→';
    color: var(--ink);
    opacity: 0.5;
    transition: opacity 0.15s ease;
  }

  .article-sidebar-list a:hover {
    color: var(--ink);
  }

  .article-sidebar-list a:hover::before {
    opacity: 1;
  }

  .article-sidebar-cta {
    width: 100%;
  }

  .article-sidebar-share {
    display: flex;
    align-items: center;
    gap: 8px;
  }
</style>

<style is:global>
  /* ============================================================
     Article content – Framer premium long-form (720px / 17px / 1.65)
     ============================================================ */
  .article-content > * + * {
    margin-top: 1.5rem;
  }

  .article-content p {
    line-height: 1.65;
    color: var(--ink);
    font-size: 17px;
    letter-spacing: -0.18px;
  }

  /* Headings */
  .article-content h2 {
    margin-top: 3.5rem;
    margin-bottom: 1rem;
    font-family: var(--font-display);
    font-size: 1.875rem;
    line-height: 1.13;
    font-weight: 500;
    letter-spacing: -1px;
    color: var(--ink);
  }
  .article-content h2:first-child {
    margin-top: 0;
  }

  .article-content h3 {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: -0.8px;
    color: var(--ink);
  }

  /* Strong */
  .article-content strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* Lists – zwykły bullet, brak orange ::marker */
  .article-content ul,
  .article-content ol {
    padding-left: 1.5rem;
    line-height: 1.65;
  }
  .article-content ul {
    list-style-type: disc;
  }
  .article-content ol {
    list-style-type: decimal;
  }
  .article-content li {
    margin-top: 0.5rem;
    color: var(--ink);
    font-size: 17px;
    letter-spacing: -0.18px;
  }
  .article-content li::marker {
    color: var(--ink-muted);
  }
  .article-content li > p {
    margin: 0;
  }

  /* Links – accent-blue, underline */
  .article-content a {
    color: var(--accent-blue);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: opacity 0.15s ease;
  }
  .article-content a:hover {
    opacity: 0.85;
  }

  /* Inline code */
  .article-content code {
    font-family: ui-monospace, 'SF Mono', monospace;
    font-size: 0.875em;
    color: var(--ink);
    background: var(--bg-surface-1);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  /* Code blocks – terminal style z neutral dots */
  .article-content pre {
    position: relative;
    background: var(--bg-surface-1);
    border-radius: var(--r-md);
    padding: 2.75rem 1.5rem 1.5rem 1.5rem;
    overflow-x: auto;
    line-height: 1.65;
    font-size: 0.875rem;
  }
  .article-content pre::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2.25rem;
    background: var(--bg-surface-2);
    border-radius: var(--r-md) var(--r-md) 0 0;
  }
  .article-content pre::after {
    content: '';
    position: absolute;
    top: 0.875rem;
    left: 1rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--ink-muted);
    box-shadow:
      1rem 0 0 var(--ink-muted),
      2rem 0 0 var(--ink-muted);
    opacity: 0.6;
  }
  .article-content pre code {
    background: transparent;
    padding: 0;
    color: var(--ink);
    font-size: inherit;
    font-family: ui-monospace, 'SF Mono', monospace;
    line-height: inherit;
  }
  .article-content pre code .line {
    display: block;
  }

  /* Callouts */
  .article-content aside.callout-fact,
  .article-content aside.callout-expert {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    margin: 32px 0;
    padding: 20px 24px;
    border-radius: var(--r-md);
    background: var(--bg-surface-1);
  }

  .article-content aside.callout-fact .callout-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: var(--r-full);
    background: var(--bg-surface-2);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .article-content aside.callout-expert {
    border-left: 1px solid var(--hairline);
    padding-left: 20px;
    border-radius: 0 var(--r-md) var(--r-md) 0;
  }

  .article-content aside.callout-expert .callout-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: var(--r-full);
    overflow: hidden;
  }

  .article-content aside.callout-expert .callout-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--r-full);
    border: none;
  }

  .article-content aside .callout-body {
    min-width: 0;
  }

  .article-content aside .callout-label {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    text-transform: none;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-bottom: 6px;
    font-weight: 500;
  }

  .article-content aside .callout-author {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-top: 8px;
  }

  .article-content aside p {
    margin: 0;
    color: var(--ink);
    line-height: 1.55;
    font-size: 16px;
  }

  .article-content aside p + p {
    margin-top: 8px;
  }

  .article-content aside.callout-fact p {
    font-style: italic;
    line-height: 1.6;
    color: var(--ink);
  }

  .article-content aside.callout-fact p strong {
    font-style: normal;
    color: var(--ink);
    font-weight: 600;
  }

  /* Blockquote */
  .article-content blockquote {
    border-left: 1px solid var(--hairline);
    background: var(--bg-surface-1);
    border-radius: 0 var(--r-md) var(--r-md) 0;
    padding: 20px 24px;
    color: var(--ink);
    font-size: 17px;
    line-height: 1.55;
    margin-left: 0;
  }
  .article-content blockquote p {
    color: var(--ink);
    margin: 0;
  }
  .article-content blockquote p + p {
    margin-top: 12px;
  }

  /* Tables */
  .article-content table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: var(--r-xl);
    overflow: hidden;
    font-size: 14px;
    background: var(--bg-surface-1);
  }
  .article-content thead {
    background: var(--bg-surface-2);
  }
  .article-content th,
  .article-content td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--hairline-soft);
    line-height: 1.5;
  }
  .article-content th {
    color: var(--ink);
    font-weight: 500;
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    text-transform: none;
  }
  .article-content tr:last-child td {
    border-bottom: none;
  }
  .article-content td {
    color: var(--ink-muted);
  }

  /* Images */
  .article-content img {
    border-radius: var(--r-xl);
    width: 100%;
    height: auto;
  }

  /* Hero – krawędzie wtapiają się w tło strony (oba motywy), bez twardego
     prostokąta. Maska gradientowa odsłania na brzegach bg-canvas. */
  .article-hero img {
    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, #000 6%, #000 94%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 8%, #000 92%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(to right, transparent 0%, #000 6%, #000 94%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, #000 8%, #000 92%, transparent 100%);
    mask-composite: intersect;
  }

  /* Infografika w treści – w light subtelna ramka + cień, żeby panel miał
     definicję na jasnym tle (treść do krawędzi, więc bez maski). */
  :root[data-theme='light'] .article-content img {
