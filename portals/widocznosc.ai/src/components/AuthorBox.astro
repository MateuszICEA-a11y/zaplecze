---
interface Props {
  author: {
    name: string;
    role: string;
    company?: string;
    shortBio?: string;
    bio: string;
    expertise?: string[];
    photo: string;
    linkedin?: string;
    iceaProfile?: string;
  };
  articleCount?: number;
  authorSlug?: string;
}

const { author, articleCount = 0, authorSlug } = Astro.props;

const firstName = author.name.split(' ')[0] ?? author.name;
const tags = (author.expertise ?? []).slice(0, 4);
const authorHref = authorSlug ? `/autor/${authorSlug}/` : '/o-nas';
const description = author.shortBio ?? author.bio;
---

<aside class="author-box" aria-label={`O autorze: ${author.name}`}>
  <div class="author-box-main">
    <a class="author-box-avatar" href={authorHref} aria-label={`Profil autora: ${author.name}`}>
      <img src={author.photo} alt={author.name} width="110" height="110" loading="lazy" />
    </a>

    <div class="author-box-content">
      <span class="author-box-eyebrow">Autor</span>
      <div class="author-box-name-row">
        <a class="author-box-name" href={authorHref}>{author.name}</a>
        <span class="author-box-divider" aria-hidden="true">·</span>
        <span class="author-box-role">
          {author.role}{author.company ? ` · ${author.company}` : ''}
        </span>
      </div>

      <p class="author-box-bio">{description}</p>

      {
        tags.length > 0 && (
          <div class="author-box-tags" aria-label="Specjalizacje autora">
            {tags.map((tag) => (
              <span class="author-box-tag">{tag}</span>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <div class="author-box-foot">
    <a href={authorHref} class="author-box-more">
      <span>
        Więcej artykułów {firstName}a
        {articleCount > 0 && <span class="author-box-more-count">{articleCount}</span>}
      </span>
      <span class="author-box-more-arrow" aria-hidden="true">→</span>
    </a>

    <div class="author-box-links" aria-label="Linki autora">
      {
        author.linkedin && (
          <a
            href={author.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="author-box-icon-link"
            aria-label={`LinkedIn: ${author.name}`}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14M8.5 18V10H6v8h2.5M7.25 8.875a1.45 1.45 0 1 0 0-2.9 1.45 1.45 0 0 0 0 2.9M18 18v-4.74c0-2.45-1.59-3.26-3.07-3.26-1.34 0-2.27.78-2.6 1.36V10H10v8h2.34v-4.5c0-1.21.79-1.81 1.6-1.81.78 0 1.56.39 1.56 1.81V18H18Z" />
            </svg>
          </a>
        )
      }
      {
        author.iceaProfile && (
          <a
            href={author.iceaProfile}
            target="_blank"
            rel="noopener noreferrer"
            class="author-box-icon-link"
            aria-label={`Profil ICEA: ${author.name}`}
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M7 17L17 7" />
              <path d="M9 7h8v8" />
              <path d="M19 19H5V5" />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</aside>

<style>
  .author-box {
    margin-top: 56px;
    overflow: hidden;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    background: var(--bg-surface-1);
  }

  .author-box-main {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 24px;
    padding: 28px;
  }

  .author-box-avatar {
    display: block;
    width: 110px;
    height: 110px;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: 18px;
    background: var(--bg-surface-2);
    text-decoration: none;
  }

  .author-box-avatar img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: inherit;
  }

  .author-box-content {
    min-width: 0;
  }

  .author-box-eyebrow {
    display: inline-flex;
    margin-bottom: 8px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .author-box-name-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .author-box-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--ink);
    text-decoration: none;
  }

  .author-box-name:hover {
    color: var(--accent-blue);
  }

  .author-box-divider {
    color: var(--ink-faint);
  }

  .author-box-role {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
  }

  .author-box-bio {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.65;
    letter-spacing: -0.12px;
    color: var(--ink);
  }

  .author-box-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .author-box-tag {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-pill);
    background: var(--bg-surface-2);
    font-family: var(--font-sans);
    font-size: var(--fs-micro);
    font-weight: 500;
    letter-spacing: -0.12px;
    color: var(--ink-muted);
  }

  .author-box-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 28px;
    border-top: 1px solid var(--hairline-soft);
    background: var(--bg-surface-2);
  }

  .author-box-more {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink);
    text-decoration: none;
  }

  .author-box-more:hover {
    color: var(--accent-blue);
  }

  .author-box-more-arrow {
    transition: transform 0.15s ease;
  }

  .author-box-more:hover .author-box-more-arrow {
    transform: translateX(3px);
  }

  .author-box-more-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    margin-left: 8px;
    padding: 0 7px;
    border-radius: var(--r-pill);
    background: var(--accent-blue-soft);
    color: var(--accent-blue);
    font-size: var(--fs-micro);
  }

  .author-box-links {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .author-box-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--hairline);
    border-radius: var(--r-full);
    background: var(--bg-surface-1);
    color: var(--ink-muted);
    text-decoration: none;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }

  .author-box-icon-link:hover {
    border-color: var(--accent-blue);
    background: var(--accent-blue-soft);
    color: var(--accent-blue);
  }

  @media (max-width: 640px) {
    .author-box {
      margin-top: 40px;
    }

    .author-box-main {
      grid-template-columns: 72px 1fr;
      gap: 16px;
      padding: 22px;
    }

    .author-box-avatar {
      width: 72px;
      height: 72px;
      border-radius: 14px;
    }

    .author-box-name {
      font-size: 1.2rem;
    }

    .author-box-role {
      width: 100%;
    }

    .author-box-bio {
      grid-column: 1 / -1;
      font-size: 14px;
      line-height: 1.6;
    }

    .author-box-tags {
      grid-column: 1 / -1;
      margin-top: 14px;
    }

    .author-box-foot {
      align-items: flex-start;
      flex-direction: column;
      padding: 18px 22px;
    }
  }
</style>
