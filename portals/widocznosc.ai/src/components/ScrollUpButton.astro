<button
  class="main-border-gray-darker bg-bgDark2 hover:bg-bgDark3 fixed right-6 bottom-6 z-50 flex hidden h-12 w-12 cursor-pointer items-center justify-center rounded-xl transition"
  id="scroll-up-btn"
  aria-label="Scroll to top"
>
  <svg
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    width="35px"
    height="35px"
    viewBox="0 0 20 20"
    aria-hidden="true"
  >
    <path
      d="M4.16732 12.5L10.0007 6.66667L15.834 12.5"
      stroke="rgb(99, 102, 241)"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</button>

<script>
  const initScrollUpButton = () => {
    const btn = document.getElementById('scroll-up-btn');
    const footer = document.querySelector('footer');

    // Stan: przycisk widoczny tylko gdy przewinięto > 300px ORAZ stopka
    // nie jest w widoku (inaczej nakłada się na ikony social w stopce).
    let pastThreshold = false;
    let footerVisible = false;
    const update = () => {
      if (pastThreshold && !footerVisible) {
        btn?.classList.remove('hidden');
      } else {
        btn?.classList.add('hidden');
      }
    };

    window.addEventListener('scroll', () => {
      pastThreshold = document.documentElement.scrollTop > 300;
      update();
    });

    if (footer && 'IntersectionObserver' in window) {
      new IntersectionObserver(
        ([entry]) => {
          footerVisible = entry.isIntersecting;
          update();
        },
        { rootMargin: '0px 0px -40px 0px' }
      ).observe(footer);
    }

    btn?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  };

  document.addEventListener('astro:page-load', initScrollUpButton);
</script>
