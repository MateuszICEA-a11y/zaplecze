---
interface Props {
  items: Array<{ value: string; label: string; accent?: 'blue' | 'orange' }>;
  eyebrow?: string;
}
const { items, eyebrow = 'MARKA ICEA · LICZBY' } = Astro.props;
---
<section class="border-y border-white/8 bg-surface-1/40">
  <div class="mx-auto max-w-default px-6 py-16">
    {eyebrow && <p class="eyebrow mb-8">{eyebrow}</p>}
    <dl class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
      {items.map(({ value, label, accent = 'blue' }) => (
        <div>
          <dt class="text-caption uppercase tracking-wide text-off/52">{label}</dt>
          <dd class={`mt-3 font-semibold text-display-lg ${accent === 'orange' ? 'text-orange' : 'text-blue'}`}>
            {value}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>
