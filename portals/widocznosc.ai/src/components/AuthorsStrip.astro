---
import { getCollection } from 'astro:content';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}

const {
  eyebrow = 'Zespół',
  title = 'Stoi za nami zespół ICEA',
  subtitle = 'Nasze kilkunastoletnie doświadczenie w SEO przekuwamy w skuteczne strategie widoczności w dobie AI Search. Nie teoretyzujemy – każda rekomendacja na tej stronie to wniosek wyciągnięty z realnych projektów, które realizujemy dla naszych klientów.',
} = Astro.props;

const ORDER = [
  'tomasz-czechowski',
  'michal-ziach',
  'piotr-wicenciak',
  'mateusz-wisniewski',
];

const allAuthors = await getCollection('authors');
const authors = ORDER
  .map((slug) => allAuthors.find((a) => a.id === slug))
  .filter((a): a is NonNullable<typeof a> => Boolean(a));
---

<section class="team-section" aria-labelledby="team-title">
  <div class="team-container">
    <header class="team-header">
      <span class="eyebrow team-eyebrow">{eyebrow}</span>
      <h2 id="team-title" class="display-lg team-title">{title}</h2>
      <p class="team-lead">{subtitle}</p>
    </header>

    <div class="team-roster">
      {
        authors.map((author, idx) => {
          const data = author.data;
          const slug = author.id;
          return (
            <article class="team-member">
              <div class="team-portrait">
                {data.photo ? (
                  <img
                    src={data.photo}
                    alt={`${data.name} – ${data.role}`}
                    class="team-portrait-img"
                    loading="lazy"
                    decoding="async"
                    width="320"
                    height="320"
                  />
                ) : (
                  <span class="team-portrait-fallback" aria-hidden="true">
                    {data.name.split(' ').map((n) => n[0]).join('').slice(0, 2)}
                  </span>
                )}
              </div>
              <div class="team-meta">
                <div class="team-meta-top">
                  <h3 class="team-name">
                    <a href={`/autor/${slug}`} aria-label={`Pełny profil: ${data.name}`}>
                      {data.name}
                    </a>
                  </h3>
                  <div class="team-role">{data.role}</div>
                </div>
                {data.shortBio && <p class="team-specialty">{data.shortBio}</p>}
                {data.linkedin && (
                  <a
                    href={data.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="team-linkedin"
                    aria-label={`LinkedIn — ${data.name} (otwiera się w nowym oknie)`}
                  >
                    <span>LinkedIn</span>
                    <svg width="11" height="11" viewBox="0 0 11 11" aria-hidden="true">
                      <path
                        d="M2 9L9 2M9 2H3.5M9 2V7.5"
                        stroke="currentColor"
                        stroke-width="1.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        fill="none"
                      />
                    </svg>
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .team-section {
    background: var(--bg-canvas);
    padding: 96px 0;
    border-top: 1px solid var(--hairline-soft);
  }

  .team-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 0 30px;
  }

  .team-header {
    max-width: 720px;
    margin: 0 auto 64px auto;
    text-align: center;
  }

  .team-eyebrow {
    margin-bottom: 16px;
  }

  .team-title {
    color: var(--ink);
    margin: 0 0 16px 0;
    text-wrap: balance;
  }

  .team-lead {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink);
    margin: 0;
  }

  .team-roster {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .team-roster {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .team-roster {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .team-member {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    overflow: hidden;
    transition: background 0.2s ease;
  }

  .team-member:hover {
    background: var(--bg-surface-2);
  }

  .team-portrait {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--bg-surface-2);
    overflow: hidden;
  }

  .team-portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .team-member:hover .team-portrait-img {
    transform: scale(1.03);
  }

  .team-portrait-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 88px;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
  }

  .team-meta {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .team-meta-top {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .team-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-headline);
    line-height: 1.2;
    letter-spacing: var(--ls-headline);
    color: var(--ink);
    margin: 0;
  }

  .team-name a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .team-name a:hover {
    opacity: 0.85;
  }

  .team-role {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
  }

  .team-specialty {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.45;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink);
    margin: 0;
    flex: 1;
  }

  .team-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--accent-blue);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .team-linkedin:hover {
    opacity: 0.85;
  }
</style>
