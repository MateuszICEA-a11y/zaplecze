---
import { getCollection } from 'astro:content';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  limit?: number;
}

const {
  eyebrow = 'Zespół',
  title = 'Stoi za nami zespół ICEA',
  subtitle = 'Kilkanaście lat doświadczenia w SEO przekładamy na budowanie widoczności w wyszukiwarkach AI. Każdy artykuł podpisany, każda rekomendacja oparta na praktyce klientów.',
  limit = 4,
} = Astro.props;

const authors = (await getCollection('authors'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name))
  .slice(0, limit);

const initials = (name: string) =>
  name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .slice(0, 2);
---

<section class="authors-section" aria-labelledby="authors-title">
  <div class="authors-container">
    <header class="authors-header">
      <span class="eyebrow authors-eyebrow">{eyebrow}</span>
      <h2 id="authors-title" class="display-lg authors-title">{title}</h2>
      <p class="authors-lead">{subtitle}</p>
    </header>

    <div class="authors-grid">
      {
        authors.map((author, idx) => {
          const data = author.data;
          const isFeatured = idx === 0;
          return (
            <article class:list={['author-card', isFeatured ? 'author-card--featured' : '']}>
              {data.photo ? (
                <div class="author-card-avatar">
                  <img
                    src={data.photo}
                    alt={data.name}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ) : (
                <div class="author-card-avatar author-card-avatar-initials" aria-hidden="true">
                  {initials(data.name)}
                </div>
              )}

              <h3 class="author-card-name">
                <a
                  href={`/autor/${author.id}`}
                  aria-label={`Profil: ${data.name}, ${data.role}`}
                >
                  {data.name}
                </a>
              </h3>

              <div class="author-card-role">{data.role}</div>

              {data.shortBio && <p class="author-card-bio">{data.shortBio}</p>}

              <div class="author-card-links">
                <a
                  href={`/autor/${author.id}`}
                  class="author-card-link"
                  aria-label={`Pełny profil: ${data.name}`}
                >
                  Profil <span aria-hidden="true">→</span>
                </a>
                {data.linkedin && (
                  <a
                    href={data.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="author-card-link"
                    aria-label={`LinkedIn: ${data.name} (otwiera się w nowym oknie)`}
                  >
                    LinkedIn <span aria-hidden="true">↗</span>
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .authors-section {
    background: var(--bg-canvas);
    padding: 96px 0;
    border-top: 1px solid var(--hairline-soft);
  }

  .authors-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 0 30px;
  }

  .authors-header {
    max-width: 720px;
    margin: 0 auto 64px auto;
    text-align: center;
  }

  .authors-eyebrow {
    display: inline-block;
    margin-bottom: 16px;
  }

  .authors-title {
    color: var(--ink);
    margin: 0 0 16px 0;
    text-wrap: balance;
  }

  .authors-lead {
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    line-height: 1.45;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink);
    margin: 0;
  }

  .authors-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .authors-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .authors-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Author card – charcoal surface-1, NO neon-glow, NO border accent */
  .author-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--bg-surface-1);
    border-radius: var(--r-xl);
    padding: 28px;
    transition: background 0.2s ease;
  }

  .author-card:hover {
    background: var(--bg-surface-2);
  }

  /* Featured (pierwsza karta) = surface-2 lift jako jedyny "active" marker */
  .author-card--featured {
    background: var(--bg-surface-2);
  }

  .author-card-avatar {
    width: 80px;
    height: 80px;
    border-radius: var(--r-full);
    overflow: hidden;
    margin-bottom: 20px;
    background: var(--bg-canvas);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .author-card-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .author-card-avatar-initials {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 24px;
    color: var(--ink-muted);
    letter-spacing: -0.02em;
  }

  .author-card-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-headline);
    line-height: 1.2;
    letter-spacing: var(--ls-headline);
    color: var(--ink);
    margin: 0 0 6px 0;
    white-space: nowrap;
  }

  .author-card-name a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .author-card-name a:hover {
    opacity: 0.85;
  }

  .author-card-role {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-bottom: 16px;
  }

  .author-card-bio {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.5;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink-muted);
    margin: 0 0 24px 0;
    flex-grow: 1;
  }

  .author-card-links {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: auto;
  }

  .author-card-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--accent-blue);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .author-card-link:hover {
    opacity: 0.85;
  }
</style>
