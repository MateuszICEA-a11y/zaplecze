---
import { getCollection } from 'astro:content';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  limit?: number;
}

const {
  eyebrow = 'Zespół',
  title = 'Stoi za nami zespół ICEA',
  subtitle = 'Kilkanaście lat doświadczenia w SEO przekładamy na budowanie widoczności w wyszukiwarkach AI. Każdy artykuł podpisany, każda rekomendacja oparta na praktyce klientów.',
  limit = 4,
} = Astro.props;

const authors = (await getCollection('authors'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name))
  .slice(0, limit);

const initials = (name: string) =>
  name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .slice(0, 2);
---

<section class="relative w-full" style="background: var(--bg);" aria-labelledby="authors-title">
  <div class="content-container py-20 lg:py-28">
    <div class="mx-auto mb-16 max-w-3xl text-center">
      <span class="meta mb-4 inline-block">{eyebrow}</span>
      <h2
        id="authors-title"
        class="text-ink font-display mt-2 mb-6 text-3xl font-semibold tracking-[-0.03em] sm:text-4xl lg:text-5xl"
      >
        {title}
      </h2>
      <p class="text-ink text-lg leading-relaxed">{subtitle}</p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-7">
      {
        authors.map((author, idx) => {
          const data = author.data;
          const isFeatured = idx === 0;
          return (
            <article
              class:list={[
                'author-card group relative flex flex-col items-center rounded-2xl border p-7 text-center transition-all duration-300',
                isFeatured ? 'author-card--featured' : '',
              ]}
            >
              {data.photo ? (
                <div
                  class:list={[
                    'mb-5 h-32 w-32 overflow-hidden rounded-full border-2 transition-colors',
                    isFeatured
                      ? 'border-[color:var(--accent-edge)]'
                      : 'border-rule group-hover:border-[color:var(--accent-edge)]',
                  ]}
                >
                  <img
                    src={data.photo}
                    alt={data.name}
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ) : (
                <div
                  class:list={[
                    'text-accent mb-5 flex h-32 w-32 items-center justify-center rounded-full border-2 font-mono text-2xl font-semibold transition-colors',
                    isFeatured
                      ? 'border-[color:var(--accent-edge)]'
                      : 'border-rule group-hover:border-[color:var(--accent-edge)]',
                  ]}
                  style="background: var(--accent-soft);"
                  aria-hidden="true"
                >
                  {initials(data.name)}
                </div>
              )}

              <h3 class="text-ink font-display mb-2 text-xl font-semibold tracking-[-0.02em] whitespace-nowrap">
                <a
                  href={`/autor/${author.id}`}
                  class="hover:text-accent transition"
                  aria-label={`Profil: ${data.name}, ${data.role}`}
                >
                  {data.name}
                </a>
              </h3>

              <div class="text-accent mb-5 font-mono text-[11px] tracking-[0.18em] uppercase">
                {data.role}
              </div>

              {data.shortBio && (
                <p class="text-ink-soft mb-6 grow text-sm leading-relaxed">
                  {data.shortBio}
                </p>
              )}

              <div class="mt-auto flex items-center gap-5">
                <a
                  href={`/autor/${author.id}`}
                  class="text-ink-soft hover:text-accent inline-flex items-center gap-1.5 font-mono text-[11px] tracking-wider uppercase transition"
                  aria-label={`Pełny profil: ${data.name}`}
                >
                  Profil <span aria-hidden="true">→</span>
                </a>
                {data.linkedin && (
                  <a
                    href={data.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-ink-soft hover:text-accent inline-flex items-center gap-1.5 font-mono text-[11px] tracking-wider uppercase transition"
                    aria-label={`LinkedIn: ${data.name} (otwiera się w nowym oknie)`}
                  >
                    LinkedIn <span aria-hidden="true">↗</span>
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  /* Glass-card – subtle gradient overlay, dark base, accent glow on hover */
  .author-card {
    background: linear-gradient(
      135deg,
      rgb(255 255 255 / 0.04) 0%,
      rgb(255 255 255 / 0) 65%
    ),
    var(--bg-card);
    border-color: var(--rule);
  }

  .author-card:hover {
    border-color: var(--accent-edge);
    box-shadow: 0 0 30px var(--accent-glow);
    transform: translateY(-2px);
  }

  /* Featured (pierwsza karta) – persistent neon glow + accent border */
  .author-card--featured {
    border-color: var(--accent-edge);
    box-shadow: 0 0 30px var(--accent-glow);
  }

  .author-card--featured:hover {
    box-shadow: 0 0 40px var(--accent-glow), 0 0 0 1px var(--accent-edge);
  }
</style>
