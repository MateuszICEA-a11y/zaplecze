---
type Author = {
  name: string;
  role: string;
  bio?: string;
  avatar?: string;
  href?: string;
};

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  authors?: Author[];
}

const {
  eyebrow = 'Zespół',
  title = 'Eksperci, którzy piszą i konsultują',
  subtitle = 'Zespół ICEA – kilkanaście lat w SEO, content marketingu i strategii AI. Każdy artykuł podpisany, każda rekomendacja oparta na praktyce klientów.',
  authors = [
    {
      name: 'Mateusz Wiśniewski',
      role: 'Project Coordinator · ICEA',
      bio: 'Koordynacja projektów GEO, AI search, content strategii.',
    },
    {
      name: 'Michał Ziach',
      role: 'Head of SEO · ICEA',
      bio: 'Strategie widoczności w wyszukiwarkach klasycznych i AI.',
    },
    {
      name: 'Piotr Wicenciak',
      role: 'Senior SEO Specialist · ICEA',
      bio: 'Audyty techniczne, optymalizacja contentu pod LLM.',
    },
    {
      name: 'Tomasz Czechowski',
      role: 'Content Strategist · ICEA',
      bio: 'Content GEO, fact-density, source signals.',
    },
  ],
} = Astro.props;

const initials = (name: string) =>
  name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .slice(0, 2);
---

<section class="relative w-full" style="background: var(--bg);" aria-labelledby="authors-title">
  <div class="content-container py-20 lg:py-28">
    <div class="mx-auto mb-14 max-w-3xl text-center">
      <span class="meta mb-4 inline-block">{eyebrow}</span>
      <h2
        id="authors-title"
        class="text-ink font-display mt-2 mb-6 text-3xl font-semibold tracking-[-0.03em] sm:text-4xl lg:text-5xl"
      >
        {title}
      </h2>
      <p class="text-ink-soft text-lg leading-relaxed">{subtitle}</p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        authors.map((author) => {
          const Tag = author.href ? 'a' : 'div';
          return (
            <Tag
              {...(author.href ? { href: author.href } : {})}
              class={`flex flex-col items-center rounded-xl border border-rule bg-bg-card p-6 text-center transition ${author.href ? 'hover:border-accent/35 hover:bg-bg-elevated cursor-pointer' : ''}`}
            >
              {author.avatar ? (
                <img
                  src={author.avatar}
                  alt={author.name}
                  class="mb-4 h-20 w-20 rounded-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div
                  class="text-accent border-accent/35 mb-4 flex h-20 w-20 items-center justify-center rounded-full border font-mono text-xl font-semibold"
                  style="background: var(--accent-soft);"
                  aria-hidden="true"
                >
                  {initials(author.name)}
                </div>
              )}
              <div class="text-ink font-semibold">{author.name}</div>
              <div class="text-accent mt-1 font-mono text-[11px] tracking-wider uppercase">
                {author.role}
              </div>
              {author.bio && (
                <p class="text-ink-soft mt-3 text-sm leading-relaxed">{author.bio}</p>
              )}
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>
