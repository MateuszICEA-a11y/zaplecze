---
import { getCollection } from 'astro:content';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  limit?: number;
}

const {
  eyebrow = 'Zespół',
  title = 'Eksperci, którzy piszą i konsultują',
  subtitle = 'Zespół ICEA – kilkanaście lat w SEO, content marketingu i strategii AI. Każdy artykuł podpisany, każda rekomendacja oparta na praktyce klientów.',
  limit = 4,
} = Astro.props;

const authors = (await getCollection('authors'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name))
  .slice(0, limit);

const initials = (name: string) =>
  name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .slice(0, 2);
---

<section class="relative w-full" style="background: var(--bg);" aria-labelledby="authors-title">
  <div class="content-container py-20 lg:py-28">
    <div class="mx-auto mb-14 max-w-3xl text-center">
      <span class="meta mb-4 inline-block">{eyebrow}</span>
      <h2
        id="authors-title"
        class="text-ink font-display mt-2 mb-6 text-3xl font-semibold tracking-[-0.03em] sm:text-4xl lg:text-5xl"
      >
        {title}
      </h2>
      <p class="text-ink-soft text-lg leading-relaxed">{subtitle}</p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        authors.map((author) => {
          const data = author.data;
          const Tag = data.iceaProfile ? 'a' : 'div';
          return (
            <Tag
              {...(data.iceaProfile
                ? { href: data.iceaProfile, target: '_blank', rel: 'noopener noreferrer' }
                : {})}
              class={`flex flex-col items-center rounded-xl border border-rule bg-bg-card p-6 text-center transition ${data.iceaProfile ? 'hover:border-accent/35 hover:bg-bg-elevated cursor-pointer' : ''}`}
            >
              {data.photo ? (
                <img
                  src={data.photo}
                  alt={data.name}
                  class="mb-4 h-20 w-20 rounded-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div
                  class="text-accent border-accent/35 mb-4 flex h-20 w-20 items-center justify-center rounded-full border font-mono text-xl font-semibold"
                  style="background: var(--accent-soft);"
                  aria-hidden="true"
                >
                  {initials(data.name)}
                </div>
              )}
              <div class="text-ink font-semibold">{data.name}</div>
              <div class="text-accent mt-1 font-mono text-[11px] tracking-wider uppercase">
                {data.role} · {data.company}
              </div>
              {data.shortBio && (
                <p class="text-ink-soft mt-3 text-sm leading-relaxed">{data.shortBio}</p>
              )}
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>
