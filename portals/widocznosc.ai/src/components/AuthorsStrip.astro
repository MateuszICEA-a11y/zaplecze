---
/**
 * AuthorsStrip / Team – landing redesign 2026-05-09 (handoff).
 * Section-head editorial 5fr/4fr + 4-col grid 4 team cards.
 * Card: editorial photo frame (diagonal-stripe + ghost initials glyph)
 * lub real photo gdy jest, name + role + bio + LinkedIn chip pinned bottom.
 */
import { getCollection } from 'astro:content';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  limit?: number;
  sectionIndex?: string;
}

const {
  eyebrow = 'Zespół',
  title = 'Stoi za nami <span class="accent">zespół ICEA</span>',
  subtitle = 'Nasze kilkunastoletnie doświadczenie w&nbsp;SEO przekuwamy w&nbsp;skuteczne strategie widoczności w&nbsp;dobie AI Search. Nie teoretyzujemy &ndash; każda rekomendacja na&nbsp;tej stronie to wniosek z&nbsp;realnych projektów.',
  limit,
  sectionIndex = 'S/06',
} = Astro.props;

const ORDER = ['tomasz-czechowski', 'michal-ziach', 'piotr-wicenciak', 'mateusz-wisniewski'];

const allAuthors = await getCollection('authors');
const authors = ORDER.map((slug) => allAuthors.find((a) => a.id === slug)).filter(
  (a): a is NonNullable<typeof a> => Boolean(a)
);
const visibleAuthors = typeof limit === 'number' ? authors.slice(0, limit) : authors;

const initialsOf = (name: string) =>
  name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();
---

<section class="team-section" id="zespol" aria-labelledby="team-title">
  <div class="container">
    <header class="section-head">
      <div class="head-left">
        <div class="head-meta">
          <span class="section-index">{sectionIndex}</span>
          <span class="eyebrow">{eyebrow}</span>
        </div>
        <h2 id="team-title" class="display-lg" set:html={title} />
      </div>
      <div class="head-right">
        <p class="subhead" set:html={subtitle} />
      </div>
    </header>

    <div class="team-grid">
      {
        visibleAuthors.map((author) => {
          const data = author.data;
          const slug = author.id;
          const initials = initialsOf(data.name);
          return (
            <article class="team-card" data-author={slug}>
              <div class="team-photo">
                {data.photo ? (
                  <img
                    src={data.photo}
                    alt={`${data.name} – ${data.role}`}
                    class="team-photo-img"
                    loading="lazy"
                    decoding="async"
                    width="320"
                    height="320"
                  />
                ) : (
                  <>
                    <span class="placeholder-tag">photo</span>
                    <span class="team-avatar-glyph">{initials}</span>
                  </>
                )}
              </div>

              <div class="team-meta-top">
                <h3 class="team-name">
                  <a href={`/autor/${slug}`} aria-label={`Pełny profil: ${data.name}`}>
                    {data.name}
                  </a>
                </h3>
                <div class="team-role">{data.role}</div>
              </div>

              {data.shortBio && <p class="team-bio">{data.shortBio}</p>}

              <div class="team-links">
                {data.linkedin && (
                  <a
                    href={data.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="team-chip"
                    aria-label={`LinkedIn – ${data.name}`}
                  >
                    LinkedIn ↗
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .team-section {
    padding: 96px 0;
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline-soft);
  }

  @media (min-width: 980px) {
    .team-section {
      padding: 120px 0;
    }
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 580px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 980px) {
    .team-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .team-card {
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xl);
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 490px;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .team-card:hover {
    background: var(--bg-surface-2);
    border-color: var(--hairline);
    transform: translateY(-2px);
  }

  .team-photo {
    aspect-ratio: 1 / 1;
    background:
      repeating-linear-gradient(45deg, var(--hairline-soft) 0 8px, transparent 8px 16px),
      var(--bg-surface-2);
    border-radius: calc(var(--r-xl) - 6px);
    position: relative;
    overflow: hidden;
    border: 1px solid var(--hairline-soft);
    isolation: isolate;
  }

  .team-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      inset 0 -32px 48px rgba(0, 0, 0, 0.1);
  }

  .team-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 24%;
    display: block;
    transform: scale(1.01);
    transition: transform 0.25s ease;
  }

  .team-card:hover .team-photo-img {
    transform: scale(1.035);
  }

  .team-card[data-author='tomasz-czechowski'] .team-photo-img {
    object-position: center 28%;
  }

  .team-card[data-author='michal-ziach'] .team-photo-img {
    object-position: center 24%;
  }

  .team-card[data-author='piotr-wicenciak'] .team-photo-img {
    object-position: center 18%;
  }

  .team-card[data-author='mateusz-wisniewski'] .team-photo-img {
    object-position: center 22%;
  }

  .placeholder-tag {
    position: absolute;
    top: 8px;
    left: 8px;
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .team-avatar-glyph {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 500;
    letter-spacing: -0.04em;
    color: color-mix(in srgb, var(--ink) 12%, transparent);
    line-height: 1;
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }

  .team-meta-top {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .team-name {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0;
  }

  .team-name a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .team-name a:hover {
    opacity: 0.85;
  }

  .team-role {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--accent-blue);
    letter-spacing: -0.12px;
    font-weight: 500;
  }

  .team-bio {
    font-family: var(--font-sans);
    font-size: 14px;
    color: color-mix(in srgb, var(--ink-muted) 92%, var(--ink));
    line-height: 1.48;
    margin: 0;
    flex: 1;
  }

  .team-links {
    display: flex;
    gap: 6px;
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid var(--hairline-soft);
  }

  .team-chip {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--ink-muted);
    padding: 4px 10px;
    border-radius: var(--r-pill);
    background: var(--bg-canvas);
    border: 1px solid var(--hairline-soft);
    letter-spacing: 0.02em;
    text-decoration: none;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .team-chip:hover {
    color: var(--ink);
    border-color: var(--hairline);
  }
</style>
