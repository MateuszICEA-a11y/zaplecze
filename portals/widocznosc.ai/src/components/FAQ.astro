---
/**
 * FAQ – landing redesign 2026-05-09 (handoff).
 * Section-head editorial 5fr/4fr + max-width 820px accordion.
 * Single-row-open behavior via JS – click to toggle.
 * + (plus) toggle rotuje 45° na open, surface-1 → surface-2.
 */

import { homepageFaq as items } from '../data/homepageFaq';
---

<section class="faq-section" id="faq" aria-labelledby="faq-title">
  <div class="container">
    <header class="section-head">
      <div class="head-left">
        <div class="head-meta">
          <span class="section-index">S/08</span>
          <span class="eyebrow">FAQ</span>
        </div>
        <h2 id="faq-title" class="display-xl">Najczęstsze pytania</h2>
      </div>
      <div class="head-right">
        <p class="subhead">
          Pięć pytań, które słyszymy od&nbsp;klientów najczęściej. Konkretne odpowiedzi, bez
          korpomowy.
        </p>
      </div>
    </header>

    <div class="faq-list">
      {
        items.map((item, i) => (
          <details class="faq-row" open={i === 0}>
            <summary class="faq-row-head">
              <h3 class="faq-q">
                <Fragment set:html={item.q} />
              </h3>
              <span class="faq-toggle" aria-hidden="true">
                +
              </span>
            </summary>
            <div class="faq-a">
              <Fragment set:html={item.a} />
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Single-row-open: gdy user otwiera details, zamyka pozostałe
  const initFaq = () => {
    const rows = document.querySelectorAll<HTMLDetailsElement>('.faq-row');
    rows.forEach((row) => {
      row.addEventListener('toggle', () => {
        if (row.open) {
          rows.forEach((other) => {
            if (other !== row) other.open = false;
          });
        }
      });
    });
  };
  document.addEventListener('astro:page-load', initFaq);
</script>

<style>
  .faq-section {
    padding: 80px 0;
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline-soft);
  }

  @media (min-width: 980px) {
    .faq-section {
      padding: 104px 0;
    }
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    max-width: 820px;
  }

  .faq-row {
    border-top: 1px solid var(--hairline-soft);
    padding: 22px 0;
  }

  .faq-row:last-child {
    border-bottom: 1px solid var(--hairline-soft);
  }

  .faq-row-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    cursor: pointer;
    list-style: none;
    transition: opacity 0.15s ease;
  }

  .faq-row-head::-webkit-details-marker {
    display: none;
  }
  .faq-row-head::marker {
    display: none;
  }
  .faq-row-head:hover {
    opacity: 0.85;
  }

  .faq-section .faq-list .faq-q {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--ink);
    margin: 0;
  }

  @media (min-width: 980px) {
    .faq-section .faq-list .faq-q {
      font-size: 18px;
    }
  }

  .faq-toggle {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--bg-surface-1);
    display: grid;
    place-items: center;
    flex-shrink: 0;
    font-size: 14px;
    font-weight: 400;
    line-height: 1;
    color: var(--ink-muted);
    transition:
      transform 0.2s ease,
      background 0.18s ease,
      color 0.18s ease;
  }

  .faq-row[open] .faq-toggle {
    transform: rotate(45deg);
    background: var(--bg-surface-2);
    color: var(--ink);
  }

  .faq-a {
    padding-top: 14px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.6;
  }

  .faq-a strong {
    color: var(--ink);
    font-weight: 500;
  }
</style>
