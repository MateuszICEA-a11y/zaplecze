---
const aiEngines = ['ChatGPT', 'Claude', 'Gemini', 'Perplexity', 'Bing Copilot'];
---

<section
  class="hero-mesh relative flex w-full items-center justify-center overflow-hidden pb-32 md:pb-40 lg:pb-48"
  style="background: var(--bg);"
  id="home"
>
  <div
    class="flex w-full flex-col items-center justify-center pt-32 text-center md:w-[58rem] md:pt-40 lg:pt-44 xl:w-[64rem]"
  >
    <!-- Eyebrow chip – meta info na żywo -->
    <div class="hero-fade-in" style="--delay: 0s">
      <span class="chip mt-12 mb-8" aria-label="Generative Engine Optimization – pozycjonowanie w wyszukiwarkach AI">
        <span class="chip-dot" aria-hidden="true"></span>
        GEO · pozycjonowanie w AI
      </span>
    </div>

    <!-- H1 – display, Inter Tight z aggressive tracking -->
    <div class="hero-fade-in mx-auto max-w-4xl px-4" style="--delay: 0.05s">
      <h1
        class="text-ink font-display text-[2.5rem] leading-[1] font-semibold tracking-[-0.04em] sm:text-[3.5rem] md:text-[4.5rem] lg:text-[5rem] xl:text-[5.5rem]"
      >
        Bądź widoczny tam,
        <br />
        gdzie pytają <span class="text-accent">AI</span>.
      </h1>
    </div>

    <!-- Lede – pozycjonowanie marki w 5 wyszukiwarkach AI -->
    <div class="hero-fade-in" style="--delay: 0.1s">
      <p
        class="text-ink-soft mx-auto mt-8 max-w-2xl px-4 text-base leading-relaxed sm:text-lg"
      >
        Pozycjonujemy marki w&nbsp;ChatGPT, Claude, Gemini i&nbsp;Perplexity. Mierzymy widoczność,
        cytowania i&nbsp;pokrycie tematyczne &ndash; nie tylko ranking.
      </p>
    </div>

    <!-- CTAs -->
    <div class="hero-fade-in" style="--delay: 0.15s">
      <div class="mt-10 mb-16 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a class="btn-primary" href="/kontakt" aria-label="Zamów audyt widoczności AI">
          Zamów audyt
        </a>
        <a class="btn-ghost" href="/narzedzia" aria-label="Sprawdź widoczność swojej marki w 90 sekund">
          Sprawdź widoczność &middot; 90s
        </a>
      </div>
    </div>

    <!-- Lista 5 silników AI – mono, subtle, sygnalizuje pokrycie -->
    <div class="hero-fade-in mt-12 px-4" style="--delay: 0.2s">
      <div class="text-ink-mute mb-4 font-mono text-[11px] tracking-[0.2em] uppercase">
        Mierzymy w 5 wyszukiwarkach AI
      </div>
      <div
        class="text-ink-soft flex flex-wrap items-center justify-center gap-x-6 gap-y-2 font-mono text-sm"
      >
        {
          aiEngines.map((engine, i) => (
            <>
              <span class="hover:text-accent transition">{engine}</span>
              {i < aiEngines.length - 1 && <span class="text-ink-mute" aria-hidden="true">·</span>}
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero-fade-in {
    opacity: 0;
    transform: translateY(10px);
    animation: heroFadeIn 0.5s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hero mesh background – orange-only (handoff B Structural).
     Trzy radials z różną intensywnością i positioning dla głębi. */
  .hero-mesh::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(at 15% 20%, rgb(255 106 46 / 0.22) 0%, transparent 55%),
      radial-gradient(at 85% 75%, rgb(255 106 46 / 0.18) 0%, transparent 55%),
      radial-gradient(at 60% 90%, rgb(255 138 79 / 0.12) 0%, transparent 45%);
    z-index: 0;
  }

  .hero-mesh > * {
    position: relative;
    z-index: 1;
  }
</style>
