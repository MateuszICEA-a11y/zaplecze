---
const aiEngines = [
  { name: 'ChatGPT', color: '#10a37f' },
  { name: 'Claude', color: '#d97757' },
  { name: 'Gemini', color: '#4285f4' },
  { name: 'Perplexity', color: '#20b8cd' },
  { name: 'Copilot', color: '#0078d4' },
];
---

<section class="hero-section" id="home">
  <div class="hero-container">

    <!-- Hero grid – 2-col: copy 7 / spotlight 5 -->
    <div class="hero-grid">

      <!-- LEFT: copy stack – display-xxl headline + body-lg subhead + 2 pill CTAs -->
      <div class="hero-copy">

        <div class="hero-fade-in" style="--delay: 0s">
          <span class="eyebrow">Generative Engine Optimization</span>
        </div>

        <div class="hero-fade-in" style="--delay: 0.05s">
          <h1 class="hero-headline">
            Sprawdź, co ChatGPT, Claude, Gemini i&nbsp;Perplexity mówią o&nbsp;<span class="accent">Twojej marce</span>.
          </h1>
        </div>

        <div class="hero-fade-in" style="--delay: 0.1s">
          <p class="hero-subhead">
            Sprawdź już teraz, czy AI poleca Twoją markę, czy boty AI mają dostęp
            do&nbsp;Twojej strony i&nbsp;jak zoptymalizować swój content, aby był cytowany
            przez wyszukiwarki AI.
          </p>
        </div>

        <div class="hero-fade-in hero-ctas" style="--delay: 0.15s">
          <a class="btn-primary" href="#audyty" aria-label="Uruchom darmowe testy widoczności AI">
            Uruchom darmowe testy
          </a>
          <a class="btn-secondary" href="/kontakt?type=full-report" aria-label="Zamów pełny raport GEO">
            Zamów pełny raport
          </a>
        </div>

      </div>

      <!-- RIGHT: violet gradient spotlight – edukacyjny GEO content (czym jest, dlaczego warto) -->
      <div class="hero-fade-in hero-spotlight-wrap" style="--delay: 0.2s" aria-hidden="false">
        <article class="card-spotlight card-spotlight-linear">
          <span class="hero-spotlight-eyebrow">Ewolucja SEO</span>
          <p class="hero-spotlight-quote">
            Wyszukiwarki AI generują odpowiedzi, nie listy linków. TOP&nbsp;1 w&nbsp;Google
            nie wystarczy – marki, których ChatGPT, Claude czy Perplexity nie cytują,
            są niewidoczne w&nbsp;decyzji zakupowej klienta.
          </p>
          <ul class="hero-spotlight-points">
            <li>Cytowania zamiast pozycji w&nbsp;rankingu</li>
            <li>Rozszerzamy klasyczne SEO o&nbsp;budowanie obecności w&nbsp;AI</li>
          </ul>
        </article>
      </div>

    </div>

    <!-- Logo wall pod heroem – tekst + brand kropka, lekki pattern -->
    <div class="hero-fade-in hero-logowall" style="--delay: 0.25s">
      <p class="eyebrow hero-logowall-label">
        Audytujemy widoczność w&nbsp;silnikach AI
      </p>
      <div class="hero-logowall-row">
        {
          aiEngines.map((engine) => (
            <span class="hero-logowall-engine">
              <span class="hero-logowall-dot" style={`background: ${engine.color};`} aria-hidden="true" />
              {engine.name}
            </span>
          ))
        }
      </div>
    </div>

  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    background: var(--bg-canvas);
    padding-bottom: 96px;
  }

  .hero-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 96px 30px 0 30px;
  }

  @media (min-width: 1024px) {
    .hero-container {
      padding: 128px 40px 0 40px;
    }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 7fr 5fr;
      gap: 60px;
    }
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  /* Display headline – Mona Sans, sygnatura Framer.
     Hierarchia: h1 hero >> h2 sekcji (display-lg max 62px).
     Mobile/tablet: clamp do 64px. Desktop 1280+: 80px. */
  .hero-headline {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--ink);
    margin: 0;

    font-size: clamp(2rem, 5.5vw + 0.5rem, 4rem);
    line-height: 1;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  @media (min-width: 1280px) {
    .hero-headline {
      font-size: 5rem;
      letter-spacing: -0.05em;
    }
  }

  /* Subhead – kluczowy tekst body, biały. Stitch iteration: 18px → 20px na lg+ */
  .hero-subhead {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    font-weight: 400;
    line-height: 1.55;
    letter-spacing: -0.01em;
    color: var(--ink);
    max-width: 580px;
    margin: 0;
  }

  /* CTAs left-aligned, primary white pill + secondary charcoal pill */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  /* Spotlight card right column – Framer rygor: większy padding (luksus),
     mniejszy quote font (nie konkuruje z h1 lewym), Inter z OpenType. */
  .hero-spotlight-wrap {
    width: 100%;
    max-width: 520px;
    margin-inline: auto;
  }

  .card-spotlight {
    aspect-ratio: 4 / 5;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 440px;
    padding: 40px 36px;
  }

  @media (min-width: 768px) {
    .card-spotlight {
      padding: 56px 48px;
    }
  }

  .hero-spotlight-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: rgba(255, 255, 255, 0.7);
  }

  /* Quote: Inter (nie Mona Sans) – nie konkuruje typograficznie z h1 poster.
     Subhead size 22px (do 24 lg+), line-height 1.30 plakatowy ciasny.
     OpenType cv01/cv05/cv09/cv11/ss03/ss07/dlig dla cyfr i małych liter. */
  .hero-spotlight-quote {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1.125rem, 1.7vw, 1.5rem);
    line-height: 1.30;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 32px 0 0 0;
    text-wrap: balance;
    font-feature-settings:
      'cv01' 1,
      'cv05' 1,
      'cv09' 1,
      'cv11' 1,
      'ss03' 1,
      'ss07' 1,
      'dlig' 1;
  }

  /* Bottom 2 punkty kluczowe – zamiast cena/dni dostawy */
  .hero-spotlight-points {
    list-style: none;
    padding: 0;
    margin: 16px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    padding-top: 16px;
  }

  .hero-spotlight-points li {
    position: relative;
    padding-left: 16px;
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    line-height: 1.30;
    letter-spacing: var(--ls-body-sm);
    color: rgba(255, 255, 255, 0.85);
  }

  .hero-spotlight-points li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: var(--ink);
  }

  /* Logo wall */
  .hero-logowall {
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid var(--hairline-soft);
  }

  .hero-logowall-label {
    text-align: center;
    margin-bottom: 24px;
  }

  /* Logo wall: lekki pattern – nazwa silnika + brand-color kropka.
     Lżejszy niż białe tile'y z PNG, lepsza kompresja informacji,
     łatwiej rozszerzyć o kolejne modele. */
  .hero-logowall-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 20px 36px;
  }

  @media (min-width: 1024px) {
    .hero-logowall-row {
      gap: 20px 56px;
    }
  }

  .hero-logowall-engine {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.125rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1;
    transition: opacity 0.15s ease;
  }

  @media (min-width: 1024px) {
    .hero-logowall-engine {
      font-size: 1.25rem;
    }
  }

  .hero-logowall-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--r-pill);
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .hero-logowall-engine {
      font-size: 1.75rem;
    }
  }

  /* Fade-in animation */
  .hero-fade-in {
    opacity: 0;
    transform: translateY(10px);
    animation: heroFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    animation-delay: var(--delay);
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade-in {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
