---
const aiEngines = ['ChatGPT', 'Claude', 'Gemini', 'Perplexity', 'Copilot'];
---

<section class="hero-section" id="home">
  <div class="hero-container">

    <!-- Hero grid – 2-col: copy 7 / spotlight 5 -->
    <div class="hero-grid">

      <!-- LEFT: copy stack – display-xxl headline + body-lg subhead + 2 pill CTAs -->
      <div class="hero-copy">

        <div class="hero-fade-in" style="--delay: 0s">
          <span class="eyebrow">Generative Engine Optimization</span>
        </div>

        <div class="hero-fade-in" style="--delay: 0.05s">
          <h1 class="hero-headline">
            Sprawdź, co ChatGPT, Claude, Gemini i&nbsp;Perplexity mówią o&nbsp;<span class="accent">Twojej marce</span>.
          </h1>
        </div>

        <div class="hero-fade-in" style="--delay: 0.1s">
          <p class="hero-subhead">
            Sprawdź już teraz, czy AI poleca Twoją markę, czy boty AI mają dostęp
            do&nbsp;Twojej strony i&nbsp;jak zoptymalizować swój content, aby był cytowany
            przez wyszukiwarki AI.
          </p>
        </div>

        <div class="hero-fade-in hero-ctas" style="--delay: 0.15s">
          <a class="btn-primary" href="#audyty" aria-label="Uruchom darmowe testy widoczności AI">
            Uruchom darmowe testy
          </a>
          <a class="btn-secondary" href="/kontakt?type=full-audit" aria-label="Zamów pełny audyt widoczności AI">
            Zamów pełny audyt
          </a>
        </div>

      </div>

      <!-- RIGHT: violet gradient spotlight – Stitch linear 2-stop + box-shadow -->
      <div class="hero-fade-in hero-spotlight-wrap" style="--delay: 0.2s" aria-hidden="false">
        <article class="card-spotlight card-spotlight-linear">
          <span class="hero-spotlight-eyebrow">5 silników AI</span>
          <p class="hero-spotlight-quote">
            "Jeden raport, pięć perspektyw. Zobacz, jak ChatGPT, Claude, Gemini, Perplexity
            i&nbsp;Bing Copilot odpowiadają o&nbsp;Twojej marce – w&nbsp;3 dni."
          </p>
          <div class="hero-spotlight-meta">
            <span>Audyt 6 900 PLN</span>
            <span aria-hidden="true">·</span>
            <span>3 dni delivery</span>
          </div>
        </article>
      </div>

    </div>

    <!-- Logo wall pod heroem – pełna szerokość, hairline separator -->
    <div class="hero-fade-in hero-logowall" style="--delay: 0.25s">
      <p class="eyebrow hero-logowall-label">
        Sprawdzamy w najpopularniejszych wyszukiwarkach AI
      </p>
      <div class="hero-logowall-row">
        {
          aiEngines.map((engine) => (
            <span class="hero-logowall-engine">{engine}</span>
          ))
        }
      </div>
    </div>

  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    background: var(--bg-canvas);
    padding-bottom: 96px;
  }

  .hero-container {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding: 96px 30px 0 30px;
  }

  @media (min-width: 1024px) {
    .hero-container {
      padding: 128px 40px 0 40px;
    }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 7fr 5fr;
      gap: 60px;
    }
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  /* Display headline – Mona Sans 110px / -5.5px sygnatura Framer */
  .hero-headline {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--ink);
    margin: 0;

    /* Desktop XL = display-lg 62px (po 2-col layout, 110px tylko full-bleed) */
    font-size: clamp(2rem, 5vw + 0.5rem, 3.875rem);
    line-height: 1;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  @media (min-width: 1280px) {
    .hero-headline {
      font-size: 4.25rem;
      letter-spacing: -3.4px;
    }
  }

  /* Subhead – kluczowy tekst body, biały. Stitch iteration: 18px → 20px na lg+ */
  .hero-subhead {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    font-weight: 400;
    line-height: 1.55;
    letter-spacing: -0.01em;
    color: var(--ink);
    max-width: 580px;
    margin: 0;
  }

  /* CTAs left-aligned, primary white pill + secondary charcoal pill */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  /* Spotlight card right column – Stitch iteration: szerszy padding, większe min-h */
  .hero-spotlight-wrap {
    width: 100%;
    max-width: 520px;
    margin-inline: auto;
  }

  .card-spotlight {
    aspect-ratio: 4 / 5;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 420px;
    padding: 40px 40px 36px;
  }

  @media (min-width: 768px) {
    .card-spotlight {
      padding: 48px 48px 44px;
    }
  }

  .hero-spotlight-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: rgba(255, 255, 255, 0.7);
  }

  .hero-spotlight-quote {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.5rem, 2.4vw, 1.875rem);
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 24px 0 0 0;
    text-wrap: balance;
  }

  .hero-spotlight-meta {
    display: flex;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    color: rgba(255, 255, 255, 0.7);
    margin-top: 16px;
  }

  /* Logo wall */
  .hero-logowall {
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid var(--hairline-soft);
  }

  .hero-logowall-label {
    text-align: center;
    margin-bottom: 24px;
  }

  /* Stitch iteration: cała grupa logos opacity 60% + grayscale,
     hover na grupę = full color (grayscale-0). Zachowanie marketing
     "te brandy nas testują/sprawdzamy je" implikatywne. */
  .hero-logowall-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 24px 48px;
    opacity: 0.6;
    filter: grayscale(1);
    transition:
      opacity 0.5s ease,
      filter 0.5s ease;
  }

  .hero-logowall-row:hover {
    opacity: 1;
    filter: grayscale(0);
  }

  @media (min-width: 1024px) {
    .hero-logowall-row {
      gap: 24px 64px;
    }
  }

  .hero-logowall-engine {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1;
  }

  @media (min-width: 1024px) {
    .hero-logowall-engine {
      font-size: 1.75rem;
    }
  }

  /* Fade-in animation */
  .hero-fade-in {
    opacity: 0;
    transform: translateY(10px);
    animation: heroFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    animation-delay: var(--delay);
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade-in {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
