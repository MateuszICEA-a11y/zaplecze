---
/**
 * CTABand / Final CTA – landing redesign 2026-05-09 (handoff).
 * Full-width surface-1 card, radius xxl 30, padding 80x64.
 * Decorative violet glow orb top-right (480x480, blur 80px, opacity 0.35).
 * 2-col grid 1.5fr/1fr: lewy CTA + meta row, prawy testimonial-style quote.
 */

interface Props {
  eyebrow?: string;
  title?: string;
  titleHtml?: string;
  subtitle?: string;
  primaryLabel?: string;
  primaryHref?: string;
  ghostLabel?: string;
  ghostHref?: string;
  rightLabel?: string;
  quote?: string;
  author?: string;
  meta?: string[];
  compactTop?: boolean;
}

const {
  eyebrow = 'Następny krok',
  title,
  titleHtml = 'Sprawdź, jak Twoja marka radzi sobie w&nbsp;<span class="accent">AI search</span>.',
  subtitle = 'Bezpłatna konsultacja 30 minut. Bez sprzedaży, bez zobowiązań &ndash; pokazujemy gdzie marka jest cytowana, gdzie traci do&nbsp;konkurencji i&nbsp;co realnie zmienić.',
  primaryLabel = 'Zamów audyt AI',
  primaryHref = '/kontakt/',
  ghostLabel = 'Bezpłatna konsultacja',
  ghostHref = '/kontakt/?type=konsultacja',
  rightLabel = 'Co dostajesz na rozmowie',
  quote = '„Pokazujemy, gdzie Twoja marka jest cytowana, gdzie traci do&nbsp;konkurencji i&nbsp;co konkretnie zmienić w&nbsp;pierwszej kolejności."',
  author = '&ndash; zespół widocznosc.ai',
  meta = ['30 minut', 'Bez zobowiązań', 'Konkretny plan'],
  compactTop = false,
} = Astro.props;
---

<section
  class:list={['final-cta-section', { 'final-cta-section--compact-top': compactTop }]}
  id="cta"
  aria-labelledby="final-cta-title"
>
  <div class="container">
    <div class="final-cta-card">
      <div class="final-cta-left">
        <span class="eyebrow">{eyebrow}</span>
        <h2 id="final-cta-title" class="display-xl">
          {title ? title : <Fragment set:html={titleHtml} />}
        </h2>
        <p class="subhead final-cta-sub" set:html={subtitle} />
        <div class="final-cta-actions">
          <a class="btn-primary" href={primaryHref} aria-label={primaryLabel}>
            {primaryLabel}
            <span aria-hidden="true">→</span>
          </a>
          <a class="btn-secondary" href={ghostHref} aria-label={ghostLabel}>
            {ghostLabel}
          </a>
        </div>
        <p class="final-cta-meta">
          {meta.map((item) => <span>{item}</span>)}
        </p>
      </div>

      <aside class="final-cta-right">
        <span class="final-cta-label">{rightLabel}</span>
        <p class="final-cta-quote" set:html={quote} />
        <span class="final-cta-author" set:html={author} />
      </aside>
    </div>
  </div>
</section>

<style>
  .final-cta-section {
    padding: 80px 0;
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline-soft);
  }

  @media (min-width: 980px) {
    .final-cta-section {
      padding: 104px 0;
    }
  }

  .final-cta-section--compact-top {
    padding-top: 40px;
  }

  @media (min-width: 980px) {
    .final-cta-section--compact-top {
      padding-top: 56px;
    }
  }

  .final-cta-card {
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-xxl);
    padding: 48px 32px;
    display: grid;
    grid-template-columns: 1fr;
    align-items: end;
    gap: 48px;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 980px) {
    .final-cta-card {
      grid-template-columns: 1.5fr 1fr;
      padding: 80px 64px;
    }
  }

  /* Decorative violet glow orb (top-right) */
  .final-cta-card::before {
    content: '';
    position: absolute;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    right: -120px;
    top: -120px;
    background: var(--grad-violet);
    filter: blur(80px);
    opacity: 0.35;
    pointer-events: none;
  }

  .final-cta-card > * {
    position: relative;
    z-index: 1;
  }

  /* Light mode – violet orb mocniej osłabiony żeby nie krzyczał na ivory */
  :root[data-theme='light'] .final-cta-card::before {
    opacity: 0.22;
  }

  .final-cta-left {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 580px;
  }

  .final-cta-sub {
    color: var(--ink);
    max-width: 520px;
  }

  .final-cta-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .final-cta-meta {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin: 0;
  }

  .final-cta-meta span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .final-cta-meta span::before {
    content: '·';
    color: var(--ink-faint);
  }

  .final-cta-meta span:first-child::before {
    display: none;
  }

  /* Right column – testimonial */
  .final-cta-right {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-muted);
  }

  .final-cta-label {
    font-family: var(--font-sans);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }

  .final-cta-quote {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: -0.025em;
    line-height: 1.2;
    color: var(--ink);
    font-weight: 500;
    margin: 0;
    text-wrap: balance;
  }

  .final-cta-author {
    font-size: 12px;
    color: var(--ink-faint);
    margin-top: 8px;
  }
</style>
