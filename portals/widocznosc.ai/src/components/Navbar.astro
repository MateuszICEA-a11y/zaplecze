---
import ThemeToggle from './ThemeToggle.astro';

type NavItem = {
  label: string;
  href: string;
  desc?: string;
};

type NavGroup = {
  label: string;
  href: string;
  items?: { heading?: string; links: NavItem[] }[];
};

const navbarLinks: NavGroup[] = [
  {
    label: 'Pozycjonowanie AI',
    href: '/pozycjonowanie-ai',
    items: [
      {
        heading: 'Modele AI',
        links: [
          { label: 'ChatGPT', desc: 'OpenAI · ~250 mln użytk./tyg.', href: '/pozycjonowanie-ai/chatgpt' },
          { label: 'Claude', desc: 'Anthropic · zastosowania B2B', href: '/pozycjonowanie-ai/claude' },
          { label: 'Gemini', desc: 'Google · zasila AI Overviews', href: '/pozycjonowanie-ai/gemini' },
          { label: 'Perplexity', desc: 'Wyszukiwarka oparta na cytowaniach', href: '/pozycjonowanie-ai/perplexity' },
          { label: 'Bing Copilot', desc: 'Microsoft · Edge i Windows', href: '/pozycjonowanie-ai/bing-copilot' },
        ],
      },
      {
        heading: 'Metodologia',
        links: [
          { label: 'Audyt widoczności', desc: 'Pełny przegląd 5 silników AI', href: '/pozycjonowanie-ai#audyt' },
          { label: 'Optymalizacja treści', desc: 'Treści pisane pod LLM', href: '/pozycjonowanie-ai#content' },
          { label: 'Monitoring cytowań', desc: 'Stałe śledzenie wzmianek', href: '/pozycjonowanie-ai#monitoring' },
          { label: 'Strategia GEO', desc: 'Plan działania na rok', href: '/pozycjonowanie-ai#strategia' },
        ],
      },
    ],
  },
  { label: 'Baza wiedzy', href: '/blog' },
  { label: 'Narzędzia', href: '/narzedzia' },
  { label: 'O nas', href: '/o-nas' },
  { label: 'Kontakt', href: '/kontakt' },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href.startsWith('/#')) return false;
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<nav class="nav-shell" id="main-nav" aria-label="Główna nawigacja">
  <div class="container nav-inner">

    <!-- Logo: 22px gradient mark + wordmark "widocznosc.ai" (accent na .ai) -->
    <a href="/" aria-label="widocznosc.ai – strona główna" class="nav-logo">
      <span class="nav-logo-mark" aria-hidden="true"></span>
      <span class="nav-logo-text">widocznosc<span class="accent">.ai</span></span>
    </a>

    <!-- Nav links (desktop, lg+) -->
    <div class="nav-links">
      {
        navbarLinks.map((group) => {
          const active = isActive(group.href);
          if (!group.items) {
            return (
              <a
                class={`nav-link${active ? ' nav-link--active' : ''}`}
                href={group.href}
                {...(active ? { 'aria-current': 'page' } : {})}
              >
                {group.label}
              </a>
            );
          }
          return (
            <div class="group relative nav-link-wrap">
              <a
                href={group.href}
                class={`nav-link nav-link--has-menu${active ? ' nav-link--active' : ''}`}
                aria-haspopup="true"
                aria-expanded="false"
                {...(active ? { 'aria-current': 'page' } : {})}
              >
                <span>{group.label}</span>
                <svg
                  class="nav-link-chev"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  width="10"
                  height="10"
                >
                  <polyline points="6,9 12,15 18,9"></polyline>
                </svg>
              </a>
              <div class="nav-dropdown" role="menu">
                <div class="nav-dropdown-grid">
                  {group.items.map((col) => (
                    <div>
                      {col.heading && <div class="nav-dropdown-heading">{col.heading}</div>}
                      <ul class="nav-dropdown-list">
                        {col.links.map((link) => (
                          <li>
                            <a href={link.href} class="nav-dropdown-link" role="menuitem">
                              <div class="nav-dropdown-link-label">{link.label}</div>
                              {link.desc && <div class="nav-dropdown-link-desc">{link.desc}</div>}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
                <div class="nav-dropdown-footer">
                  <a href={group.href} class="nav-dropdown-footer-link">
                    Zobacz wszystkie usługi
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>

    <!-- CTA right: theme toggle + primary CTA -->
    <div class="nav-cta">
      <ThemeToggle />
      <a class="btn-primary nav-cta-btn" href="/narzedzia" aria-label="Uruchom darmowy test widoczności AI">
        Uruchom test za darmo
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      class="nav-mobile-toggle"
      id="mobile-menu-toggle"
      aria-label="Otwórz menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>

  <!-- Mobile overlay -->
  <div class="nav-mobile-overlay hidden" id="mobile-menu-overlay"></div>

  <!-- Mobile menu – flat list -->
  <div class="nav-mobile-menu hidden" id="mobile-menu">
    {
      navbarLinks.map((group) => {
        if (!group.items) {
          return (
            <a class="nav-mobile-link" href={group.href}>
              {group.label}
            </a>
          );
        }
        return (
          <div class="nav-mobile-group">
            <a href={group.href} class="nav-mobile-link nav-mobile-link--group">
              {group.label}
            </a>
            <div class="nav-mobile-sub">
              {group.items.map((col) =>
                col.links.map((link) => (
                  <a href={link.href} class="nav-mobile-link nav-mobile-link--sub">
                    {link.label}
                  </a>
                ))
              )}
            </div>
          </div>
        );
      })
    }
    <div class="nav-mobile-theme-row">
      <span class="nav-mobile-theme-label">Motyw</span>
      <ThemeToggle />
    </div>
    <a class="btn-primary nav-mobile-cta" href="/narzedzia">
      Uruchom test za darmo
    </a>
  </div>
</nav>

<script>
  const initNavbar = () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');
    const nav = document.getElementById('main-nav');

    const updateNavBackground = () => {
      if (!nav) return;
      nav.dataset.scrolled = window.scrollY > 16 ? 'true' : 'false';
    };

    updateNavBackground();
    window.addEventListener('scroll', updateNavBackground, { passive: true });

    const openMenu = () => {
      menu?.classList.remove('hidden');
      menu?.classList.add('is-open');
      overlay?.classList.remove('hidden');
      toggle?.setAttribute('aria-expanded', 'true');
    };
    const closeMenu = () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('is-open');
      overlay?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    };

    toggle?.addEventListener('click', () => {
      const isOpen = menu?.classList.contains('is-open');
      isOpen ? closeMenu() : openMenu();
    });
    overlay?.addEventListener('click', closeMenu);

    document.querySelectorAll('.nav-mobile-link').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu?.classList.contains('is-open')) {
        closeMenu();
        toggle?.focus();
      }
    });
  };

  document.addEventListener('astro:page-load', initNavbar);
</script>

<style is:global>
  /* ============================================================
     Navbar – landing redesign 2026-05-09 (handoff)
     64px height, blurred canvas, gradient logo mark
     ============================================================ */

  .nav-shell {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg-canvas) 78%, transparent);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border-bottom: 1px solid var(--hairline-soft);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .nav-shell[data-scrolled='true'] {
    background: color-mix(in srgb, var(--bg-canvas) 92%, transparent);
    border-bottom-color: var(--hairline);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 24px;
  }

  /* Logo – gradient mark + wordmark */
  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
    text-decoration: none;
  }

  .nav-logo-mark {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 30%,
      var(--accent-blue),
      color-mix(in srgb, var(--accent-blue) 30%, #000) 75%
    );
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.10);
    flex-shrink: 0;
  }

  .nav-logo-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
  }

  .nav-logo-text .accent {
    color: var(--accent-blue);
  }

  /* Nav links (desktop) */
  .nav-links {
    display: none;
    gap: 2px;
    font-size: 14px;
  }

  @media (min-width: 980px) {
    .nav-links { display: flex; align-items: center; }
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 14px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.14px;
    line-height: 1;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.18s ease, background 0.18s ease;
    white-space: nowrap;
    border-radius: var(--r-pill);
  }

  .nav-link:hover {
    color: var(--ink);
    background: var(--pill-translucent);
  }

  .nav-link--active { color: var(--ink); }

  .nav-link-chev {
    color: currentColor;
    opacity: 0.6;
    transition: transform 0.2s ease, opacity 0.15s ease;
  }

  .nav-link-wrap:hover .nav-link-chev {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* Dropdown */
  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    width: 560px;
    margin-top: 8px;
    padding: 0;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-card);
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;
    z-index: 50;
  }

  .nav-link-wrap:hover .nav-dropdown,
  .nav-link-wrap:focus-within .nav-dropdown {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    padding: 20px;
  }

  .nav-dropdown-heading {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 8px;
    padding: 0 12px;
  }

  .nav-dropdown-list {
    display: flex;
    flex-direction: column;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-dropdown-link {
    display: block;
    padding: 8px 12px;
    border-radius: var(--r-md);
    transition: background 0.15s ease;
    text-decoration: none;
  }

  .nav-dropdown-link:hover { background: var(--bg-surface-2); }

  .nav-dropdown-link-label {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.14px;
    color: var(--ink);
    line-height: 1.3;
  }

  .nav-dropdown-link-desc {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: -0.12px;
    color: var(--ink-muted);
    line-height: 1.4;
    margin-top: 2px;
  }

  .nav-dropdown-footer {
    border-top: 1px solid var(--hairline-soft);
    padding: 12px 20px;
  }

  .nav-dropdown-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: -0.12px;
    color: var(--accent-blue);
    text-decoration: none;
    transition: gap 0.15s ease;
  }

  .nav-dropdown-footer-link:hover { gap: 10px; }

  /* CTA cluster */
  .nav-cta {
    display: none;
    align-items: center;
    gap: 8px;
  }

  @media (min-width: 980px) {
    .nav-cta { display: inline-flex; }
  }

  .nav-cta-btn {
    /* slightly smaller pill in nav */
    min-height: 36px;
    padding: 8px 14px;
    font-size: 13px;
  }

  /* Mobile menu toggle */
  .nav-mobile-toggle {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: var(--r-sm);
  }

  @media (min-width: 980px) {
    .nav-mobile-toggle { display: none; }
  }

  .nav-mobile-toggle span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--ink);
    transition: background 0.15s ease;
  }

  /* Mobile overlay */
  .nav-mobile-overlay {
    position: fixed;
    inset: 64px 0 0 0;
    background: color-mix(in srgb, var(--bg-canvas) 60%, transparent);
    z-index: 38;
  }

  .nav-mobile-overlay.hidden { display: none; }

  /* Mobile menu */
  .nav-mobile-menu {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    max-height: calc(100vh - 64px);
    overflow-y: auto;
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline);
    padding: 20px 30px 40px 30px;
    z-index: 40;
  }

  .nav-mobile-menu.hidden { display: none; }

  .nav-mobile-menu.is-open {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  @media (min-width: 980px) {
    .nav-mobile-menu,
    .nav-mobile-overlay {
      display: none !important;
    }
  }

  .nav-mobile-link {
    display: block;
    padding: 12px 16px;
    border-radius: var(--r-md);
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.18px;
    color: var(--ink);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .nav-mobile-link:hover { background: var(--pill-translucent); }

  .nav-mobile-link--sub {
    font-size: 15px;
    color: var(--ink-muted);
    padding: 8px 16px 8px 32px;
  }

  .nav-mobile-link--sub:hover { color: var(--ink); }

  .nav-mobile-group { display: flex; flex-direction: column; }

  .nav-mobile-sub {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 1px solid var(--hairline);
    margin-left: 16px;
  }

  .nav-mobile-cta {
    margin-top: 16px;
    align-self: flex-start;
  }

  .nav-mobile-theme-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-radius: var(--r-md);
    margin-top: 8px;
  }

  .nav-mobile-theme-label {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
  }
</style>
