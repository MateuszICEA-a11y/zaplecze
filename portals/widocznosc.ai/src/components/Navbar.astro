---
import ThemeToggle from './ThemeToggle.astro';
import { getCollection } from 'astro:content';
import { BLOG_PILLARS, PILLAR_LABELS } from '../content.config';

type NavItem = {
  label: string;
  href: string;
};

type NavGroup = {
  label: string;
  href: string;
  items?: { heading?: string; links: NavItem[] }[];
};

const posts = await getCollection('blog');
const activePillars = BLOG_PILLARS.filter((p) => posts.some((post) => post.data.pillar === p));

const navbarLinks: NavGroup[] = [
  {
    label: 'Pozycjonowanie AI',
    href: '/pozycjonowanie-ai',
    items: [
      {
        heading: 'Modele',
        links: [
          { label: 'Pozycjonowanie ChatGPT', href: '/pozycjonowanie-ai/chatgpt' },
          { label: 'Pozycjonowanie Claude', href: '/pozycjonowanie-ai/claude' },
          { label: 'Pozycjonowanie Gemini', href: '/pozycjonowanie-ai/gemini' },
          { label: 'Pozycjonowanie Perplexity', href: '/pozycjonowanie-ai/perplexity' },
          { label: 'Pozycjonowanie Bing Copilot', href: '/pozycjonowanie-ai/bing-copilot' },
        ],
      },
    ],
  },
  {
    label: 'Baza wiedzy',
    href: '/blog',
    items: [
      {
        heading: 'Kategorie',
        links: activePillars.map((p) => ({
          label: PILLAR_LABELS[p],
          href: `/${p}/`,
        })),
      },
    ],
  },
  { label: 'Narzędzia', href: '/narzedzia' },
  { label: 'O nas', href: '/o-nas' },
  { label: 'Kontakt', href: '/kontakt' },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href.startsWith('/#')) return false;
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<nav class="nav-shell" id="main-nav" aria-label="Główna nawigacja">
  <div class="nav-inner container">
    <!-- Logo: aperture mark + wordmark "widocznosc.ai" (accent na .ai) -->
    <a href="/" aria-label="widocznosc.ai – strona główna" class="nav-logo">
      <span class="nav-logo-mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" focusable="false">
          <path
            d="M 24.49 7.51 A 12 12 0 1 0 24.49 24.49"
            stroke="currentColor"
            stroke-width="2.75"
            fill="none"
            stroke-linecap="round"></path>
          <circle cx="16" cy="16" r="5" stroke="var(--accent-blue)" stroke-width="1.75" fill="none"
          ></circle>
          <circle cx="16" cy="16" r="3" fill="var(--accent-blue)"></circle>
          <circle cx="16" cy="16" r="1" fill="var(--bg-canvas)"></circle>
        </svg>
      </span>
      <span class="nav-logo-text">widocznosc<span class="accent">.ai</span></span>
    </a>

    <!-- Nav links (desktop, lg+) -->
    <div class="nav-links">
      {
        navbarLinks.map((group) => {
          const active = isActive(group.href);
          if (!group.items) {
            return (
              <a
                class={`nav-link${active ? ' nav-link--active' : ''}`}
                href={group.href}
                {...(active ? { 'aria-current': 'page' } : {})}
              >
                {group.label}
              </a>
            );
          }
          return (
            <div class="group nav-link-wrap relative">
              <a
                href={group.href}
                class={`nav-link nav-link--has-menu${active ? ' nav-link--active' : ''}`}
                aria-haspopup="true"
                aria-expanded="false"
                {...(active ? { 'aria-current': 'page' } : {})}
              >
                <span>{group.label}</span>
                <svg
                  class="nav-link-chev"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  width="10"
                  height="10"
                >
                  <polyline points="6,9 12,15 18,9" />
                </svg>
              </a>
              <div
                class="nav-dropdown"
                role="menu"
                style={group.href === '/pozycjonowanie-ai' ? 'width: 320px;' : 'width: 280px;'}
              >
                <div
                  class={`nav-dropdown-grid${group.items.length === 1 ? ' nav-dropdown-grid--single' : ''}`}
                >
                  {group.items.map((col) => (
                    <div>
                      {col.heading && <div class="nav-dropdown-heading">{col.heading}</div>}
                      <ul class="nav-dropdown-list">
                        {col.links.map((link) => (
                          <li>
                            <a href={link.href} class="nav-dropdown-link" role="menuitem">
                              <div class="nav-dropdown-link-label">{link.label}</div>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
                <div class="nav-dropdown-footer">
                  <a href={group.href} class="nav-dropdown-footer-link">
                    {group.href === '/blog' ? 'Wszystkie artykuły' : 'Zobacz wszystkie usługi'}
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>

    <!-- CTA right: theme toggle + primary CTA -->
    <div class="nav-cta">
      <ThemeToggle />
      <a
        class="btn-primary nav-cta-btn"
        href="/narzedzia"
        aria-label="Uruchom darmowy test widoczności AI"
      >
        Uruchom test za darmo
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      class="nav-mobile-toggle"
      id="mobile-menu-toggle"
      aria-label="Otwórz menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>

  <!-- Mobile overlay -->
  <div class="nav-mobile-overlay hidden" id="mobile-menu-overlay"></div>

  <!-- Mobile menu – flat list -->
  <div class="nav-mobile-menu hidden" id="mobile-menu">
    {
      navbarLinks.map((group) => {
        if (!group.items) {
          return (
            <a class="nav-mobile-link" href={group.href}>
              {group.label}
            </a>
          );
        }
        return (
          <details class="nav-mobile-details">
            <summary class="nav-mobile-link nav-mobile-link--summary">
              <span>{group.label}</span>
              <span class="nav-mobile-chevron" aria-hidden="true" />
            </summary>
            <div class="nav-mobile-sub">
              <a
                href={group.href}
                class="nav-mobile-link nav-mobile-link--sub nav-mobile-link--overview"
              >
                {group.href === '/blog' ? 'Wszystkie artykuły' : 'Przegląd'}
              </a>
              {group.items.map((col) => (
                <div class="nav-mobile-subgroup">
                  {col.heading && <div class="nav-mobile-subheading">{col.heading}</div>}
                  {col.links.map((link) => (
                    <a href={link.href} class="nav-mobile-link nav-mobile-link--sub">
                      {link.label}
                    </a>
                  ))}
                </div>
              ))}
            </div>
          </details>
        );
      })
    }
    <div class="nav-mobile-theme-row">
      <span class="nav-mobile-theme-label">Motyw</span>
      <ThemeToggle />
    </div>
    <a class="btn-primary nav-mobile-cta" href="/narzedzia"> Uruchom test za darmo </a>
  </div>
</nav>

<script>
  const initNavbar = () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');
    const nav = document.getElementById('main-nav');
    const desktopMenuTriggers = document.querySelectorAll<HTMLElement>('.nav-link-wrap');

    const updateNavBackground = () => {
      if (!nav) return;
      nav.dataset.scrolled = window.scrollY > 16 ? 'true' : 'false';
    };

    updateNavBackground();
    window.addEventListener('scroll', updateNavBackground, { passive: true });

    const openMenu = () => {
      menu?.classList.remove('hidden');
      menu?.classList.add('is-open');
      overlay?.classList.remove('hidden');
      toggle?.setAttribute('aria-expanded', 'true');
    };
    const closeMenu = () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('is-open');
      overlay?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    };

    toggle?.addEventListener('click', () => {
      const isOpen = menu?.classList.contains('is-open');
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });
    overlay?.addEventListener('click', closeMenu);

    document.querySelectorAll('.nav-mobile-menu a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu?.classList.contains('is-open')) {
        closeMenu();
        toggle?.focus();
      }

      if (e.key === 'Escape') {
        desktopMenuTriggers.forEach((wrap) => {
          wrap.classList.remove('is-open');
          wrap.querySelector('.nav-link--has-menu')?.setAttribute('aria-expanded', 'false');
        });
      }
    });

    desktopMenuTriggers.forEach((wrap) => {
      const trigger = wrap.querySelector<HTMLAnchorElement>('.nav-link--has-menu');
      if (!trigger) return;

      // Desktop: NIE blokujemy click — link nawiguje do strony kategorii.
      // Dropdown otwiera się na hover/focus-within (CSS).

      wrap.querySelectorAll('.nav-dropdown a').forEach((link) => {
        link.addEventListener('click', () => {
          (document.activeElement as HTMLElement)?.blur();
        });
      });
    });

    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      if (!nav?.contains(target)) {
        desktopMenuTriggers.forEach((wrap) => {
          wrap.classList.remove('is-open');
          wrap.querySelector('.nav-link--has-menu')?.setAttribute('aria-expanded', 'false');
        });
      }
    });
  };

  document.addEventListener('astro:page-load', initNavbar);
</script>

<style is:global>
  /* ============================================================
     Navbar – landing redesign 2026-05-09 (handoff)
     64px height, blurred canvas, aperture logo mark
     ============================================================ */

  .nav-shell {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 50;
    background: color-mix(in srgb, var(--bg-canvas) 78%, transparent);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border-bottom: 1px solid var(--hairline-soft);
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .nav-shell[data-scrolled='true'] {
    background: color-mix(in srgb, var(--bg-canvas) 92%, transparent);
    border-bottom-color: var(--hairline);
  }

  .nav-shell + * {
    margin-top: 64px;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 24px;
  }

  /* Logo – aperture mark + wordmark */
  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
    text-decoration: none;
  }

  .nav-logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    color: var(--ink);
    flex-shrink: 0;
  }

  .nav-logo-mark svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .nav-logo-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
  }

  .nav-logo-text .accent {
    color: var(--accent-blue);
  }

  /* Nav links (desktop) */
  .nav-links {
    display: none;
    gap: 2px;
    font-size: 14px;
  }

  @media (min-width: 980px) {
    .nav-links {
      display: flex;
      align-items: center;
    }
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 14px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.14px;
    line-height: 1;
    color: var(--ink-muted);
    text-decoration: none;
    transition:
      color 0.18s ease,
      background 0.18s ease;
    white-space: nowrap;
    border-radius: var(--r-pill);
  }

  .nav-link:hover {
    color: var(--ink);
    background: var(--pill-translucent);
  }

  .nav-link--active {
    color: var(--ink);
  }

  .nav-link-chev {
    color: currentColor;
    opacity: 0.6;
    transition:
      transform 0.2s ease,
      opacity 0.15s ease;
  }

  .nav-link-wrap:hover .nav-link-chev {
    transform: rotate(180deg);
    opacity: 1;
  }

  .nav-link-wrap.is-open .nav-link-chev {
    transform: rotate(180deg);
    opacity: 1;
  }

  .nav-link-wrap::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 12px;
  }

  /* Dropdown */
  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    width: 460px;
    margin-top: 6px;
    padding: 0;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-card);
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-3px);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0.15s ease;
    z-index: 50;
  }

  .nav-link-wrap:hover .nav-dropdown,
  .nav-link-wrap:focus-within .nav-dropdown,
  .nav-link-wrap.is-open .nav-dropdown {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    padding: 12px;
  }

  .nav-dropdown-grid--single {
    grid-template-columns: 1fr;
  }

  .nav-dropdown-heading {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 6px;
    padding: 0 10px;
  }

  .nav-dropdown-list {
    display: flex;
    flex-direction: column;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-dropdown-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 9px 10px;
    border-radius: var(--r-sm);
    transition:
      background 0.15s ease,
      color 0.15s ease;
    text-decoration: none;
  }

  .nav-dropdown-link::after {
    content: '→';
    color: var(--ink-faint);
    opacity: 0;
    transform: translateX(-3px);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      color 0.15s ease;
  }

  .nav-dropdown-link:hover {
    background: var(--bg-surface-2);
  }

  .nav-dropdown-link:hover::after {
    color: var(--accent-blue);
    opacity: 1;
    transform: translateX(0);
  }

  .nav-dropdown-link-label {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.14px;
    color: var(--ink);
    line-height: 1.2;
  }

  .nav-dropdown-footer {
    border-top: 1px solid var(--hairline-soft);
    padding: 11px 20px 12px;
  }

  .nav-dropdown-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: -0.12px;
    color: var(--accent-blue);
    text-decoration: none;
    transition: gap 0.15s ease;
  }

  .nav-dropdown-footer-link:hover {
    gap: 10px;
  }

  /* CTA cluster */
  .nav-cta {
    display: none;
    align-items: center;
    gap: 8px;
  }

  @media (min-width: 980px) {
    .nav-cta {
      display: inline-flex;
    }
  }

  .nav-cta-btn {
    /* slightly smaller pill in nav */
    min-height: 36px;
    padding: 8px 14px;
    font-size: 13px;
  }

  /* Mobile menu toggle */
  .nav-mobile-toggle {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 44px;
    height: 44px;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline);
    cursor: pointer;
    border-radius: var(--r-full);
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .nav-mobile-toggle:hover {
    background: var(--bg-surface-2);
    border-color: var(--hairline);
  }

  @media (min-width: 980px) {
    .nav-mobile-toggle {
      display: none;
    }
  }

  .nav-mobile-toggle span {
    display: block;
    width: 17px;
    height: 1.5px;
    background: var(--ink);
    transform-origin: center;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      background 0.15s ease;
  }

  .nav-mobile-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }

  .nav-mobile-toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }

  .nav-mobile-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }

  /* Mobile overlay */
  .nav-mobile-overlay {
    position: fixed;
    inset: 64px 0 0 0;
    background: color-mix(in srgb, var(--bg-canvas) 60%, transparent);
    z-index: 38;
  }

  .nav-mobile-overlay.hidden {
    display: none;
  }

  /* Mobile menu */
  .nav-mobile-menu {
    position: fixed;
    top: 64px;
    bottom: 0;
    left: 0;
    right: 0;
    height: calc(100vh - 64px);
    max-height: calc(100vh - 64px);
    overflow-y: auto;
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline);
    padding: 16px 20px 36px;
    z-index: 40;
  }

  .nav-mobile-menu.hidden {
    display: none;
  }

  .nav-mobile-menu.is-open {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  @media (min-width: 980px) {
    .nav-mobile-menu,
    .nav-mobile-overlay {
      display: none !important;
    }
  }

  .nav-mobile-link {
    display: block;
    padding: 13px 14px;
    border-radius: var(--r-md);
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.18px;
    color: var(--ink);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .nav-mobile-link:hover {
    background: var(--pill-translucent);
  }

  .nav-mobile-link--summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    list-style: none;
    cursor: pointer;
  }

  .nav-mobile-link--summary::-webkit-details-marker {
    display: none;
  }

  .nav-mobile-details[open] .nav-mobile-link--summary {
    background: var(--bg-surface-1);
  }

  .nav-mobile-details[open] .nav-mobile-chevron {
    transform: rotate(180deg);
  }

  .nav-mobile-chevron {
    width: 8px;
    height: 8px;
    border-right: 1.5px solid var(--ink-muted);
    border-bottom: 1.5px solid var(--ink-muted);
    transform: rotate(45deg);
    transition: transform 0.15s ease;
  }

  .nav-mobile-link--sub {
    font-size: 15px;
    color: var(--ink-muted);
    padding: 9px 14px;
  }

  .nav-mobile-link--sub:hover {
    color: var(--ink);
  }

  .nav-mobile-link--overview {
    color: var(--ink);
  }

  .nav-mobile-details {
    display: block;
  }

  .nav-mobile-sub {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 6px 0 8px 12px;
    margin-left: 14px;
    border-left: 1px solid var(--hairline-soft);
  }

  .nav-mobile-subgroup {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-mobile-subheading {
    padding: 12px 14px 4px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .nav-mobile-cta {
    margin-top: 16px;
    width: 100%;
    align-self: stretch;
  }

  .nav-mobile-theme-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-radius: var(--r-md);
    margin-top: 8px;
  }

  .nav-mobile-theme-label {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
  }
</style>
