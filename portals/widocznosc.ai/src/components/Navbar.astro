---
type NavItem = {
  label: string;
  href: string;
  desc?: string;
};

type NavGroup = {
  label: string;
  href: string;
  items?: { heading?: string; links: NavItem[] }[];
};

const navbarLinks: NavGroup[] = [
  {
    label: 'Pozycjonowanie AI',
    href: '/pozycjonowanie-ai',
    items: [
      {
        heading: 'Modele AI',
        links: [
          {
            label: 'ChatGPT',
            desc: 'OpenAI · ~700 mln użytk./tyg.',
            href: '/pozycjonowanie-ai/chatgpt',
          },
          {
            label: 'Claude',
            desc: 'Anthropic · zastosowania B2B',
            href: '/pozycjonowanie-ai/claude',
          },
          {
            label: 'Gemini',
            desc: 'Google · zasila AI Overviews',
            href: '/pozycjonowanie-ai/gemini',
          },
          {
            label: 'Perplexity',
            desc: 'Wyszukiwarka oparta o cytowania',
            href: '/pozycjonowanie-ai/perplexity',
          },
          {
            label: 'Bing Copilot',
            desc: 'Microsoft · Edge i Windows',
            href: '/pozycjonowanie-ai/bing-copilot',
          },
        ],
      },
      {
        heading: 'Metodologia',
        links: [
          {
            label: 'Audyt widoczności',
            desc: 'Pełny przegląd 5 silników AI',
            href: '/pozycjonowanie-ai#audyt',
          },
          {
            label: 'Optymalizacja treści',
            desc: 'Treści pisane pod LLM',
            href: '/pozycjonowanie-ai#content',
          },
          {
            label: 'Monitoring cytowań',
            desc: 'Stałe śledzenie wzmianek',
            href: '/pozycjonowanie-ai#monitoring',
          },
          {
            label: 'Strategia GEO',
            desc: 'Plan działania na rok',
            href: '/pozycjonowanie-ai#strategia',
          },
        ],
      },
    ],
  },
  { label: 'Baza wiedzy', href: '/blog' },
  { label: 'Narzędzia', href: '/narzedzia' },
  { label: 'O nas', href: '/o-nas' },
  { label: 'Kontakt', href: '/kontakt' },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href.startsWith('/#')) return false;
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<nav class="nav-shell" id="main-nav" aria-label="Główna nawigacja">
  <div class="nav-inner">
    <!-- Logo: plain wordmark Mona Sans, zero pulse, zero dot accent -->
    <a href="/" aria-label="widocznosc.ai – strona główna" class="logo-wordmark">
      widocznosc.ai
    </a>

    <!-- Nav links (desktop, lg+) -->
    <div class="nav-links hidden lg:flex">
      {
        navbarLinks.map((group) => {
          const active = isActive(group.href);
          if (!group.items) {
            return (
              <a
                class={`nav-link${active ? ' nav-link--active' : ''}`}
                href={group.href}
                {...(active ? { 'aria-current': 'page' } : {})}
              >
                {group.label}
              </a>
            );
          }
          return (
            <div class="group relative">
              <a
                href={group.href}
                class={`nav-link nav-link--has-menu${active ? ' nav-link--active' : ''}`}
                aria-haspopup="true"
                aria-expanded="false"
                {...(active ? { 'aria-current': 'page' } : {})}
              >
                <span>{group.label}</span>
                <svg
                  class="nav-link-chev"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  width="10"
                  height="10"
                >
                  <polyline points="6,9 12,15 18,9" />
                </svg>
              </a>
              <!-- Dropdown – surface-1, hairline, no shadow -->
              <div class="nav-dropdown" role="menu">
                <div class="nav-dropdown-grid">
                  {group.items.map((col) => (
                    <div>
                      {col.heading && (
                        <div class="nav-dropdown-heading">{col.heading}</div>
                      )}
                      <ul class="nav-dropdown-list">
                        {col.links.map((link) => (
                          <li>
                            <a href={link.href} class="nav-dropdown-link" role="menuitem">
                              <div class="nav-dropdown-link-label">{link.label}</div>
                              {link.desc && <div class="nav-dropdown-link-desc">{link.desc}</div>}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
                <div class="nav-dropdown-footer">
                  <a href={group.href} class="nav-dropdown-footer-link">
                    Zobacz wszystkie usługi
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>

    <!-- CTA right – primary white pill -->
    <div class="hidden lg:flex lg:items-center lg:gap-2">
      <a class="btn-primary" href="/narzedzia" aria-label="Uruchom darmowy test widoczności AI">
        Uruchom test za darmo
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      class="nav-mobile-toggle lg:hidden"
      id="mobile-menu-toggle"
      aria-label="Otwórz menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>

  <!-- Mobile menu overlay -->
  <div class="nav-mobile-overlay hidden lg:hidden" id="mobile-menu-overlay"></div>

  <!-- Mobile menu – flat list -->
  <div class="nav-mobile-menu hidden lg:hidden" id="mobile-menu">
    {
      navbarLinks.map((group) => {
        if (!group.items) {
          return (
            <a class="nav-mobile-link" href={group.href}>
              {group.label}
            </a>
          );
        }
        return (
          <div class="nav-mobile-group">
            <a href={group.href} class="nav-mobile-link nav-mobile-link--group">
              {group.label}
            </a>
            <div class="nav-mobile-sub">
              {group.items.map((col) =>
                col.links.map((link) => (
                  <a href={link.href} class="nav-mobile-link nav-mobile-link--sub">
                    {link.label}
                  </a>
                ))
              )}
            </div>
          </div>
        );
      })
    }
    <a class="btn-primary nav-mobile-cta" href="/narzedzia">
      Uruchom test za darmo
    </a>
  </div>
</nav>

<script>
  const initNavbar = () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');
    const nav = document.getElementById('main-nav');

    const updateNavBackground = () => {
      if (!nav) return;
      if (window.scrollY > 16) {
        nav.dataset.scrolled = 'true';
      } else {
        nav.dataset.scrolled = 'false';
      }
    };

    updateNavBackground();
    window.addEventListener('scroll', updateNavBackground, { passive: true });

    const openMenu = () => {
      menu?.classList.remove('hidden');
      menu?.classList.add('is-open');
      overlay?.classList.remove('hidden');
      toggle?.setAttribute('aria-expanded', 'true');
    };

    const closeMenu = () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('is-open');
      overlay?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    };

    toggle?.addEventListener('click', () => {
      const isOpen = menu?.classList.contains('is-open');
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    overlay?.addEventListener('click', closeMenu);

    document.querySelectorAll('.nav-mobile-link').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu?.classList.contains('is-open')) {
        closeMenu();
        toggle?.focus();
      }
    });
  };

  document.addEventListener('astro:page-load', initNavbar);
</script>

<style is:global>
  /* ============================================================
     Navbar – Framer DNA: 56px sticky, canvas bg, no chrome
     ============================================================ */

  /* Stitch iteration: nav zawsze ma blur + border-bottom (stabilny look od startu),
     na scroll subtelnie ciemniejsze tło dla lepszego kontrastu. */
  .nav-shell {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 56px;
    display: flex;
    align-items: center;
    z-index: 40;
    background: rgb(10 10 11 / 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: background 0.2s ease;
  }

  .nav-shell[data-scrolled='true'] {
    background: rgb(10 10 11 / 0.95);
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 30px;
    height: 100%;
  }

  /* Nav links */

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 12px;
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    line-height: 1;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
    white-space: nowrap;
    border-radius: var(--r-sm);
  }

  .nav-link:hover {
    color: var(--ink);
  }

  .nav-link--active {
    color: var(--ink);
  }

  .nav-link-chev {
    color: currentColor;
    opacity: 0.6;
    transition: transform 0.2s ease, opacity 0.15s ease;
  }

  .group:hover .nav-link-chev {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* Dropdown */

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    width: 560px;
    margin-top: 8px;
    padding: 0;
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline);
    border-radius: var(--r-lg);
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0.15s ease;
    z-index: 50;
  }

  .group:hover .nav-dropdown,
  .group:focus-within .nav-dropdown {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    padding: 20px;
  }

  .nav-dropdown-heading {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    margin-bottom: 8px;
    padding: 0 12px;
  }

  .nav-dropdown-list {
    display: flex;
    flex-direction: column;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-dropdown-link {
    display: block;
    padding: 8px 12px;
    border-radius: var(--r-md);
    transition: background 0.15s ease;
    text-decoration: none;
  }

  .nav-dropdown-link:hover {
    background: var(--bg-surface-2);
  }

  .nav-dropdown-link-label {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: 500;
    letter-spacing: var(--ls-body-sm);
    color: var(--ink);
    line-height: 1.3;
  }

  .nav-dropdown-link-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 400;
    letter-spacing: var(--ls-caption);
    color: var(--ink-muted);
    line-height: 1.4;
    margin-top: 2px;
  }

  .nav-dropdown-footer {
    border-top: 1px solid var(--hairline-soft);
    padding: 12px 20px;
  }

  .nav-dropdown-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: var(--ls-caption);
    color: var(--accent-blue);
    text-decoration: none;
    transition: gap 0.15s ease;
  }

  .nav-dropdown-footer-link:hover {
    gap: 10px;
  }

  /* Mobile toggle */

  .nav-mobile-toggle {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: var(--r-sm);
  }

  .nav-mobile-toggle span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--ink);
    transition: background 0.15s ease;
  }

  /* Mobile overlay */

  .nav-mobile-overlay {
    position: fixed;
    inset: 56px 0 0 0;
    background: rgb(10 10 11 / 0.6);
    z-index: 38;
  }

  /* Mobile menu */

  .nav-mobile-menu {
    position: fixed;
    top: 56px;
    left: 0;
    right: 0;
    max-height: calc(100vh - 56px);
    overflow-y: auto;
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline);
    padding: 20px 30px 40px 30px;
    z-index: 40;
  }

  .nav-mobile-menu.is-open {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-mobile-link {
    display: block;
    padding: 12px 16px;
    border-radius: var(--r-md);
    font-family: var(--font-sans);
    font-size: var(--fs-body-lg);
    font-weight: 500;
    letter-spacing: var(--ls-body-lg);
    color: var(--ink);
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .nav-mobile-link:hover {
    background: var(--bg-surface-1);
  }

  .nav-mobile-link--group {
    font-weight: 500;
  }

  .nav-mobile-link--sub {
    font-size: var(--fs-body);
    color: var(--ink-muted);
    padding: 8px 16px 8px 32px;
  }

  .nav-mobile-link--sub:hover {
    color: var(--ink);
  }

  .nav-mobile-group {
    display: flex;
    flex-direction: column;
  }

  .nav-mobile-sub {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 1px solid var(--hairline);
    margin-left: 16px;
    padding-left: 0;
  }

  .nav-mobile-cta {
    margin-top: 16px;
    align-self: flex-start;
  }
</style>
