---
/**
 * Industries – landing redesign 2026-05-09 (handoff).
 * Section-head editorial 5fr/4fr + 3-col grid 6 cards
 * (B2B SaaS, Finanse i Prawo, Medycyna, E-commerce, Edukacja, Usługi B2B).
 * Card: surface-1, hairline, hover surface-2.
 */

interface Industry {
  name: string;
  desc: string;
}

const industries: Industry[] = [
  {
    name: 'B2B SaaS i Tech',
    desc: 'Długa droga zakupowa oparta na researchu. Decydent pyta ChatGPT „najlepsze X dla zespołu Y" – warto, żebyście pojawili się w odpowiedzi.',
  },
  {
    name: 'Finanse i Prawo',
    desc: 'Wysoka wartość transakcji, AI bywa pierwszym doradcą klienta. Wzmianka w odpowiedzi AI to rozmowa z osobą, która już wie, czego szuka.',
  },
  {
    name: 'Medycyna i Zdrowie',
    desc: 'Pacjenci pytają AI o objawy, leki i miejsca leczenia. AI Overviews coraz częściej zastępują pierwszy etap szukania w klasycznej wyszukiwarce.',
  },
  {
    name: 'E-commerce i DTC',
    desc: 'Pytania porównawcze („X vs Y", „tańszy zamiennik dla Z"). Ruch z AI to użytkownicy w końcowej fazie wyboru produktu.',
  },
  {
    name: 'Edukacja i Szkolenia',
    desc: 'Długi proces decyzyjny z wieloma punktami styku. Kursanci pytają AI o „najlepszy kurs X" miesiące przed zapisem.',
  },
  {
    name: 'Usługi B2B',
    desc: 'Konsulting, agencje, software house’y. Klienci pytają AI o polecanych dostawców, zanim wyślą pierwszego maila.',
  },
];
---

<section class="industries-section" id="branze" aria-labelledby="industries-title">
  <div class="container">
    <header class="section-head">
      <div class="head-left">
        <div class="head-meta">
          <span class="section-index">S/04</span>
          <span class="eyebrow">Dla kogo</span>
        </div>
        <h2 id="industries-title" class="display-lg">
          Sześć branż, na których <span class="accent">koncentrujemy uwagę</span>
        </h2>
      </div>
      <div class="head-right">
        <p class="subhead">
          Tam, gdzie klient zaczyna od pytania zadanego AI, a&nbsp;decyzja zakupowa wymaga
          rzetelnego rozeznania. To branże, w&nbsp;których widzimy największy wpływ wyszukiwarek AI
          &ndash; nie jedyne, z&nbsp;którymi pracujemy.
        </p>
      </div>
    </header>

    <div class="industries-grid">
      {
        industries.map((it) => (
          <article class="industry-card">
            <h3 class="industry-name">{it.name}</h3>
            <p class="industry-desc">{it.desc}</p>
          </article>
        ))
      }
    </div>

    <p class="process-footer">
      Twoja branża nie jest na liście? <a href="/kontakt">Sprawdzimy potencjał →</a>
    </p>
  </div>
</section>

<style>
  .industries-section {
    padding: 96px 0;
    background: var(--bg-canvas);
    border-top: 1px solid var(--hairline-soft);
  }

  @media (min-width: 980px) {
    .industries-section {
      padding: 120px 0;
    }
  }

  .industries-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 640px) {
    .industries-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .industries-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .industry-card {
    background: var(--bg-surface-1);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--r-lg);
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 140px;
    transition:
      background 0.18s ease,
      border-color 0.18s ease;
  }

  .industry-card:hover {
    background: var(--bg-surface-2);
    border-color: var(--hairline);
  }

  .industry-name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }

  .industry-desc {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.45;
    margin: 0;
  }
</style>
