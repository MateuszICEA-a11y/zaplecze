---
// Mona Sans Variable – display headings (Framer poster-grade)
import '@fontsource-variable/mona-sans';
// Inter Variable – body & UI z OpenType character variants (Framer body voice)
import '@fontsource-variable/inter';
import monaSansLatin from '@fontsource-variable/mona-sans/files/mona-sans-latin-wght-normal.woff2?url';
import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import { ClientRouter } from 'astro:transitions';
import '../styles/Theme.css';
import InvitationModal from '../components/InvitationModal.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  articleMeta?: {
    publishedTime: string;
    author: string;
    tags: string[];
  };
  noindex?: boolean;
}

const {
  title,
  description = 'widocznosc.ai – pozycjonowanie marek w wyszukiwarkach AI (ChatGPT, Claude, Perplexity, Google AI Overviews). Audyty widoczności, content, doradztwo GEO.',
  ogType = 'website',
  articleMeta,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://widocznosc.ai';
const ogImage = `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preload" href={monaSansLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={interLatin} as="font" type="font/woff2" crossorigin />
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <title>{title}</title>
    <ClientRouter />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1228" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="widocznosc.ai" />
    <meta property="og:locale" content="pl_PL" />
    {articleMeta && <meta property="article:published_time" content={articleMeta.publishedTime} />}
    {articleMeta && <meta property="article:author" content={articleMeta.author} />}
    {articleMeta?.tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="overflow-x-hidden">
    <main aria-label="Main content">
      <slot />
    </main>
    <InvitationModal />
    <style is:global>
      html {
        font-family: 'Inter Variable', 'Inter', -apple-system, system-ui, sans-serif;
        background-color: var(--bg-canvas);
        overflow-x: hidden;
        scroll-behavior: smooth !important;
      }

      body {
        background-color: var(--bg-canvas);
      }

      .fade-in {
        opacity: 0;
        transition: opacity 0.5s ease;
      }

      .fade-in.is-visible {
        opacity: 1;
      }
    </style>
    <script is:inline data-astro-rerun>
      (function () {
        const obs = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );

        document.querySelectorAll('.fade-in:not(.is-visible)').forEach(function (el) {
          obs.observe(el);
        });
      })();
    </script>
  </body>
</html>
