---
// Mona Sans Variable – display headings (Framer poster-grade)
import '@fontsource-variable/mona-sans';
// Inter Variable – body & UI z OpenType character variants (Framer body voice)
import '@fontsource-variable/inter';
import monaSansLatin from '@fontsource-variable/mona-sans/files/mona-sans-latin-wght-normal.woff2?url';
import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import { ClientRouter } from 'astro:transitions';
import '../styles/Theme.css';
import { buildGraph, organizationNode, websiteNode, SITE_URL } from '../lib/schema';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  articleMeta?: {
    publishedTime: string;
    author: string;
    tags: string[];
  };
  noindex?: boolean;
}

const {
  title,
  description = 'widocznosc.ai – pozycjonowanie marek w wyszukiwarkach AI (ChatGPT, Claude, Perplexity, Google AI Overviews). Audyty widoczności, content, doradztwo GEO.',
  ogType = 'website',
  articleMeta,
  noindex = false,
} = Astro.props;

const siteUrl = SITE_URL;
const ogImage = `${siteUrl}/og-image.png`;

// Bazowy @graph emitowany na KAŻDEJ stronie – Organization + WebSite.
// Strony customowe (artykuły, profile, taxonomy, kontakt) dodają własne
// JSON-LD <script> z page-specific nodami; Google traktuje wszystkie skrypty
// na stronie jako jeden graf (cross-ref przez @id działa).
const baseGraph = buildGraph(organizationNode(), websiteNode());
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Consent Mode v2 default – MUSI być przed GTM. Domyślnie denied;
         powracający użytkownik → natychmiastowy update z cookie wai_consent.
         Wersja `s.v === 1` zsynchronizowana z CONSENT_VERSION w src/lib/consent.ts. -->
    <script is:inline>
      (function () {
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        window.gtag = gtag;
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          // pinned 'denied': brak osadzeń YouTube/personalizacji na stronie.
          // Gdy dojdzie YouTube, zmapuj do zgody marketingowej (default + update).
          personalization_storage: 'denied',
          analytics_storage: 'denied',
          functionality_storage: 'granted',
          security_storage: 'granted',
          wait_for_update: 500,
        });
        gtag('set', 'ads_data_redaction', true);
        try {
          var m = /(?:^|; )wai_consent=([^;]+)/.exec(document.cookie);
          if (m) {
            var s = JSON.parse(decodeURIComponent(m[1]));
            if (s && s.v === 1) {
              gtag('consent', 'update', {
                analytics_storage: s.analytics ? 'granted' : 'denied',
                ad_storage: s.marketing ? 'granted' : 'denied',
                ad_user_data: s.marketing ? 'granted' : 'denied',
                ad_personalization: s.marketing ? 'granted' : 'denied',
              });
            }
          }
        } catch (e) {}
      })();
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-58684HSJ');</script>
    <!-- End Google Tag Manager -->
    <!-- Microsoft Clarity – startuje cookieless; ciasteczka dopiero po zgodzie
         analitycznej (clarity('consent')): sync z cookie wai_consent tutaj,
         a live przy kliknięciu w banerze (CookieConsent.astro). -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "xntfosggp9");
      try {
        var cm = /(?:^|; )wai_consent=([^;]+)/.exec(document.cookie);
        if (cm) {
          var cs = JSON.parse(decodeURIComponent(cm[1]));
          if (cs && cs.v === 1) window.clarity('consent', !!cs.analytics);
        }
      } catch (e) {}
    </script>
    <!-- Theme init – musi być pierwszy, przed CSS, bez flash.
         Re-applikuje się po astro:after-swap (View Transitions / ClientRouter)
         bo SPA swap wymienia <html> i atrybut data-theme znika. -->
    <script is:inline>
      (() => {
        const apply = () => {
          try {
            const stored = localStorage.getItem('theme');
            const resolved = stored === 'light' || stored === 'dark' ? stored : 'dark';
            document.documentElement.dataset.theme = resolved;
          } catch {
            document.documentElement.dataset.theme = 'dark';
          }
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preload" href={monaSansLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={interLatin} as="font" type="font/woff2" crossorigin />
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, follow'
        : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />
    <meta
      name="googlebot"
      content={noindex
        ? 'noindex, follow'
        : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />
    <title>{title}</title>
    <ClientRouter />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="widocznosc.ai" />
    <meta property="og:locale" content="pl_PL" />
    {articleMeta && <meta property="article:published_time" content={articleMeta.publishedTime} />}
    {articleMeta && <meta property="article:author" content={articleMeta.author} />}
    {articleMeta?.tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD: base graph (Organization + WebSite) – eat-your-own-dogfood dla GEO -->
    <script type="application/ld+json" is:inline set:html={baseGraph} />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-58684HSJ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a href="#main" class="skip-link">Przejdź do treści</a>
    <main id="main" aria-label="Main content">
      <slot />
    </main>
    <CookieConsent />
    <style is:global>
      html {
        font-family:
          'Inter Variable',
          'Inter',
          -apple-system,
          system-ui,
          sans-serif;
        background-color: var(--bg-canvas);
        /* clip (zamiast hidden) przycina poziomy nadmiar BEZ tworzenia
           kontekstu przewijania – inaczej psuje position:sticky potomków
           (np. sticky sidebar / spis treści na wpisach). */
        overflow-x: clip;
        scroll-behavior: smooth !important;
      }

      body {
        background-color: var(--bg-canvas);
        overflow-x: clip;
      }

      .fade-in {
        opacity: 0;
        transition: opacity 0.5s ease;
      }

      .fade-in.is-visible {
        opacity: 1;
      }
    </style>
    <!-- SPA pageview → dataLayer. astro:after-swap odpala się tylko przy nawigacji
         ClientRouter (nie przy pierwszym wejściu), więc nie dublujemy initial pageview
         wysyłanego przez gtm.js. Listener na document przeżywa swapy, dodajemy go raz. -->
    <script is:inline>
      document.addEventListener('astro:after-swap', function () {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'page_view',
          page_path: location.pathname + location.search,
          page_title: document.title,
        });
      });
    </script>
    <script is:inline data-astro-rerun>
      (function () {
        const obs = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );

        document.querySelectorAll('.fade-in:not(.is-visible)').forEach(function (el) {
          obs.observe(el);
        });
      })();
    </script>
  </body>
</html>
